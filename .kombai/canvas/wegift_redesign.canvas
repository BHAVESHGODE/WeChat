      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Oswald:wght@700&display=swap');\n\n  :root {\n    --bg-charcoal: #1a1a23;\n    --maverick: #7c4dff;\n    --bell: #ff6b9d;\n    --goju: #43e97b;\n    --sticker-bg: #f8f9fa;\n  }\n\n  .font-oswald { font-family: 'Oswald', sans-serif; }\n  .font-inter { font-family: 'Inter', sans-serif; }\n\n  .halftone-bg {\n    background-color: var(--bg-charcoal);\n    background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1.5px, transparent 0);\n    background-size: 24px 24px;\n  }\n\n  .sticker-card {\n    background: var(--sticker-bg);\n    border: 4px solid #000;\n    box-shadow: 10px 10px 0px #000;\n    transition: all 0.2s ease;\n  }\n\n  .sticker-card:hover {\n    transform: translate(-4px, -4px) rotate(0deg) !important;\n    box-shadow: 14px 14px 0px #000;\n  }\n\n  .pop-title span {\n    display: inline-block;\n    -webkit-text-stroke: 3px #000;\n    filter: drop-shadow(8px 8px 0px #000);\n    margin-right: -0.1em;\n  }\n\n  .speech-bubble {\n    position: relative;\n    background: #fff;\n    border: 3px solid #000;\n    box-shadow: 4px 4px 0px #000;\n  }\n\n  .speech-bubble:after {\n    content: '';\n    position: absolute;\n    bottom: -15px;\n    left: 20px;\n    border-width: 15px 15px 0 0;\n    border-style: solid;\n    border-color: #000 transparent transparent transparent;\n  }\n\n  .peel-corner {\n    position: absolute;\n    top: -2px;\n    right: -2px;\n    width: 40px;\n    height: 40px;\n    background: linear-gradient(225deg, transparent 50%, #ddd 50%);\n    border-left: 3px solid #000;\n    border-bottom: 3px solid #000;\n    border-radius: 0 0 0 4px;\n  }\n\n  .feature-tag {\n    border: 3px solid #000;\n    box-shadow: 4px 4px 0px #000;\n    transform: rotate(var(--rot));\n  }\n\n  .masking-tape {\n    background: rgba(255, 255, 255, 0.9);\n    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);\n    transform: rotate(-1deg);\n  }\n</style>\n\n<div class=\"halftone-bg min-h-[900px] w-full p-12 flex flex-col items-center justify-between font-inter text-white overflow-hidden relative\" data-kid=\"1\">\n  \n  \n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/wrapping-star.svg\" class=\"absolute top-20 left-20 w-32 h-32 opacity-10 rotate-12\" style=\"filter: invert(1);\" data-kid=\"2\">\n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/zigzag-hieroglyph.svg\" class=\"absolute bottom-40 right-10 w-48 h-48 opacity-10 -rotate-45\" style=\"filter: invert(1);\" data-kid=\"3\">\n\n  \n  <div class=\"absolute top-8 right-12 flex gap-4 text-sm font-bold uppercase tracking-widest z-20\" data-kid=\"4\">\n    <a href=\"#\" class=\"hover:text-(--maverick) transition-colors\" data-kid=\"5\">Sign In</a>\n    <span class=\"opacity-30\" data-kid=\"6\">/</span>\n    <a href=\"#\" class=\"hover:text-(--bell) transition-colors\" data-kid=\"7\">Register</a>\n  </div>\n\n  \n  <header class=\"w-full max-w-6xl flex flex-col md:flex-row items-center justify-between mt-8 relative z-10\" data-kid=\"8\">\n    <div class=\"flex flex-col items-start\" data-kid=\"9\">\n      <div class=\"pop-title font-oswald text-[120px] leading-none mb-4 select-none\" data-kid=\"10\">\n        <span class=\"text-(--maverick) -rotate-6\" data-kid=\"11\">W</span>\n        <span class=\"text-(--bell) rotate-3\" data-kid=\"12\">E</span>\n        <span class=\"text-(--goju) -rotate-2\" data-kid=\"13\">G</span>\n        <span class=\"text-white rotate-6\" data-kid=\"14\">I</span>\n        <span class=\"text-(--maverick) -rotate-3\" data-kid=\"15\">F</span>\n        <span class=\"text-(--bell) rotate-2\" data-kid=\"16\">T</span>\n      </div>\n      \n      <div class=\"speech-bubble py-3 px-6 text-black font-extrabold text-xl ml-12 animate-bounce\" data-kid=\"17\">\n        Choose your path!\n      </div>\n    </div>\n\n    \n    <div class=\"hidden lg:flex flex-wrap gap-4 max-w-sm justify-end\" data-kid=\"18\">\n      <div class=\"feature-tag bg-(--maverick) px-4 py-2 text-white font-oswald text-2xl uppercase\" style=\"--rot: -3deg\" data-kid=\"19\">🎵 Music</div>\n      <div class=\"feature-tag bg-(--bell) px-4 py-2 text-white font-oswald text-2xl uppercase\" style=\"--rot: 2deg\" data-kid=\"20\">🌸 Anime</div>\n      <div class=\"feature-tag bg-(--goju) px-4 py-2 text-white font-oswald text-2xl uppercase\" style=\"--rot: -5deg\" data-kid=\"21\">🎮 Games</div>\n      <div class=\"feature-tag bg-white text-black px-4 py-2 font-oswald text-2xl uppercase\" style=\"--rot: 4deg\" data-kid=\"22\">📚 Study</div>\n      <div class=\"feature-tag bg-orange-400 px-4 py-2 text-white font-oswald text-2xl uppercase\" style=\"--rot: -2deg\" data-kid=\"23\">🍿 Movies</div>\n    </div>\n  </header>\n\n  \n  <main class=\"w-full max-w-5xl grid grid-cols-1 md:grid-cols-3 gap-12 my-12 relative z-10\" data-kid=\"24\">\n    \n    <button class=\"sticker-card relative flex flex-col items-center p-8 group -rotate-3\" data-kid=\"25\">\n      <div class=\"peel-corner\" data-kid=\"26\"></div>\n      <div class=\"w-32 h-32 rounded-full bg-(--maverick)/20 border-4 border-black flex items-center justify-center mb-6\" data-kid=\"27\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/rocket.svg\" class=\"w-20 h-20 group-hover:scale-110 transition-transform\" loading=\"lazy\" decoding=\"async\" data-kid=\"28\">\n      </div>\n      <h2 class=\"font-oswald text-4xl text-black uppercase mb-2\" data-kid=\"29\">Maverick</h2>\n      <p class=\"text-black/60 font-bold text-sm tracking-tight mb-6\" data-kid=\"30\">ROCKET TO SUCCESS</p>\n      <div class=\"bg-black text-white px-8 py-3 font-black uppercase text-lg hover:bg-(--maverick) transition-colors\" data-kid=\"31\">Launch →</div>\n    </button>\n\n    \n    <button class=\"sticker-card relative flex flex-col items-center p-10 group translate-y-8 rotate-2\" data-kid=\"32\">\n      <div class=\"peel-corner\" data-kid=\"33\"></div>\n      <div class=\"w-32 h-32 rounded-full bg-(--bell)/20 border-4 border-black flex items-center justify-center mb-6\" data-kid=\"34\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bell.svg\" class=\"w-20 h-20 group-hover:scale-110 transition-transform\" loading=\"lazy\" decoding=\"async\" data-kid=\"35\">\n      </div>\n      <h2 class=\"font-oswald text-4xl text-black uppercase mb-2\" data-kid=\"36\">Bell</h2>\n      <p class=\"text-black/60 font-bold text-sm tracking-tight mb-6\" data-kid=\"37\">RING THE VIBE</p>\n      <div class=\"bg-black text-white px-8 py-3 font-black uppercase text-lg hover:bg-(--bell) transition-colors\" data-kid=\"38\">Ring In →</div>\n    </button>\n\n    \n    <button class=\"sticker-card relative flex flex-col items-center p-8 group rotate-6\" data-kid=\"39\">\n      <div class=\"peel-corner\" data-kid=\"40\"></div>\n      <div class=\"w-32 h-32 rounded-full bg-(--goju)/20 border-4 border-black flex items-center justify-center mb-6\" data-kid=\"41\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/dragon.svg\" class=\"w-20 h-20 group-hover:scale-110 transition-transform\" loading=\"lazy\" decoding=\"async\" data-kid=\"42\">\n      </div>\n      <h2 class=\"font-oswald text-4xl text-black uppercase mb-2\" data-kid=\"43\">Goju</h2>\n      <p class=\"text-black/60 font-bold text-sm tracking-tight mb-6\" data-kid=\"44\">AWAKEN THE DRAGON</p>\n      <div class=\"bg-black text-white px-8 py-3 font-black uppercase text-lg hover:bg-(--goju) transition-colors\" data-kid=\"45\">Enter →</div>\n    </button>\n  </main>\n\n  \n  <footer class=\"w-full flex justify-center pb-8 relative z-10\" data-kid=\"46\">\n    <div class=\"masking-tape py-2 px-12 text-black font-bold flex gap-8 items-center border-y-2 border-black/10\" data-kid=\"47\">\n      <span class=\"opacity-50\" data-kid=\"48\">V2.0 SYSTEM ONLINE</span>\n      <span class=\"h-4 w-px bg-black/20\" data-kid=\"49\"></span>\n      <span data-kid=\"50\">DEMO MODE ENABLED</span>\n      <span class=\"h-4 w-px bg-black/20\" data-kid=\"51\"></span>\n      <a href=\"#\" class=\"underline hover:text-(--maverick)\" data-kid=\"52\">HELP & DOCS</a>\n    </div>\n  </footer>\n\n</div>",
