      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Oswald:wght@200..700&family=Inter:wght@400;600&family=Fira+Code:wght@400;500&display=swap');\n\n  :root {\n    --retro-mahogany: #2a150a;\n    --retro-leather: #1a0f0a;\n    --retro-gold: #b8934c;\n    --retro-parchment: #fdf6e3;\n    --retro-ink: #2c2c2c;\n  }\n\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-condensed { font-family: 'Oswald', sans-serif; }\n  .font-mono { font-family: 'Fira Code', monospace; }\n\n  .desk-surface {\n    background-color: #1e0d07;\n    background-image: url(\"https://www.transparenttextures.com/patterns/dark-wood.png\");\n    min-height: 1000px;\n  }\n\n  .library-blur {\n    background-image: url(\"https://images.unsplash.com/photo-1728506972831-193841eb2961?auto=format&w=1440&q=80&fit=crop\");\n    background-size: cover;\n    background-position: center;\n    filter: blur(8px) brightness(0.3);\n  }\n\n  .ledger-book {\n    background: #e6dec5;\n    box-shadow: \n      0 30px 60px -12px rgba(0,0,0,0.5), \n      0 18px 36px -18px rgba(0,0,0,0.6),\n      inset 0 0 100px rgba(0,0,0,0.1);\n    border-radius: 4px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .ledger-center-spine {\n    position: absolute;\n    left: 50%;\n    top: 0;\n    bottom: 0;\n    width: 2px;\n    background: rgba(0,0,0,0.1);\n    box-shadow: 0 0 15px 5px rgba(0,0,0,0.15);\n    z-index: 5;\n  }\n\n  .paper-texture {\n    background-image: url(\"https://www.transparenttextures.com/patterns/handmade-paper.png\");\n  }\n\n  .gold-emboss {\n    color: var(--retro-gold);\n    text-shadow: 1px 1px 0px rgba(255,255,255,0.1), -1px -1px 0px rgba(0,0,0,0.5);\n    background: linear-gradient(to bottom, #d4af37, #b8934c);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .pocket-book {\n    perspective: 800px;\n    transition: transform 0.4s ease;\n  }\n\n  .pocket-book:hover {\n    transform: translateY(-5px) scale(1.05);\n  }\n\n  .pocket-book-cover {\n    box-shadow: 3px 3px 10px rgba(0,0,0,0.5);\n    transition: transform 0.4s ease;\n  }\n\n  .pocket-book:hover .pocket-book-cover {\n    transform: rotateY(-20deg);\n  }\n\n  .ink-text { color: var(--retro-ink); }\n  \n  .btn-ink {\n    border-bottom: 2px solid var(--retro-gold);\n    transition: all 0.2s;\n  }\n  \n  .btn-ink:hover {\n    background: rgba(184, 147, 76, 0.1);\n    padding-left: 8px;\n    padding-right: 8px;\n  }\n\n  .lamp-light {\n    background: radial-gradient(circle at 50% 0%, rgba(246, 200, 121, 0.25) 0%, transparent 60%);\n  }\n</style>\n\n<div class=\"desk-surface w-full flex flex-col items-center relative overflow-hidden text-[#fff9e6] lamp-light\" data-kid=\"1\">\n  \n  \n  <div class=\"absolute inset-0 library-blur opacity-50 pointer-events-none\" data-kid=\"2\"></div>\n\n  \n  <div class=\"relative z-10 mt-12 mb-16 text-center\" data-kid=\"3\">\n    <h1 class=\"font-serif text-6xl font-bold gold-emboss\" data-kid=\"4\">WeGift</h1>\n    <p class=\"font-mono text-xs tracking-[0.5em] uppercase text-[#b8934c] opacity-60 mt-4\" data-kid=\"5\">\n      The Great Archive of Digital Wonders\n    </p>\n  </div>\n\n  \n  <div class=\"relative z-10 w-full max-w-5xl px-8\" data-kid=\"6\">\n    \n    \n    <div class=\"ledger-book min-h-[500px] flex paper-texture border-4 border-[#3d2b1f]/20\" data-kid=\"7\">\n      <div class=\"ledger-center-spine\" data-kid=\"8\"></div>\n      \n      \n      <div class=\"flex-1 p-16 border-r border-black/5 relative\" data-kid=\"9\">\n        <div class=\"absolute top-8 left-12 font-serif italic text-sm text-black/30\" data-kid=\"10\">Registry No. 1024</div>\n        \n        <div class=\"mt-8\" data-kid=\"11\">\n          <h2 class=\"font-serif text-4xl font-bold ink-text mb-2\" data-kid=\"12\">Returning Traveler</h2>\n          <div class=\"h-1 w-20 bg-[#b8934c]/30 mb-8\" data-kid=\"13\"></div>\n          \n          <p class=\"font-serif italic ink-text opacity-70 mb-12 text-lg\" data-kid=\"14\">\n            Welcome back to the library. Please sign your name in the guest record to resume your studies.\n          </p>\n\n          <a href=\"#\" class=\"font-condensed text-2xl font-bold ink-text tracking-widest btn-ink inline-block pb-1\" data-kid=\"15\">\n            SIGN IN WITH EMAIL &rarr;\n          </a>\n          \n          <div class=\"mt-20 opacity-40\" data-kid=\"16\">\n            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/feather.svg\" class=\"w-16 h-16 grayscale\" alt=\"feather\" data-kid=\"17\">\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"flex-1 p-16 relative\" data-kid=\"18\">\n        <div class=\"absolute top-8 right-12 font-serif italic text-sm text-black/30\" data-kid=\"19\">Entry Date: 2026.06.10</div>\n\n        <div class=\"mt-8\" data-kid=\"20\">\n          <h2 class=\"font-serif text-4xl font-bold ink-text mb-2\" data-kid=\"21\">New Enrollment</h2>\n          <div class=\"h-1 w-20 bg-[#b8934c]/30 mb-8\" data-kid=\"22\"></div>\n\n          <p class=\"font-serif italic ink-text opacity-70 mb-12 text-lg\" data-kid=\"23\">\n            If this is your first visit, we must record your identity in our archives before granting passage.\n          </p>\n\n          <a href=\"#\" class=\"font-condensed text-2xl font-bold ink-text tracking-widest btn-ink inline-block pb-1\" data-kid=\"24\">\n            REGISTER NEW ACCOUNT &rarr;\n          </a>\n          \n          <div class=\"mt-20 flex justify-end opacity-40\" data-kid=\"25\">\n            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/ink-well.svg\" class=\"w-16 h-16 grayscale\" alt=\"inkwell\" data-kid=\"26\">\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"absolute -left-20 top-1/2 -translate-y-1/2 flex flex-col gap-8\" data-kid=\"27\">\n       \n       <div class=\"pocket-book w-44 rotate-[-12deg] cursor-pointer\" data-kid=\"28\">\n         <div class=\"pocket-book-cover h-60 bg-[#4a2e6e] rounded-r border-l-4 border-[#341d52] p-4 flex flex-col items-center justify-between\" data-kid=\"29\">\n            <span class=\"font-serif italic text-[10px] opacity-60 self-start\" data-kid=\"30\">Vol. I</span>\n            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/rocket.svg\" class=\"w-10 h-10\" alt=\"Maverick\" data-kid=\"31\">\n            <h3 class=\"font-serif text-xl font-bold\" data-kid=\"32\">Maverick</h3>\n            <div class=\"text-[8px] font-condensed tracking-widest border border-white/20 px-2 py-1 rounded-full\" data-kid=\"33\">OPEN</div>\n         </div>\n       </div>\n    </div>\n\n    <div class=\"absolute -right-20 top-1/4 flex flex-col gap-8\" data-kid=\"34\">\n      \n      <div class=\"pocket-book w-44 rotate-[8deg] cursor-pointer\" data-kid=\"35\">\n        <div class=\"pocket-book-cover h-60 bg-[#7a2e4a] rounded-r border-l-4 border-[#5e1f36] p-4 flex flex-col items-center justify-between\" data-kid=\"36\">\n           <span class=\"font-serif italic text-[10px] opacity-60 self-start\" data-kid=\"37\">Vol. II</span>\n           <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bell.svg\" class=\"w-10 h-10\" alt=\"Bell\" data-kid=\"38\">\n           <h3 class=\"font-serif text-xl font-bold\" data-kid=\"39\">Bell</h3>\n           <div class=\"text-[8px] font-condensed tracking-widest border border-white/20 px-2 py-1 rounded-full\" data-kid=\"40\">OPEN</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"absolute -right-16 bottom-0 flex flex-col gap-8\" data-kid=\"41\">\n      \n      <div class=\"pocket-book w-44 rotate-[-5deg] cursor-pointer\" data-kid=\"42\">\n        <div class=\"pocket-book-cover h-60 bg-[#2e4a35] rounded-r border-l-4 border-[#1f3424] p-4 flex flex-col items-center justify-between\" data-kid=\"43\">\n           <span class=\"font-serif italic text-[10px] opacity-60 self-start\" data-kid=\"44\">Vol. III</span>\n           <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/dragon.svg\" class=\"w-10 h-10\" alt=\"Goju\" data-kid=\"45\">\n           <h3 class=\"font-serif text-xl font-bold\" data-kid=\"46\">Goju</h3>\n           <div class=\"text-[8px] font-condensed tracking-widest border border-white/20 px-2 py-1 rounded-full\" data-kid=\"47\">OPEN</div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n  \n  <div class=\"mt-24 w-full max-w-4xl px-8 pb-12 relative z-10\" data-kid=\"48\">\n    <div class=\"flex items-center gap-4 justify-center mb-8 opacity-40\" data-kid=\"49\">\n      <div class=\"h-px w-32 bg-white/20\" data-kid=\"50\"></div>\n      <span class=\"font-serif italic text-sm\" data-kid=\"51\">Reference Catalog</span>\n      <div class=\"h-px w-32 bg-white/20\" data-kid=\"52\"></div>\n    </div>\n    \n    <div class=\"grid grid-cols-3 gap-8\" data-kid=\"53\">\n      <div class=\"flex items-center gap-3 group cursor-pointer opacity-70 hover:opacity-100 transition-opacity\" data-kid=\"54\">\n        <div class=\"w-12 h-12 rounded border border-white/10 flex items-center justify-center bg-black/20\" data-kid=\"55\">\n          <i class=\"ti ti-radio text-xl text-[#b8934c]\" data-kid=\"56\"></i>\n        </div>\n        <div data-kid=\"57\">\n          <h4 class=\"font-condensed text-sm font-bold tracking-tight\" data-kid=\"58\">MUSIC ARCHIVE</h4>\n          <p class=\"text-[9px] opacity-40\" data-kid=\"59\">CATALOG 12.04</p>\n        </div>\n      </div>\n      <div class=\"flex items-center gap-3 group cursor-pointer opacity-70 hover:opacity-100 transition-opacity\" data-kid=\"60\">\n        <div class=\"w-12 h-12 rounded border border-white/10 flex items-center justify-center bg-black/20\" data-kid=\"61\">\n          <i class=\"ti ti-video text-xl text-[#b8934c]\" data-kid=\"62\"></i>\n        </div>\n        <div data-kid=\"63\">\n          <h4 class=\"font-condensed text-sm font-bold tracking-tight\" data-kid=\"64\">ANIME REELS</h4>\n          <p class=\"text-[9px] opacity-40\" data-kid=\"65\">CATALOG 08.15</p>\n        </div>\n      </div>\n      <div class=\"flex items-center gap-3 group cursor-pointer opacity-70 hover:opacity-100 transition-opacity\" data-kid=\"66\">\n        <div class=\"w-12 h-12 rounded border border-white/10 flex items-center justify-center bg-black/20\" data-kid=\"67\">\n          <i class=\"ti ti-pencil text-xl text-[#b8934c]\" data-kid=\"68\"></i>\n        </div>\n        <div data-kid=\"69\">\n          <h4 class=\"font-condensed text-sm font-bold tracking-tight\" data-kid=\"70\">STUDY HALL</h4>\n          <p class=\"text-[9px] opacity-40\" data-kid=\"71\">CATALOG 22.09</p>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"mt-auto py-8 w-full border-t border-white/5 flex justify-between px-12 text-[10px] font-mono opacity-30\" data-kid=\"72\">\n    <p data-kid=\"73\">EST. 2026 // WEGIFT MERN V2</p>\n    <p data-kid=\"74\">OPERATIONAL // ASSETS SECURE</p>\n  </div>\n\n</div>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"75\">",
