      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-deep: #0f0f13;\n    --bg-secondary: #1a1a23;\n    --accent-purple: #7c4dff;\n    --accent-pink: #ff6b9d;\n    --accent-green: #43e97b;\n    --text-primary: #ffffff;\n    --text-silver: rgba(255, 255, 255, 0.65);\n  }\n\n  .font-outfit { font-family: 'Outfit', sans-serif; }\n  .font-fira { font-family: 'Fira Code', monospace; }\n  .font-inter { font-family: 'Inter', sans-serif; }\n\n  .cosmic-bg {\n    background: radial-gradient(circle at top right, rgba(124, 77, 255, 0.1), transparent 40%),\n                radial-gradient(circle at bottom left, rgba(67, 233, 123, 0.05), transparent 40%),\n                linear-gradient(135deg, var(--bg-deep) 0%, #1a1a2e 50%, #16213e 100%);\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(24px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .asymmetric-radius {\n    border-radius: 40px 12px 40px 12px;\n  }\n\n  .glow-purple:hover { box-shadow: 0 0 40px rgba(124, 77, 255, 0.25); border-color: rgba(124, 77, 255, 0.4); }\n  .glow-pink:hover { box-shadow: 0 0 40px rgba(255, 107, 157, 0.25); border-color: rgba(255, 107, 157, 0.4); }\n  .glow-green:hover { box-shadow: 0 0 40px rgba(67, 233, 123, 0.25); border-color: rgba(67, 233, 123, 0.4); }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0); }\n    50% { transform: translateY(-10px); }\n  }\n\n  .animate-float { animation: float 4s ease-in-out infinite; }\n\n  .sparkle-pattern {\n    background-image: url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/sparkles.svg');\n    background-size: 100px;\n    opacity: 0.05;\n  }\n</style>\n\n<div class=\"cosmic-bg font-inter text-white w-full min-h-[900px] flex flex-col items-center justify-center relative overflow-hidden p-8\" data-kid=\"1\">\n  \n  <div class=\"absolute inset-0 sparkle-pattern pointer-events-none\" data-kid=\"2\"></div>\n\n  \n  <nav class=\"absolute top-8 right-12 flex items-center gap-6 z-20\" data-kid=\"3\">\n    <a href=\"#\" class=\"text-sm font-medium text-[var(--text-silver)] hover:text-white transition-colors\" data-kid=\"4\">Sign in with email</a>\n    <span class=\"text-white/20\" data-kid=\"5\">/</span>\n    <a href=\"#\" class=\"text-sm font-medium text-[var(--text-silver)] hover:text-white transition-colors\" data-kid=\"6\">Register</a>\n    <div class=\"ml-4 px-3 py-1 bg-white/5 border border-white/10 rounded-full text-[10px] font-bold tracking-widest text-[var(--accent-purple)] uppercase\" data-kid=\"7\">\n      v2.0 ONLINE\n    </div>\n  </nav>\n\n  \n  <header class=\"text-center mb-16 relative z-10\" data-kid=\"8\">\n    <h1 class=\"font-outfit text-7xl font-black mb-4 tracking-tight\" style=\"text-shadow: 0 0 30px rgba(255,255,255,0.2);\" data-kid=\"9\">\n      WeGift\n    </h1>\n    <div class=\"font-fira text-sm tracking-[4px] text-[var(--text-silver)] uppercase\" data-kid=\"10\">\n      >>> Choose your path <<<\n    </div>\n  </header>\n\n  \n  <main class=\"flex flex-wrap justify-center gap-10 max-w-6xl w-full relative z-10 px-4\" data-kid=\"11\">\n    \n    <div class=\"glass-card asymmetric-radius glow-purple w-full max-w-[300px] p-10 flex flex-col items-center text-center group cursor-pointer\" data-kid=\"12\">\n      <div class=\"w-24 h-24 mb-8 p-4 bg-[var(--accent-purple)]/10 rounded-3xl group-hover:scale-110 transition-transform duration-500\" data-kid=\"13\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/rocket.svg\" alt=\"Rocket\" class=\"w-full h-full object-contain animate-float\" loading=\"lazy\" decoding=\"async\" data-kid=\"14\">\n      </div>\n      <h2 class=\"font-outfit text-3xl font-bold mb-4\" data-kid=\"15\">Maverick</h2>\n      <p class=\"text-sm text-[var(--text-silver)] mb-10 leading-relaxed\" data-kid=\"16\">Pioneer of the cosmic frontier. Ready for lift-off.</p>\n      <button class=\"w-full py-4 bg-[var(--accent-purple)] rounded-2xl font-bold text-sm tracking-widest uppercase hover:shadow-[0_0_20px_rgba(124,77,255,0.4)] transition-all\" data-kid=\"17\">\n        Launch\n      </button>\n    </div>\n\n    \n    <div class=\"glass-card asymmetric-radius glow-pink w-full max-w-[320px] p-10 flex flex-col items-center text-center group cursor-pointer scale-110 border-white/20\" data-kid=\"18\">\n      <div class=\"w-24 h-24 mb-8 p-4 bg-[var(--accent-pink)]/10 rounded-3xl group-hover:scale-110 transition-transform duration-500\" data-kid=\"19\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bell.svg\" alt=\"Bell\" class=\"w-full h-full object-contain animate-float\" style=\"animation-delay: -1s;\" loading=\"lazy\" decoding=\"async\" data-kid=\"20\">\n      </div>\n      <h2 class=\"font-outfit text-3xl font-bold mb-4\" data-kid=\"21\">Bell</h2>\n      <p class=\"text-sm text-[var(--text-silver)] mb-10 leading-relaxed\" data-kid=\"22\">The rhythmic pulse of the portal. Harmonize your world.</p>\n      <button class=\"w-full py-4 bg-[var(--accent-pink)] rounded-2xl font-bold text-sm tracking-widest uppercase hover:shadow-[0_0_20px_rgba(255,107,157,0.4)] transition-all\" data-kid=\"23\">\n        Ring In\n      </button>\n    </div>\n\n    \n    <div class=\"glass-card asymmetric-radius glow-green w-full max-w-[300px] p-10 flex flex-col items-center text-center group cursor-pointer\" data-kid=\"24\">\n      <div class=\"w-24 h-24 mb-8 p-4 bg-[var(--accent-green)]/10 rounded-3xl group-hover:scale-110 transition-transform duration-500\" data-kid=\"25\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/dragon.svg\" alt=\"Dragon\" class=\"w-full h-full object-contain animate-float\" style=\"animation-delay: -2s;\" loading=\"lazy\" decoding=\"async\" data-kid=\"26\">\n      </div>\n      <h2 class=\"font-outfit text-3xl font-bold mb-4\" data-kid=\"27\">Goju</h2>\n      <p class=\"text-sm text-[var(--text-silver)] mb-10 leading-relaxed\" data-kid=\"28\">Guardian of ancient digital myths. Awaken the power.</p>\n      <button class=\"w-full py-4 bg-[var(--accent-green)] rounded-2xl font-bold text-sm tracking-widest uppercase hover:shadow-[0_0_20px_rgba(67,233,123,0.4)] transition-all\" data-kid=\"29\">\n        Awaken\n      </button>\n    </div>\n  </main>\n\n  \n  <footer class=\"fixed bottom-10 left-1/2 -translate-x-1/2 z-30\" data-kid=\"30\">\n    <div class=\"bg-white/5 backdrop-blur-3xl border border-white/10 rounded-3xl px-6 py-3 flex items-center gap-8 shadow-2xl\" data-kid=\"31\">\n      <div class=\"group relative\" data-kid=\"32\">\n        <button class=\"w-12 h-12 flex items-center justify-center rounded-2xl hover:bg-white/10 text-white/60 hover:text-[var(--accent-purple)] transition-all\" data-kid=\"33\">\n          <i class=\"ti ti-music text-2xl\" data-kid=\"34\"></i>\n        </button>\n        <span class=\"absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1 bg-black/80 rounded-lg text-[10px] font-bold opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none\" data-kid=\"35\">MUSIC</span>\n      </div>\n      \n      <div class=\"group relative\" data-kid=\"36\">\n        <button class=\"w-12 h-12 flex items-center justify-center rounded-2xl hover:bg-white/10 text-white/60 hover:text-[var(--accent-pink)] transition-all\" data-kid=\"37\">\n          <i class=\"ti ti-device-tv text-2xl\" data-kid=\"38\"></i>\n        </button>\n        <span class=\"absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1 bg-black/80 rounded-lg text-[10px] font-bold opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none\" data-kid=\"39\">ANIME</span>\n      </div>\n\n      <div class=\"group relative\" data-kid=\"40\">\n        <button class=\"w-12 h-12 flex items-center justify-center rounded-2xl hover:bg-white/10 text-white/60 hover:text-[var(--accent-green)] transition-all\" data-kid=\"41\">\n          <i class=\"ti ti-book-open text-2xl\" data-kid=\"42\"></i>\n        </button>\n        <span class=\"absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1 bg-black/80 rounded-lg text-[10px] font-bold opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none\" data-kid=\"43\">STUDY</span>\n      </div>\n\n      <div class=\"group relative\" data-kid=\"44\">\n        <button class=\"w-12 h-12 flex items-center justify-center rounded-2xl hover:bg-white/10 text-white/60 hover:text-cyan-400 transition-all\" data-kid=\"45\">\n          <i class=\"ti ti-gamepad-2 text-2xl\" data-kid=\"46\"></i>\n        </button>\n        <span class=\"absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1 bg-black/80 rounded-lg text-[10px] font-bold opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none\" data-kid=\"47\">GAMES</span>\n      </div>\n\n      <div class=\"group relative\" data-kid=\"48\">\n        <button class=\"w-12 h-12 flex items-center justify-center rounded-2xl hover:bg-white/10 text-white/60 hover:text-orange-400 transition-all\" data-kid=\"49\">\n          <i class=\"ti ti-film text-2xl\" data-kid=\"50\"></i>\n        </button>\n        <span class=\"absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1 bg-black/80 rounded-lg text-[10px] font-bold opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none\" data-kid=\"51\">MOVIES</span>\n      </div>\n    </div>\n  </footer>\n\n  \n  <div class=\"absolute bottom-8 right-12 text-[10px] font-bold tracking-widest text-white/20 uppercase\" data-kid=\"52\">\n    Demo Mode — No login required\n  </div>\n</div>",
