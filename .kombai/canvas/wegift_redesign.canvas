      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Oswald:wght@200..700&family=Inter:wght@400;600&display=swap');\n\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-condensed { font-family: 'Oswald', sans-serif; }\n  .font-sans { font-family: 'Inter', sans-serif; }\n\n  .mahogany-split {\n    background-color: #1a0f0a;\n    display: flex;\n    min-height: 900px;\n    width: 100%;\n    color: #fff9e6;\n  }\n\n  /* Left Side: Bookshelf Sidebar */\n  .bookshelf-sidebar {\n    width: 320px;\n    background: linear-gradient(to right, #2a150a, #1a0f0a);\n    border-right: 4px solid #3d2b1f;\n    box-shadow: 10px 0 30px rgba(0,0,0,0.5);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 3rem 0;\n    position: relative;\n    z-index: 20;\n    flex-shrink: 0;\n  }\n\n  .sidebar-label {\n    writing-mode: vertical-rl;\n    text-orientation: mixed;\n    transform: rotate(180deg);\n    color: #b8934c;\n    opacity: 0.6;\n    font-size: 12px;\n    letter-spacing: 0.2em;\n    margin-bottom: 2rem;\n    font-style: italic;\n  }\n\n  /* Right Side: Main Reception */\n  .main-reception {\n    flex: 1;\n    position: relative;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    overflow: hidden;\n    background-color: #0f0a07;\n  }\n\n  .bg-library {\n    position: absolute;\n    inset: 0;\n    opacity: 0.5;\n    background-image: url(\"https://images.unsplash.com/photo-1728506972831-193841eb2961?auto=format&w=1440&q=80&fit=crop\");\n    background-size: cover;\n    background-position: center;\n    filter: blur(2px) sepia(0.3);\n  }\n\n  .lamp-glow-reception {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    width: 120%;\n    height: 120%;\n    background: radial-gradient(circle at center, rgba(246, 200, 121, 0.25) 0%, transparent 60%);\n    pointer-events: none;\n  }\n\n  /* Book Styling (Vertical Stack) */\n  .book-card-sm {\n    width: 180px;\n    height: 220px;\n    perspective: 800px;\n    margin-bottom: 2.5rem;\n    cursor: pointer;\n    transition: transform 0.4s ease;\n  }\n\n  .book-cover-sm {\n    width: 100%;\n    height: 100%;\n    border-radius: 0 4px 4px 0;\n    border-left: 6px solid rgba(0,0,0,0.3);\n    position: relative;\n    padding: 1rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: space-between;\n    transform-origin: left;\n    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n    box-shadow: 10px 10px 20px rgba(0,0,0,0.4);\n  }\n\n  .book-card-sm:hover .book-cover-sm {\n    transform: rotateY(-35deg);\n  }\n  \n  .book-card-sm:hover {\n    transform: translateX(10px);\n  }\n\n  .fabric-texture {\n    position: absolute;\n    inset: 0;\n    opacity: 0.08;\n    background-image: url('https://www.transparenttextures.com/patterns/fabric-of-the-nation.png');\n    pointer-events: none;\n  }\n\n  /* Main UI Elements */\n  .leather-plaque {\n    background-color: #1a0f0a;\n    background-image: url(\"https://www.transparenttextures.com/patterns/dark-leather.png\");\n    padding: 2.5rem 5rem;\n    border: 1px solid #3d2b1f;\n    box-shadow: inset 0 0 20px rgba(0,0,0,0.5), 0 10px 40px rgba(0,0,0,0.8);\n    margin-bottom: 4rem;\n    position: relative;\n    z-index: 10;\n  }\n\n  .gold-title {\n    font-size: 6rem;\n    font-weight: 800;\n    letter-spacing: -0.02em;\n    color: #b8934c;\n    background: linear-gradient(to bottom, #f6c879, #b8934c);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    text-shadow: 2px 2px 0px rgba(255,255,255,0.05);\n  }\n\n  .cta-container {\n    display: flex;\n    flex-direction: column;\n    gap: 1.5rem;\n    width: 100%;\n    max-width: 400px;\n    position: relative;\n    z-index: 10;\n  }\n\n  .reception-btn {\n    width: 100%;\n    padding: 1.25rem;\n    background: linear-gradient(135deg, #d4af37, #b8934c);\n    border: 1px solid #8a6d00;\n    color: #1a0f0a;\n    font-family: 'Oswald', sans-serif;\n    font-weight: 700;\n    font-size: 1.25rem;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    cursor: pointer;\n    box-shadow: 0 4px 20px rgba(0,0,0,0.3);\n    transition: all 0.3s ease;\n    border-radius: 2px;\n  }\n\n  .reception-btn:hover {\n    transform: translateY(-4px) scale(1.02);\n    box-shadow: 0 8px 30px rgba(184, 147, 76, 0.4);\n    background: linear-gradient(135deg, #f6c879, #d4af37);\n  }\n\n  .reception-btn.secondary {\n    background: transparent;\n    border: 1px solid #b8934c;\n    color: #b8934c;\n  }\n\n  .reception-btn.secondary:hover {\n    background: rgba(184, 147, 76, 0.1);\n    color: #f6c879;\n  }\n\n  .footer-caption {\n    position: absolute;\n    bottom: 2.5rem;\n    right: 3.5rem;\n    font-family: 'Playfair Display', serif;\n    font-style: italic;\n    font-size: 18px;\n    color: #f6c879;\n    opacity: 0.9;\n    letter-spacing: 0.15em;\n    text-shadow: 0 0 10px rgba(246, 200, 121, 0.4);\n    border-bottom: 1px solid rgba(184, 147, 76, 0.3);\n    padding-bottom: 0.5rem;\n  }\n\n  /* Catalog Drawer Overlay (Discreet) */\n  .catalog-mini-dock {\n    position: absolute;\n    bottom: 2rem;\n    left: 3rem;\n    display: flex;\n    gap: 1rem;\n    z-index: 30;\n  }\n\n  .mini-drawer {\n    width: 60px;\n    height: 60px;\n    background: #2a150a;\n    border: 1px solid #3d2b1f;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: #b8934c;\n    cursor: pointer;\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    border-radius: 4px;\n    box-shadow: 0 4px 15px rgba(0,0,0,0.4);\n  }\n\n  .mini-drawer i {\n    font-size: 1.75rem;\n  }\n\n  .mini-drawer:hover {\n    background: #b8934c;\n    color: #1a0f0a;\n    transform: translateY(-8px) scale(1.1);\n    box-shadow: 0 10px 25px rgba(184, 147, 76, 0.3);\n  }\n\n</style>\n\n<div class=\"mahogany-split font-sans\" data-kid=\"1\">\n  \n  \n  <aside class=\"bookshelf-sidebar\" data-kid=\"2\">\n    <div class=\"sidebar-label font-condensed\" data-kid=\"3\">( for the loved & closest ones )</div>\n    \n    \n    <div class=\"book-card-sm\" data-kid=\"4\">\n      <div class=\"book-cover-sm bg-[#4a2e6e]\" style=\"border-left-color: #341d52;\" data-kid=\"5\">\n        <div class=\"fabric-texture\" data-kid=\"6\"></div>\n        <div class=\"flex justify-between w-full items-start\" data-kid=\"7\">\n          <span class=\"font-serif italic text-[10px] opacity-60\" data-kid=\"8\">Vol. I</span>\n          <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/rocket.svg\" class=\"w-6 h-6\" alt=\"rocket\" data-kid=\"9\">\n        </div>\n        <h3 class=\"font-serif text-xl font-bold text-center\" data-kid=\"10\">Maverick</h3>\n        <span class=\"font-condensed text-[8px] tracking-widest opacity-40\" data-kid=\"11\">enter</span>\n      </div>\n    </div>\n\n    \n    <div class=\"book-card-sm\" data-kid=\"12\">\n      <div class=\"book-cover-sm bg-[#7a2e4a]\" style=\"border-left-color: #5e1f36;\" data-kid=\"13\">\n        <div class=\"fabric-texture\" data-kid=\"14\"></div>\n        <div class=\"flex justify-between w-full items-start\" data-kid=\"15\">\n          <span class=\"font-serif italic text-[10px] opacity-60\" data-kid=\"16\">Vol. II</span>\n          <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bell.svg\" class=\"w-6 h-6\" alt=\"bell\" data-kid=\"17\">\n        </div>\n        <h3 class=\"font-serif text-xl font-bold text-center\" data-kid=\"18\">Bell</h3>\n        <span class=\"font-condensed text-[8px] tracking-widest opacity-40\" data-kid=\"19\">enter</span>\n      </div>\n    </div>\n\n    \n    <div class=\"book-card-sm\" data-kid=\"20\">\n      <div class=\"book-cover-sm bg-[#2e4a35]\" style=\"border-left-color: #1f3424;\" data-kid=\"21\">\n        <div class=\"fabric-texture\" data-kid=\"22\"></div>\n        <div class=\"flex justify-between w-full items-start\" data-kid=\"23\">\n          <span class=\"font-serif italic text-[10px] opacity-60\" data-kid=\"24\">Vol. III</span>\n          <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/dragon.svg\" class=\"w-6 h-6\" alt=\"dragon\" data-kid=\"25\">\n        </div>\n        <h3 class=\"font-serif text-xl font-bold text-center\" data-kid=\"26\">Goju</h3>\n        <span class=\"font-condensed text-[8px] tracking-widest opacity-40\" data-kid=\"27\">enter</span>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"main-reception\" data-kid=\"28\">\n    <div class=\"bg-library\" data-kid=\"29\"></div>\n    <div class=\"lamp-glow-reception\" data-kid=\"30\"></div>\n\n    <div class=\"leather-plaque\" data-kid=\"31\">\n      <h1 class=\"font-serif gold-title\" data-kid=\"32\">WeGift</h1>\n      <div class=\"flex items-center gap-4 mt-2 justify-center\" data-kid=\"33\">\n        <div class=\"h-px flex-1 bg-gradient-to-r from-transparent to-[#b8934c]/50\" data-kid=\"34\"></div>\n        <p class=\"font-condensed text-lg tracking-[0.2em] text-[#b8934c] opacity-90\" data-kid=\"35\">\n          By - MAVERICK aka BHAVESH\n        </p>\n        <div class=\"h-px flex-1 bg-gradient-to-l from-transparent to-[#b8934c]/50\" data-kid=\"36\"></div>\n      </div>\n    </div>\n\n    <div class=\"cta-container\" data-kid=\"37\">\n      <button class=\"reception-btn\" data-kid=\"38\">EMAIL LOGIN</button>\n      <button class=\"reception-btn secondary\" data-kid=\"39\">REGISTER ACCOUNT</button>\n      \n      <p class=\"text-center text-[10px] font-condensed tracking-[0.2em] opacity-30 mt-4 uppercase\" data-kid=\"40\">\n        Authentication Required for Full Access\n      </p>\n    </div>\n\n    <div class=\"catalog-mini-dock\" data-kid=\"41\">\n      <div class=\"mini-drawer\" title=\"Music\" data-kid=\"42\"><i class=\"ti ti-music\" data-kid=\"43\"></i></div>\n      <div class=\"mini-drawer\" title=\"Anime\" data-kid=\"44\"><i class=\"ti ti-video\" data-kid=\"45\"></i></div>\n      <div class=\"mini-drawer\" title=\"Books\" data-kid=\"100\"><i class=\"ti ti-books\" data-kid=\"101\"></i></div>\n      <div class=\"mini-drawer\" title=\"Movies\" data-kid=\"102\"><i class=\"ti ti-movie\" data-kid=\"103\"></i></div>\n      <div class=\"mini-drawer\" title=\"YouTube\" data-kid=\"104\"><i class=\"ti ti-brand-youtube\" data-kid=\"105\"></i></div>\n      <div class=\"mini-drawer\" title=\"Games\" data-kid=\"106\"><i class=\"ti ti-device-gamepad-2\" data-kid=\"107\"></i></div>\n      <div class=\"mini-drawer\" title=\"Study Zone\" data-kid=\"46\"><i class=\"ti ti-pencil\" data-kid=\"47\"></i></div>\n    </div>\n\n    <div class=\"footer-caption uppercase font-condensed tracking-widest opacity-30\" data-kid=\"48\">\n      a forever memory\n    </div>\n  </main>\n</div>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"49\">",
