      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Oswald:wght@200..700&family=Inter:wght@400;600&display=swap');\n\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-condensed { font-family: 'Oswald', sans-serif; }\n  .font-sans { font-family: 'Inter', sans-serif; }\n\n  .mahogany-bg {\n    background-color: #2a150a;\n    background-image: radial-gradient(circle at top, rgba(246, 200, 121, 0.15) 0%, transparent 70%);\n  }\n\n  .leather-texture {\n    background-color: #1a0f0a;\n    background-image: url(\"https://www.transparenttextures.com/patterns/dark-leather.png\");\n    box-shadow: inset 0 0 20px rgba(0,0,0,0.5), 0 10px 30px rgba(0,0,0,0.5);\n  }\n\n  .gold-emboss {\n    color: #b8934c;\n    text-shadow: 1px 1px 0px rgba(255,255,255,0.1), -1px -1px 0px rgba(0,0,0,0.5);\n    background: linear-gradient(to bottom, #d4af37, #b8934c);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .book-card {\n    perspective: 1000px;\n    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .book-cover {\n    transform-origin: left;\n    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n    box-shadow: 5px 5px 15px rgba(0,0,0,0.6);\n  }\n\n  .book-card:hover .book-cover {\n    transform: rotateY(-30deg);\n  }\n\n  .book-card:hover {\n    transform: translateY(-10px) scale(1.05);\n  }\n\n  .drawer-face {\n    background: linear-gradient(135deg, #4a2511, #361b0d);\n    border: 1px solid #5d3a24;\n    box-shadow: inset 2px 2px 5px rgba(255,255,255,0.05), 0 4px 10px rgba(0,0,0,0.4);\n  }\n\n  .brass-label {\n    background: linear-gradient(135deg, #d4af37, #a67c00);\n    border: 1px solid #8a6d00;\n    box-shadow: 1px 1px 3px rgba(0,0,0,0.3);\n  }\n\n  .lamp-glow {\n    mask-image: radial-gradient(circle at center, black, transparent 80%);\n  }\n</style>\n\n<div class=\"mahogany-bg min-h-[900px] w-full flex flex-col items-center relative overflow-hidden text-[#fff9e6] font-sans\" data-kid=\"1\">\n  \n  \n  <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-full h-[700px] opacity-60 pointer-events-none\" data-kid=\"2\">\n    <img src=\"https://images.unsplash.com/photo-1728506972831-193841eb2961?auto=format&w=1440&q=80&fit=crop\" class=\"w-full h-full object-cover lamp-glow\" decoding=\"async\" loading=\"lazy\" alt=\"Vintage library bookshelves\" data-kid=\"3\">\n  </div>\n\n  \n  <div class=\"relative z-10 mt-20 flex flex-col items-center\" data-kid=\"4\">\n    <div class=\"leather-texture px-16 py-8 rounded-sm border border-[#3d2b1f] mb-6\" data-kid=\"5\">\n      <h1 class=\"font-serif text-7xl font-bold tracking-tight gold-emboss\" data-kid=\"6\">WeGift</h1>\n    </div>\n    <div class=\"flex items-center gap-4\" data-kid=\"7\">\n      <div class=\"h-px w-20 bg-gradient-to-r from-transparent to-[#b8934c]\" data-kid=\"8\"></div>\n      <p class=\"font-condensed text-xl tracking-[0.3em] uppercase text-[#b8934c] opacity-80 animate-pulse\" data-kid=\"9\">\n        Choose Your Volume\n      </p>\n      <div class=\"h-px w-20 bg-gradient-to-l from-transparent to-[#b8934c]\" data-kid=\"10\"></div>\n    </div>\n  </div>\n\n  \n  <div class=\"relative z-10 mt-24 flex gap-16 justify-center max-w-6xl w-full px-8\" data-kid=\"11\">\n    \n    \n    <div class=\"book-card group cursor-pointer w-64\" data-kid=\"12\">\n      <div class=\"book-cover h-80 w-full bg-[#4a2e6e] rounded-r-md border-l-8 border-[#341d52] relative p-6 flex flex-col items-center justify-between\" data-kid=\"13\">\n        <div class=\"absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/fabric-of-the-nation.png')] pointer-events-none\" data-kid=\"14\"></div>\n        <div class=\"w-full border-b border-[#fff9e6]/20 pb-2 flex justify-between items-start\" data-kid=\"15\">\n          <span class=\"font-serif italic text-sm opacity-60\" data-kid=\"16\">Vol. I</span>\n          <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/rocket.svg\" class=\"w-8 h-8\" alt=\"rocket\" data-kid=\"17\">\n        </div>\n        <h2 class=\"font-serif text-3xl font-bold text-center mt-4\" data-kid=\"18\">Maverick</h2>\n        <div class=\"mt-auto w-full text-center\" data-kid=\"19\">\n          <button class=\"font-condensed tracking-widest text-xs border border-[#fff9e6]/30 px-4 py-2 rounded-full hover:bg-[#fff9e6]/10 transition-colors\" data-kid=\"20\">\n            OPEN VOLUME\n          </button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"book-card group cursor-pointer w-64 -translate-y-8\" data-kid=\"21\">\n      <div class=\"book-cover h-80 w-full bg-[#7a2e4a] rounded-r-md border-l-8 border-[#5e1f36] relative p-6 flex flex-col items-center justify-between\" data-kid=\"22\">\n        <div class=\"absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/fabric-of-the-nation.png')] pointer-events-none\" data-kid=\"23\"></div>\n        <div class=\"w-full border-b border-[#fff9e6]/20 pb-2 flex justify-between items-start\" data-kid=\"24\">\n          <span class=\"font-serif italic text-sm opacity-60\" data-kid=\"25\">Vol. II</span>\n          <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bell.svg\" class=\"w-8 h-8\" alt=\"bell\" data-kid=\"26\">\n        </div>\n        <h2 class=\"font-serif text-3xl font-bold text-center mt-4\" data-kid=\"27\">Bell</h2>\n        <div class=\"mt-auto w-full text-center\" data-kid=\"28\">\n          <button class=\"font-condensed tracking-widest text-xs border border-[#fff9e6]/30 px-4 py-2 rounded-full hover:bg-[#fff9e6]/10 transition-colors\" data-kid=\"29\">\n            OPEN VOLUME\n          </button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"book-card group cursor-pointer w-64\" data-kid=\"30\">\n      <div class=\"book-cover h-80 w-full bg-[#2e4a35] rounded-r-md border-l-8 border-[#1f3424] relative p-6 flex flex-col items-center justify-between\" data-kid=\"31\">\n        <div class=\"absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/fabric-of-the-nation.png')] pointer-events-none\" data-kid=\"32\"></div>\n        <div class=\"w-full border-b border-[#fff9e6]/20 pb-2 flex justify-between items-start\" data-kid=\"33\">\n          <span class=\"font-serif italic text-sm opacity-60\" data-kid=\"34\">Vol. III</span>\n          <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/dragon.svg\" class=\"w-8 h-8\" alt=\"dragon\" data-kid=\"35\">\n        </div>\n        <h2 class=\"font-serif text-3xl font-bold text-center mt-4\" data-kid=\"36\">Goju</h2>\n        <div class=\"mt-auto w-full text-center\" data-kid=\"37\">\n          <button class=\"font-condensed tracking-widest text-xs border border-[#fff9e6]/30 px-4 py-2 rounded-full hover:bg-[#fff9e6]/10 transition-colors\" data-kid=\"38\">\n            OPEN VOLUME\n          </button>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n  \n  <div class=\"mt-auto w-full max-w-4xl px-8 pb-16 relative z-10\" data-kid=\"39\">\n    <div class=\"flex flex-col gap-2 mb-4\" data-kid=\"40\">\n      <h3 class=\"font-serif italic text-[#b8934c] text-center\" data-kid=\"41\">Reference Catalog</h3>\n      <div class=\"h-px w-full bg-gradient-to-r from-transparent via-[#b8934c]/30 to-transparent\" data-kid=\"42\"></div>\n    </div>\n    \n    <div class=\"grid grid-cols-3 gap-6\" data-kid=\"43\">\n      \n      <div class=\"drawer-face p-6 flex flex-col items-center gap-4 cursor-pointer hover:translate-x-2 transition-transform\" data-kid=\"44\">\n        <div class=\"brass-label px-6 py-2 rounded-sm flex items-center gap-2\" data-kid=\"45\">\n          <i class=\"ti ti-radio text-[#1a0f0a] text-lg\" data-kid=\"46\"></i>\n          <span class=\"font-condensed text-[#1a0f0a] font-bold tracking-tighter\" data-kid=\"47\">MUSIC</span>\n        </div>\n        <p class=\"text-[10px] font-serif uppercase tracking-widest opacity-40\" data-kid=\"48\">Section 12.04</p>\n      </div>\n\n      \n      <div class=\"drawer-face p-6 flex flex-col items-center gap-4 cursor-pointer hover:translate-x-2 transition-transform\" data-kid=\"49\">\n        <div class=\"brass-label px-6 py-2 rounded-sm flex items-center gap-2\" data-kid=\"50\">\n          <i class=\"ti ti-video text-[#1a0f0a] text-lg\" data-kid=\"51\"></i>\n          <span class=\"font-condensed text-[#1a0f0a] font-bold tracking-tighter\" data-kid=\"52\">ANIME</span>\n        </div>\n        <p class=\"text-[10px] font-serif uppercase tracking-widest opacity-40\" data-kid=\"53\">Section 08.15</p>\n      </div>\n\n      \n      <div class=\"drawer-face p-6 flex flex-col items-center gap-4 cursor-pointer hover:translate-x-2 transition-transform\" data-kid=\"54\">\n        <div class=\"brass-label px-6 py-2 rounded-sm flex items-center gap-2\" data-kid=\"55\">\n          <i class=\"ti ti-pencil text-[#1a0f0a] text-lg\" data-kid=\"56\"></i>\n          <span class=\"font-condensed text-[#1a0f0a] font-bold tracking-tighter\" data-kid=\"57\">STUDY</span>\n        </div>\n        <p class=\"text-[10px] font-serif uppercase tracking-widest opacity-40\" data-kid=\"58\">Section 22.09</p>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"absolute bottom-6 left-12 flex items-center gap-8 text-[10px] font-serif italic opacity-30\" data-kid=\"59\">\n    <p data-kid=\"60\">EST. 2026</p>\n    <p data-kid=\"61\">MERN PLATFORM V2</p>\n  </div>\n  \n  <div class=\"absolute bottom-6 right-12 flex items-center gap-4 text-[11px] font-condensed tracking-widest opacity-50\" data-kid=\"62\">\n    <a href=\"#\" class=\"hover:text-[#b8934c] transition-colors\" data-kid=\"63\">EMAIL LOGIN</a>\n    <span data-kid=\"64\">|</span>\n    <a href=\"#\" class=\"hover:text-[#b8934c] transition-colors\" data-kid=\"65\">REGISTER</a>\n  </div>\n\n</div>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"66\">",
