      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@400;600&family=Fira+Code:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .lofi-bg {\n    background-image: url('https://images.unsplash.com/photo-1611072337226-1140ab367200?auto=format&w=1440&q=80&fit=crop');\n    background-size: cover;\n    background-position: center;\n    background-attachment: fixed;\n  }\n\n  .paper-shadow {\n    box-shadow: 2px 4px 8px rgba(0,0,0,0.15);\n  }\n\n  .ripped-paper {\n    background-color: #fdfbf7;\n    background-image: repeating-linear-gradient(#fdfbf7, #fdfbf7 24px, #e5e5e5 25px);\n    mask-image: url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/ripped-paper.svg'); /* Fallback or CSS clip-path */\n    clip-path: polygon(0% 5%, 15% 0%, 35% 8%, 55% 2%, 75% 10%, 100% 4%, 98% 95%, 80% 100%, 60% 92%, 40% 98%, 20% 94%, 0% 100%);\n  }\n\n  .polaroid-coaster {\n    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n    background: #fff;\n    padding: 12px 12px 32px 12px;\n    box-shadow: 0 8px 16px rgba(0,0,0,0.2);\n  }\n\n  .polaroid-coaster:hover {\n    transform: scale(1.05) rotate(0deg) translateY(-10px);\n    z-index: 10;\n  }\n\n  .spiral-notebook {\n    background-color: #fdfbf7;\n    border-left: 20px solid #d4c5b3;\n    position: relative;\n  }\n\n  .spiral-notebook::before {\n    content: '';\n    position: absolute;\n    left: -15px;\n    top: 20px;\n    bottom: 20px;\n    width: 30px;\n    background-image: radial-gradient(circle, #3a2e2a 4px, transparent 5px);\n    background-size: 30px 24px;\n    z-index: 2;\n  }\n\n  .lofi-font-serif { font-family: 'Playfair Display', serif; }\n  .lofi-font-sans { font-family: 'Inter', sans-serif; }\n  .lofi-font-mono { font-family: 'Fira Code', monospace; }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0); }\n    50% { transform: translateY(-5px); }\n  }\n\n  .animate-float { animation: float 3s ease-in-out infinite; }\n</style>\n\n<div class=\"lofi-bg min-h-[900px] w-full relative overflow-hidden flex flex-col items-center p-12 selection:bg-rose-200\" data-kid=\"1\">\n  \n  <div class=\"absolute inset-0 bg-sepia-200/10 pointer-events-none\" data-kid=\"2\"></div>\n\n  \n  <div class=\"relative z-10 mt-12 mb-16 rotate-[-2deg] transition-transform hover:rotate-0\" data-kid=\"3\">\n    <div class=\"ripped-paper paper-shadow px-16 py-10 max-w-2xl text-center\" data-kid=\"4\">\n      <h1 class=\"lofi-font-serif text-5xl font-black text-[#3a2e2a] mb-2\" data-kid=\"5\">Welcome to WeGift</h1>\n      <p class=\"lofi-font-mono text-sm tracking-widest text-[#3a2e2a]/60 uppercase\" data-kid=\"6\">Choose your path</p>\n      \n      \n      <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/pushpin.svg\" class=\"absolute -top-4 left-1/2 -translate-x-1/2 w-8 drop-shadow-sm\" alt=\"pin\" data-kid=\"7\">\n    </div>\n  </div>\n\n  \n  <div class=\"flex flex-wrap justify-center gap-12 mb-20 relative z-10\" data-kid=\"8\">\n    \n    \n    <button class=\"polaroid-coaster rotate-[-4deg] flex flex-col items-center group\" data-kid=\"9\">\n      <div class=\"w-48 h-48 bg-[#6c63ff]/10 rounded-sm mb-4 flex items-center justify-center overflow-hidden border border-[#6c63ff]/20\" data-kid=\"10\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/rocket.svg\" class=\"w-24 group-hover:scale-110 transition-transform duration-500\" alt=\"Maverick\" data-kid=\"11\">\n      </div>\n      <span class=\"lofi-font-serif text-2xl font-bold text-[#3a2e2a]\" data-kid=\"12\">Maverick</span>\n      <span class=\"lofi-font-mono text-[10px] text-[#3a2e2a]/40 mt-1\" data-kid=\"13\">LIFT OFF →</span>\n    </button>\n\n    \n    <button class=\"polaroid-coaster rotate-[2deg] translate-y-4 flex flex-col items-center group\" data-kid=\"14\">\n      <div class=\"w-48 h-48 bg-[#ff6584]/10 rounded-sm mb-4 flex items-center justify-center overflow-hidden border border-[#ff6584]/20\" data-kid=\"15\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bell.svg\" class=\"w-24 group-hover:rotate-12 transition-transform duration-500\" alt=\"Bell\" data-kid=\"16\">\n      </div>\n      <span class=\"lofi-font-serif text-2xl font-bold text-[#3a2e2a]\" data-kid=\"17\">Bell</span>\n      <span class=\"lofi-font-mono text-[10px] text-[#3a2e2a]/40 mt-1\" data-kid=\"18\">RING IN →</span>\n    </button>\n\n    \n    <button class=\"polaroid-coaster rotate-[-2deg] flex flex-col items-center group\" data-kid=\"19\">\n      <div class=\"w-48 h-48 bg-[#43e97b]/10 rounded-sm mb-4 flex items-center justify-center overflow-hidden border border-[#43e97b]/20\" data-kid=\"20\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/dragon.svg\" class=\"w-24 group-hover:scale-110 transition-transform duration-500\" alt=\"Goju\" data-kid=\"21\">\n      </div>\n      <span class=\"lofi-font-serif text-2xl font-bold text-[#3a2e2a]\" data-kid=\"22\">Goju</span>\n      <span class=\"lofi-font-mono text-[10px] text-[#3a2e2a]/40 mt-1\" data-kid=\"23\">AWAKEN →</span>\n    </button>\n  </div>\n\n  \n  <div class=\"max-w-4xl w-full spiral-notebook paper-shadow p-12 rotate-[1deg] translate-x-4\" data-kid=\"24\">\n    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"25\">\n      \n      \n      <div class=\"flex flex-col items-center text-center p-4 rounded-lg hover:bg-[#d4c5b3]/10 transition-colors\" data-kid=\"26\">\n        <div class=\"text-4xl text-[#3a2e2a] mb-3 opacity-80\" data-kid=\"27\">\n          <i class=\"ti ti-device-audio-tape\" data-kid=\"28\"></i>\n        </div>\n        <h3 class=\"lofi-font-serif text-xl font-bold text-[#3a2e2a] mb-1\" data-kid=\"29\">Music Hub</h3>\n        <p class=\"lofi-font-sans text-xs text-[#3a2e2a]/60 italic\" data-kid=\"30\">Lofi beats to study / relax to.</p>\n      </div>\n\n      \n      <div class=\"flex flex-col items-center text-center p-4 rounded-lg hover:bg-[#d4c5b3]/10 transition-colors\" data-kid=\"31\">\n        <div class=\"text-4xl text-[#3a2e2a] mb-3 opacity-80\" data-kid=\"32\">\n          <i class=\"ti ti-device-tv\" data-kid=\"33\"></i>\n        </div>\n        <h3 class=\"lofi-font-serif text-xl font-bold text-[#3a2e2a] mb-1\" data-kid=\"34\">Anime Zone</h3>\n        <p class=\"lofi-font-sans text-xs text-[#3a2e2a]/60 italic\" data-kid=\"35\">Your sanctuary for tracking & watching.</p>\n      </div>\n\n      \n      <div class=\"flex flex-col items-center text-center p-4 rounded-lg hover:bg-[#d4c5b3]/10 transition-colors\" data-kid=\"36\">\n        <div class=\"text-4xl text-[#3a2e2a] mb-3 opacity-80\" data-kid=\"37\">\n          <i class=\"ti ti-coffee\" data-kid=\"38\"></i>\n        </div>\n        <h3 class=\"lofi-font-serif text-xl font-bold text-[#3a2e2a] mb-1\" data-kid=\"39\">Study Room</h3>\n        <p class=\"lofi-font-sans text-xs text-[#3a2e2a]/60 italic\" data-kid=\"40\">Focus timers, tasks, and notes.</p>\n      </div>\n\n    </div>\n\n    \n    <div class=\"mt-8 pt-6 border-t border-[#3a2e2a]/10 flex justify-between items-center\" data-kid=\"41\">\n      <div class=\"flex gap-4\" data-kid=\"42\">\n        <a href=\"#\" class=\"lofi-font-mono text-[10px] text-[#3a2e2a]/40 hover:text-[#3a2e2a] transition-colors\" data-kid=\"43\">SIGN IN →</a>\n        <a href=\"#\" class=\"lofi-font-mono text-[10px] text-[#3a2e2a]/40 hover:text-[#3a2e2a] transition-colors\" data-kid=\"44\">REGISTER</a>\n      </div>\n      <div class=\"lofi-font-mono text-[10px] text-[#3a2e2a]/20\" data-kid=\"45\">DEMO MODE ON</div>\n    </div>\n  </div>\n\n  \n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/swirl-ring.svg\" class=\"absolute top-20 right-20 w-32 opacity-10 pointer-events-none rotate-45\" alt=\"doodle\" data-kid=\"46\">\n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/ink-swirl.svg\" class=\"absolute bottom-40 left-10 w-48 opacity-10 pointer-events-none -rotate-12\" alt=\"doodle\" data-kid=\"47\">\n\n</div>",
