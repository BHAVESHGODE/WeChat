      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@400;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  @keyframes blink {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0; }\n  }\n\n  @keyframes ticker {\n    0% { transform: translateX(100%); }\n    100% { transform: translateX(-100%); }\n  }\n\n  .arcade-frame {\n    clip-path: polygon(\n      0% 20px, 20px 0%, \n      calc(100% - 20px) 0%, 100% 20px, \n      100% calc(100% - 20px), calc(100% - 20px) 100%, \n      20px 100%, 0% calc(100% - 20px)\n    );\n  }\n\n  .ticket-notch {\n    background-image: radial-gradient(circle at center, transparent 15px, var(--bg-color) 16px);\n    background-size: 30px 30px;\n  }\n\n  .animate-blink {\n    animation: blink 1s step-end infinite;\n  }\n\n  .ticket-group:hover .ticket-top {\n    transform: translateY(-12px);\n  }\n</style>\n\n<div class=\"min-h-[900px] bg-[#0f0f13] text-white font-['Inter'] relative overflow-hidden flex flex-col items-center justify-center py-20\" data-kid=\"1\">\n  \n  \n  <div class=\"absolute top-8 left-8 font-['Fira_Code'] text-[12px] text-[#43e97b] opacity-80 leading-relaxed\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2 hover:opacity-100 cursor-pointer\" data-kid=\"3\">\n      <span class=\"text-white\" data-kid=\"4\">></span> login --email\n    </div>\n    <div class=\"flex items-center gap-2 mt-1 hover:opacity-100 cursor-pointer\" data-kid=\"5\">\n      <span class=\"text-white\" data-kid=\"6\">></span> register --new\n    </div>\n  </div>\n\n  \n  <div class=\"relative mb-24 text-center\" data-kid=\"7\">\n    <div class=\"arcade-frame border-2 border-[#00d4ff] p-8 md:p-12 shadow-[0_0_30px_rgba(0,212,255,0.3)] bg-[#0f0f13]/80 backdrop-blur-sm\" data-kid=\"8\">\n      <h1 class=\"font-['Fira_Code'] text-6xl md:text-8xl font-bold tracking-[0.2em] bg-linear-to-r from-[#00d4ff] to-[#7c4dff] bg-clip-text text-transparent\" data-kid=\"9\">\n        W E G I F T\n      </h1>\n    </div>\n    \n    <div class=\"mt-8 flex items-center justify-center gap-6\" data-kid=\"10\">\n      <i class=\"ti ti-device-gamepad-2 text-[#7c4dff] text-2xl\" data-kid=\"11\"></i>\n      <p class=\"font-['Fira_Code'] text-lg text-[#ff6b9d] tracking-[0.3em] animate-blink\" data-kid=\"12\">\n        >>> CHOOSE YOUR PATH <<<\n      </p>\n      <i class=\"ti ti-device-gamepad-2 text-[#7c4dff] text-2xl\" data-kid=\"13\"></i>\n    </div>\n  </div>\n\n  \n  <div class=\"flex flex-wrap justify-center gap-8 px-6 mb-32\" data-kid=\"14\">\n    \n    \n    <div class=\"ticket-group relative w-[280px] transition-all duration-300 cursor-pointer\" data-kid=\"15\">\n      <div class=\"ticket-top bg-[#1a1a2e] border-2 border-[#7c4dff] border-b-0 h-[220px] rounded-t-2xl relative transition-transform duration-300 overflow-hidden flex items-center justify-center\" data-kid=\"16\">\n        \n        <div class=\"absolute -left-4 top-1/2 -translate-y-1/2 w-8 h-8 bg-[#0f0f13] rounded-full\" data-kid=\"17\"></div>\n        <div class=\"absolute -right-4 top-1/2 -translate-y-1/2 w-8 h-8 bg-[#0f0f13] rounded-full\" data-kid=\"18\"></div>\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/rocket.svg\" class=\"w-32 h-32\" alt=\"Maverick\" loading=\"lazy\" decoding=\"async\" data-kid=\"19\">\n      </div>\n      <div class=\"h-0 border-t-2 border-dashed border-[#7c4dff] relative z-10\" data-kid=\"20\"></div>\n      <div class=\"bg-[#1a1a2e] border-2 border-[#7c4dff] border-t-0 p-6 rounded-b-2xl text-center\" data-kid=\"21\">\n        <h3 class=\"font-['Playfair_Display'] italic text-3xl text-white mb-4\" data-kid=\"22\">Maverick</h3>\n        <div class=\"bg-black/40 h-10 flex items-center justify-center overflow-hidden\" data-kid=\"23\">\n          <div class=\"w-full h-full opacity-50 bg-[url('https://www.transparenttextures.com/patterns/barcode.png')] bg-repeat-x bg-contain\" data-kid=\"24\"></div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"ticket-group relative w-[280px] transition-all duration-300 cursor-pointer mt-8 md:mt-0\" data-kid=\"25\">\n      <div class=\"ticket-top bg-[#2d1b24] border-2 border-[#ff6b9d] border-b-0 h-[220px] rounded-t-2xl relative transition-transform duration-300 overflow-hidden flex items-center justify-center\" data-kid=\"26\">\n        \n        <div class=\"absolute -left-4 top-1/2 -translate-y-1/2 w-8 h-8 bg-[#0f0f13] rounded-full\" data-kid=\"27\"></div>\n        <div class=\"absolute -right-4 top-1/2 -translate-y-1/2 w-8 h-8 bg-[#0f0f13] rounded-full\" data-kid=\"28\"></div>\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bell.svg\" class=\"w-32 h-32\" alt=\"Bell\" loading=\"lazy\" decoding=\"async\" data-kid=\"29\">\n      </div>\n      <div class=\"h-0 border-t-2 border-dashed border-[#ff6b9d] relative z-10\" data-kid=\"30\"></div>\n      <div class=\"bg-[#2d1b24] border-2 border-[#ff6b9d] border-t-0 p-6 rounded-b-2xl text-center\" data-kid=\"31\">\n        <h3 class=\"font-['Playfair_Display'] italic text-3xl text-white mb-4\" data-kid=\"32\">Bell</h3>\n        <div class=\"bg-black/40 h-10 flex items-center justify-center overflow-hidden\" data-kid=\"33\">\n          <div class=\"w-full h-full opacity-50 bg-[url('https://www.transparenttextures.com/patterns/barcode.png')] bg-repeat-x bg-contain\" data-kid=\"34\"></div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"ticket-group relative w-[280px] transition-all duration-300 cursor-pointer mt-16 md:mt-0\" data-kid=\"35\">\n      <div class=\"ticket-top bg-[#1b2d21] border-2 border-[#43e97b] border-b-0 h-[220px] rounded-t-2xl relative transition-transform duration-300 overflow-hidden flex items-center justify-center\" data-kid=\"36\">\n        \n        <div class=\"absolute -left-4 top-1/2 -translate-y-1/2 w-8 h-8 bg-[#0f0f13] rounded-full\" data-kid=\"37\"></div>\n        <div class=\"absolute -right-4 top-1/2 -translate-y-1/2 w-8 h-8 bg-[#0f0f13] rounded-full\" data-kid=\"38\"></div>\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/dragon.svg\" class=\"w-32 h-32\" alt=\"Goju\" loading=\"lazy\" decoding=\"async\" data-kid=\"39\">\n      </div>\n      <div class=\"h-0 border-t-2 border-dashed border-[#43e97b] relative z-10\" data-kid=\"40\"></div>\n      <div class=\"bg-[#1b2d21] border-2 border-[#43e97b] border-t-0 p-6 rounded-b-2xl text-center\" data-kid=\"41\">\n        <h3 class=\"font-['Playfair_Display'] italic text-3xl text-white mb-4\" data-kid=\"42\">Goju</h3>\n        <div class=\"bg-black/40 h-10 flex items-center justify-center overflow-hidden\" data-kid=\"43\">\n          <div class=\"w-full h-full opacity-50 bg-[url('https://www.transparenttextures.com/patterns/barcode.png')] bg-repeat-x bg-contain\" data-kid=\"44\"></div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n  \n  <div class=\"fixed bottom-12 w-full max-w-4xl px-8\" data-kid=\"45\">\n    <div class=\"bg-black border-4 border-[#1a1a23] rounded-xl p-4 shadow-[inset_0_0_20px_rgba(0,0,0,0.8)] overflow-hidden\" data-kid=\"46\">\n      <div class=\"flex gap-12 font-['Fira_Code'] text-xl uppercase whitespace-nowrap\" data-kid=\"47\">\n        <span class=\"text-[#00d4ff] shadow-[0_0_8px_#00d4ff]\" data-kid=\"48\">[ MUSIC ]</span>\n        <span class=\"text-[#ff6b9d] shadow-[0_0_8px_#ff6b9d]\" data-kid=\"49\">[ ANIME ]</span>\n        <span class=\"text-[#00d4ff] shadow-[0_0_8px_#00d4ff]\" data-kid=\"50\">[ STUDY ZONE ]</span>\n        <span class=\"text-[#ff6b9d] shadow-[0_0_8px_#ff6b9d]\" data-kid=\"51\">[ GAMES ]</span>\n        <span class=\"text-[#00d4ff] shadow-[0_0_8px_#00d4ff]\" data-kid=\"52\">[ MOVIES ]</span>\n        \n        <span class=\"text-[#ff6b9d] shadow-[0_0_8px_#ff6b9d] hidden lg:inline\" data-kid=\"53\">[ ADMIT ONE ]</span>\n      </div>\n    </div>\n  </div>\n\n</div>",
