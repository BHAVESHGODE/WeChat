      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&family=Fira+Code:wght@400;500&family=Playfair+Display:ital,wght@1,700&family=Oswald:wght@700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .paper-bg {\n    background-image: url('https://images.unsplash.com/photo-1603484477859-abe6a73f9366?auto=format&w=1440&q=80&fit=crop');\n    background-size: cover;\n    background-position: center;\n  }\n\n  .magazine-cutout {\n    display: inline-block;\n    padding: 0.25rem 0.5rem;\n    margin: 0.1rem;\n    border: 1px solid #2c2c2c;\n    box-shadow: 2px 2px 0px rgba(0,0,0,0.8);\n    background: #fff;\n    font-weight: 800;\n  }\n\n  .polaroid {\n    background: #fff;\n    padding: 12px 12px 40px 12px;\n    box-shadow: 0 4px 15px rgba(0,0,0,0.1);\n    transition: all 0.3s ease;\n  }\n\n  .polaroid:hover {\n    transform: scale(1.05) rotate(0deg) !important;\n    box-shadow: 0 10px 25px rgba(0,0,0,0.2);\n    z-index: 10;\n  }\n\n  .washi-tape {\n    height: 30px;\n    width: 100px;\n    opacity: 0.6;\n    background: #C87941;\n    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);\n    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);\n  }\n\n  .paper-pocket {\n    background: rgba(255, 255, 255, 0.3);\n    border: 2px solid #C87941;\n    border-top: none;\n    border-radius: 0 0 16px 16px;\n    position: relative;\n    height: 120px;\n    width: 200px;\n  }\n\n  .ticket {\n    background: #fdf6e3;\n    border: 1px dashed #C87941;\n    transition: transform 0.3s ease;\n  }\n\n  .paper-pocket:hover .ticket {\n    transform: translateY(-40px);\n  }\n\n  .typewriter {\n    font-family: 'Fira Code', monospace;\n  }\n</style>\n\n<div class=\"paper-bg min-h-[900px] w-full relative overflow-hidden flex flex-col items-center py-16 px-8 select-none\" data-kid=\"1\">\n  \n  \n  <header class=\"mb-16 animate-fade-in\" data-kid=\"2\">\n    <div class=\"flex items-center justify-center\" data-kid=\"3\">\n      <span class=\"magazine-cutout font-oswald text-5xl rotate-[-3deg] bg-red-100 text-[#C87941]\" data-kid=\"4\">W</span>\n      <span class=\"magazine-cutout font-outfit text-4xl rotate-[2deg] bg-blue-100 text-[#5B7586]\" data-kid=\"5\">E</span>\n      <span class=\"magazine-cutout font-oswald text-6xl rotate-[-1deg] bg-yellow-100 text-[#DDBA61]\" data-kid=\"6\">G</span>\n      <span class=\"magazine-cutout font-outfit text-4xl rotate-[4deg] bg-green-100 text-[#43e97b]\" data-kid=\"7\">I</span>\n      <span class=\"magazine-cutout font-oswald text-5xl rotate-[-2deg] bg-pink-100 text-[#ff6b9d]\" data-kid=\"8\">F</span>\n      <span class=\"magazine-cutout font-outfit text-4xl rotate-[3deg] bg-purple-100 text-[#7c4dff]\" data-kid=\"9\">T</span>\n    </div>\n    <p class=\"typewriter text-[#2C2C2C] text-center mt-4 text-lg font-medium opacity-80 italic\" data-kid=\"10\">\n      — established v2.0 since today —\n    </p>\n  </header>\n\n  \n  <div class=\"max-w-5xl w-full grid grid-cols-1 md:grid-cols-3 gap-12 mb-24 relative\" data-kid=\"11\">\n    \n    \n    <div class=\"relative group\" data-kid=\"12\">\n      <div class=\"washi-tape absolute -top-4 -left-8 rotate-[-15deg] z-20\" data-kid=\"13\"></div>\n      <div class=\"polaroid rotate-[-4deg] relative cursor-pointer\" data-kid=\"14\">\n        <div class=\"bg-[#f0f0f0] aspect-square flex items-center justify-center overflow-hidden mb-4\" data-kid=\"15\">\n          <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/rocket.svg\" class=\"w-24 h-24 transform group-hover:translate-y-[-10px] transition-transform duration-500\" alt=\"Rocket\" data-kid=\"16\">\n        </div>\n        <h2 class=\"font-outfit text-2xl font-bold text-center text-[#2C2C2C]\" data-kid=\"17\">Maverick</h2>\n        <p class=\"typewriter text-xs text-center mt-1 text-[#2C2C2C]/60 uppercase tracking-widest\" data-kid=\"18\">Digital Explorer</p>\n      </div>\n    </div>\n\n    \n    <div class=\"relative group mt-8 md:mt-0\" data-kid=\"19\">\n      <div class=\"washi-tape absolute -top-6 left-1/2 -translate-x-1/2 rotate-[2deg] z-20 bg-[#5B7586]/40\" data-kid=\"20\"></div>\n      <div class=\"polaroid rotate-[1deg] relative cursor-pointer\" data-kid=\"21\">\n        <div class=\"bg-[#f0f0f0] aspect-square flex items-center justify-center overflow-hidden mb-4\" data-kid=\"22\">\n          <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bell.svg\" class=\"w-24 h-24 transform group-hover:scale-110 transition-transform duration-500\" alt=\"Bell\" data-kid=\"23\">\n        </div>\n        <h2 class=\"font-outfit text-2xl font-bold text-center text-[#2C2C2C]\" data-kid=\"24\">Bell</h2>\n        <p class=\"typewriter text-xs text-center mt-1 text-[#2C2C2C]/60 uppercase tracking-widest\" data-kid=\"25\">Melody Weaver</p>\n      </div>\n    </div>\n\n    \n    <div class=\"relative group\" data-kid=\"26\">\n      <div class=\"washi-tape absolute -top-4 -right-8 rotate-[18deg] z-20 bg-[#43e97b]/40\" data-kid=\"27\"></div>\n      <div class=\"polaroid rotate-[5deg] relative cursor-pointer\" data-kid=\"28\">\n        <div class=\"bg-[#f0f0f0] aspect-square flex items-center justify-center overflow-hidden mb-4\" data-kid=\"29\">\n          <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/dragon.svg\" class=\"w-24 h-24 transform group-hover:rotate-12 transition-transform duration-500\" alt=\"Dragon\" data-kid=\"30\">\n        </div>\n        <h2 class=\"font-outfit text-2xl font-bold text-center text-[#2C2C2C]\" data-kid=\"31\">Goju</h2>\n        <p class=\"typewriter text-xs text-center mt-1 text-[#2C2C2C]/60 uppercase tracking-widest\" data-kid=\"32\">Content Guardian</p>\n      </div>\n    </div>\n\n  </div>\n\n  \n  <div class=\"w-full max-w-4xl\" data-kid=\"33\">\n    <h3 class=\"font-playfair text-3xl italic text-[#C87941] text-center mb-12\" data-kid=\"34\">The Archive</h3>\n    \n    <div class=\"flex flex-wrap justify-center gap-16\" data-kid=\"35\">\n      \n      <div class=\"flex flex-col items-center\" data-kid=\"36\">\n        <div class=\"paper-pocket group cursor-pointer\" data-kid=\"37\">\n          <div class=\"ticket absolute inset-x-4 bottom-4 h-32 p-4 flex flex-col items-center justify-start translate-y-0 group-hover:-translate-y-12 shadow-sm\" data-kid=\"38\">\n            <i class=\"ti ti-headphones text-2xl text-[#C87941] mb-1\" data-kid=\"39\"></i>\n            <span class=\"font-oswald text-xs uppercase tracking-tighter\" data-kid=\"40\">Admit One</span>\n            <span class=\"font-outfit font-bold text-sm mt-2 text-center\" data-kid=\"41\">LO-FI<br data-kid=\"42\">STATION</span>\n          </div>\n        </div>\n        <p class=\"typewriter text-sm font-bold mt-4 text-[#2C2C2C]\" data-kid=\"43\">Music Room</p>\n      </div>\n\n      \n      <div class=\"flex flex-col items-center\" data-kid=\"44\">\n        <div class=\"paper-pocket group cursor-pointer\" data-kid=\"45\">\n          <div class=\"ticket absolute inset-x-4 bottom-4 h-32 p-4 flex flex-col items-center justify-start translate-y-0 group-hover:-translate-y-12 shadow-sm\" data-kid=\"46\">\n            <i class=\"ti ti-movie text-2xl text-[#5B7586] mb-1\" data-kid=\"47\"></i>\n            <span class=\"font-oswald text-xs uppercase tracking-tighter\" data-kid=\"48\">Row 7 Seat 4</span>\n            <span class=\"font-outfit font-bold text-sm mt-2 text-center\" data-kid=\"49\">ANIME<br data-kid=\"50\">HUB</span>\n          </div>\n        </div>\n        <p class=\"typewriter text-sm font-bold mt-4 text-[#2C2C2C]\" data-kid=\"51\">Manga Zone</p>\n      </div>\n\n      \n      <div class=\"flex flex-col items-center\" data-kid=\"52\">\n        <div class=\"paper-pocket group cursor-pointer\" data-kid=\"53\">\n          <div class=\"ticket absolute inset-x-4 bottom-4 h-32 p-4 flex flex-col items-center justify-start translate-y-0 group-hover:-translate-y-12 shadow-sm\" data-kid=\"54\">\n            <i class=\"ti ti-book-2 text-2xl text-[#DDBA61] mb-1\" data-kid=\"55\"></i>\n            <span class=\"font-oswald text-xs uppercase tracking-tighter\" data-kid=\"56\">Due Date: Never</span>\n            <span class=\"font-outfit font-bold text-sm mt-2 text-center\" data-kid=\"57\">FOCUS<br data-kid=\"58\">PORTAL</span>\n          </div>\n        </div>\n        <p class=\"typewriter text-sm font-bold mt-4 text-[#2C2C2C]\" data-kid=\"59\">Study Desk</p>\n      </div>\n    </div>\n  </div>\n\n  \n  <footer class=\"mt-32 flex gap-8\" data-kid=\"60\">\n    <a href=\"#\" class=\"typewriter text-sm font-bold text-[#C87941] border-b-2 border-transparent hover:border-[#C87941] transition-all\" data-kid=\"61\">Sign in by Mail</a>\n    <span class=\"text-gray-300\" data-kid=\"62\">|</span>\n    <a href=\"#\" class=\"typewriter text-sm font-bold text-[#C87941] border-b-2 border-transparent hover:border-[#C87941] transition-all\" data-kid=\"63\">Join the Hub</a>\n  </footer>\n\n  \n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/swirl-string.svg\" class=\"absolute top-20 left-10 w-32 h-32 opacity-10 rotate-45 pointer-events-none\" style=\"filter: sepia(1) saturate(5);\" alt data-kid=\"64\">\n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/star-pupil.svg\" class=\"absolute bottom-40 right-10 w-24 h-24 opacity-10 -rotate-12 pointer-events-none\" style=\"filter: sepia(1) saturate(5);\" alt data-kid=\"65\">\n\n</div>",
