      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Oswald:wght@200..700&family=Inter:wght@400;600&display=swap');\n\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-condensed { font-family: 'Oswald', sans-serif; }\n  .font-sans { font-family: 'Inter', sans-serif; }\n\n  .mahogany-bg {\n    background-color: #2a150a;\n    background-image: radial-gradient(circle at top, rgba(246, 200, 121, 0.15) 0%, transparent 70%);\n  }\n\n  .leather-texture {\n    background-color: #1a0f0a;\n    background-image: url(\"https://www.transparenttextures.com/patterns/dark-leather.png\");\n    box-shadow: inset 0 0 20px rgba(0,0,0,0.5), 0 10px 30px rgba(0,0,0,0.5);\n  }\n\n  .gold-emboss {\n    color: #b8934c;\n    text-shadow: 1px 1px 0px rgba(255,255,255,0.1), -1px -1px 0px rgba(0,0,0,0.5);\n    background: linear-gradient(to bottom, #d4af37, #b8934c);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .membership-card {\n    background: #fff9e6;\n    color: #1a0f0a;\n    border: 2px solid #b8934c;\n    box-shadow: 0 10px 25px rgba(0,0,0,0.5), inset 0 0 40px rgba(184, 147, 76, 0.1);\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    cursor: pointer;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .membership-card::before {\n    content: '';\n    position: absolute;\n    top: 0; left: 0; right: 0; bottom: 0;\n    background-image: url('https://www.transparenttextures.com/patterns/natural-paper.png');\n    opacity: 0.3;\n    pointer-events: none;\n  }\n\n  .membership-card:hover {\n    transform: translateY(-8px) scale(1.02);\n    box-shadow: 0 15px 35px rgba(0,0,0,0.6), inset 0 0 60px rgba(184, 147, 76, 0.2);\n    border-color: #d4af37;\n  }\n\n  .book-card-sm {\n    perspective: 800px;\n    transition: transform 0.4s ease;\n  }\n\n  .book-cover-sm {\n    transform-origin: left;\n    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n    box-shadow: 3px 3px 10px rgba(0,0,0,0.6);\n  }\n\n  .book-card-sm:hover .book-cover-sm {\n    transform: rotateY(-25deg);\n  }\n\n  .lamp-glow {\n    mask-image: radial-gradient(circle at center, black, transparent 80%);\n    -webkit-mask-image: radial-gradient(circle at center, black, transparent 80%);\n  }\n\n  .divider-gold {\n    height: 1px;\n    background: linear-gradient(to right, transparent, #b8934c, transparent);\n  }\n\n  .stamp-effect {\n    opacity: 0.15;\n    filter: sepia(1) saturate(5);\n    transform: rotate(-15deg);\n  }\n</style>\n\n<div class=\"mahogany-bg min-h-[950px] w-full flex flex-col items-center relative overflow-hidden text-[#fff9e6] font-sans\" data-kid=\"1\">\n  \n  \n  <div class=\"absolute inset-0 opacity-50 pointer-events-none\" data-kid=\"2\">\n    <img src=\"https://images.unsplash.com/photo-1728506972831-193841eb2961?auto=format&w=1440&q=80&fit=crop\" class=\"w-full h-full object-cover lamp-glow\" alt=\"Library Background\" data-kid=\"3\">\n  </div>\n\n  \n  <div class=\"relative z-10 mt-16 flex flex-col items-center\" data-kid=\"4\">\n    <div class=\"leather-texture px-16 py-6 rounded-sm border border-[#3d2b1f] mb-4\" data-kid=\"5\">\n      <h1 class=\"font-serif text-6xl font-bold tracking-tight gold-emboss\" data-kid=\"6\">WeGift</h1>\n    </div>\n    <p class=\"font-condensed text-lg tracking-[0.4em] uppercase text-[#b8934c]/60\" data-kid=\"7\">\n      The Archive of Experiences\n    </p>\n  </div>\n\n  \n  <div class=\"relative z-10 mt-16 flex gap-10 justify-center w-full max-w-4xl px-8\" data-kid=\"8\">\n    \n    <div class=\"membership-card w-[340px] h-[200px] p-8 rounded-sm flex flex-col justify-between group\" data-kid=\"9\">\n      <div class=\"flex justify-between items-start\" data-kid=\"10\">\n        <div class=\"flex flex-col\" data-kid=\"11\">\n          <span class=\"font-condensed text-[10px] tracking-widest opacity-40 uppercase\" data-kid=\"12\">Membership Access</span>\n          <span class=\"font-serif italic text-2xl font-bold\" data-kid=\"13\">Email Login</span>\n        </div>\n        <i class=\"ti ti-mail text-3xl opacity-20 group-hover:opacity-40 transition-opacity\" data-kid=\"14\"></i>\n      </div>\n      <div class=\"flex flex-col gap-2\" data-kid=\"15\">\n        <div class=\"h-px w-full bg-black/10\" data-kid=\"16\"></div>\n        <div class=\"flex justify-between items-end\" data-kid=\"17\">\n          <span class=\"font-condensed text-[10px] tracking-tighter opacity-30\" data-kid=\"18\">REF: USER_AUTH_01</span>\n          <span class=\"font-condensed text-sm tracking-widest font-bold group-hover:text-[#b8934c] transition-colors\" data-kid=\"19\">ENTER PORTAL →</span>\n        </div>\n      </div>\n      \n      <div class=\"absolute bottom-4 right-10 pointer-events-none\" data-kid=\"20\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/closed-lock-with-key.svg\" class=\"w-12 h-12 stamp-effect\" alt=\"stamp\" data-kid=\"21\">\n      </div>\n    </div>\n\n    <div class=\"membership-card w-[340px] h-[200px] p-8 rounded-sm flex flex-col justify-between group\" data-kid=\"22\">\n      <div class=\"flex justify-between items-start\" data-kid=\"23\">\n        <div class=\"flex flex-col\" data-kid=\"24\">\n          <span class=\"font-condensed text-[10px] tracking-widest opacity-40 uppercase\" data-kid=\"25\">New Enrollment</span>\n          <span class=\"font-serif italic text-2xl font-bold\" data-kid=\"26\">Register Account</span>\n        </div>\n        <i class=\"ti ti-user-plus text-3xl opacity-20 group-hover:opacity-40 transition-opacity\" data-kid=\"27\"></i>\n      </div>\n      <div class=\"flex flex-col gap-2\" data-kid=\"28\">\n        <div class=\"h-px w-full bg-black/10\" data-kid=\"29\"></div>\n        <div class=\"flex justify-between items-end\" data-kid=\"30\">\n          <span class=\"font-condensed text-[10px] tracking-tighter opacity-30\" data-kid=\"31\">FORM: NEW_MEMBER_26</span>\n          <span class=\"font-condensed text-sm tracking-widest font-bold group-hover:text-[#b8934c] transition-colors\" data-kid=\"32\">JOIN ARCHIVE →</span>\n        </div>\n      </div>\n      \n      <div class=\"absolute bottom-4 right-10 pointer-events-none\" data-kid=\"33\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/fountain-pen.svg\" class=\"w-12 h-12 stamp-effect\" alt=\"stamp\" data-kid=\"34\">\n      </div>\n    </div>\n\n  </div>\n\n  \n  <div class=\"relative z-10 mt-20 flex flex-col items-center w-full\" data-kid=\"35\">\n    <div class=\"w-full max-w-xl flex items-center gap-4 mb-10\" data-kid=\"36\">\n      <div class=\"divider-gold flex-1 opacity-30\" data-kid=\"37\"></div>\n      <h3 class=\"font-serif italic text-[#b8934c]/80 text-sm tracking-widest\" data-kid=\"38\">GUEST VOLUMES</h3>\n      <div class=\"divider-gold flex-1 opacity-30\" data-kid=\"39\"></div>\n    </div>\n\n    <div class=\"flex gap-12 justify-center\" data-kid=\"40\">\n      \n      <div class=\"book-card-sm group cursor-pointer w-48\" data-kid=\"41\">\n        <div class=\"book-cover-sm h-64 w-full bg-[#4a2e6e] rounded-r-sm border-l-4 border-[#341d52] relative p-4 flex flex-col items-center justify-between\" data-kid=\"42\">\n          <div class=\"absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/fabric-of-the-nation.png')] pointer-events-none\" data-kid=\"43\"></div>\n          <div class=\"w-full border-b border-[#fff9e6]/10 pb-1 flex justify-between items-start\" data-kid=\"44\">\n            <span class=\"font-serif italic text-[10px] opacity-40\" data-kid=\"45\">Vol. I</span>\n            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/rocket.svg\" class=\"w-5 h-5 opacity-80\" alt=\"rocket\" data-kid=\"46\">\n          </div>\n          <h2 class=\"font-serif text-xl font-bold text-center\" data-kid=\"47\">Maverick</h2>\n          <button class=\"font-condensed tracking-widest text-[9px] border border-[#fff9e6]/20 px-3 py-1 rounded-full hover:bg-[#fff9e6]/10 transition-colors uppercase\" data-kid=\"48\">\n            Quick Entry\n          </button>\n        </div>\n      </div>\n\n      <div class=\"book-card-sm group cursor-pointer w-48\" data-kid=\"49\">\n        <div class=\"book-cover-sm h-64 w-full bg-[#7a2e4a] rounded-r-sm border-l-4 border-[#5e1f36] relative p-4 flex flex-col items-center justify-between\" data-kid=\"50\">\n          <div class=\"absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/fabric-of-the-nation.png')] pointer-events-none\" data-kid=\"51\"></div>\n          <div class=\"w-full border-b border-[#fff9e6]/10 pb-1 flex justify-between items-start\" data-kid=\"52\">\n            <span class=\"font-serif italic text-[10px] opacity-40\" data-kid=\"53\">Vol. II</span>\n            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bell.svg\" class=\"w-5 h-5 opacity-80\" alt=\"bell\" data-kid=\"54\">\n          </div>\n          <h2 class=\"font-serif text-xl font-bold text-center\" data-kid=\"55\">Bell</h2>\n          <button class=\"font-condensed tracking-widest text-[9px] border border-[#fff9e6]/20 px-3 py-1 rounded-full hover:bg-[#fff9e6]/10 transition-colors uppercase\" data-kid=\"56\">\n            Quick Entry\n          </button>\n        </div>\n      </div>\n\n      <div class=\"book-card-sm group cursor-pointer w-48\" data-kid=\"57\">\n        <div class=\"book-cover-sm h-64 w-full bg-[#2e4a35] rounded-r-sm border-l-4 border-[#1f3424] relative p-4 flex flex-col items-center justify-between\" data-kid=\"58\">\n          <div class=\"absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/fabric-of-the-nation.png')] pointer-events-none\" data-kid=\"59\"></div>\n          <div class=\"w-full border-b border-[#fff9e6]/10 pb-1 flex justify-between items-start\" data-kid=\"60\">\n            <span class=\"font-serif italic text-[10px] opacity-40\" data-kid=\"61\">Vol. III</span>\n            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/dragon.svg\" class=\"w-5 h-5 opacity-80\" alt=\"dragon\" data-kid=\"62\">\n          </div>\n          <h2 class=\"font-serif text-xl font-bold text-center\" data-kid=\"63\">Goju</h2>\n          <button class=\"font-condensed tracking-widest text-[9px] border border-[#fff9e6]/20 px-3 py-1 rounded-full hover:bg-[#fff9e6]/10 transition-colors uppercase\" data-kid=\"64\">\n            Quick Entry\n          </button>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  \n  <div class=\"mt-auto w-full max-w-5xl px-8 pb-12 relative z-10\" data-kid=\"65\">\n    <div class=\"grid grid-cols-3 gap-8\" data-kid=\"66\">\n      <div class=\"flex items-center gap-4 group cursor-pointer\" data-kid=\"67\">\n        <div class=\"w-10 h-10 rounded-full border border-[#b8934c]/20 flex items-center justify-center group-hover:bg-[#b8934c]/10 transition-colors\" data-kid=\"68\">\n          <i class=\"ti ti-radio text-[#b8934c] text-lg\" data-kid=\"69\"></i>\n        </div>\n        <div class=\"flex flex-col\" data-kid=\"70\">\n          <span class=\"font-condensed text-xs font-bold tracking-widest\" data-kid=\"71\">MUSIC LIBRARY</span>\n          <span class=\"text-[9px] font-serif italic opacity-30\" data-kid=\"72\">SECTION 12.04</span>\n        </div>\n      </div>\n      <div class=\"flex items-center gap-4 group cursor-pointer\" data-kid=\"73\">\n        <div class=\"w-10 h-10 rounded-full border border-[#b8934c]/20 flex items-center justify-center group-hover:bg-[#b8934c]/10 transition-colors\" data-kid=\"74\">\n          <i class=\"ti ti-video text-[#b8934c] text-lg\" data-kid=\"75\"></i>\n        </div>\n        <div class=\"flex flex-col\" data-kid=\"76\">\n          <span class=\"font-condensed text-xs font-bold tracking-widest\" data-kid=\"77\">ANIME ARCHIVE</span>\n          <span class=\"text-[9px] font-serif italic opacity-30\" data-kid=\"78\">SECTION 08.15</span>\n        </div>\n      </div>\n      <div class=\"flex items-center gap-4 group cursor-pointer\" data-kid=\"79\">\n        <div class=\"w-10 h-10 rounded-full border border-[#b8934c]/20 flex items-center justify-center group-hover:bg-[#b8934c]/10 transition-colors\" data-kid=\"80\">\n          <i class=\"ti ti-pencil text-[#b8934c] text-lg\" data-kid=\"81\"></i>\n        </div>\n        <div class=\"flex flex-col\" data-kid=\"82\">\n          <span class=\"font-condensed text-xs font-bold tracking-widest\" data-kid=\"83\">STUDY HALL</span>\n          <span class=\"text-[9px] font-serif italic opacity-30\" data-kid=\"84\">SECTION 22.09</span>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"absolute bottom-4 w-full flex justify-between px-12 text-[9px] font-serif italic opacity-20 pointer-events-none\" data-kid=\"85\">\n    <p data-kid=\"86\">EST. 2026 — MERN PLATFORM V2</p>\n    <p data-kid=\"87\">CURATED BY WEGIFT LIBRARIANS</p>\n  </div>\n\n</div>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"88\">",
