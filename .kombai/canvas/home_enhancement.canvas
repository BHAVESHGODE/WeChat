mg src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/rocket.svg\" class=\"w-7 h-7 opacity-60 group-hover:opacity-100 group-hover:scale-110 transition-all duration-500 drop-shadow-[0_4px_6px_rgba(0,0,0,1)] grayscale-[0.2]\" alt=\"Rocket\" decoding=\"async\" loading=\"lazy\" data-kid=\"46\">\n                </div>\n                \n                <div class=\"mt-auto flex flex-col items-center\" data-kid=\"47\">\n                    <div class=\"w-16 h-[1px] bg-[#D4AF37]/40 mb-10\" data-kid=\"48\"></div>\n                    <h2 class=\"text-4xl md:text-5xl font-['Cinzel'] font-bold text-[#D4AF37] tracking-[0.05em] mb-14 drop-shadow-[0_4px_4px_rgba(0,0,0,1)] text-center leading-tight\" data-kid=\"49\">Maverick</h2>\n                    \n                    <button class=\"enter-btn relative w-full py-4 bg-[#1A0F0A]/60 border border-[#D4AF37]/30 rounded-xs flex items-center justify-center text-[#D4AF37] font-['Cinzel'] text-[10px] tracking-[0.6em] font-bold overflow-hidden shadow-[inset_0_2px_5px_rgba(0,0,0,0.8)] group-hover:border-[#D4AF37] group-hover:shadow-[0_0_20px_rgba(212,175,55,0.2)]\" data-kid=\"50\">\n                        <span class=\"relative z-10\" data-kid=\"51\">OPEN PATH</span>\n                        <div class=\"absolute inset-0 bg-[#D4AF37] translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-in-out -z-0\" data-kid=\"52\"></div>\n                        <span class=\"absolute z-10 text-[#1A0F0A] opacity-0 group-hover:opacity-100 transition-opacity duration-500\" data-kid=\"53\">OPEN PATH</span>\n                    </button>\n                </div>\n                \n                \n                <div class=\"absolute left-[-14px] top-[10%] h-[80%] w-[1px] bg-white/5\" data-kid=\"54\"></div>\n            </div>\n\n            \n            <div class=\"book-card group relative bg-[#541E2B] h-[450px] rounded-sm shadow-[30px_30px_80px_-10px_rgba(0,0,0,0.9)] flex flex-col p-12 cursor-pointer border-l-[14px] border-black/50 transform-gpu perspective-1200\" data-kid=\"55\">\n                <div class=\"absolute inset-0 opacity-30 pointer-events-none\" style=\"background-image: url('https://www.transparenttextures.com/patterns/leather.png');\" data-kid=\"56\"></div>\n                <div class=\"flex justify-between items-start mb-10\" data-kid=\"57\">\n                    <div class=\"flex flex-col\" data-kid=\"58\">\n                        <span class=\"font-['Cinzel'] text-xs text-[#D4AF37]/50 italic tracking-[0.3em] font-bold mb-1\" data-kid=\"59\">EDITION</span>\n                        <span class=\"font-['Cinzel'] text-sm text-[#D4AF37] font-bold tracking-widest\" data-kid=\"60\">VOL. II</span>\n                    </div>\n                    \n                    <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bell.svg\" class=\"w-7 h-7 opacity-60 group-hover:opacity-100 group-hover:scale-110 transition-all duration-500 drop-shadow-[0_4px_6px_rgba(0,0,0,1)] grayscale-[0.2]\" alt=\"Bell\" decoding=\"async\" loading=\"lazy\" data-kid=\"61\">\n                </div>\n                <div class=\"mt-auto flex flex-col items-center\" data-kid=\"62\">\n                    <div class=\"w-16 h-[1px] bg-[#D4AF37]/40 mb-10\" data-kid=\"63\"></div>\n                    <h2 class=\"text-4xl md:text-5xl font-['Cinzel'] font-bold text-[#D4AF37] tracking-[0.05em] mb-14 drop-shadow-[0_4px_4px_rgba(0,0,0,1)] text-center leading-tight\" data-kid=\"64\">Bell</h2>\n                    <button class=\"enter-btn relative w-full py-4 bg-[#1A0F0A]/60 border border-[#D4AF37]/30 rounded-xs flex items-center justify-center text-[#D4AF37] font-['Cinzel'] text-[10px] tracking-[0.6em] font-bold overflow-hidden shadow-[inset_0_2px_5px_rgba(0,0,0,0.8)] group-hover:border-[#D4AF37] group-hover:shadow-[0_0_20px_rgba(212,175,55,0.2)]\" data-kid=\"65\">\n                        <span class=\"relative z-10\" data-kid=\"66\">OPEN PATH</span>\n                        <div class=\"absolute inset-0 bg-[#D4AF37] translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-in-out -z-0\" data-kid=\"67\"></div>\n                        <span class=\"absolute z-10 text-[#1A0F0A] opacity-0 group-hover:opacity-100 transition-opacity duration-500\" data-kid=\"68\">OPEN PATH</span>\n                    </button>\n                </div>\n                <div class=\"absolute left-[-14px] top-[10%] h-[80%] w-[1px] bg-white/5\" data-kid=\"69\"></div>\n            </div>\n\n            \n            <div class=\"book-card group relative bg-[#1B3528] h-[450px] rounded-sm shadow-[30px_30px_80px_-10px_rgba(0,0,0,0.9)] flex flex-col p-12 cursor-pointer border-l-[14px] border-black/50 transform-gpu perspective-1200\" data-kid=\"70\">\n                <div class=\"absolute inset-0 opacity-30 pointer-events-none\" style=\"background-image: url('https://www.transparenttextures.com/patterns/leather.png');\" data-kid=\"71\"></div>\n                <div class=\"flex justify-between items-start mb-10\" data-kid=\"72\">\n                    <div class=\"flex flex-col\" data-kid=\"73\">\n                        <span class=\"font-['Cinzel'] text-xs text-[#D4AF37]/50 italic tracking-[0.3em] font-bold mb-1\" data-kid=\"74\">EDITION</span>\n                        <span class=\"font-['Cinzel'] text-sm text-[#D4AF37] font-bold tracking-widest\" data-kid=\"75\">VOL. III</span>\n                    </div>\n                    \n                    <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/dragon.svg\" class=\"w-7 h-7 opacity-60 group-hover:opacity-100 group-hover:scale-110 transition-all duration-500 drop-shadow-[0_4px_6px_rgba(0,0,0,1)] grayscale-[0.2]\" alt=\"Dragon\" decoding=\"async\" loading=\"lazy\" data-kid=\"76\">\n                </div>\n                <div class=\"mt-auto flex flex-col items-center\" data-kid=\"77\">\n                    <div class=\"w-16 h-[1px] bg-[#D4AF37]/40 mb-10\" data-kid=\"78\"></div>\n                    <h2 class=\"text-4xl md:text-5xl font-['Cinzel'] font-bold text-[#D4AF37] tracking-[0.05em] mb-14 drop-shadow-[0_4px_4px_rgba(0,0,0,1)] text-center leading-tight\" data-kid=\"79\">Goju</h2>\n                    <button class=\"enter-btn relative w-full py-4 bg-[#1A0F0A]/60 border border-[#D4AF37]/30 rounded-xs flex items-center justify-center text-[#D4AF37] font-['Cinzel'] text-[10px] tracking-[0.6em] font-bold overflow-hidden shadow-[inset_0_2px_5px_rgba(0,0,0,0.8)] group-hover:border-[#D4AF37] group-hover:shadow-[0_0_20px_rgba(212,175,55,0.2)]\" data-kid=\"80\">\n                        <span class=\"relative z-10\" data-kid=\"81\">OPEN PATH</span>\n                        <div class=\"absolute inset-0 bg-[#D4AF37] translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-in-out -z-0\" data-kid=\"82\"></div>\n                        <span class=\"absolute z-10 text-[#1A0F0A] opacity-0 group-hover:opacity-100 transition-opacity duration-500\" data-kid=\"83\">OPEN PATH</span>\n                    </button>\n                </div>\n                <div class=\"absolute left-[-14px] top-[10%] h-[80%] w-[1px] bg-white/5\" data-kid=\"84\"></div>\n            </div>\n        </div>\n    </div>\n\n    \n    <div class=\"fixed top-0 left-0 w-1/3 h-1/3 bg-radial-[circle_at_top_left,_rgba(212,175,55,0.08),_transparent_70%] pointer-events-none z-5\" data-kid=\"85\"></div>\n    <div class=\"fixed bottom-0 right-0 w-1/3 h-1/3 bg-radial-[circle_at_bottom_right,_rgba(212,175,55,0.08),_transparent_70%] pointer-events-none z-5\" data-kid=\"86\"></div>\n\n</section>\n\n<style data-kid=\"87\">\n@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Crimson+Text:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n/* Custom Brass Coin Styling */\n.brass-coin {\n    background: radial-gradient(circle at 35% 35%, #FFF0BE 0%, #E6C87E 25%, #D4AF37 45%, #B8860B 70%, #5C4314 100%);\n    box-shadow: \n        inset 0 4px 8px rgba(255,255,255,0.6),\n        inset 0 -4px 8px rgba(0,0,0,0.7),\n        0 20px 40px rgba(0,0,0,0.8),\n        0 0 0 2px #3A2A0D;\n    border: none;\n    will-change: transform;\n}\n\n.brass-coin:active {\n    transform: translateY(2px) scale(0.95);\n    box-shadow: inset 0 6px 12px rgba(0,0,0,0.8);\n}\n\n/* Book Card Interaction */\n.book-card {\n    will-change: transform;\n}\n\n/* Shine Animation */\n@keyframes shine {\n    from { transform: translateX(-100%) skewX(-20deg); }\n    to { transform: translateX(200%) skewX(-20deg); }\n}\n.shine-anim {\n    animation: shine 6s infinite linear;\n    width: 50%;\n}\n\n/* Hide scrollbar for clean look */\n::-webkit-scrollbar {\n    width: 8px;\n}\n::-webkit-scrollbar-track {\n    background: #000;\n}\n::-webkit-scrollbar-thumb {\n    background: #2A140E;\n    border: 2px solid #D4AF37;\n    border-radius: 4px;\n}\n</style>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"88\"></script>\n<script data-kid=\"89\">\ndocument.addEventListener('DOMContentLoaded', () => {\n    const tl = gsap.timeline({ defaults: { ease: \"power4.out\" } });\n\n    // Entrance Animation sequence\n    tl.from(\"#logo-container\", {\n        y: -150,\n        opacity: 0,\n        duration: 2,\n        clearProps: \"all\"\n    })\n    .from(\".brass-coin\", {\n        scale: 0,\n        opacity: 0,\n        y: 50,\n        stagger: 0.1,\n        duration: 1.2,\n        ease: \"back.out(1.5)\"\n    }, \"-=1.2\")\n    .from(\".book-card\", {\n        y: 150,\n        opacity: 0,\n        stagger: 0.15,\n        duration: 1.5\n    }, \"-=1\");\n\n    // Enhanced Tactile Hover Interactions\n    document.querySelectorAll('.brass-coin').forEach(coin => {\n        coin.addEventListener('mouseenter', () => {\n            gsap.to(coin, { \n                y: -12, \n                scale: 1.15, \n                rotation: 8, \n                boxShadow: \"0 35px 50px rgba(0,0,0,0.9)\",\n                duration: 0.6, \n                ease: \"power2.out\",\n                overwrite: true \n            });\n        });\n        coin.addEventListener('mouseleave', () => {\n            gsap.to(coin, { \n                y: 0, \n                scale: 1, \n                rotation: 0, \n                boxShadow: \"0 20px 40px rgba(0,0,0,0.8)\",\n                duration: 0.8, \n                ease: \"elastic.out(1, 0.75)\" \n            });\n        });\n    });\n\n    document.querySelectorAll('.book-card').forEach(book => {\n        book.addEventListener('mouseenter', () => {\n            gsap.to(book, {\n                rotateY: -10,\n                y: -15,\n                boxShadow: \"40px 40px 80px rgba(0,0,0,1)\",\n                duration: 0.8,\n                ease: \"power3.out\"\n            });\n        });\n        book.addEventListener('mouseleave', () => {\n            gsap.to(book, {\n                rotateY: 0,\n                y: 0,\n                boxShadow: \"30px 30px 80px -10px rgba(0,0,0,0.9)\",\n                duration: 1,\n                ease: \"power3.out\"\n            });\n        });\n    });\n\n    // Ambient floating for coins (subtle)\n    gsap.to(\".brass-coin\", {\n        y: \"+=4\",\n        duration: 3,\n        repeat: -1,\n        yoyo: true,\n        ease: \"sine.inOut\",\n        stagger: {\n            amount: 2,\n            from: \"random\"\n        }\n    });\n\n    // Subtitle gold pulse\n    gsap.to(\"p.tracking-[0.6em]\", {\n        opacity: 0.4,\n        duration: 3,\n        repeat: -1,\n        yoyo: true,\n        ease: \"sine.inOut\"\n    });\n});\n</script>\n",
