, U+110-111, U+128-129, U+168-169, U+1A0-1A1, U+1AF-1B0, U+300-301, U+303-304, U+308-309, U+323, U+329, U+1EA0-1EF9, U+20AB; }\n@font-face { font-family: Oswald; font-style: normal; font-weight: 700; font-display: swap; src: url(\"https://fonts.gstatic.com/s/oswald/v57/TK3IWkUHHAIjg75cFRf3bXL8LICs1_Fv40pKlN4NNSeSASz7FmlYHYjedg.woff2\") format(\"woff2\"); unicode-range: U+100-2BA, U+2BD-2C5, U+2C7-2CC, U+2CE-2D7, U+2DD-2FF, U+304, U+308, U+329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF; }\n@font-face { font-family: Oswald; font-style: normal; font-weight: 700; font-display: swap; src: url(\"https://fonts.gstatic.com/s/oswald/v57/TK3IWkUHHAIjg75cFRf3bXL8LICs1_Fv40pKlN4NNSeSASz7FmlWHYg.woff2\") format(\"woff2\"); unicode-range: U+0-FF, U+131, U+152-153, U+2BB-2BC, U+2C6, U+2DA, U+2DC, U+304, U+308, U+329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }\n:root { --hub-bg: #0d0d0f; --hub-surface: rgba(255,255,255,0.04); --hub-surface-hover: rgba(255,255,255,0.08); --hub-glass: rgba(255,255,255,0.05); --hub-glass-border: rgba(255,255,255,0.08); --hub-glass-strong: rgba(18,18,22,0.85); --hub-text: #ffffff; --hub-text-secondary: rgba(255,255,255,0.7); --hub-text-tertiary: rgba(255,255,255,0.4); --hub-neon-1: #ff00cc; --hub-neon-2: #00ffff; --hub-neon-3: #ff9900; --hub-gradient-1: linear-gradient(135deg, #ff00cc, #00ffff); --hub-gradient-2: linear-gradient(135deg, #7c4dff, #43e97b); --hub-gradient-3: linear-gradient(135deg, #ff6b9d, #ffa751); --hub-radius-sm: 8px; --hub-radius-md: 14px; --hub-radius-lg: 20px; --hub-radius-xl: 28px; --hub-transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); --hub-glow: 0 0 30px rgba(255, 0, 204, 0.15); }\n[data-theme=\"light\"] { --hub-bg: #f0f0f5; --hub-surface: rgba(0,0,0,0.03); --hub-surface-hover: rgba(0,0,0,0.06); --hub-glass: rgba(255,255,255,0.6); --hub-glass-border: rgba(0,0,0,0.08); --hub-glass-strong: rgba(255,255,255,0.85); --hub-text: #0d0d0f; --hub-text-secondary: rgba(0,0,0,0.6); --hub-text-tertiary: rgba(0,0,0,0.35); }\n* { margin: 0px; padding: 0px; box-sizing: border-box; }\n.hub-container { height: 100vh; width: 100vw; display: flex; background: var(--hub-bg); color: var(--hub-text); font-family: Inter, sans-serif; overflow: hidden; position: relative; }\n.hub-bg-canvas { position: fixed; inset: 0px; pointer-events: none; z-index: 0; overflow: hidden; }\n.hub-particle { position: absolute; border-radius: 50%; background: radial-gradient(circle, rgba(255, 255, 255, 0.3), transparent); animation: auto linear 0s infinite normal none running hubParticleFloat; opacity: 0; }\n@keyframes hubParticleFloat {\n0% { transform: translateY(100vh) scale(0); opacity: 0; }\n10% { opacity: 0.6; }\n90% { opacity: 0.6; }\n100% { transform: translateY(-10vh) scale(1); opacity: 0; }\n}\n.hub-sidebar { width: 72px; min-width: 72px; height: 100vh; background: var(--hub-glass-strong); backdrop-filter: blur(20px); border-right: 1px solid var(--hub-glass-border); display: flex; flex-direction: column; align-items: center; padding: 1.25rem 0px; z-index: 30; position: relative; transition: width var(--hub-transition); }\n.hub-sidebar:hover { width: 200px; min-width: 200px; }\n.hub-sidebar-logo { font-family: Orbitron, sans-serif; font-size: 0.95rem; font-weight: 700; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 2.5rem; letter-spacing: 0.15em; white-space: nowrap; overflow: hidden; width: 100%; text-align: center; flex-shrink: 0; }\n.hub-sidebar-nav { display: flex; flex-direction: column; gap: 0.35rem; width: 100%; padding: 0px 0.5rem; flex: 1 1 0%; overflow: hidden; }\n.hub-sidebar-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.7rem 0.9rem; border-radius: var(--hub-radius-sm); cursor: pointer; transition: all var(--hub-transition); white-space: nowrap; overflow: hidden; border: none; background: none; color: var(--hub-text-secondary); font-family: Inter, sans-serif; font-size: 0.85rem; font-weight: 500; text-decoration: none; width: 100%; text-align: left; position: relative; }\n.hub-sidebar-item i { font-size: 1.25rem; min-width: 1.25rem; text-align: center; transition: all var(--hub-transition); }\n.hub-sidebar-item span { opacity: 0; transition: opacity var(--hub-transition); }\n.hub-sidebar:hover .hub-sidebar-item span { opacity: 1; }\n.hub-sidebar-item:hover, .hub-sidebar-item.active { background: rgba(255, 0, 204, 0.1); color: rgb(255, 255, 255); }\n.hub-sidebar-item.active { border-left: 3px solid rgb(255, 0, 204); background: linear-gradient(90deg, rgba(255, 0, 204, 0.12), transparent); }\n.hub-sidebar-item.active i { color: rgb(255, 0, 204); text-shadow: rgba(255, 0, 204, 0.4) 0px 0px 12px; }\n.hub-sidebar-footer { width: 100%; padding: 0px 0.5rem; flex-shrink: 0; }\n.hub-main { flex: 1 1 0%; min-width: 0px; display: flex; flex-direction: column; height: 100vh; overflow: hidden; position: relative; z-index: 10; }\n.hub-main-scroll { flex: 1 1 0%; overflow: hidden auto; padding: 1.5rem 2rem 1rem; }\n.hub-main-scroll::-webkit-scrollbar { width: 4px; }\n.hub-main-scroll::-webkit-scrollbar-track { background: transparent; }\n.hub-main-scroll::-webkit-scrollbar-thumb { background: rgba(255, 0, 204, 0.3); border-radius: 2px; }\n.hub-header { display: flex; align-items: center; justify-content: space-between; padding-bottom: 1.75rem; border-bottom: 1px solid var(--hub-glass-border); margin-bottom: 2rem; gap: 1rem; flex-wrap: wrap; }\n.hub-greeting h1 { font-family: Orbitron, sans-serif; font-size: 1.65rem; font-weight: 700; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; line-height: 1.2; }\n.hub-greeting p { font-size: 0.85rem; color: var(--hub-text-secondary); margin-top: 0.2rem; }\n.hub-header-right { display: flex; align-items: center; gap: 1rem; }\n.hub-search { display: flex; align-items: center; background: var(--hub-glass); border: 1px solid var(--hub-glass-border); border-radius: var(--hub-radius-full, 999px); padding: 0.45rem 1rem; gap: 0.5rem; transition: all var(--hub-transition); min-width: 200px; }\n.hub-search:focus-within { border-color: rgb(255, 0, 204); box-shadow: rgba(255, 0, 204, 0.15) 0px 0px 20px; }\n.hub-search i { color: var(--hub-text-tertiary); font-size: 1rem; }\n.hub-search input { background: none; border: none; outline: none; color: var(--hub-text); font-family: Inter, sans-serif; font-size: 0.85rem; width: 100%; }\n.hub-search input::placeholder { color: var(--hub-text-tertiary); }\n.hub-quick-btn { width: 38px; height: 38px; border-radius: 50%; border: 1px solid var(--hub-glass-border); background: var(--hub-glass); color: var(--hub-text-secondary); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all var(--hub-transition); font-size: 1.1rem; position: relative; }\n.hub-quick-btn:hover { background: var(--hub-surface-hover); color: rgb(255, 255, 255); border-color: rgb(255, 0, 204); box-shadow: rgba(255, 0, 204, 0.15) 0px 0px 16px; }\n.hub-quick-btn .badge { position: absolute; top: -4px; right: -4px; width: 16px; height: 16px; background: rgb(255, 0, 204); border-radius: 50%; font-size: 0.55rem; display: flex; align-items: center; justify-content: center; color: rgb(255, 255, 255); font-weight: 700; box-shadow: rgba(255, 0, 204, 0.4) 0px 0px 8px; }\n.hub-profile-card { display: flex; align-items: center; gap: 0.85rem; padding: 0.5rem 1rem 0.5rem 0.5rem; border-radius: var(--hub-radius-full, 999px); background: var(--hub-glass); border: 1px solid var(--hub-glass-border); cursor: pointer; transition: all var(--hub-transition); }\n.hub-profile-card:hover { background: var(--hub-surface-hover); border-color: rgba(255, 0, 204, 0.2); }\n.hub-avatar { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: Orbitron, sans-serif; font-weight: 700; font-size: 0.9rem; color: rgb(255, 255, 255); position: relative; flex-shrink: 0; }\n.hub-avatar-ring { box-shadow: rgba(255, 0, 204, 0.3) 0px 0px 0px 2px, rgba(255, 0, 204, 0.15) 0px 0px 12px; }\n.hub-profile-info { display: none; flex-direction: column; }\n.hub-sidebar:hover ~ .hub-main .hub-profile-info, .hub-profile-card:hover .hub-profile-info { display: flex; }\n.hub-profile-name { font-size: 0.8rem; font-weight: 600; line-height: 1.2; }\n.hub-profile-role { font-size: 0.65rem; color: var(--hub-text-tertiary); text-transform: uppercase; letter-spacing: 0.08em; }\n.hub-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1.25rem; margin-bottom: 2rem; }\n.hub-tile { height: 190px; border-radius: var(--hub-radius-lg); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; cursor: pointer; transition: all var(--hub-transition); position: relative; overflow: hidden; border: 1px solid rgba(255, 255, 255, 0.06); text-decoration: none; color: rgb(255, 255, 255); padding: 1rem; isolation: isolate; }\n.hub-tile::before { content: \"\"; position: absolute; inset: 0px; background: inherit; border-radius: inherit; z-index: -1; transition: transform 0.6s; }\n.hub-tile::after { content: \"\"; position: absolute; inset: 0px; border-radius: inherit; background: linear-gradient(rgba(255, 255, 255, 0.08) 0%, transparent 50%); pointer-events: none; z-index: 0; }\n.hub-tile i { font-size: 2.5rem; position: relative; z-index: 1; transition: all var(--hub-transition); filter: drop-shadow(rgba(255, 255, 255, 0.15) 0px 0px 8px); }\n.hub-tile span { font-family: Oswald, sans-serif; font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; position: relative; z-index: 1; text-align: center; line-height: 1.2; }\n.hub-tile:hover { transform: scale(1.05) translateY(-4px); box-shadow: var(--hub-glow); }\n.hub-tile:hover i { transform: scale(1.15); filter: drop-shadow(rgba(255, 255, 255, 0.3) 0px 0px 16px); }\n.hub-tile:active { transform: scale(0.97); }\n.hub-tile-loading { background: linear-gradient(135deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.03)) 0% 0% / 200% 200%; animation: 1.5s ease 0s infinite normal none running hubShimmer; pointer-events: none; }\n@keyframes hubShimmer {\n0% { background-position: 0% 50%; }\n50% { background-position: 100% 50%; }\n100% { background-position: 0% 50%; }\n}\n.tile-study { background: linear-gradient(135deg, rgb(124, 77, 255), rgb(67, 233, 123)); }\n.tile-music { background: linear-gradient(135deg, rgb(255, 107, 157), rgb(255, 167, 81)); }\n.tile-youtube { background: linear-gradient(135deg, rgb(255, 0, 0), rgb(255, 107, 107)); }\n.tile-chat { background: linear-gradient(135deg, rgb(88, 166, 255), rgb(163, 113, 247)); }\n.tile-games { background: linear-gradient(135deg, rgb(255, 153, 0), rgb(255, 204, 0)); }\n.tile-animehub { background: linear-gradient(135deg, rgb(240, 147, 251), rgb(245, 87, 108)); }\n.tile-watch { background: linear-gradient(135deg, rgb(255, 107, 157), rgb(124, 77, 255)); }\n.tile-manga { background: linear-gradient(135deg, rgb(67, 233, 123), rgb(0, 212, 255)); }\n.tile-tracking { background: linear-gradient(135deg, rgb(79, 172, 254), rgb(0, 242, 254)); }\n.tile-books { background: linear-gradient(135deg, rgb(102, 126, 234), rgb(118, 75, 162)); }\n.tile-movies { background: linear-gradient(135deg, rgb(229, 9, 20), rgb(229, 169, 59)); }\n.tile-birthday { background: linear-gradient(135deg, rgb(255, 107, 157), rgb(255, 215, 0), rgb(163, 113, 247)) 0% 0% / 200% 200%; animation: 4s ease-in-out 0s infinite alternate none running tile-birthday-shift; }\n@keyframes tile-birthday-shift {\n0% { background-position: 0% 50%; }\n100% { background-position: 100% 50%; }\n}\n.hub-footer { padding: 0.75rem 0px 0.25rem; border-top: 1px solid var(--hub-glass-border); display: flex; align-items: center; justify-content: center; gap: 0.75rem; }\n.hub-footer-meta { display: flex; align-items: center; gap: 1rem; font-size: 0.65rem; color: var(--hub-text-tertiary); }\n.hub-drawer-overlay { position: fixed; inset: 0px; background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px); z-index: 100; opacity: 0; pointer-events: none; transition: opacity var(--hub-transition); }\n.hub-drawer-overlay.open { opacity: 1; pointer-events: all; }\n.hub-drawer { position: fixed; top: 0px; right: -380px; width: 360px; max-width: 90vw; height: 100vh; background: var(--hub-glass-strong); backdrop-filter: blur(30px); border-left: 1px solid var(--hub-glass-border); z-index: 101; transition: right var(--hub-transition); display: flex; flex-direction: column; padding: 1.5rem; }\n.hub-drawer.open { right: 0px; }\n.hub-drawer-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--hub-glass-border); }\n.hub-drawer-header h3 { font-family: Orbitron, sans-serif; font-size: 1rem; letter-spacing: 0.1em; }\n.hub-drawer-close { background: none; border: none; color: var(--hub-text-secondary); cursor: pointer; font-size: 1.2rem; transition: color var(--hub-transition); }\n.hub-drawer-close:hover { color: rgb(255, 255, 255); }\n.hub-drawer-item { display: flex; align-items: flex-start; gap: 0.85rem; padding: 0.85rem; border-radius: var(--hub-radius-sm); transition: background var(--hub-transition); cursor: pointer; }\n.hub-drawer-item:hover { background: var(--hub-surface); }\n.hub-drawer-item-icon { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: rgba(255, 0, 204, 0.12); color: rgb(255, 0, 204); font-size: 1rem; flex-shrink: 0; }\n.hub-drawer-item-text { flex: 1 1 0%; }\n.hub-drawer-item-text p { font-size: 0.82rem; line-height: 1.4; }\n.hub-drawer-item-text span { font-size: 0.65rem; color: var(--hub-text-tertiary); }\n.hub-modal-overlay { position: fixed; inset: 0px; background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(8px); z-index: 200; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity var(--hub-transition); }\n.hub-modal-overlay.open { opacity: 1; pointer-events: all; }\n.hub-modal { background: var(--hub-glass-strong); backdrop-filter: blur(30px); border: 1px solid var(--hub-glass-border); border-radius: var(--hub-radius-xl); padding: 2.5rem; width: 400px; max-width: 90vw; transform: scale(0.9); transition: transform var(--hub-transition); box-shadow: rgba(0, 0, 0, 0.5) 0px 30px 80px; }\n.hub-modal-overlay.open .hub-modal { transform: scale(1); }\n.hub-modal h2 { font-family: Orbitron, sans-serif; text-align: center; margin-bottom: 0.5rem; font-size: 1.4rem; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; }\n.hub-modal p { text-align: center; color: var(--hub-text-secondary); font-size: 0.85rem; margin-bottom: 2rem; }\n.hub-modal-input { width: 100%; padding: 0.8rem 1rem; background: var(--hub-glass); border: 1px solid var(--hub-glass-border); border-radius: var(--hub-radius-sm); color: var(--hub-text); font-family: Inter, sans-serif; font-size: 0.9rem; outline: none; transition: border-color var(--hub-transition); margin-bottom: 1rem; }\n.hub-modal-input:focus { border-color: rgb(255, 0, 204); box-shadow: rgba(255, 0, 204, 0.1) 0px 0px 16px; }\n.hub-modal-btn { width: 100%; padding: 0.85rem; border: none; border-radius: var(--hub-radius-sm); background: var(--hub-gradient-1); color: rgb(255, 255, 255); font-family: Orbitron, sans-serif; font-weight: 600; font-size: 0.85rem; letter-spacing: 0.1em; cursor: pointer; transition: all var(--hub-transition); }\n.hub-modal-btn:hover { transform: translateY(-2px); box-shadow: rgba(255, 0, 204, 0.3) 0px 8px 30px; }\n.hub-theme-toggle { position: relative; width: 44px; height: 24px; background: var(--hub-glass); border: 1px solid var(--hub-glass-border); border-radius: 12px; cursor: pointer; transition: all var(--hub-transition); display: flex; align-items: center; padding: 2px; }\n.hub-theme-toggle .toggle-thumb { width: 18px; height: 18px; border-radius: 50%; background: var(--hub-gradient-1); transition: transform var(--hub-transition); display: flex; align-items: center; justify-content: center; font-size: 0.55rem; color: rgb(255, 255, 255); }\n.hub-theme-toggle.light .toggle-thumb { transform: translateX(20px); }\n.hub-ripple { position: absolute; border-radius: 50%; background: rgba(255, 255, 255, 0.2); transform: scale(0); animation: 0.6s ease-out 0s 1 normal none running hubRippleAnim; pointer-events: none; }\n@keyframes hubRippleAnim {\n100% { transform: scale(4); opacity: 0; }\n}\n@media (max-width: 1024px) {\n.hub-sidebar { width: 60px; min-width: 60px; }\n.hub-sidebar:hover { width: 60px; min-width: 60px; }\n.hub-sidebar-item span { display: none; }\n.hub-sidebar-logo { font-size: 0.9rem; }\n.hub-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 1rem; }\n.hub-tile { height: 160px; }\n.hub-tile i { font-size: 2rem; }\n.hub-tile span { font-size: 0.75rem; }\n}\n@media (max-width: 768px) {\n.hub-sidebar { display: none; }\n.hub-main-scroll { padding: 1rem; }\n.hub-header { flex-direction: column; align-items: flex-start; gap: 0.75rem; padding-bottom: 1rem; margin-bottom: 1.25rem; }\n.hub-header-right { width: 100%; justify-content: space-between; }\n.hub-search { min-width: unset; flex: 1 1 0%; }\n.hub-greeting h1 { font-size: 1.25rem; }\n.hub-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.75rem; }\n.hub-tile { height: 130px; border-radius: var(--hub-radius-md); gap: 0.5rem; }\n.hub-tile i { font-size: 1.6rem; }\n.hub-tile span { font-size: 0.65rem; }\n.hub-profile-info { display: flex; }\n.hub-footer { flex-direction: column; text-align: center; }\n}\n@media (max-width: 480px) {\n.hub-grid { grid-template-columns: repeat(2, 1fr); gap: 0.6rem; }\n.hub-tile { height: 110px; border-radius: var(--hub-radius-sm); gap: 0.4rem; padding: 0.6rem; }\n.hub-tile i { font-size: 1.3rem; }\n.hub-tile span { font-size: 0.6rem; letter-spacing: 0.05em; }\n.hub-drawer { width: 100%; max-width: 100vw; }\n}\n.hub-mobile-nav { display: none; position: fixed; bottom: 0px; left: 0px; right: 0px; height: 60px; background: var(--hub-glass-strong); backdrop-filter: blur(20px); border-top: 1px solid var(--hub-glass-border); z-index: 30; justify-content: space-around; align-items: center; padding: 0px 0.5rem; }\n@media (max-width: 768px) {\n.hub-mobile-nav { display: flex; }\n.hub-container { padding-bottom: 60px; }\n}\n.hub-mobile-nav-item { display: flex; flex-direction: column; align-items: center; gap: 2px; background: none; border: none; color: var(--hub-text-secondary); cursor: pointer; padding: 0.35rem; font-size: 0.55rem; transition: color var(--hub-transition); font-family: Inter, sans-serif; }\n.hub-mobile-nav-item i { font-size: 1.2rem; }\n.hub-mobile-nav-item.active { color: rgb(255, 0, 204); }\n.hub-back-btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.4rem 0.85rem; border-radius: var(--hub-radius-full, 999px); border: 1px solid var(--hub-glass-border); background: var(--hub-glass); color: var(--hub-text-secondary); font-family: Inter, sans-serif; font-size: 0.75rem; cursor: pointer; transition: all var(--hub-transition); text-decoration: none; }\n.hub-back-btn:hover { background: var(--hub-surface-hover); color: rgb(255, 255, 255); border-color: rgb(255, 0, 204); }\n.ytc { min-height: 100vh; background: radial-gradient(circle at 10% 20%, rgb(15, 15, 25) 0%, rgb(5, 5, 10) 90.2%); color: rgb(255, 255, 255); font-family: var(--font-rounded), sans-serif; overflow-x: hidden; width: 100%; }\n.ytc-header { display: flex; align-items: center; padding: 0px 20px; height: 64px; background: rgba(10, 10, 15, 0.7); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255, 255, 255, 0.08); position: sticky; top: 0px; z-index: 100; gap: 16px; }\n.ytc-logo { font-size: 22px; font-weight: 800; cursor: pointer; display: flex; align-items: center; gap: 6px; white-space: nowrap; flex-shrink: 0; color: rgb(255, 255, 255); text-shadow: rgba(6, 182, 212, 0.4) 0px 0px 10px; }\n.ytc-logo-icon { color: rgb(6, 182, 212); font-size: 28px; text-shadow: rgba(6, 182, 212, 0.6) 0px 0px 15px; }\n.ytc-logo-badge { font-size: 9px; color: rgb(244, 63, 94); border: 1px solid rgba(244, 63, 94, 0.5); padding: 1px 4px; border-radius: 4px; align-self: flex-start; margin-top: 4px; font-weight: 700; text-shadow: rgba(244, 63, 94, 0.5) 0px 0px 5px; }\n.ytc-search-wrap { flex: 1 1 0%; display: flex; justify-content: center; }\n.ytc-search { display: flex; width: 100%; max-width: 500px; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 24px; padding: 2px 4px 2px 14px; transition: 0.3s; }\n.ytc-search:focus-within { border-color: rgb(0, 212, 255); box-shadow: rgba(0, 212, 255, 0.25) 0px 0px 15px; background: rgba(255, 255, 255, 0.08); }\n.ytc-search input { flex: 1 1 0%; height: 36px; background: transparent; border: none; color: rgb(255, 255, 255); font-size: 14px; outline: none; min-width: 0px; }\n.ytc-search button { height: 34px; width: 44px; min-width: 44px; background: rgba(255, 255, 255, 0.1); border: none; border-radius: 50%; color: rgb(255, 255, 255); cursor: pointer; font-size: 14px; display: flex; align-items: center; justify-content: center; transition: background 0.2s; }\n.ytc-search button:hover { background: rgba(0, 212, 255, 0.3); color: rgb(255, 255, 255); }\n.ytc-hdr-actions { display: flex; gap: 8px; flex-shrink: 0; align-items: center; }\n.ytc-hdr-btn { background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.08); color: rgb(255, 255, 255); cursor: pointer; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; transition: 0.25s; }\n.ytc-hdr-btn:hover { background: rgba(0, 212, 255, 0.15); border-color: rgb(0, 212, 255); transform: translateY(-2px); box-shadow: rgba(0, 212, 255, 0.3) 0px 0px 10px; }\n.ytc-hdr-badge { position: relative; }\n.ytc-hdr-badge::after { content: attr(data-count); position: absolute; top: -2px; right: -2px; background: rgb(255, 0, 127); color: rgb(255, 255, 255); font-size: 9px; font-weight: 700; width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: rgb(255, 0, 127) 0px 0px 8px; }\n.ytc-chips { display: flex; gap: 10px; padding: 12px 20px; overflow-x: auto; border-bottom: 1px solid rgba(255, 255, 255, 0.06); scrollbar-width: none; }\n.ytc-chips::-webkit-scrollbar { display: none; }\n.ytc-chip { padding: 8px 16px; border-radius: 20px; background: rgba(255, 255, 255, 0.05); color: rgba(255, 255, 255, 0.8); border: 1px solid rgba(255, 255, 255, 0.06); cursor: pointer; font-size: 13px; white-space: nowrap; font-weight: 600; flex-shrink: 0; transition: 0.25s; }\n.ytc-chip:hover { background: rgba(255, 255, 255, 0.1); color: rgb(255, 255, 255); border-color: rgba(255, 255, 255, 0.2); }\n.ytc-chip.active { background: linear-gradient(135deg, rgb(0, 212, 255), rgb(188, 19, 254)); color: rgb(255, 255, 255); border-color: rgb(255, 255, 255); box-shadow: rgba(0, 212, 255, 0.4) 0px 0px 12px; }\n.ytc-grid-wrap { padding: 20px; }\n.ytc-grid { column-count: 4; column-gap: 20px; }\n@media (max-width: 1200px) {\n.ytc-grid { column-count: 3; }\n}\n@media (max-width: 900px) {\n.ytc-grid { column-count: 2; column-gap: 16px; }\n.ytc-grid-wrap { padding: 16px; }\n}\n@media (max-width: 600px) {\n.ytc-grid { column-count: 1; }\n.ytc-grid-wrap { padding: 12px; }\n}\n.ytc-card { break-inside: avoid; margin-bottom: 20px; display: inline-block; width: 100%; cursor: pointer; border-radius: 16px; overflow: hidden; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); backdrop-filter: blur(8px); transition: 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); }\n.ytc-card:hover { background: rgba(255, 255, 255, 0.07); border-color: rgba(0, 212, 255, 0.3); transform: translateY(-5px); box-shadow: rgba(0, 0, 0, 0.4) 0px 12px 30px, rgba(0, 212, 255, 0.15) 0px 0px 15px; }\n.ytc-thumb-wrap { position: relative; width: 100%; aspect-ratio: 16 / 9; background: rgb(0, 0, 0); overflow: hidden; }\n.ytc-thumb { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s; }\n.ytc-card:hover .ytc-thumb { transform: scale(1.04); }\n.ytc-dur { position: absolute; bottom: 8px; right: 8px; background: rgba(0, 0, 0, 0.8); border: 1px solid rgba(255, 255, 255, 0.15); color: rgb(255, 255, 255); padding: 2px 6px; border-radius: 4px; font-size: 11px; font-weight: 700; letter-spacing: 0.3px; }\n.ytc-card-body { padding: 12px 14px; display: flex; gap: 12px; }\n.ytc-avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, rgb(188, 19, 254), rgb(0, 212, 255)); color: rgb(255, 255, 255); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; border: 1.5px solid rgb(255, 255, 255); box-shadow: rgba(188, 19, 254, 0.4) 0px 0px 8px; }\n.ytc-card-info { flex: 1 1 0%; min-width: 0px; }\n.ytc-card-title { font-size: 14px; font-weight: 700; line-height: 19px; color: rgb(255, 255, 255); max-height: 38px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; margin-bottom: 6px; }\n.ytc-card-meta { font-size: 12px; color: rgba(255, 255, 255, 0.55); line-height: 16px; }\n.ytc-card-meta span { display: block; }\n.ytc-watch { display: flex; gap: 24px; padding: 24px; max-width: 1400px; margin: 0px auto; align-items: flex-start; }\n@media (max-width: 1000px) {\n.ytc-watch { flex-direction: column; padding: 12px; gap: 16px; }\n}\n.ytc-watch.theater { max-width: 100%; padding: 0px; gap: 0px; }\n.ytc-watch.theater .ytc-sidebar { display: none; }\n.ytc-watch.theater .ytc-info-section { max-width: 1000px; margin: 0px auto; padding: 16px 20px; }\n.ytc-player-section { flex: 1 1 0%; min-width: 0px; max-width: 100%; }\n.ytc-player-wrap { position: relative; background: rgb(0, 0, 0); border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.08); overflow: hidden; width: 100%; box-shadow: rgba(0, 0, 0, 0.5) 0px 16px 40px, rgba(0, 212, 255, 0.1) 0px 0px 30px; }\n.ytc-watch.theater .ytc-player-wrap { border-radius: 0px; border-top: none; border-right: none; border-left: none; border-image: initial; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }\n.ytc-player { width: 100%; display: block; max-height: 70vh; aspect-ratio: 16 / 9; background: rgb(0, 0, 0); }\n.ytc-watch.theater .ytc-player { max-height: 80vh; }\n.ytc-player-placeholder { width: 100%; aspect-ratio: 16 / 9; display: flex; align-items: center; justify-content: center; background: rgb(9, 9, 13); flex-direction: column; gap: 16px; min-height: 200px; }\n.ytc-player-embed { position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; border: 0px; }\n.ytc-controls { position: absolute; bottom: 0px; left: 0px; right: 0px; background: rgba(10, 10, 15, 0.75); backdrop-filter: blur(12px); border-top: 1px solid rgba(255, 255, 255, 0.08); padding: 24px 16px 10px; opacity: 0; transition: opacity 0.3s; }\n.ytc-player-wrap:hover .ytc-controls, .ytc-controls.show { opacity: 1; }\n.ytc-progress-bar { width: 100%; height: 5px; background: rgba(255, 255, 255, 0.15); border-radius: 3px; cursor: pointer; margin-bottom: 8px; position: relative; }\n.ytc-progress-bar:hover { height: 7px; }\n.ytc-progress-fill { height: 100%; background: linear-gradient(90deg, rgb(0, 212, 255), rgb(188, 19, 254)); border-radius: 3px; position: relative; transition: width 0.1s linear; box-shadow: rgb(0, 212, 255) 0px 0px 8px; }\n.ytc-progress-buffer { position: absolute; top: 0px; left: 0px; height: 100%; background: rgba(255, 255, 255, 0.2); border-radius: 3px; }\n.ytc-controls-row { display: flex; align-items: center; justify-content: space-between; gap: 8px; }\n.ytc-ctrl-left { display: flex; align-items: center; gap: 4px; }\n.ytc-ctrl-right { display: flex; align-items: center; gap: 4px; }\n.ytc-ctrl-btn { background: none; border: 0px; color: rgb(255, 255, 255); cursor: pointer; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; transition: 0.2s; }\n.ytc-ctrl-btn:hover { background: rgba(0, 212, 255, 0.2); color: rgb(0, 212, 255); text-shadow: rgb(0, 212, 255) 0px 0px 8px; }\n.ytc-ctrl-btn.active { color: rgb(255, 0, 127); text-shadow: rgb(255, 0, 127) 0px 0px 10px; }\n.ytc-ctrl-btn.labeled { width: auto; border-radius: 6px; padding: 0px 8px; font-size: 12px; gap: 4px; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.08); }\n.ytc-time { font-size: 12px; color: rgba(255, 255, 255, 0.8); font-variant-numeric: tabular-nums; white-space: nowrap; font-weight: 600; }\n.ytc-vol-slider { width: 60px; accent-color: rgb(0, 212, 255); height: 3px; cursor: pointer; }\n@media (max-width: 600px) {\n.ytc-vol-slider { width: 40px; }\n}\n.ytc-info-section { padding: 16px 0px; }\n.ytc-video-title { font-size: 20px; font-weight: 800; margin-bottom: 8px; line-height: 26px; color: rgb(255, 255, 255); text-shadow: rgba(255, 255, 255, 0.1) 0px 0px 10px; }\n.ytc-video-meta { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 16px; }\n.ytc-video-stats { font-size: 13px; color: rgba(255, 255, 255, 0.6); display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }\n.ytc-actions { display: flex; gap: 8px; flex-wrap: wrap; }\n.ytc-action-btn { display: flex; align-items: center; gap: 6px; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.08); color: rgb(255, 255, 255); padding: 8px 16px; border-radius: 20px; cursor: pointer; font-size: 13px; font-weight: 600; transition: 0.25s; white-space: nowrap; position: relative; }\n.ytc-action-btn:hover { background: rgba(0, 212, 255, 0.15); border-color: rgb(0, 212, 255); color: rgb(255, 255, 255); box-shadow: rgba(0, 212, 255, 0.25) 0px 0px 10px; }\n.ytc-action-btn.active { background: rgba(255, 0, 127, 0.15); border-color: rgb(255, 0, 127); color: rgb(255, 0, 127); box-shadow: rgba(255, 0, 127, 0.25) 0px 0px 10px; }\n.ytc-action-btn:disabled { opacity: 0.5; cursor: not-allowed; }\n.ytc-channel-row { display: flex; align-items: center; gap: 12px; padding: 12px 0px; border-top: 1px solid rgba(255, 255, 255, 0.08); border-bottom: 1px solid rgba(255, 255, 255, 0.08); margin-bottom: 16px; }\n.ytc-channel-avatar { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, rgb(0, 212, 255), rgb(188, 19, 254)); display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; border: 1.5px solid rgb(255, 255, 255); flex-shrink: 0; }\n.ytc-channel-info { flex: 1 1 0%; min-width: 0px; }\n.ytc-channel-name { font-weight: 700; font-size: 15px; color: rgb(255, 255, 255); }\n.ytc-channel-subs { font-size: 12px; color: rgba(255, 255, 255, 0.5); }\n.ytc-settings { display: flex; align-items: center; gap: 14px; padding: 6px 0px; flex-wrap: wrap; }\n.ytc-toggle { display: flex; align-items: center; gap: 6px; cursor: pointer; font-size: 13px; color: rgb(204, 204, 204); user-select: none; }\n.ytc-toggle input[type=\"checkbox\"] { accent-color: rgb(255, 0, 0); cursor: pointer; }\n.ytc-select { background: rgb(39, 39, 39); color: rgb(255, 255, 255); border: 1px solid rgb(68, 68, 68); border-radius: 4px; padding: 4px 10px; font-size: 12px; cursor: pointer; outline: none; }\n.ytc-sidebar { width: 360px; flex-shrink: 0; }\n@media (max-width: 900px) {\n.ytc-sidebar { width: 100%; }\n}\n.ytc-sidebar-title { font-size: 15px; font-weight: 600; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }\n.ytc-sidebar-title label { display: flex; align-items: center; gap: 4px; font-size: 12px; font-weight: 400; color: rgb(170, 170, 170); cursor: pointer; }\n.ytc-related-card { display: flex; gap: 8px; cursor: pointer; padding: 6px; border-radius: 6px; transition: background 0.2s; }\n.ytc-related-card:hover { background: rgb(26, 26, 26); }\n.ytc-related-thumb { width: 160px; min-width: 160px; height: 90px; border-radius: 6px; object-fit: cover; background: rgb(26, 26, 26); }\n@media (max-width: 400px) {\n.ytc-related-thumb { width: 120px; min-width: 120px; height: 68px; }\n}\n.ytc-related-info { flex: 1 1 0%; min-width: 0px; }\n.ytc-related-title { font-size: 13px; font-weight: 600; line-height: 16px; max-height: 32px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; margin-bottom: 2px; }\n.ytc-related-meta { font-size: 11px; color: rgb(170, 170, 170); }\n.ytc-playlist-panel { position: fixed; bottom: 0px; left: 16px; width: 320px; max-height: 55vh; background: rgb(26, 26, 26); border-radius: 10px 10px 0px 0px; box-shadow: rgba(0, 0, 0, 0.5) 0px -4px 20px; z-index: 200; display: flex; flex-direction: column; border-top: 1px solid rgb(39, 39, 39); border-right: 1px solid rgb(39, 39, 39); border-left: 1px solid rgb(39, 39, 39); border-image: initial; border-bottom: none; }\n@media (max-width: 500px) {\n.ytc-playlist-panel { left: 0px; right: 0px; width: 100%; border-radius: 0px; }\n}\n.ytc-playlist-header { display: flex; justify-content: space-between; align-items: center; padding: 10px 14px; border-bottom: 1px solid rgb(51, 51, 51); }\n.ytc-playlist-title { font-size: 14px; font-weight: 600; }\n.ytc-playlist-close { background: none; border: 0px; color: rgb(255, 255, 255); cursor: pointer; font-size: 16px; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }\n.ytc-playlist-close:hover { background: rgb(51, 51, 51); }\n.ytc-playlist-creator { display: flex; gap: 6px; padding: 8px 14px; border-bottom: 1px solid rgb(39, 39, 39); }\n.ytc-playlist-creator input { flex: 1 1 0%; background: rgb(18, 18, 18); border: 1px solid rgb(51, 51, 51); border-radius: 4px; padding: 6px 10px; color: rgb(255, 255, 255); font-size: 12px; outline: none; }\n.ytc-playlist-creator button { background: rgb(255, 0, 0); border: 0px; color: rgb(255, 255, 255); border-radius: 4px; padding: 6px 12px; cursor: pointer; font-size: 12px; font-weight: 600; }\n.ytc-playlist-creator button:hover { background: rgb(204, 0, 0); }\n.ytc-playlist-list { flex: 1 1 0%; overflow-y: auto; padding: 6px; }\n.ytc-playlist-item { display: flex; align-items: center; gap: 8px; padding: 8px 10px; border-radius: 6px; cursor: pointer; transition: background 0.2s; }\n.ytc-playlist-item:hover { background: rgba(255, 255, 255, 0.06); }\n.ytc-playlist-item.active { background: rgba(255, 0, 0, 0.1); border-left: 3px solid rgb(255, 0, 0); }\n.ytc-playlist-icon { font-size: 18px; flex-shrink: 0; }\n.ytc-playlist-name { flex: 1 1 0%; font-size: 13px; font-weight: 500; }\n.ytc-playlist-count { font-size: 11px; color: rgb(136, 136, 136); }\n.ytc-playlist-empty { text-align: center; padding: 20px; color: rgb(136, 136, 136); font-size: 13px; }\n.ytc-pl-videos { padding: 4px 0px; }\n.ytc-pl-video { display: flex; align-items: center; gap: 6px; padding: 5px 10px 5px 20px; border-radius: 4px; cursor: pointer; font-size: 12px; transition: background 0.2s; }\n.ytc-pl-video:hover { background: rgba(255, 255, 255, 0.05); }\n.ytc-pl-video-thumb { width: 28px; height: 28px; border-radius: 3px; object-fit: cover; background: rgb(51, 51, 51); flex-shrink: 0; }\n.ytc-pl-video-info { flex: 1 1 0%; min-width: 0px; }\n.ytc-pl-video-title { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 12px; }\n.ytc-pl-video-remove { background: none; border: 0px; color: rgb(102, 102, 102); cursor: pointer; font-size: 12px; padding: 2px; }\n.ytc-pl-video-remove:hover { color: rgb(255, 68, 68); }\n.ytc-queue-panel { position: fixed; bottom: 0px; right: 16px; width: 340px; max-height: 50vh; background: rgb(26, 26, 26); border-radius: 10px 10px 0px 0px; box-shadow: rgba(0, 0, 0, 0.5) 0px -4px 20px; z-index: 200; display: flex; flex-direction: column; border-top: 1px solid rgb(39, 39, 39); border-right: 1px solid rgb(39, 39, 39); border-left: 1px solid rgb(39, 39, 39); border-image: initial; border-bottom: none; }\n@media (max-width: 400px) {\n.ytc-queue-panel { right: 0px; left: 0px; width: 100%; border-radius: 0px; }\n}\n.ytc-queue-header { display: flex; justify-content: space-between; align-items: center; padding: 10px 14px; border-bottom: 1px solid rgb(51, 51, 51); }\n.ytc-queue-title { font-size: 14px; font-weight: 600; }\n.ytc-queue-close { background: none; border: 0px; color: rgb(255, 255, 255); cursor: pointer; font-size: 16px; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }\n.ytc-queue-close:hover { background: rgb(51, 51, 51); }\n.ytc-queue-list { flex: 1 1 0%; overflow-y: auto; padding: 6px; }\n.ytc-queue-item { display: flex; gap: 6px; padding: 6px; border-radius: 6px; cursor: pointer; align-items: center; transition: background 0.2s; }\n.ytc-queue-item:hover { background: rgba(255, 255, 255, 0.06); }\n.ytc-queue-item.active { background: rgba(255, 255, 255, 0.08); }\n.ytc-queue-thumb { width: 36px; height: 36px; min-width: 36px; border-radius: 3px; object-fit: cover; background: rgb(51, 51, 51); }\n.ytc-queue-info { flex: 1 1 0%; min-width: 0px; }\n.ytc-queue-item-title { font-size: 12px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.ytc-queue-item-artist { font-size: 11px; color: rgb(170, 170, 170); }\n.ytc-queue-remove { background: none; border: 0px; color: rgb(170, 170, 170); cursor: pointer; font-size: 14px; padding: 4px; border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; }\n.ytc-queue-remove:hover { background: rgba(255, 255, 255, 0.1); color: rgb(255, 255, 255); }\n.ytc-msg { position: fixed; bottom: 60px; left: 50%; transform: translateX(-50%); background: rgb(51, 51, 51); color: rgb(255, 255, 255); padding: 8px 20px; border-radius: 6px; z-index: 300; font-size: 13px; white-space: nowrap; animation: 0.2s ease 0s 1 normal none running ytcFadeIn; }\n@keyframes ytcFadeIn {\n0% { opacity: 0; transform: translateX(-50%) translateY(10px); }\n100% { opacity: 1; transform: translateX(-50%) translateY(0px); }\n}\n.ytc-loading { display: flex; justify-content: center; padding: 60px; }\n.ytc-spinner { width: 32px; height: 32px; border-width: 3px; border-style: solid; border-color: rgb(255, 0, 0) rgb(51, 51, 51) rgb(51, 51, 51); border-image: initial; border-radius: 50%; animation: 0.8s linear 0s infinite normal none running ytcSpin; }\n@keyframes ytcSpin {\n100% { transform: rotate(360deg); }\n}\n.ytc-empty { text-align: center; padding: 60px 20px; color: rgb(136, 136, 136); }\n.ytc-empty-icon { font-size: 48px; margin-bottom: 12px; display: block; }\n.ytc-shortcuts-hint { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(0, 0, 0, 0.9); border: 1px solid rgb(68, 68, 68); border-radius: 12px; padding: 24px 32px; z-index: 500; min-width: 280px; backdrop-filter: blur(8px); }\n.ytc-shortcuts-hint h3 { margin: 0px 0px 14px; font-size: 16px; text-align: center; }\n.ytc-shortcut-row { display: flex; justify-content: space-between; align-items: center; padding: 5px 0px; font-size: 13px; gap: 24px; }\n.ytc-shortcut-key { background: rgb(51, 51, 51); border: 1px solid rgb(85, 85, 85); border-radius: 4px; padding: 2px 8px; font-size: 11px; font-weight: 600; color: rgb(255, 255, 255); min-width: 20px; text-align: center; }\n.ytc-mini-player { position: fixed; bottom: 80px; right: 16px; width: 320px; height: 180px; background: rgb(0, 0, 0); border-radius: 10px; overflow: hidden; z-index: 400; box-shadow: rgba(0, 0, 0, 0.5) 0px 10px 30px; border: 1px solid rgba(255, 255, 255, 0.08); cursor: move; transition: opacity 0.3s; }\n.ytc-mini-player video { width: 100%; height: 100%; object-fit: contain; pointer-events: none; }\n.ytc-mini-player-close { position: absolute; top: 4px; right: 4px; background: rgba(0, 0, 0, 0.7); border: 0px; color: rgb(255, 255, 255); width: 24px; height: 24px; border-radius: 50%; cursor: pointer; font-size: 12px; display: flex; align-items: center; justify-content: center; z-index: 2; }\n.ytc-mini-player-close:hover { background: rgba(244, 63, 94, 0.85); }\n:root { --study-bg: #1a110a; --study-sidebar-bg: #110904; --study-card: #281b11; --study-card-hover: #352519; --study-accent: #e5a96c; --study-accent-green: #90a98c; --study-accent-red: #d97d75; --study-text: #f8ecdf; --study-text-dim: #bdae9f; --study-border: rgba(229, 169, 108, 0.2); }\n.sz-layout { display: flex; height: 100vh; width: 100%; background: var(--study-bg); color: var(--study-text); overflow: hidden; --accent-1: var(--study-accent); --accent-2: var(--study-accent-green); --accent-3: var(--study-accent-red); font-family: var(--font-rounded), sans-serif !important; }\n.sz-sidebar { width: 210px; min-width: 210px; background: var(--study-sidebar-bg); display: flex; flex-direction: column; padding: 1.25rem 0.75rem; gap: 0.2rem; border-right: 1px solid var(--study-border); overflow-y: auto; z-index: 100; }\n.sz-sidebar-logo { font-size: 1.15rem; font-weight: 800; color: var(--study-accent); padding: 0.5rem 0.75rem; margin-bottom: 0.75rem; cursor: pointer; letter-spacing: 0.5px; display: flex; align-items: center; gap: 8px; }\n.sz-sidebar-logo::before { content: \"вҳ•\"; font-size: 1.3rem; }\n.sz-sidebar-nav { display: flex; flex-direction: column; gap: 0.15rem; }\n.sz-sidebar-link { background: none; border: none; color: var(--study-text-dim); padding: 0.7rem 0.75rem; border-radius: 6px; text-align: left; font-size: 0.95rem; font-family: var(--font-rounded); font-weight: 600; cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 0.5rem; width: 100%; }\n.sz-sidebar-link:hover { background: var(--study-card-hover); color: var(--study-text); transform: translateX(3px); }\n.sz-sidebar-link.active { background: rgba(229, 169, 108, 0.15); color: var(--study-accent); border: 1px solid rgba(229, 169, 108, 0.3); }\n.sz-sidebar-icon { font-size: 1.1rem; width: 24px; text-align: center; }\n.sz-sidebar-label { font-size: 0.88rem; }\n.sz-sidebar-divider { height: 1px; background: var(--study-border); margin: 0.75rem 0px; }\n.sz-sidebar-section-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1.2px; color: var(--study-text-dim); opacity: 0.5; padding: 0.5rem 0.75rem; font-weight: 700; }\n.sz-sidebar-footer { margin-top: auto; padding-top: 0.75rem; }\n.sz-sidebar-back { background: var(--study-card); border: 1px solid var(--study-border); color: var(--study-text-dim); padding: 0.6rem 0.75rem; border-radius: 20px; font-size: 0.85rem; font-weight: 700; font-family: var(--font-rounded); cursor: pointer; width: 100%; transition: 0.2s; }\n.sz-sidebar-back:hover { border-color: var(--study-text); color: var(--study-text); background: var(--study-card-hover); }\n.sz-main { flex: 1 1 0%; overflow: hidden; display: flex; flex-direction: column; }\n.sz-topbar { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2rem; background: rgba(26, 17, 10, 0.85); backdrop-filter: blur(12px); border-bottom: 1px solid var(--study-border); gap: 1rem; }\n.sz-topbar-left { display: flex; flex-direction: column; gap: 0.1rem; }\n.sz-topbar-title { font-size: 1.4rem; font-weight: 800; color: var(--study-accent); }\n.sz-topbar-subtitle { font-size: 0.85rem; color: var(--study-text-dim); }\n.sz-topbar-right { display: flex; align-items: center; gap: 0.75rem; }\n.sz-topbar-search { padding: 0.5rem 1rem; border: 1px solid var(--study-border); border-radius: 20px; font-size: 0.85rem; font-family: var(--font-rounded); outline: none; background: rgba(0, 0, 0, 0.3); color: rgb(255, 255, 255); width: 200px; transition: 0.25s; }\n.sz-topbar-search:focus { border-color: var(--study-accent); box-shadow: rgba(229, 169, 108, 0.15) 0px 0px 10px; }\n.sz-topbar-search::placeholder { color: var(--study-text-dim); opacity: 0.5; }\n.sz-main-scroll { flex: 1 1 0%; overflow-y: auto; padding: 1.5rem 2rem 120px; scroll-behavior: smooth; }\n.sz-section-title { font-size: 1.3rem; font-weight: 700; color: var(--text-primary); margin: 0px; }\n.sz-empty { text-align: center; padding: 3rem 1rem; color: var(--text-tertiary); }\n.sz-empty-icon { font-size: 3rem; display: block; margin-bottom: 0.75rem; }\n.sz-empty p { font-size: 0.95rem; }\n.sz-masonry { column-count: 3; column-gap: 0.75rem; }\n@media (max-width: 1200px) {\n.sz-masonry { column-count: 2; }\n}\n@media (max-width: 700px) {\n.sz-masonry { column-count: 1; }\n}\n.sz-masonry .glass-card { break-inside: avoid; margin-bottom: 0.75rem; display: inline-block; width: 100%; }\n.sz-overview { animation: 0.5s ease 0s 1 normal none running fadeUp; }\n.sz-overview-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin-top: 1.5rem; }\n.sz-overview-card { padding: 1.5rem; text-align: center; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; transition: all var(--transition); }\n.sz-overview-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-glow); }\n.sz-overview-icon { font-size: 2.2rem; }\n.sz-overview-card h3 { font-size: 1.1rem; font-weight: 600; color: var(--text-primary); }\n.sz-overview-card p { font-size: 0.85rem; color: var(--text-tertiary); }\n.sz-quote-card { position: relative; padding: 2rem; border-radius: var(--radius-xl); overflow: hidden; min-height: 160px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; border: none; }\n.sz-quote-overlay { position: absolute; inset: 0px; background: rgba(0, 0, 0, 0.25); }\n.sz-quote-content { position: relative; z-index: 1; text-align: center; color: rgb(255, 255, 255); }\n.sz-quote-icon { font-size: 2rem; display: block; margin-bottom: 0.5rem; }\n.sz-quote-text { font-size: 1.2rem; font-style: italic; font-weight: 500; line-height: 1.6; margin-bottom: 0.5rem; text-shadow: rgba(0, 0, 0, 0.2) 0px 2px 8px; }\n.sz-quote-author { font-size: 0.95rem; opacity: 0.85; margin-bottom: 0.5rem; }\n.sz-quote-date { font-size: 0.8rem; opacity: 0.6; }\n.sz-tasks { animation: 0.4s ease 0s 1 normal none running fadeUp; }\n.sz-tasks-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }\n.sz-task-form { padding: 1.25rem; margin-bottom: 1rem; animation: 0.3s ease 0s 1 normal none running slideUp; }\n.sz-task-form-row { display: flex; gap: 0.5rem; margin-bottom: 0.5rem; flex-wrap: wrap; }\n.sz-input { flex: 1 1 0%; min-width: 120px; padding: 0.6rem 0.9rem; border: 1px solid var(--border-glass); border-radius: var(--radius-md); font-size: 0.9rem; font-family: var(--font); outline: none; background: rgba(255, 255, 255, 0.06); color: var(--text-primary); transition: border-color var(--transition); }\n.sz-input:focus { border-color: var(--accent-1); }\n.sz-select { padding: 0.6rem 0.9rem; border: 1px solid var(--border-glass); border-radius: var(--radius-md); font-size: 0.85rem; font-family: var(--font); outline: none; background: rgba(255, 255, 255, 0.06); color: var(--text-primary); cursor: pointer; transition: border-color var(--transition); }\n.sz-select:focus { border-color: var(--accent-1); }\n.sz-select option { background: var(--bg-secondary); color: var(--text-primary); }\n.sz-textarea { width: 100%; padding: 0.6rem 0.9rem; border: 1px solid var(--border-glass); border-radius: var(--radius-md); font-size: 0.9rem; font-family: var(--font); outline: none; background: rgba(255, 255, 255, 0.06); color: var(--text-primary); resize: vertical; margin-bottom: 0.5rem; transition: border-color var(--transition); }\n.sz-textarea:focus { border-color: var(--accent-1); }\n.sz-category-pills { display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap; }\n.sz-category-pill { background: var(--bg-card); border: 1px solid var(--border-glass); border-radius: var(--radius-full); padding: 0.35rem 0.85rem; font-size: 0.8rem; font-family: var(--font); cursor: pointer; color: var(--text-secondary); transition: all var(--transition); display: flex; align-items: center; gap: 0.3rem; }\n.sz-category-pill:hover { background: var(--bg-card-hover); color: var(--text-primary); }\n.sz-category-pill.active { background: rgba(124, 77, 255, 0.15); border-color: var(--accent-1); color: var(--accent-1); }\n.sz-category-count { background: rgba(255, 255, 255, 0.08); border-radius: var(--radius-full); padding: 0.05rem 0.45rem; font-size: 0.7rem; }\n.sz-category-pill.active .sz-category-count { background: rgba(124, 77, 255, 0.2); }\n.sz-task-card { padding: 1.25rem; background: rgba(255, 255, 255, 0.02); color: var(--study-text); border: 1px solid var(--study-border); border-radius: 12px; box-shadow: rgba(0, 0, 0, 0.2) 0px 4px 20px; transition: all var(--transition); }\n.sz-task-card:hover { background: rgba(255, 255, 255, 0.05); border-color: rgba(245, 158, 11, 0.4); transform: translateY(-4px); box-shadow: rgba(245, 158, 11, 0.08) 0px 8px 30px; }\n.sz-task-card:nth-child(2n) { background: rgba(255, 255, 255, 0.02); border-color: rgba(16, 185, 129, 0.15); }\n.sz-task-card:nth-child(2n):hover { border-color: rgba(16, 185, 129, 0.4); box-shadow: rgba(16, 185, 129, 0.08) 0px 8px 30px; }\n.sz-task-card:nth-child(3n) { background: rgba(255, 255, 255, 0.02); border-color: rgba(99, 102, 241, 0.15); }\n.sz-task-card:nth-child(3n):hover { border-color: rgba(99, 102, 241, 0.4); box-shadow: rgba(99, 102, 241, 0.08) 0px 8px 30px; }\n.sz-task-card.completed { opacity: 0.45; background: rgba(255, 255, 255, 0.01) !important; border-color: rgba(255, 255, 255, 0.08) !important; }\n.sz-task-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem; }\n.sz-task-category-tag { font-size: 0.72rem; padding: 0.15rem 0.5rem; border-radius: 6px; border: 1px solid rgba(245, 158, 11, 0.2); color: var(--study-accent); background: rgba(245, 158, 11, 0.06); text-transform: capitalize; font-weight: 700; }\n.sz-task-card:nth-child(2n) .sz-task-category-tag { color: var(--study-accent-green); border-color: rgba(16, 185, 129, 0.2); background: rgba(16, 185, 129, 0.06); }\n.sz-task-card:nth-child(3n) .sz-task-category-tag { color: rgb(139, 92, 246); border-color: rgba(139, 92, 246, 0.2); background: rgba(139, 92, 246, 0.06); }\n.sz-task-priority-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; box-shadow: currentcolor 0px 0px 8px; }\n.sz-task-card-title { font-size: 0.95rem; font-weight: 700; color: rgb(255, 255, 255); margin-bottom: 0.35rem; line-height: 1.4; }\n.sz-task-card-title.done { text-decoration: line-through; color: var(--study-text-dim); opacity: 0.6; }\n.sz-task-card-desc { font-size: 0.82rem; color: var(--study-text-dim); margin-bottom: 0.75rem; line-height: 1.45; }\n.sz-task-card-meta { display: flex; gap: 0.75rem; font-size: 0.75rem; color: var(--study-text-dim); opacity: 0.8; margin-bottom: 0.75rem; }\n.sz-task-card-status-row { margin-bottom: 0.5rem; }\n.sz-status-btn { font-size: 0.72rem; padding: 0.25rem 0.6rem; border-radius: 6px; border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(255, 255, 255, 0.03); color: var(--study-text-dim); cursor: pointer; font-family: var(--font-rounded); font-weight: 700; transition: 0.2s; }\n.sz-status-btn:hover { background: rgba(255, 255, 255, 0.08); color: rgb(255, 255, 255); }\n.sz-status-btn.completed { border-color: rgba(16, 185, 129, 0.3); color: var(--study-accent-green); background: rgba(16, 185, 129, 0.08); }\n.sz-status-btn.in_progress { border-color: rgba(245, 158, 11, 0.3); color: var(--study-accent); background: rgba(245, 158, 11, 0.08); }\n.sz-task-card-actions { display: flex; gap: 0.4rem; justify-content: flex-end; }\n.sz-icon-btn { background: none; border: none; cursor: pointer; font-size: 0.9rem; padding: 0.2rem 0.3rem; border-radius: 4px; transition: 0.2s; line-height: 1; color: var(--study-text-dim); opacity: 0.6; }\n.sz-icon-btn:hover { background: rgba(255, 255, 255, 0.06); color: rgb(255, 255, 255); opacity: 1; transform: scale(1.1); }\n.sz-notes { animation: 0.4s ease 0s 1 normal none running fadeUp; }\n.sz-notes-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.75rem; }\n.sz-notes-actions { display: flex; align-items: center; gap: 0.5rem; }\n.sz-search-input { padding: 0.5rem 0.9rem; border: 1px solid var(--study-border); border-radius: 20px; font-size: 0.85rem; font-family: var(--font-rounded); outline: none; background: rgba(0, 0, 0, 0.25); color: rgb(255, 255, 255); width: 180px; transition: 0.2s; }\n.sz-search-input:focus { border-color: var(--study-accent); }\n.sz-search-input::placeholder { color: var(--study-text-dim); opacity: 0.5; }\n.sz-note-editor { padding: 1.25rem; background: var(--study-card); border: 1px solid var(--study-border); border-radius: 8px; margin-bottom: 1.5rem; animation: 0.3s ease 0s 1 normal none running slideUp; }\n.sz-note-title-input { width: 100%; margin-bottom: 0.75rem; font-weight: 700; border: 1px solid var(--study-border); font-size: 1.15rem !important; background: rgba(0, 0, 0, 0.2) !important; color: rgb(255, 255, 255) !important; }\n.sz-note-toolbar { display: flex; align-items: center; gap: 0.4rem; padding: 0.5rem; background: rgba(0, 0, 0, 0.2); border-radius: 6px; margin-bottom: 0.75rem; flex-wrap: wrap; border: 1px solid var(--study-border); }\n.sz-toolbar-btn { background: none; border: none; color: var(--study-text-dim); padding: 0.35rem 0.65rem; border-radius: 4px; cursor: pointer; font-family: var(--font-rounded); font-size: 0.85rem; font-weight: 600; transition: 0.2s; }\n.sz-toolbar-btn:hover { background: rgba(255, 255, 255, 0.06); color: rgb(255, 255, 255); }\n.sz-toolbar-sep { width: 1px; height: 20px; background: var(--study-border); margin: 0px 0.3rem; }\n.sz-color-dot { width: 18px; height: 18px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; transition: 0.2s; }\n.sz-color-dot.active { border-color: rgb(255, 255, 255); transform: scale(1.25); }\n.sz-color-dot:hover { transform: scale(1.15); }\n.sz-note-content-editable { min-height: 160px; padding: 0.75rem; border: 1px solid var(--study-border); border-radius: 6px; font-size: 0.95rem; line-height: 1.6; color: rgb(255, 255, 255); outline: none; background: rgba(0, 0, 0, 0.2); margin-bottom: 0.75rem; transition: border-color 0.2s; }\n.sz-note-content-editable:focus { border-color: var(--study-accent); }\n.sz-note-content-editable:empty::before { content: attr(data-placeholder); color: var(--study-text-dim); opacity: 0.5; font-style: italic; }\n.sz-note-editor-actions { display: flex; gap: 0.5rem; }\n.sz-note-card { padding: 1.25rem; background: var(--study-card); border: 1px solid var(--study-border); border-radius: 8px; transition: 0.25s; }\n.sz-note-card:hover { transform: translateY(-4px); background: var(--study-card-hover); box-shadow: rgba(0, 0, 0, 0.4) 0px 8px 24px; }\n.sz-note-card-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 0.5rem; }\n.sz-note-card-title { font-size: 1rem; font-weight: 700; color: rgb(255, 255, 255); flex: 1 1 0%; word-break: break-word; }\n.sz-note-card-actions { display: flex; gap: 0.25rem; flex-shrink: 0; }\n.sz-note-card-content { font-size: 0.88rem; color: var(--study-text-dim); line-height: 1.55; word-break: break-word; }\n.sz-note-card-footer { margin-top: 0.75rem; padding-top: 0.5rem; border-top: 1px solid var(--study-border); }\n.sz-note-date { font-size: 0.75rem; color: var(--study-text-dim); opacity: 0.6; }\n.sz-pomodoro { animation: 0.4s ease 0s 1 normal none running fadeUp; display: flex; flex-direction: column; align-items: center; }\n.sz-pomodoro-header { display: flex; align-items: center; justify-content: space-between; width: 100%; margin-bottom: 1rem; }\n.sz-pomodoro-presets { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; }\n.sz-preset-btn { background: var(--study-card); border: 1px solid var(--study-border); border-radius: 20px; padding: 0.45rem 1.1rem; font-size: 0.85rem; font-family: var(--font-rounded); font-weight: 600; cursor: pointer; color: var(--study-text-dim); transition: 0.2s; }\n.sz-preset-btn:hover { background: var(--study-card-hover); color: rgb(255, 255, 255); }\n.sz-preset-btn.active { background: var(--study-accent); border-color: rgb(255, 255, 255); color: rgb(26, 18, 11); box-shadow: 2px 2px 0 var(--study-accent-green); }\n.sz-pomodoro-custom { padding: 1rem; margin-bottom: 1.5rem; display: flex; gap: 1.5rem; flex-wrap: wrap; justify-content: center; }\n.sz-custom-row { display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; color: var(--study-text-dim); }\n.sz-custom-row input { width: 70px; padding: 0.4rem 0.6rem; border: 1px solid var(--study-border); border-radius: 4px; font-family: var(--font-rounded); font-size: 0.95rem; background: rgba(0, 0, 0, 0.3); color: rgb(255, 255, 255); text-align: center; outline: none; }\n.sz-custom-row input:focus { border-color: var(--study-accent); }\n.sz-pomodoro-ring { position: relative; width: 220px; height: 220px; margin-bottom: 1.5rem; }\n.sz-pomodoro-svg { width: 100%; height: 100%; transform: rotate(-90deg); }\n.sz-pomodoro-svg circle { transition: stroke-dashoffset 0.3s; }\n.sz-pomodoro-display { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; }\n.sz-pomodoro-time { font-size: 2.8rem; font-weight: 800; font-variant-numeric: tabular-nums; color: var(--study-text); display: block; letter-spacing: 1px; }\n.sz-pomodoro-mode { font-size: 0.8rem; color: var(--study-accent); text-transform: uppercase; letter-spacing: 1.5px; font-weight: 700; }\n.sz-pomodoro-controls { display: flex; gap: 0.75rem; margin-bottom: 1rem; }\n.sz-pomodoro-stats { font-size: 0.85rem; color: var(--study-text-dim); }\n.sz-pomodoro-stats strong { color: var(--study-accent-green); }\n.sz-progress { animation: 0.4s ease 0s 1 normal none running fadeUp; }\n.sz-progress-tabs { display: flex; gap: 0.5rem; margin: 1rem 0px; }\n.sz-progress-tab { background: var(--bg-card); border: 1px solid var(--border-glass); border-radius: var(--radius-md); padding: 0.45rem 1rem; font-size: 0.9rem; font-family: var(--font); cursor: pointer; color: var(--text-secondary); transition: all var(--transition); }\n.sz-progress-tab:hover { background: var(--bg-card-hover); color: var(--text-primary); }\n.sz-progress-tab.active { background: rgba(124, 77, 255, 0.15); border-color: var(--accent-1); color: var(--accent-1); }\n.sz-streak-hero { padding: 2rem; text-align: center; margin-bottom: 1rem; }\n.sz-streak-flame { display: flex; flex-direction: column; align-items: center; gap: 0.25rem; }\n.sz-streak-emoji { font-size: 3rem; }\n.sz-streak-number { font-size: 4rem; font-weight: 900; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; line-height: 1; }\n.sz-streak-label { font-size: 1rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 2px; }\n.sz-stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 0.75rem; margin-bottom: 1rem; }\n.sz-stat-card { padding: 1.25rem; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 0.3rem; }\n.sz-stat-icon { font-size: 1.5rem; }\n.sz-stat-value { font-size: 1.5rem; font-weight: 700; color: var(--text-primary); font-variant-numeric: tabular-nums; }\n.sz-stat-label { font-size: 0.75rem; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.5px; }\n.sz-week-chart { padding: 1.25rem; margin-bottom: 1rem; }\n.sz-week-chart-title { font-size: 0.95rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 1rem; }\n.sz-week-bars { display: flex; justify-content: space-between; align-items: flex-end; gap: 0.5rem; height: 140px; }\n.sz-week-bar-item { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; flex: 1 1 0%; height: 100%; justify-content: flex-end; }\n.sz-week-bar-track { width: 100%; max-width: 36px; height: 100px; background: rgba(255, 255, 255, 0.04); border-radius: var(--radius-sm); position: relative; overflow: hidden; display: flex; align-items: flex-end; }\n.sz-week-bar-fill { width: 100%; background: var(--gradient-1); border-radius: var(--radius-sm); transition: height 0.5s; min-height: 2px; }\n.sz-week-bar-label { font-size: 0.7rem; color: var(--text-tertiary); text-transform: uppercase; }\n.sz-badges-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 0.75rem; }\n.sz-badge-card { padding: 1rem; display: flex; align-items: center; gap: 0.75rem; transition: all var(--transition); }\n.sz-badge-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }\n.sz-badge-card.locked { opacity: 0.5; }\n.sz-badge-icon { font-size: 2rem; width: 48px; text-align: center; flex-shrink: 0; }\n.sz-badge-info { flex: 1 1 0%; min-width: 0px; }\n.sz-badge-name { font-size: 0.9rem; font-weight: 600; color: var(--text-primary); }\n.sz-badge-desc { font-size: 0.75rem; color: var(--text-tertiary); }\n.sz-badge-progress-track { width: 60px; height: 6px; background: rgba(255, 255, 255, 0.08); border-radius: 3px; overflow: hidden; flex-shrink: 0; }\n.sz-badge-progress-fill { height: 100%; background: var(--gradient-1); border-radius: 3px; transition: width 0.5s; }\n.sz-badge-progress-text { font-size: 0.75rem; color: var(--text-tertiary); min-width: 36px; text-align: right; }\n@media (max-width: 768px) {\n.sz-sidebar { width: 56px; min-width: 56px; padding: 1rem 0.4rem; }\n.sz-sidebar-logo { font-size: 0px; padding: 0.5rem; }\n.sz-sidebar-logo::after { content: \"рҹ“ҡ\"; font-size: 1.3rem; -webkit-text-fill-color: initial; background: none; }\n.sz-sidebar-label { display: none; }\n.sz-sidebar-link { font-size: 0px; padding: 0.6rem; justify-content: center; }\n.sz-sidebar-section-label { display: none; }\n.sz-sidebar-back { font-size: 0px; padding: 0.5rem; }\n.sz-main-scroll { padding: 1rem 1rem 100px; }\n.sz-topbar { padding: 0.75rem 1rem; flex-direction: column; align-items: flex-start; }\n.sz-topbar-search { width: 100%; }\n.sz-topbar-title { font-size: 1rem; }\n.sz-overview-grid { grid-template-columns: 1fr 1fr; }\n.sz-pomodoro-ring { width: 180px; height: 180px; }\n.sz-pomodoro-time { font-size: 2rem; }\n}\n:root { --anime-bg: #020204; --anime-accent: #f43f5e; --anime-accent2: #8b5cf6; --anime-accent3: #06b6d4; --manga-accent: #06b6d4; --manga-accent2: #f43f5e; --sidebar-width: 240px; }\n.anime-hub { display: flex; min-height: 100vh; background: var(--anime-bg); position: relative; letter-spacing: 0.5px; font-family: var(--font-condensed) !important; }\n@keyframes punk-glitch {\n0% { text-shadow: 2px -2px 0px var(--anime-accent), -2px 2px 0px var(--anime-accent3); transform: translate(0px, 0px); }\n20% { text-shadow: -2px 2px 0px var(--anime-accent), 2px -2px 0px var(--anime-accent3); transform: translate(-1px, 1px); }\n40% { text-shadow: 2px 2px 0px var(--anime-accent2), -2px -2px 0px var(--anime-accent); transform: translate(1px, -1px); }\n60% { text-shadow: -2px -2px 0px var(--anime-accent2), 2px 2px 0px var(--anime-accent3); transform: translate(-1px, -1px); }\n80% { text-shadow: 2px -2px 0px var(--anime-accent), -2px 2px 0px var(--anime-accent2); transform: translate(1px, 1px); }\n100% { text-shadow: 2px -2px 0px var(--anime-accent), -2px 2px 0px var(--anime-accent3); transform: translate(0px, 0px); }\n}\n.anime-hub::before { content: \"\"; position: fixed; inset: 0px; background: linear-gradient(217deg, rgba(255, 0, 127, 0.04), rgba(255, 0, 127, 0) 70.71%), linear-gradient(127deg, rgba(188, 19, 254, 0.03), rgba(188, 19, 254, 0) 70.71%), linear-gradient(336deg, rgba(0, 212, 255, 0.04), rgba(0, 212, 255, 0) 70.71%); pointer-events: none; z-index: 0; }\n.anime-sidebar { width: var(--sidebar-width); flex-shrink: 0; background: rgb(0, 0, 0); border-right: 3px solid var(--anime-accent2); padding: 1.5rem 0px; display: flex; flex-direction: column; gap: 0.15rem; position: sticky; top: 0px; height: 100vh; overflow-y: auto; z-index: 10; }\n.sidebar-brand { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 1.5rem 1.25rem; border-bottom: 2px dashed var(--anime-accent); margin-bottom: 1.5rem; }\n.sidebar-brand .brand-icon { font-size: 1.5rem; color: var(--anime-accent); }\n.sidebar-brand h2 { font-size: 1.5rem; font-weight: 900; text-transform: uppercase; color: rgb(255, 255, 255); letter-spacing: 1px; background: none; -webkit-text-fill-color: initial; text-shadow: 2px 2px 0px var(--anime-accent2); margin: 0px; }\n.sidebar-brand h2:hover { animation: 0.3s ease 0s infinite normal none running punk-glitch; }\n.sidebar-nav, .sidebar-tabs { display: flex; flex-direction: column; gap: 0.3rem; padding: 0px 0.75rem; }\n.sidebar-nav-btn, .sidebar-tab { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border: 1px solid transparent; background: transparent; color: rgb(201, 209, 217); font-size: 1rem; font-weight: 700; text-transform: uppercase; font-family: var(--font-condensed); cursor: pointer; border-radius: 0px; transition: 0.15s ease-in-out; text-align: left; width: 100%; }\n.sidebar-nav-btn:hover, .sidebar-tab:hover { background: var(--anime-accent); color: rgb(0, 0, 0); border-color: rgb(255, 255, 255); transform: skewX(-5deg); }\n.sidebar-nav-btn.active, .sidebar-tab.active { background: var(--anime-accent2); color: rgb(255, 255, 255); border: 2px solid rgb(255, 255, 255); box-shadow: 4px 4px 0px var(--anime-accent3); }\n.sidebar-divider { height: 2px; background: var(--anime-accent3); margin: 1rem 0.75rem; }\n.anime-content { flex: 1 1 0%; padding: 1.5rem 2.5rem; overflow-y: auto; max-height: 100vh; position: relative; z-index: 1; }\n.anime-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 3px solid rgb(255, 255, 255); }\n.page-title { font-size: 2.2rem; font-weight: 900; text-transform: uppercase; color: rgb(255, 255, 255); letter-spacing: 2px; text-shadow: 3px 3px 0px var(--anime-accent); margin: 0px; background: none; -webkit-text-fill-color: initial; }\n.page-title:hover { animation: 0.3s ease 0s infinite normal none running punk-glitch; }\n.header-actions { display: flex; align-items: center; gap: 0.75rem; }\n.view-toggle { display: flex; gap: 0.25rem; background: rgb(0, 0, 0); border: 2px solid var(--anime-accent); padding: 0.2rem; }\n.view-btn { border: none; background: transparent; color: rgba(255, 255, 255, 0.6); padding: 0.3rem 0.6rem; cursor: pointer; font-size: 1rem; font-weight: 700; font-family: var(--font-condensed); transition: 0.2s; }\n.view-btn.active { background: var(--anime-accent3); color: rgb(0, 0, 0); }\n.glass { background: rgb(9, 9, 14); border: 2px solid var(--anime-accent); box-shadow: 4px 4px 0px var(--anime-accent2); }\n.search-bar { display: flex; gap: 0.75rem; padding: 1.25rem; margin-bottom: 2rem; flex-wrap: wrap; align-items: center; }\n.search-bar input { flex: 1 1 0%; min-width: 200px; padding: 0.75rem 1rem; background: rgb(0, 0, 0); border: 2px solid var(--anime-accent2); font-family: var(--font-condensed); font-weight: 700; font-size: 1.05rem; outline: none; color: rgb(255, 255, 255); text-transform: uppercase; transition: border-color 0.2s; }\n.search-bar input:focus { border-color: var(--anime-accent); box-shadow: rgba(255, 0, 127, 0.5) 0px 0px 10px; }\n.search-filters { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }\n.search-filters select { padding: 0.7rem 0.8rem; background: rgb(0, 0, 0); border: 2px solid var(--anime-accent3); font-family: var(--font-condensed); font-weight: 700; font-size: 0.95rem; outline: none; color: rgb(255, 255, 255); text-transform: uppercase; cursor: pointer; }\n.search-btn, .primary-btn { padding: 0.7rem 1.6rem; background: var(--anime-accent); border: 2px solid rgb(255, 255, 255); color: rgb(0, 0, 0); font-family: var(--font-condensed); font-size: 1.05rem; font-weight: 900; text-transform: uppercase; cursor: pointer; transition: 0.15s; }\n.search-btn:hover, .primary-btn:hover { background: var(--anime-accent3); color: rgb(0, 0, 0); transform: translateY(-2px) skewX(-5deg); box-shadow: rgb(255, 255, 255) 4px 4px 0px; }\n.seasonal-filters, .schedule-filters { display: flex; gap: 0.75rem; padding: 1.25rem; margin-bottom: 2rem; flex-wrap: wrap; align-items: center; }\n.seasonal-filters select { padding: 0.7rem 0.8rem; background: rgb(0, 0, 0); border: 2px solid var(--anime-accent2); font-family: var(--font-condensed); font-weight: 700; font-size: 0.95rem; outline: none; color: rgb(255, 255, 255); text-transform: uppercase; cursor: pointer; }\n.day-pills { display: flex; gap: 0.5rem; flex-wrap: wrap; }\n.day-pill { padding: 0.5rem 1rem; border: 2px solid var(--anime-accent3); background: rgb(0, 0, 0); color: var(--anime-accent3); font-family: var(--font-condensed); font-size: 0.9rem; font-weight: 700; text-transform: uppercase; cursor: pointer; transition: 0.15s; }\n.day-pill:hover { background: var(--anime-accent3); color: rgb(0, 0, 0); transform: scale(1.05); }\n.day-pill.active { background: var(--anime-accent); border-color: rgb(255, 255, 255); color: rgb(255, 255, 255); box-shadow: 3px 3px 0px var(--anime-accent2); }\n.anime-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.5rem; padding: 0.5rem 0px; }\n.anime-grid.list { grid-template-columns: 1fr; }\n.anime-card { border-radius: 0px; overflow: hidden; background: rgb(0, 0, 0); border: 3px solid var(--anime-accent2); cursor: pointer; transition: 0.2s ease-in-out; position: relative; }\n.anime-card:hover { transform: translateY(-8px) rotate(-1deg); border-color: var(--anime-accent); box-shadow: 8px 8px 0px var(--anime-accent3); }\n.card-image { position: relative; width: 100%; padding-top: 140%; overflow: hidden; border-bottom: 3px solid var(--anime-accent2); }\n.anime-card:hover .card-image { border-bottom-color: var(--anime-accent); }\n.card-image img { position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease-out; filter: contrast(1.1) brightness(0.9); }\n.anime-card:hover .card-image img { transform: scale(1.08); filter: contrast(1.2) brightness(1); }\n.card-overlay { position: absolute; inset: 0px; background: rgba(0, 0, 0, 0.7); opacity: 0; transition: opacity 0.2s; display: flex; flex-direction: column; justify-content: flex-start; align-items: flex-end; padding: 0.75rem; gap: 0.5rem; }\n.anime-card:hover .card-overlay { opacity: 1; }\n.card-action-btn { width: 36px; height: 36px; border-radius: 0px; border: 2px solid rgb(255, 255, 255); background: rgb(0, 0, 0); color: white; font-size: 1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.15s; }\n.card-action-btn:hover { transform: scale(1.1) rotate(5deg); background: var(--anime-accent); color: rgb(0, 0, 0); }\n.card-score { position: absolute; top: 0.6rem; left: 0.6rem; padding: 0.25rem 0.6rem; background: var(--anime-accent); color: rgb(255, 255, 255); border: 2px solid rgb(255, 255, 255); font-size: 0.85rem; font-weight: 900; }\n.card-source-badge { position: absolute; top: 0.6rem; right: 0.6rem; padding: 0.2rem 0.5rem; background: var(--anime-accent3); color: rgb(0, 0, 0); border: 2px solid rgb(255, 255, 255); font-size: 0.75rem; font-weight: 900; }\n.card-body { padding: 1rem; background: rgb(0, 0, 0); }\n.card-title { font-size: 1.05rem; font-weight: 800; text-transform: uppercase; color: rgb(255, 255, 255); margin: 0px 0px 0.5rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.2; }\n.card-meta { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.5rem; }\n.badge { padding: 0.2rem 0.5rem; background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); color: rgb(255, 255, 255); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }\n.card-genres { display: flex; gap: 0.3rem; flex-wrap: wrap; }\n.genre-tag { padding: 0.15rem 0.45rem; background: rgba(188, 19, 254, 0.2); border: 1px solid var(--anime-accent2); color: rgb(255, 255, 255); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; }\n.loading-spinner { grid-column: 1 / -1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4rem 0px; gap: 1rem; }\n.spinner { width: 44px; height: 44px; border-right: 4px solid rgba(255, 255, 255, 0.1); border-bottom: 4px solid rgba(255, 255, 255, 0.1); border-left: 4px solid rgba(255, 255, 255, 0.1); border-image: initial; border-top: 4px solid var(--anime-accent); border-radius: 50%; animation: 0.6s linear 0s infinite normal none running spin; }\n@keyframes spin {\n100% { transform: rotate(360deg); }\n}\n.loading-spinner p { color: var(--anime-accent3); font-size: 1.1rem; font-weight: 700; text-transform: uppercase; margin: 0px; }\n.empty-state { grid-column: 1 / -1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 5rem 0px; gap: 0.75rem; }\n.empty-icon { font-size: 3rem; color: var(--anime-accent); opacity: 0.5; }\n.empty-state p { color: var(--anime-accent3); font-family: var(--font-condensed); font-size: 1.2rem; font-weight: 700; text-transform: uppercase; margin: 0px; }\n.pagination { display: flex; justify-content: center; padding: 2rem 0px 3rem; }\n.page-btn { padding: 0.75rem 2.5rem; border: 3px solid rgb(255, 255, 255); background: rgb(0, 0, 0); color: var(--anime-accent3); font-family: var(--font-condensed); font-size: 1.1rem; font-weight: 900; text-transform: uppercase; cursor: pointer; transition: 0.2s; }\n.page-btn:hover { background: var(--anime-accent2); color: rgb(255, 255, 255); transform: translateY(-3px) skewX(-5deg); box-shadow: 4px 4px 0px var(--anime-accent); }\n@media (max-width: 768px) {\n.anime-sidebar { width: 100%; height: auto; position: static; flex-flow: wrap; padding: 0.5rem; gap: 0.25rem; border-right: none; border-bottom: 3px solid var(--anime-accent2); }\n.sidebar-brand { display: none; }\n.sidebar-nav, .sidebar-tabs { flex-flow: wrap; padding: 0px; gap: 0.2rem; }\n.sidebar-nav-btn, .sidebar-tab { padding: 0.4rem 0.6rem; font-size: 0.85rem; width: auto; border-radius: 0px; }\n.sidebar-nav-btn.active, .sidebar-tab.active { box-shadow: none; }\n.sidebar-divider { display: none; }\n.anime-content { padding: 1rem; max-height: none; }\n.anime-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 1rem; }\n}\n.reader-layout { display: flex; flex-direction: column; height: 100vh; width: 100vw; background: rgb(0, 0, 0); color: rgb(255, 255, 255); font-family: var(--font-condensed); overflow: hidden; position: relative; }\n.reader-header { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1.5rem; background: rgb(0, 0, 0); border-bottom: 3px solid var(--anime-accent); position: relative; z-index: 100; }\n.reader-header-left { display: flex; align-items: center; gap: 1.25rem; }\n.reader-header-info { display: flex; flex-direction: column; }\n.reader-manga-title { font-size: 1.25rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; color: rgb(255, 255, 255); text-shadow: 2px 2px 0px var(--anime-accent2); }\n.reader-chapter-info { font-size: 0.85rem; font-weight: 700; text-transform: uppercase; color: var(--anime-accent3); }\n.reader-header-right { display: flex; align-items: center; gap: 1rem; }\n.reader-progress-pct { font-size: 1.1rem; font-weight: 900; color: rgb(255, 255, 255); background: var(--anime-accent2); border: 1px solid rgb(255, 255, 255); padding: 0.2rem 0.5rem; box-shadow: 2px 2px 0px var(--anime-accent); }\n.reader-body { display: flex; flex: 1 1 0%; overflow: hidden; position: relative; }\n.reader-main { flex: 1 1 0%; overflow-y: scroll; padding: 1rem; display: flex; flex-direction: column; align-items: center; scroll-behavior: smooth; }\n.reader-pages { display: flex; flex-direction: column; align-items: center; width: 100%; max-width: 850px; }\n.reader-page-wrap { width: 100%; position: relative; margin-bottom: 0px; border: 4px solid var(--anime-accent2); background: rgb(5, 5, 8); }\n.reader-page-wrap:hover { border-color: var(--anime-accent); }\n.reader-page { width: 100%; display: block; }\n.reader-page-num { position: absolute; bottom: 0.5rem; right: 0.5rem; background: rgb(0, 0, 0); border: 1px solid rgb(255, 255, 255); color: rgb(255, 255, 255); font-size: 0.75rem; padding: 0.1rem 0.4rem; font-weight: 700; }\n.reader-nav { width: 80px; display: flex; align-items: center; justify-content: center; cursor: pointer; background: rgba(0, 0, 0, 0.4); transition: 0.2s; user-select: none; z-index: 10; }\n.reader-nav:hover { background: rgba(255, 0, 127, 0.15); }\n.reader-nav-arrow { font-size: 3rem; font-weight: 900; color: var(--anime-accent); }\n.reader-nav-btns { display: flex; gap: 1rem; padding: 2rem 0px 4rem; }\n.reader-btn { padding: 0.6rem 1.4rem; background: rgb(0, 0, 0); border: 2px solid var(--anime-accent3); color: var(--anime-accent3); font-family: var(--font-condensed); font-weight: 700; text-transform: uppercase; cursor: pointer; transition: 0.15s; }\n.reader-btn:hover { background: var(--anime-accent3); color: rgb(0, 0, 0); transform: skewX(-5deg); }\n.reader-btn-primary { background: var(--anime-accent); border-color: rgb(255, 255, 255); color: rgb(0, 0, 0); }\n.reader-btn-primary:hover { background: var(--anime-accent2); color: rgb(255, 255, 255); box-shadow: 3px 3px 0px var(--anime-accent3); }\n.reader-toggle { display: flex; align-items: center; gap: 0.25rem; cursor: pointer; border: 1px solid var(--anime-accent); padding: 0.2rem 0.4rem; background: rgb(0, 0, 0); }\n.reader-toggle input { display: none; }\n.reader-toggle-label { font-size: 0.85rem; font-weight: 700; color: rgb(255, 255, 255); text-transform: uppercase; }\n.reader-toggle input:checked + .reader-toggle-label { color: var(--anime-accent3); }\n.reader-loading, .reader-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 6rem 2rem; text-align: center; }\n.reader-loading p, .reader-empty p { color: var(--anime-accent); font-size: 1.2rem; font-weight: 700; text-transform: uppercase; margin-top: 1rem; }\n.reader-layout::after { content: \"\"; position: absolute; bottom: 0px; left: 0px; height: 6px; background: linear-gradient(90deg, var(--anime-accent), var(--anime-accent2), var(--anime-accent3)); z-index: 101; width: var(--reader-progress, 0%); transition: width 0.1s linear; }\n.reader-chapter-sidebar { position: fixed; top: 0px; right: 0px; width: 320px; height: 100vh; background: rgb(5, 5, 8); border-left: 3px solid var(--anime-accent2); padding: 1.5rem; display: flex; flex-direction: column; z-index: 200; animation: 0.3s ease 0s 1 normal none running slideLeft; }\n@keyframes slideLeft {\n0% { transform: translateX(100%); }\n100% { transform: translateX(0px); }\n}\n.reader-chapter-sidebar-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; border-bottom: 2px dashed var(--anime-accent); padding-bottom: 0.75rem; }\n.reader-chapter-sidebar-header h3 { font-size: 1.25rem; text-transform: uppercase; font-weight: 900; color: rgb(255, 255, 255); }\n.reader-chapter-list { flex: 1 1 0%; overflow-y: auto; display: flex; flex-direction: column; gap: 0.4rem; }\n.reader-chapter-item { display: flex; flex-direction: column; padding: 0.6rem 0.8rem; border: 1px solid var(--anime-accent2); background: rgb(0, 0, 0); color: rgb(255, 255, 255); font-family: var(--font-condensed); text-align: left; cursor: pointer; transition: 0.15s; }\n.reader-chapter-item:hover { background: var(--anime-accent); color: rgb(0, 0, 0); transform: skewX(-3deg); }\n.reader-chapter-item.active { background: var(--anime-accent3); border-color: rgb(255, 255, 255); color: rgb(0, 0, 0); box-shadow: 3px 3px 0px var(--anime-accent2); }\n.reader-chapter-item-title { font-size: 0.75rem; color: rgba(255, 255, 255, 0.6); text-transform: uppercase; }\n.reader-chapter-item:hover .reader-chapter-item-title { color: rgba(0, 0, 0, 0.7); }\n.reader-chapter-item.active .reader-chapter-item-title { color: rgba(0, 0, 0, 0.6); }\n@media (max-width: 768px) {\n.reader-nav { display: none; }\n.reader-header { padding: 0.5rem 1rem; }\n.reader-manga-title { font-size: 1rem; }\n.reader-page-wrap { border-width: 2px; }\n.reader-chapter-sidebar { width: 280px; }\n}\n.vp-wrapper { width: 100%; animation: 0.4s ease 0s 1 normal none running vpFadeIn; }\n.vp-top-bar { display: flex; align-items: center; justify-content: space-between; padding: 0.6rem 0px; margin-bottom: 0.5rem; gap: 0.75rem; flex-wrap: wrap; }\n.vp-top-left { display: flex; align-items: center; gap: 0.6rem; min-width: 0px; flex: 1 1 0%; }\n.vp-title { font-size: 0.95rem; font-weight: 700; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.vp-episode { font-size: 0.78rem; color: var(--text-tertiary); background: rgba(255, 255, 255, 0.06); padding: 0.2rem 0.6rem; border-radius: 6px; white-space: nowrap; flex-shrink: 0; }\n.vp-top-right { display: flex; gap: 0.4rem; flex-shrink: 0; }\n.vp-btn { background: none; border: none; color: rgba(255, 255, 255, 0.85); font-size: 0.85rem; cursor: pointer; padding: 0.35rem 0.55rem; border-radius: 8px; transition: 0.2s; font-family: var(--font); display: flex; align-items: center; gap: 0.25rem; line-height: 1; }\n.vp-btn:hover { background: rgba(255, 255, 255, 0.1); color: rgb(255, 255, 255); transform: scale(1.05); }\n.vp-btn:disabled { opacity: 0.35; cursor: not-allowed; transform: none; }\n.vp-btn-nav { background: rgba(255, 255, 255, 0.06); padding: 0.35rem 0.8rem; font-size: 0.78rem; font-weight: 600; border: 1px solid rgba(255, 255, 255, 0.06); }\n.vp-btn-nav:hover:not(:disabled) { background: rgba(124, 77, 255, 0.2); border-color: rgba(124, 77, 255, 0.3); }\n.vp-container { position: relative; width: 100%; aspect-ratio: 16 / 9; background: rgb(0, 0, 0); border-radius: 16px; overflow: hidden; box-shadow: rgba(0, 0, 0, 0.5) 0px 8px 40px; cursor: pointer; }\n.vp-video { width: 100%; height: 100%; display: block; object-fit: contain; }\n.vp-loading, .vp-error { position: absolute; inset: 0px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; background: rgb(10, 10, 10); }\n.vp-spinner { width: 40px; height: 40px; border-width: 3px; border-style: solid; border-right-color: rgba(124, 77, 255, 0.15); border-bottom-color: rgba(124, 77, 255, 0.15); border-left-color: rgba(124, 77, 255, 0.15); border-image: initial; border-top-color: var(--anime-accent, #ff6b9d); border-radius: 50%; animation: 0.8s linear 0s infinite normal none running vpSpin; }\n@keyframes vpSpin {\n100% { transform: rotate(360deg); }\n}\n.vp-loading p { color: rgba(255, 255, 255, 0.4); font-size: 0.85rem; margin: 0px; }\n.vp-error-icon { font-size: 2.5rem; opacity: 0.4; }\n.vp-error p { color: rgba(255, 255, 255, 0.6); font-size: 0.9rem; margin: 0px; }\n.vp-error-hint { color: rgba(255, 255, 255, 0.3); font-size: 0.78rem; }\n.vp-overlay { position: absolute; inset: 0px; display: flex; flex-direction: column; justify-content: flex-end; background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.3) 30%, rgba(0, 0, 0, 0.1) 60%, transparent 100%); opacity: 0; transition: opacity 0.35s; }\n.vp-overlay.visible { opacity: 1; }\n.vp-center-play { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 2; pointer-events: none; }\n.vp-big-play { font-size: 3.5rem; color: rgb(255, 255, 255); text-shadow: rgba(0, 0, 0, 0.5) 0px 4px 30px; opacity: 0.85; transition: 0.3s; width: 80px; height: 80px; background: rgba(255, 255, 255, 0.12); backdrop-filter: blur(12px); border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 2px solid rgba(255, 255, 255, 0.15); }\n.vp-overlay.visible .vp-big-play { opacity: 1; }\n.vp-big-play:hover { background: rgba(255, 255, 255, 0.2); transform: scale(1.08); }\n.vp-bottom-controls { padding: 0px 1rem 0.75rem; position: relative; z-index: 3; }\n.vp-progress-wrap { padding: 0.5rem 0px; cursor: pointer; position: relative; }\n.vp-progress-bg { height: 4px; background: rgba(255, 255, 255, 0.15); border-radius: 4px; position: relative; transition: height 0.15s; }\n.vp-progress-wrap:hover .vp-progress-bg { height: 6px; }\n.vp-progress-buffered { position: absolute; top: 0px; left: 0px; height: 100%; background: rgba(255, 255, 255, 0.2); border-radius: 4px; transition: width 0.3s; }\n.vp-progress-fill { position: absolute; top: 0px; left: 0px; height: 100%; background: linear-gradient(90deg, var(--anime-accent, #ff6b9d), var(--anime-accent2, #7c4dff)); border-radius: 4px; transition: width 0.1s linear; }\n.vp-progress-thumb { position: absolute; top: 50%; transform: translate(-50%, -50%); width: 14px; height: 14px; background: rgb(255, 255, 255); border-radius: 50%; opacity: 0; transition: opacity 0.2s; box-shadow: rgba(0, 0, 0, 0.3) 0px 2px 8px; pointer-events: none; margin-left: -1px; }\n.vp-progress-wrap:hover .vp-progress-thumb { opacity: 1; }\n.vp-controls-row { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }\n.vp-controls-left, .vp-controls-right { display: flex; align-items: center; gap: 0.15rem; }\n.vp-time { font-size: 0.75rem; color: rgba(255, 255, 255, 0.6); font-variant-numeric: tabular-nums; margin-left: 0.3rem; white-space: nowrap; }\n.vp-vol-wrap { position: relative; display: flex; align-items: center; }\n.vp-vol-slider { position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); background: rgba(15, 15, 19, 0.95); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 10px; padding: 0.5rem 0.75rem; margin-bottom: 0.5rem; box-shadow: rgba(0, 0, 0, 0.4) 0px 8px 32px; }\n.vp-vol-slider input[type=\"range\"] { writing-mode: vertical-lr; direction: rtl; width: 6px; height: 80px; accent-color: var(--anime-accent, #ff6b9d); cursor: pointer; }\n.vp-speed-wrap { position: relative; }\n.vp-speed-btn { min-width: 42px; text-align: center; font-weight: 600; }\n.vp-speed-menu { position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); background: rgba(15, 15, 19, 0.95); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 12px; padding: 0.35rem; display: flex; flex-direction: column; gap: 0.15rem; margin-bottom: 0.5rem; box-shadow: rgba(0, 0, 0, 0.4) 0px 8px 32px; min-width: 60px; }\n.vp-speed-opt { background: none; border: none; color: rgba(255, 255, 255, 0.6); padding: 0.35rem 0.75rem; border-radius: 6px; font-size: 0.78rem; font-family: var(--font); cursor: pointer; transition: 0.2s; text-align: center; }\n.vp-speed-opt:hover { background: rgba(255, 255, 255, 0.08); color: rgb(255, 255, 255); }\n.vp-speed-opt.active { background: rgba(124, 77, 255, 0.2); color: var(--anime-accent2, #7c4dff); font-weight: 700; }\n.vp-sub-select { background: rgba(255, 255, 255, 0.06); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 8px; padding: 0.3rem 0.5rem; font-size: 0.72rem; font-family: var(--font); color: rgba(255, 255, 255, 0.8); cursor: pointer; outline: none; max-width: 100px; }\n.vp-sub-select:focus { border-color: var(--anime-accent2, #7c4dff); }\n.vp-sub-select option { background: rgb(26, 26, 46); color: rgb(255, 255, 255); }\n@keyframes vpFadeIn {\n0% { opacity: 0; transform: translateY(8px); }\n100% { opacity: 1; transform: translateY(0px); }\n}\n@media (max-width: 768px) {\n.vp-container { border-radius: 10px; }\n.vp-top-bar { flex-direction: column; align-items: flex-start; }\n.vp-big-play { font-size: 2.5rem; width: 60px; height: 60px; }\n.vp-bottom-controls { padding: 0px 0.6rem 0.5rem; }\n.vp-time { font-size: 0.65rem; }\n.vp-btn { font-size: 0.78rem; padding: 0.3rem 0.4rem; }\n.vp-vol-slider input[type=\"range\"] { height: 60px; }\n}\n:root { --book-bg: #0b0907; --book-sidebar-bg: #060504; --book-card-bg: #14100d; --book-accent: #f59e0b; --book-accent2: #d97706; --book-accent3: #fafaf9; --book-gold: #fbbf24; --sidebar-width: 240px; }\n.book-hub { display: flex; min-height: 100vh; background: var(--book-bg); position: relative; font-family: var(--font-rounded), sans-serif; }\n.book-hub::before { content: \"\"; position: fixed; inset: 0px; background: radial-gradient(at 20% 50%, rgba(212, 163, 115, 0.06) 0%, transparent 60%), radial-gradient(at 80% 20%, rgba(137, 94, 56, 0.04) 0%, transparent 50%); pointer-events: none; z-index: 0; }\n.book-sidebar { width: var(--sidebar-width); flex-shrink: 0; background: var(--book-sidebar-bg); border-right: 1px solid rgba(212, 163, 115, 0.15); padding: 1.5rem 0px; display: flex; flex-direction: column; gap: 0.15rem; position: sticky; top: 0px; height: 100vh; overflow-y: auto; z-index: 10; }\n.book-sidebar .sidebar-brand h2 { font-family: var(--font-serif); font-style: italic; font-weight: 800; color: var(--book-accent); background: none; -webkit-text-fill-color: initial; text-shadow: rgba(0, 0, 0, 0.5) 1px 1px 0px; }\n.book-sidebar .sidebar-nav-btn, .book-sidebar .sidebar-tab { color: rgb(235, 213, 192); font-weight: 600; border-radius: 4px; font-family: var(--font-rounded); }\n.book-sidebar .sidebar-nav-btn.active, .book-sidebar .sidebar-tab.active { background: rgba(212, 163, 115, 0.15); color: var(--book-accent); border: 1px solid rgba(212, 163, 115, 0.3); box-shadow: inset 3px 0 0 var(--book-accent); }\n.book-sidebar .sidebar-nav-btn:hover, .book-sidebar .sidebar-tab:hover { background: rgba(212, 163, 115, 0.08); color: rgb(255, 255, 255); }\n.book-content { flex: 1 1 0%; padding: 1.5rem 2.5rem; overflow-y: auto; max-height: 100vh; position: relative; z-index: 1; }\n.book-content .page-title { font-family: var(--font-serif); font-weight: 800; color: var(--book-accent3); background: none; -webkit-text-fill-color: initial; margin: 0px; }\n.book-content .search-btn, .book-content .primary-btn { background: var(--book-accent2); color: rgb(255, 255, 255); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 6px; font-weight: 700; font-family: var(--font-rounded); }\n.book-content .search-btn:hover, .book-content .primary-btn:hover { background: var(--book-accent); color: rgb(26, 18, 11); box-shadow: rgba(212, 163, 115, 0.3) 0px 4px 15px; }\n.book-content .glass { background: var(--book-card-bg); border: 1px solid rgba(212, 163, 115, 0.15); border-radius: 8px; box-shadow: rgba(0, 0, 0, 0.3) 0px 8px 24px; }\n.book-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1.5rem; padding: 0.5rem 0px; }\n.book-grid.list { grid-template-columns: 1fr; }\n.book-card { border-radius: 4px; overflow: hidden; background: var(--book-card-bg); border: 1px solid rgba(212, 163, 115, 0.2); cursor: pointer; transition: 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); box-shadow: rgba(0, 0, 0, 0.4) 0px 4px 10px; }\n.book-card:hover { transform: translateY(-8px) scale(1.02); border-color: var(--book-accent); box-shadow: 0 15px 30px rgba(0, 0, 0, 0.6), 5px 5px 0 var(--book-accent2); }\n.book-card .card-image { position: relative; width: 100%; padding-top: 150%; overflow: hidden; background: rgb(17, 10, 5); border-bottom: 2px solid rgba(212, 163, 115, 0.2); }\n.book-card .card-image img { position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; box-shadow: rgba(0, 0, 0, 0.8) 0px 0px 40px inset; }\n.book-card:hover .card-image img { transform: scale(1.05); }\n.book-card .card-image .no-cover { position: absolute; inset: 0px; display: flex; align-items: center; justify-content: center; font-family: var(--font-serif); font-style: italic; font-size: 3rem; color: var(--book-accent2); background: rgb(28, 21, 16); opacity: 0.6; }\n.book-card .card-body { padding: 0.85rem; background: var(--book-card-bg); }\n.book-card .card-title { font-family: var(--font-serif); font-size: 0.95rem; font-weight: 700; color: var(--book-accent3); margin: 0px 0px 0.4rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.3; }\n.book-card .card-author { font-family: var(--font-rounded); font-size: 0.78rem; color: rgba(255, 255, 255, 0.55); margin: 0px 0px 0.5rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.book-card .card-meta { display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center; }\n.book-card .card-source { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; padding: 0.15rem 0.45rem; border-radius: 2px; }\n.card-source.openlibrary { background: rgba(212, 163, 115, 0.15); color: var(--book-accent); border: 1px solid rgba(212, 163, 115, 0.3); }\n.card-source.gutenberg { background: rgba(137, 94, 56, 0.15); color: rgb(197, 168, 128); border: 1px solid rgba(137, 94, 56, 0.3); }\n.card-source.googlebooks { background: rgba(255, 215, 0, 0.1); color: var(--book-gold); border: 1px solid rgba(255, 215, 0, 0.2); }\n.book-card .card-year { font-size: 0.7rem; color: rgba(255, 255, 255, 0.4); }\n.source-tabs { display: flex; gap: 0.5rem; margin-bottom: 2rem; flex-wrap: wrap; }\n.source-tab { padding: 0.5rem 1.25rem; border: 1px solid rgba(212, 163, 115, 0.2); border-radius: 4px; background: rgb(17, 10, 5); color: rgb(235, 213, 192); font-family: var(--font-rounded); font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: 0.2s; }\n.source-tab:hover { background: rgba(212, 163, 115, 0.1); color: rgb(255, 255, 255); }\n.source-tab.active { background: var(--book-accent); color: rgb(26, 18, 11); border-color: rgb(255, 255, 255); box-shadow: 3px 3px 0 var(--book-accent2); }\n.book-detail { flex: 1 1 0%; padding: 2rem 2.5rem; overflow-y: auto; max-height: 100vh; position: relative; z-index: 1; }\n.book-detail-header { display: flex; gap: 2rem; margin-bottom: 2rem; }\n.book-detail-cover { width: 260px; flex-shrink: 0; }\n.book-detail-cover img { width: 100%; border-radius: 4px; box-shadow: rgba(0, 0, 0, 0.7) 10px 10px 30px, rgba(255, 255, 255, 0.1) 2px 2px 0px inset; }\n.book-detail-cover .no-cover { width: 100%; aspect-ratio: 2 / 3; border-radius: 4px; background: var(--book-card-bg); border: 1px solid rgba(212, 163, 115, 0.2); display: flex; align-items: center; justify-content: center; font-family: var(--font-serif); font-size: 4rem; opacity: 0.5; color: var(--book-accent2); }\n.book-detail-info { flex: 1 1 0%; }\n.book-detail-info h1 { font-family: var(--font-serif); font-size: 2.2rem; font-weight: 800; margin: 0px 0px 0.5rem; color: var(--book-accent3); text-shadow: rgba(0, 0, 0, 0.4) 1px 1px 0px; }\n.book-detail-info .book-author { font-size: 1.25rem; font-family: var(--font-serif); font-style: italic; color: var(--book-accent); margin: 0px 0px 1.25rem; }\n.book-detail-info .book-metadata { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.25rem; }\n.book-detail-info .book-metadata span { padding: 0.4rem 0.8rem; background: rgba(212, 163, 115, 0.08); border: 1px solid rgba(212, 163, 115, 0.15); border-radius: 4px; font-size: 0.8rem; color: rgba(255, 255, 255, 0.75); }\n.book-detail-info .book-description { color: rgba(255, 255, 255, 0.7); font-size: 0.95rem; line-height: 1.7; margin-bottom: 2rem; }\n.book-detail-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }\n.book-detail-actions .action-btn, .read-btn { padding: 0.75rem 1.8rem; border: none; border-radius: 4px; font-family: var(--font-rounded); font-size: 0.95rem; font-weight: 700; cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 0.5rem; }\n.read-btn { background: var(--book-accent); color: rgb(26, 18, 11); box-shadow: 4px 4px 0px var(--book-accent2); }\n.read-btn:hover { background: rgb(255, 255, 255); color: rgb(26, 18, 11); transform: translateY(-2px); box-shadow: 5px 5px 0px var(--book-accent); }\n.read-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }\n.book-detail-actions .action-btn { background: rgba(212, 163, 115, 0.08); color: rgb(235, 213, 192); border: 1px solid rgba(212, 163, 115, 0.2); }\n.book-detail-actions .action-btn:hover { background: rgba(212, 163, 115, 0.15); color: white; }\n.book-detail-actions .action-btn.active { background: var(--book-accent2); border-color: var(--book-accent); color: rgb(255, 255, 255); }\n.related-books { margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid rgba(212, 163, 115, 0.15); }\n.related-books h3 { font-family: var(--font-serif); font-size: 1.25rem; font-weight: 700; color: var(--book-accent3); margin: 0px 0px 1.25rem; }\n.related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 1.25rem; }\n.related-card { border-radius: 4px; overflow: hidden; background: var(--book-card-bg); border: 1px solid rgba(212, 163, 115, 0.15); cursor: pointer; transition: 0.25s; box-shadow: rgba(0, 0, 0, 0.3) 0px 4px 8px; }\n.related-card:hover { transform: translateY(-4px); border-color: var(--book-accent); box-shadow: rgba(0, 0, 0, 0.5) 0px 8px 16px; }\n.related-card .related-cover { width: 100%; aspect-ratio: 2 / 3; object-fit: cover; }\n.related-card .related-info { padding: 0.5rem; }\n.related-card .related-info h4 { font-size: 0.72rem; margin: 0px; color: rgba(255, 255, 255, 0.7); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }\n.related-card .related-info span { font-size: 0.62rem; color: rgba(255, 255, 255, 0.4); }\n.reader-container { display: flex; flex-direction: column; height: 100vh; background: var(--book-bg); position: relative; }\n.reader-toolbar { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1.5rem; background: var(--book-sidebar-bg); border-bottom: 2px solid rgba(212, 163, 115, 0.25); gap: 0.75rem; flex-wrap: wrap; z-index: 20; }\n.reader-toolbar-left, .reader-toolbar-center, .reader-toolbar-right { display: flex; align-items: center; gap: 0.75rem; }\n.reader-toolbar button { padding: 0.5rem 1rem; border: 1px solid rgba(212, 163, 115, 0.3); border-radius: 4px; background: var(--book-card-bg); color: rgb(235, 213, 192); font-family: var(--font-rounded); font-size: 0.82rem; font-weight: 600; cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 0.4rem; }\n.reader-toolbar button:hover { background: rgba(212, 163, 115, 0.15); color: white; }\n.reader-toolbar button.active { background: var(--book-accent); border-color: rgb(255, 255, 255); color: rgb(26, 18, 11); box-shadow: 2px 2px 0px var(--book-accent2); }\n.reader-toolbar select { padding: 0.45rem 0.8rem; background: var(--book-card-bg); border: 1px solid rgba(212, 163, 115, 0.3); border-radius: 4px; color: rgb(235, 213, 192); font-family: var(--font-rounded); font-size: 0.82rem; font-weight: 600; outline: none; cursor: pointer; }\n.reader-progress-bar { height: 5px; background: rgba(212, 163, 115, 0.15); position: relative; }\n.reader-progress-bar .progress-fill { height: 100%; background: linear-gradient(90deg, var(--book-accent2), var(--book-accent)); transition: width 0.3s; }\n.reader-content { flex: 1 1 0%; overflow-y: auto; padding: 3rem 5rem; line-height: 1.9; font-family: var(--font-serif); color: rgb(235, 213, 192); font-size: 19px; position: relative; }\n.reader-content.light { background: rgb(251, 249, 244); color: rgb(43, 43, 43); }\n.reader-content.dark { background: rgb(18, 13, 9); color: rgb(227, 212, 197); }\n.reader-content.sepia { background: rgb(244, 236, 216); color: rgb(91, 70, 54); }\n.reader-content pre { white-space: pre-wrap; font-family: inherit; padding: 0px; max-width: 760px; margin: 0px auto; font-size: inherit; }\n.reader-content .reader-text { max-width: 760px; margin: 0px auto; white-space: pre-wrap; overflow-wrap: break-word; font-size: inherit; line-height: inherit; }\n.reader-content .highlighted { background-color: rgba(212, 163, 115, 0.35); border-bottom: 2px dashed var(--book-accent); cursor: pointer; }\n.reader-content .highlighted:hover { background-color: rgba(212, 163, 115, 0.5); }\n.reader-footer { padding: 0.6rem 1.5rem; background: var(--book-sidebar-bg); border-top: 1px solid rgba(212, 163, 115, 0.25); display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; font-family: var(--font-rounded); color: rgba(235, 213, 192, 0.6); z-index: 20; }\n.bookmarks-panel, .highlights-panel { position: fixed; top: 0px; right: 0px; width: 340px; height: 100vh; background: rgb(30, 21, 15); border-left: 3px solid var(--book-accent); padding: 2rem 1.5rem; overflow-y: auto; z-index: 30; transform: translateX(100%); transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); box-shadow: rgba(0, 0, 0, 0.6) -10px 0px 30px; }\n.bookmarks-panel.open, .highlights-panel.open { transform: translateX(0px); }\n.bookmarks-panel h3, .highlights-panel h3 { font-family: var(--font-serif); font-size: 1.25rem; margin: 0px 0px 1.5rem; color: var(--book-accent); border-bottom: 2px dashed rgba(212, 163, 115, 0.3); padding-bottom: 0.5rem; }\n.bookmark-item { padding: 0.75rem 0.5rem; border-bottom: 1px dashed rgba(212, 163, 115, 0.2); display: flex; justify-content: space-between; align-items: center; }\n.bookmark-item span { font-family: var(--font-serif); font-style: italic; font-size: 0.95rem; color: rgb(235, 213, 192); cursor: pointer; }\n.bookmark-item span:hover { color: var(--book-accent); }\n.bookmark-item button { background: none; border: none; color: rgb(255, 82, 82); cursor: pointer; font-size: 0.9rem; }\n.bookmark-item button:hover { transform: scale(1.1); }\n.highlight-item { padding: 1rem; margin-bottom: 0.75rem; border-radius: 4px; background: var(--book-card-bg); border-top: 1px solid rgba(212, 163, 115, 0.2); border-right: 1px solid rgba(212, 163, 115, 0.2); border-bottom: 1px solid rgba(212, 163, 115, 0.2); border-image: initial; border-left: 4px solid var(--book-accent); cursor: pointer; transition: 0.2s; }\n.highlight-item:hover { border-color: var(--book-accent); transform: translateX(-4px); }\n.highlight-item p { font-family: var(--font-serif); font-size: 0.9rem; color: rgb(235, 213, 192); margin: 0px 0px 0.5rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }\n.highlight-item .highlight-note { font-size: 0.78rem; color: var(--book-accent); font-style: italic; }\n.highlight-item .highlight-actions { display: flex; gap: 0.75rem; margin-top: 0.5rem; border-top: 1px solid rgba(212, 163, 115, 0.1); padding-top: 0.5rem; }\n.highlight-item .highlight-actions button { background: none; border: none; color: rgba(235, 213, 192, 0.5); cursor: pointer; font-size: 0.75rem; font-family: var(--font-rounded); }\n.highlight-item .highlight-actions button:hover { color: rgb(255, 255, 255); }\n@media (max-width: 768px) {\n.book-sidebar { width: 100%; height: auto; position: static; flex-flow: wrap; padding: 0.5rem; gap: 0.25rem; border-right: none; border-bottom: 2px solid rgba(212, 163, 115, 0.2); }\n.book-sidebar .sidebar-brand { display: none; }\n.book-sidebar .sidebar-nav { flex-flow: wrap; padding: 0px; }\n.book-sidebar .sidebar-nav-btn { padding: 0.4rem 0.6rem; font-size: 0.85rem; width: auto; border-radius: 4px; }\n.book-content, .book-detail { padding: 1rem; max-height: none; }\n.book-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 1rem; }\n.book-detail-header { flex-direction: column; align-items: center; gap: 1rem; }\n.book-detail-cover { width: 160px; }\n.reader-content { padding: 1.5rem 1.5rem 4rem; font-size: 17px; }\n.bookmarks-panel, .highlights-panel { width: 100%; }\n}\n:root { --cbkh-bg: #07090e; --cbkh-grid-color: rgba(0, 240, 255, 0.03); --cbkh-accent-cyan: #00f0ff; --cbkh-accent-purple: #bd00ff; --cbkh-accent-green: #39ff14; --cbkh-accent-amber: #ffaa00; --cbkh-border: rgba(0, 240, 255, 0.15); --cbkh-border-glow: rgba(0, 240, 255, 0.3); --cbkh-text: #d8e4f0; --cbkh-text-dim: #708090; --cbkh-card-bg: rgba(10, 15, 26, 0.75); --cbkh-hover: rgba(0, 240, 255, 0.08); }\n.cbkh { display: flex; height: 100vh; background-image: radial-gradient(circle, rgba(189, 0, 255, 0.08) 0%, transparent 60%), radial-gradient(circle at 10% 20%, rgba(0, 240, 255, 0.06) 0%, transparent 40%), linear-gradient(rgb(7, 9, 14), rgb(10, 13, 22)); background-position-x: initial, initial, initial; background-position-y: initial, initial, initial; background-size: initial, initial, initial; background-repeat: initial, initial, initial; background-attachment: initial, initial, initial; background-origin: initial, initial, initial; background-clip: initial, initial, initial; background-color: var(--cbkh-bg); color: var(--cbkh-text); overflow: hidden; position: relative; font-family: \"Fira Code\", Consolas, Monaco, monospace !important; }\n.cbkh::before { content: \"\"; position: absolute; inset: 0px; background-image: linear-gradient(to right, var(--cbkh-grid-color) 1px, transparent 1px),\n    linear-gradient(to bottom, var(--cbkh-grid-color) 1px, transparent 1px); background-size: 24px 24px; pointer-events: none; z-index: 1; }\n.cbkh-ai { display: flex; flex-direction: column; height: 100%; width: 100%; position: relative; z-index: 2; }\n.cbkh-header { display: flex; align-items: center; justify-content: space-between; padding: 0.85rem 1.5rem; border-bottom: 1px dashed var(--cbkh-border); flex-shrink: 0; background: rgba(7, 9, 14, 0.8); backdrop-filter: blur(12px); box-shadow: rgba(0, 0, 0, 0.5) 0px 4px 30px; }\n.cbkh-header-left { display: flex; align-items: center; gap: 1rem; }\n.cbkh-title { font-size: 1.1rem; font-weight: 700; margin: 0px; text-transform: uppercase; letter-spacing: 1.5px; color: rgb(255, 255, 255); text-shadow: rgba(0, 240, 255, 0.5) 0px 0px 10px; display: flex; align-items: center; gap: 0.5rem; }\n.cbkh-title::before { content: \"вҡЎ\"; color: var(--cbkh-accent-cyan); animation: 2s ease 0s infinite alternate none running cbkh-flicker; }\n@keyframes cbkh-flicker {\n0%, 100% { opacity: 1; }\n50% { opacity: 0.4; }\n}\n.cbkh-clear-btn { background: transparent; border: 1px solid rgba(255, 0, 127, 0.4); color: rgb(255, 0, 127); padding: 0.4rem 0.9rem; border-radius: 4px; font-size: 0.75rem; font-family: inherit; font-weight: 600; cursor: pointer; transition: 0.2s; text-transform: uppercase; letter-spacing: 0.5px; }\n.cbkh-clear-btn:hover { background: rgba(255, 0, 127, 0.15); box-shadow: rgba(255, 0, 127, 0.3) 0px 0px 8px; text-shadow: rgba(255, 0, 127, 0.5) 0px 0px 3px; }\n.cbkh-header-actions { display: flex; align-items: center; gap: 0.75rem; }\n.cbkh-msg-count { font-size: 0.7rem; color: var(--cbkh-accent-cyan); padding: 0.15rem 0.5rem; background: rgba(0, 240, 255, 0.08); border: 1px solid rgba(0, 240, 255, 0.2); border-radius: 4px; }\n.cbkh-messages { flex: 1 1 0%; overflow-y: auto; padding: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; scroll-behavior: smooth; }\n.cbkh-msg { display: flex; gap: 0.85rem; max-width: 85%; animation: 0.3s cubic-bezier(0.16, 1, 0.3, 1) 0s 1 normal none running cbkh-fade-in; }\n@keyframes cbkh-fade-in {\n0% { opacity: 0; transform: translateY(8px); }\n100% { opacity: 1; transform: translateY(0px); }\n}\n.cbkh-msg.user { align-self: flex-end; flex-direction: row-reverse; }\n.cbkh-msg.ai { align-self: flex-start; }\n.cbkh-msg-avatar { width: 32px; height: 32px; border-radius: 4px; overflow: hidden; flex-shrink: 0; display: flex; align-items: center; justify-content: center; background: rgba(0, 240, 255, 0.05); border: 1px solid var(--cbkh-border); font-size: 0.9rem; box-shadow: rgba(0, 240, 255, 0.1) 0px 0px 8px; }\n.cbkh-msg.user .cbkh-msg-avatar { background: rgba(189, 0, 255, 0.05); border-color: rgba(189, 0, 255, 0.3); box-shadow: rgba(189, 0, 255, 0.1) 0px 0px 8px; }\n.cbkh-msg-bubble { background: var(--cbkh-card-bg); backdrop-filter: blur(8px); border: 1px solid var(--cbkh-border); border-radius: 4px; padding: 0.75rem 1rem; position: relative; transition: 0.25s; box-shadow: rgba(0, 0, 0, 0.3) 0px 4px 20px; }\n.cbkh-msg.ai .cbkh-msg-bubble { border-left: 3px solid var(--cbkh-accent-cyan); box-shadow: rgba(0, 240, 255, 0.02) 1px 0px 10px inset; }\n.cbkh-msg.user .cbkh-msg-bubble { border-right: 3px solid var(--cbkh-accent-purple); box-shadow: rgba(189, 0, 255, 0.02) -1px 0px 10px inset; background: rgba(15, 10, 25, 0.8); }\n.cbkh-msg-author { font-size: 0.72rem; font-weight: 700; color: var(--cbkh-accent-cyan); margin-bottom: 0.35rem; text-transform: uppercase; letter-spacing: 1.2px; }\n.cbkh-msg.user .cbkh-msg-author { color: var(--cbkh-accent-purple); }\n.cbkh-msg.ai .cbkh-msg-author { color: var(--cbkh-accent-cyan); }\n.cbkh-msg-body { font-size: 0.88rem; line-height: 1.6; word-break: break-word; }\n.cbkh-msg-body strong { color: rgb(255, 255, 255); font-weight: 700; }\n.cbkh-msg-meta { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem; padding-top: 0.4rem; border-top: 1px dashed rgba(255, 255, 255, 0.05); }\n.cbkh-msg-time { font-size: 0.65rem; color: var(--cbkh-text-dim); }\n.cbkh-provider-badge { font-size: 0.58rem; font-weight: 700; text-transform: uppercase; padding: 0.1rem 0.4rem; border-radius: 2px; background: rgba(255, 255, 255, 0.04); color: var(--cbkh-text-dim); border: 1px solid rgba(255, 255, 255, 0.08); }\n.cbkh-provider-badge.nvapi { background: rgba(57, 255, 20, 0.08); color: var(--cbkh-accent-green); border-color: rgba(57, 255, 20, 0.2); }\n.cbkh-input-area { padding: 1rem 1.5rem; border-top: 1px dashed var(--cbkh-border); flex-shrink: 0; background: rgba(7, 9, 14, 0.95); backdrop-filter: blur(12px); display: flex; gap: 0.75rem; align-items: flex-end; }\n.cbkh-input { flex: 1 1 0%; background: rgba(0, 0, 0, 0.4); border: 1px solid var(--cbkh-border); border-radius: 4px; padding: 0.75rem 1rem; color: var(--cbkh-text); font-family: inherit; font-size: 0.88rem; outline: none; resize: none; box-sizing: border-box; min-height: 48px; transition: 0.2s; }\n.cbkh-input:focus { border-color: var(--cbkh-accent-cyan); box-shadow: rgba(0, 240, 255, 0.2) 0px 0px 10px; background: rgba(0, 0, 0, 0.6); }\n.cbkh-input:disabled { opacity: 0.4; cursor: not-allowed; }\n.cbkh-send-btn { padding: 0.75rem 1.5rem; background: linear-gradient(135deg, var(--cbkh-accent-cyan), var(--cbkh-accent-purple)); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 4px; color: rgb(255, 255, 255); font-family: inherit; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: 0.25s; white-space: nowrap; height: 48px; text-transform: uppercase; letter-spacing: 1px; }\n.cbkh-send-btn:disabled { opacity: 0.3; cursor: not-allowed; background: rgba(255, 255, 255, 0.05); border-color: transparent; color: var(--cbkh-text-dim); }\n.cbkh-send-btn:not(:disabled):hover { transform: translateY(-1px); box-shadow: rgba(0, 240, 255, 0.4) 0px 0px 15px; text-shadow: rgb(255, 255, 255) 0px 0px 3px; }\n.cbkh-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; gap: 0.85rem; color: var(--cbkh-text-dim); text-align: center; padding: 3rem; max-width: 600px; margin: 0px auto; }\n.cbkh-empty-icon { font-size: 3rem; animation: 4s ease-in-out 0s infinite alternate none running cbkh-float; filter: drop-shadow(rgba(0, 240, 255, 0.4) 0px 0px 12px); }\n@keyframes cbkh-float {\n0% { transform: translateY(0px); }\n100% { transform: translateY(-8px); }\n}\n.cbkh-empty h2 { font-size: 1.15rem; color: rgb(255, 255, 255); letter-spacing: 1px; text-transform: uppercase; }\n.cbkh-empty-hint { font-size: 0.75rem; color: var(--cbkh-text-dim); border: 1px dashed rgba(255, 255, 255, 0.08); padding: 0.6rem 1rem; border-radius: 4px; background: rgba(0, 0, 0, 0.2); }\n.cbkh-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3rem 0px; gap: 0.75rem; }\n.cbkh-spinner { width: 28px; height: 28px; border-right: 2px solid rgba(0, 240, 255, 0.1); border-bottom: 2px solid rgba(0, 240, 255, 0.1); border-left: 2px solid rgba(0, 240, 255, 0.1); border-image: initial; border-top: 2px solid var(--cbkh-accent-cyan); border-radius: 50%; animation: 0.8s linear 0s infinite normal none running cbkh-spin; box-shadow: rgba(0, 240, 255, 0.2) 0px 0px 8px; }\n@keyframes cbkh-spin {\n100% { transform: rotate(360deg); }\n}\n.cbkh-typing { display: flex; gap: 0.35rem; padding: 0.4rem 0.2rem; align-items: center; }\n.cbkh-dot { width: 6px; height: 6px; background: var(--cbkh-accent-cyan); border-radius: 50%; animation: 1.2s ease 0s infinite normal none running cbkh-bounce; box-shadow: 0 0 5px var(--cbkh-accent-cyan); }\n.cbkh-dot:nth-child(2) { animation-delay: 0.2s; background: var(--cbkh-accent-purple); box-shadow: 0 0 5px var(--cbkh-accent-purple); }\n.cbkh-dot:nth-child(3) { animation-delay: 0.4s; background: var(--cbkh-accent-green); box-shadow: 0 0 5px var(--cbkh-accent-green); }\n@keyframes cbkh-bounce {\n0%, 80%, 100% { transform: scale(0.7); opacity: 0.4; }\n40% { transform: scale(1.1); opacity: 1; }\n}\n.cbkh-code-block { background: rgba(0, 0, 0, 0.5); border: 1px solid var(--cbkh-border); border-radius: 4px; margin: 0.75rem 0px; overflow: hidden; box-shadow: rgba(0, 0, 0, 0.4) 0px 4px 12px; }\n.cbkh-code-lang { display: block; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.2px; color: var(--cbkh-accent-cyan); padding: 0.3rem 0.75rem; background: rgba(0, 240, 255, 0.03); border-bottom: 1px solid var(--cbkh-border); font-family: inherit; font-weight: 700; }\n.cbkh-code-block pre { margin: 0px; padding: 0.85rem; overflow-x: auto; }\n.cbkh-code-block code { font-size: 0.8rem; line-height: 1.5; color: rgb(226, 232, 240); font-family: \"Fira Code\", Consolas, Monaco, monospace !important; }\n.cbkh-inline-code { background: rgba(0, 240, 255, 0.08); color: var(--cbkh-accent-cyan); padding: 0.15rem 0.35rem; border-radius: 2px; border: 1px solid rgba(0, 240, 255, 0.15); font-family: inherit; font-size: 0.82rem; }\n.cbkh-nvidia-toolbar { display: flex; gap: 0.5rem; padding: 0.5rem 1.5rem; border-top: 1px dashed var(--cbkh-border); background: rgba(7, 9, 14, 0.7); flex-shrink: 0; overflow-x: auto; }\n.cbkh-nvidia-tools { display: flex; gap: 0.5rem; }\n.cbkh-task-btn { padding: 0.4rem 0.8rem; background: rgba(0, 0, 0, 0.3); border: 1px solid var(--cbkh-border); border-radius: 4px; color: var(--cbkh-text-dim); font-family: inherit; font-size: 0.75rem; cursor: pointer; transition: 0.2s; white-space: nowrap; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; }\n.cbkh-task-btn:hover:not(:disabled) { background: rgba(57, 255, 20, 0.05); border-color: var(--cbkh-accent-green); color: var(--cbkh-accent-green); box-shadow: rgba(57, 255, 20, 0.2) 0px 0px 8px; }\n.cbkh-task-btn:disabled { opacity: 0.3; cursor: not-allowed; }\n.cbkh-toggle-label { display: flex; align-items: center; gap: 0.4rem; font-size: 0.72rem; color: var(--cbkh-text-dim); cursor: pointer; padding: 0.3rem 0.65rem; border-radius: 4px; border: 1px solid var(--cbkh-border); user-select: none; background: rgba(0, 0, 0, 0.2); transition: 0.2s; text-transform: uppercase; }\n.cbkh-toggle-label input { accent-color: var(--cbkh-accent-cyan); cursor: pointer; }\n.cbkh-toggle-label:hover { background: var(--cbkh-hover); border-color: var(--cbkh-accent-cyan); color: rgb(255, 255, 255); }\n.cbkh-provider-select { background: rgba(0, 0, 0, 0.4); border: 1px solid var(--cbkh-border); border-radius: 4px; color: var(--cbkh-text); font-family: inherit; font-size: 0.75rem; padding: 0.3rem 0.6rem; cursor: pointer; outline: none; transition: 0.2s; }\n.cbkh-provider-select:hover, .cbkh-provider-select:focus { border-color: var(--cbkh-accent-cyan); box-shadow: rgba(0, 240, 255, 0.2) 0px 0px 5px; }\n.cbkh-provider-select option { background: rgb(7, 9, 14); color: var(--cbkh-text); }\n.cbkh-messages::-webkit-scrollbar { width: 6px; }\n.cbkh-messages::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.2); }\n.cbkh-messages::-webkit-scrollbar-thumb { background: var(--cbkh-border); border-radius: 3px; }\n.cbkh-messages::-webkit-scrollbar-thumb:hover { background: var(--cbkh-accent-cyan); }\n@media (max-width: 768px) {\n.cbkh-messages { padding: 1rem; gap: 1rem; }\n.cbkh-msg { max-width: 92%; }\n.cbkh-header { padding: 0.75rem 1rem; }\n.cbkh-input-area { padding: 0.75rem 1rem; }\n}\n:root { --ghchat-bg: #07090e; --ghchat-sidebar-bg: rgba(7, 9, 14, 0.95); --ghchat-grid-color: rgba(0, 240, 255, 0.03); --ghchat-accent: #00f0ff; --ghchat-accent-purple: #bd00ff; --ghchat-accent-green: #39ff14; --ghchat-accent-amber: #ffaa00; --ghchat-border: rgba(0, 240, 255, 0.15); --ghchat-text: #d8e4f0; --ghchat-text-dim: #708090; --ghchat-card-bg: rgba(10, 15, 26, 0.75); --ghchat-hover: rgba(0, 240, 255, 0.08); --ghchat-sidebar-width: 260px; }\n.ghchat { display: flex; height: 100vh; background-image: radial-gradient(circle, rgba(189, 0, 255, 0.08) 0%, transparent 60%), radial-gradient(circle at 10% 20%, rgba(0, 240, 255, 0.06) 0%, transparent 40%), linear-gradient(rgb(7, 9, 14), rgb(10, 13, 22)); background-position-x: initial, initial, initial; background-position-y: initial, initial, initial; background-size: initial, initial, initial; background-repeat: initial, initial, initial; background-attachment: initial, initial, initial; background-origin: initial, initial, initial; background-clip: initial, initial, initial; background-color: var(--ghchat-bg); color: var(--ghchat-text); overflow: hidden; position: relative; font-family: \"Fira Code\", Consolas, Monaco, monospace !important; }\n.ghchat::before { content: \"\"; position: absolute; inset: 0px; background-image: linear-gradient(to right, var(--ghchat-grid-color) 1px, transparent 1px),\n    linear-gradient(to bottom, var(--ghchat-grid-color) 1px, transparent 1px); background-size: 24px 24px; pointer-events: none; z-index: 1; }\n.ghchat-sidebar { width: var(--ghchat-sidebar-width); flex-shrink: 0; background: var(--ghchat-sidebar-bg); border-right: 1px dashed var(--ghchat-border); display: flex; flex-direction: column; padding: 0px; overflow-y: auto; z-index: 2; position: relative; }\n.ghchat-brand { display: flex; align-items: center; gap: 0.6rem; padding: 1.2rem 1.25rem; border-bottom: 1px dashed var(--ghchat-border); }\n.ghchat-brand-icon { font-size: 1.3rem; filter: drop-shadow(0 0 5px var(--ghchat-accent)); }\n.ghchat-brand h2 { font-size: 1rem; font-weight: 700; margin: 0px; text-transform: uppercase; letter-spacing: 1px; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; }\n.ghchat-repo-input { padding: 0.75rem 1rem; }\n.ghchat-repo-input input { width: 100%; padding: 0.55rem 0.75rem; background: rgba(0, 0, 0, 0.4); border: 1px solid var(--ghchat-border); border-radius: 4px; color: var(--ghchat-text); font-size: 0.8rem; font-family: inherit; outline: none; box-sizing: border-box; transition: 0.2s; }\n.ghchat-repo-input input:focus { border-color: var(--ghchat-accent); box-shadow: rgba(0, 240, 255, 0.2) 0px 0px 8px; }\n.ghchat-nav { display: flex; flex-direction: column; gap: 0.15rem; padding: 0.25rem 0.5rem; }\n.ghchat-nav-btn { display: flex; align-items: center; gap: 0.6rem; padding: 0.6rem 0.75rem; border: 1px solid transparent; background: transparent; color: var(--ghchat-text-dim); font-size: 0.82rem; font-weight: 600; font-family: inherit; cursor: pointer; border-radius: 4px; transition: 0.2s; text-align: left; width: 100%; }\n.ghchat-nav-btn:hover { background: var(--ghchat-hover); color: rgb(255, 255, 255); border-color: rgba(0, 240, 255, 0.1); }\n.ghchat-nav-btn.active { background: rgba(0, 240, 255, 0.08); color: var(--ghchat-accent); border-color: var(--ghchat-border); box-shadow: rgba(0, 240, 255, 0.1) 0px 0px 10px; }\n.ghchat-nav-btn.small { font-size: 0.75rem; padding: 0.4rem 0.6rem; }\n.ghchat-divider { height: 1px; background: var(--ghchat-border); border-bottom: 1px dashed rgba(0, 240, 255, 0.1); margin: 0.5rem 1rem; }\n.ghchat-section-label { padding: 0.25rem 1rem; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.2px; color: var(--ghchat-text-dim); font-weight: 700; }\n.ghchat-empty-hint { padding: 0.4rem 1rem; font-size: 0.72rem; color: var(--ghchat-text-dim); opacity: 0.5; }\n.ghchat-content { flex: 1 1 0%; display: flex; flex-direction: column; overflow: hidden; z-index: 2; position: relative; }\n.ghchat-header { display: flex; align-items: center; justify-content: space-between; padding: 0.85rem 1.5rem; border-bottom: 1px dashed var(--ghchat-border); flex-shrink: 0; background: rgba(7, 9, 14, 0.8); backdrop-filter: blur(12px); box-shadow: rgba(0, 0, 0, 0.4) 0px 4px 30px; }\n.ghchat-header-left { display: flex; align-items: center; gap: 0.75rem; }\n.ghchat-title { font-size: 1.05rem; font-weight: 700; margin: 0px; display: flex; align-items: center; gap: 0.5rem; text-transform: uppercase; letter-spacing: 1px; }\n.ghchat-subtitle { font-size: 0.75rem; color: var(--ghchat-text-dim); }\n.ghchat-repo-badge { font-size: 0.7rem; font-weight: 700; background: rgba(0, 240, 255, 0.08); color: var(--ghchat-accent); padding: 0.15rem 0.5rem; border-radius: 4px; border: 1px solid rgba(0, 240, 255, 0.2); }\n.ghchat-refresh-btn { background: transparent; border: 1px solid var(--ghchat-border); color: var(--ghchat-text-dim); width: 28px; height: 28px; border-radius: 4px; cursor: pointer; font-size: 0.95rem; display: flex; align-items: center; justify-content: center; transition: 0.2s; }\n.ghchat-refresh-btn:hover { background: var(--ghchat-hover); color: rgb(255, 255, 255); border-color: var(--ghchat-accent); }\n.ghchat-tabs { display: flex; gap: 0.35rem; }\n.ghchat-tab { padding: 0.4rem 0.8rem; border: 1px solid var(--ghchat-border); background: transparent; color: var(--ghchat-text-dim); font-family: inherit; font-size: 0.75rem; font-weight: 600; cursor: pointer; border-radius: 4px; transition: 0.2s; text-transform: uppercase; }\n.ghchat-tab.active { background: rgba(0, 240, 255, 0.08); border-color: var(--ghchat-accent); color: var(--ghchat-accent); box-shadow: rgba(0, 240, 255, 0.1) 0px 0px 8px; }\n.ghchat-tab:hover { background: var(--ghchat-hover); color: rgb(255, 255, 255); }\n.ghchat-body { display: flex; flex: 1 1 0%; overflow: hidden; }\n.ghchat-thread-list { width: 300px; flex-shrink: 0; border-right: 1px dashed var(--ghchat-border); overflow-y: auto; padding: 0.75rem; background: rgba(7, 9, 14, 0.3); }\n.ghchat-thread-card { padding: 0.75rem; border-radius: 4px; cursor: pointer; transition: 0.2s; margin-bottom: 0.5rem; border: 1px solid rgba(255, 255, 255, 0.04); background: rgba(0, 0, 0, 0.2); }\n.ghchat-thread-card:hover { background: var(--ghchat-hover); border-color: rgba(0, 240, 255, 0.15); }\n.ghchat-thread-card.active { background: rgba(0, 240, 255, 0.06); border-color: var(--ghchat-accent); box-shadow: rgba(0, 240, 255, 0.05) 0px 0px 10px; }\n.ghchat-thread-header { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.35rem; }\n.ghchat-thread-icon { font-size: 0.85rem; }\n.ghchat-thread-state { font-size: 0.55rem; text-transform: uppercase; padding: 0.1rem 0.35rem; border-radius: 2px; font-weight: 700; letter-spacing: 0.5px; }\n.ghchat-thread-state[data-state=\"open\"] { background: rgba(57, 255, 20, 0.1); color: var(--ghchat-accent-green); border: 1px solid rgba(57, 255, 20, 0.2); }\n.ghchat-thread-state[data-state=\"closed\"] { background: rgba(255, 0, 127, 0.1); color: rgb(255, 0, 127); border: 1px solid rgba(255, 0, 127, 0.2); }\n.ghchat-pin-badge, .ghchat-fav-badge { font-size: 0.65rem; margin-left: auto; }\n.ghchat-thread-title { font-size: 0.8rem; font-weight: 700; margin-bottom: 0.4rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; color: rgb(255, 255, 255); line-height: 1.4; }\n.ghchat-thread-meta { display: flex; align-items: center; gap: 0.5rem; font-size: 0.68rem; color: var(--ghchat-text-dim); }\n.ghchat-thread-actions { margin-left: auto; display: flex; gap: 0.25rem; }\n.ghchat-icon-btn { background: transparent; border: none; cursor: pointer; font-size: 0.72rem; padding: 0.1rem; opacity: 0.4; transition: opacity 0.2s, transform 0.2s; }\n.ghchat-icon-btn:hover { opacity: 1; transform: scale(1.15); }\n.ghchat-chat { flex: 1 1 0%; display: flex; flex-direction: column; overflow: hidden; }\n.ghchat-thread-detail-header { display: flex; align-items: center; gap: 0.75rem; padding: 0.85rem 1.5rem; border-bottom: 1px dashed var(--ghchat-border); flex-shrink: 0; background: rgba(7, 9, 14, 0.4); }\n.ghchat-thread-detail-header h2 { font-size: 0.95rem; font-weight: 700; margin: 0px; color: rgb(255, 255, 255); }\n.ghchat-messages { flex: 1 1 0%; overflow-y: auto; padding: 1.5rem; }\n.ghchat-msg { display: flex; gap: 0.85rem; margin-bottom: 1.25rem; max-width: 85%; animation: 0.3s cubic-bezier(0.16, 1, 0.3, 1) 0s 1 normal none running ghchat-fade-in; }\n@keyframes ghchat-fade-in {\n0% { opacity: 0; transform: translateY(8px); }\n100% { opacity: 1; transform: translateY(0px); }\n}\n.ghchat-msg.user { align-self: flex-end; flex-direction: row-reverse; margin-left: auto; }\n.ghchat-msg-avatar { width: 32px; height: 32px; border-radius: 4px; overflow: hidden; flex-shrink: 0; display: flex; align-items: center; justify-content: center; background: rgba(255, 255, 255, 0.05); border: 1px solid var(--ghchat-border); font-size: 0.85rem; font-weight: 700; box-shadow: rgba(0, 240, 255, 0.1) 0px 0px 8px; }\n.ghchat-msg-avatar img { width: 100%; height: 100%; object-fit: cover; }\n.ghchat-msg-bubble { background: var(--ghchat-card-bg); border: 1px solid var(--ghchat-border); border-radius: 4px; padding: 0.75rem 1rem; box-shadow: rgba(0, 0, 0, 0.3) 0px 4px 20px; }\n.ghchat-msg.ai .ghchat-msg-bubble { border-left: 3px solid var(--ghchat-accent-cyan); background: rgba(10, 18, 20, 0.85); }\n.ghchat-msg.user .ghchat-msg-bubble { border-right: 3px solid var(--ghchat-accent-purple); background: rgba(15, 10, 25, 0.85); }\n.ghchat-msg-author { font-size: 0.72rem; font-weight: 700; color: var(--ghchat-accent); margin-bottom: 0.3rem; text-transform: uppercase; letter-spacing: 1px; }\n.ghchat-msg.user .ghchat-msg-author { color: var(--ghchat-accent-purple); }\n.ghchat-msg.ai .ghchat-msg-author { color: var(--ghchat-accent-green); }\n.ghchat-msg-body { font-size: 0.88rem; line-height: 1.6; word-break: break-word; }\n.ghchat-msg-body code { background: rgba(255, 255, 255, 0.06); padding: 0.15rem 0.35rem; border-radius: 2px; font-size: 0.82rem; border: 1px solid rgba(255, 255, 255, 0.08); }\n.ghchat-msg-body pre { background: rgba(0, 0, 0, 0.5); padding: 0.85rem; border-radius: 4px; overflow-x: auto; margin: 0.75rem 0px; border: 1px solid var(--ghchat-border); }\n.ghchat-msg-body pre code { background: none; padding: 0px; border: none; font-family: inherit; }\n.ghchat-msg-body a { color: var(--ghchat-accent); text-decoration: underline; }\n.ghchat-msg-time { font-size: 0.65rem; color: var(--ghchat-text-dim); margin-top: 0.5rem; padding-top: 0.4rem; border-top: 1px dashed rgba(255, 255, 255, 0.05); }\n.ghchat-input-area { padding: 1rem 1.5rem; border-top: 1px dashed var(--ghchat-border); flex-shrink: 0; background: rgba(7, 9, 14, 0.95); backdrop-filter: blur(12px); }\n.ghchat-input { width: 100%; background: rgba(0, 0, 0, 0.4); border: 1px solid var(--ghchat-border); border-radius: 4px; padding: 0.75rem 1rem; color: var(--ghchat-text); font-family: inherit; font-size: 0.88rem; outline: none; resize: none; box-sizing: border-box; transition: 0.2s; }\n.ghchat-input:focus { border-color: var(--ghchat-accent); box-shadow: rgba(0, 240, 255, 0.2) 0px 0px 10px; background: rgba(0, 0, 0, 0.6); }\n.ghchat-input-actions { display: flex; align-items: center; gap: 0.75rem; margin-top: 0.75rem; }\n.ghchat-gist-btn { background: transparent; border: 1px solid var(--ghchat-border); color: var(--ghchat-text-dim); padding: 0.45rem 1rem; border-radius: 4px; font-size: 0.75rem; cursor: pointer; transition: 0.2s; font-family: inherit; font-weight: 600; text-transform: uppercase; }\n.ghchat-gist-btn:hover { background: var(--ghchat-hover); color: rgb(255, 255, 255); border-color: var(--ghchat-accent); }\n.ghchat-hint { font-size: 0.68rem; color: var(--ghchat-text-dim); opacity: 0.5; flex: 1 1 0%; }\n.ghchat-send-btn { padding: 0.55rem 1.5rem; background: linear-gradient(135deg, var(--ghchat-accent), var(--ghchat-accent-purple)); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 4px; color: white; font-family: inherit; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: 0.25s; text-transform: uppercase; letter-spacing: 1px; }\n.ghchat-send-btn:disabled { opacity: 0.3; cursor: not-allowed; background: rgba(255, 255, 255, 0.05); border-color: transparent; color: var(--ghchat-text-dim); }\n.ghchat-send-btn:not(:disabled):hover { transform: translateY(-1px); box-shadow: rgba(0, 240, 255, 0.4) 0px 0px 15px; text-shadow: rgb(255, 255, 255) 0px 0px 3px; }\n.ghchat-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; gap: 0.75rem; color: var(--ghchat-text-dim); }\n.ghchat-empty-icon { font-size: 3rem; opacity: 0.3; filter: drop-shadow(rgba(0, 240, 255, 0.2) 0px 0px 10px); animation: 4s ease-in-out 0s infinite alternate none running ghchat-float; }\n@keyframes ghchat-float {\n0% { transform: translateY(0px); }\n100% { transform: translateY(-8px); }\n}\n.ghchat-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3rem 0px; gap: 0.75rem; }\n.ghchat-spinner { width: 28px; height: 28px; border-right: 2px solid rgba(0, 240, 255, 0.1); border-bottom: 2px solid rgba(0, 240, 255, 0.1); border-left: 2px solid rgba(0, 240, 255, 0.1); border-image: initial; border-top: 2px solid var(--ghchat-accent); border-radius: 50%; animation: 0.8s linear 0s infinite normal none running ghchat-spin; box-shadow: rgba(0, 240, 255, 0.2) 0px 0px 8px; }\n@keyframes ghchat-spin {\n100% { transform: rotate(360deg); }\n}\n.ghchat-typing { display: flex; gap: 0.3rem; padding: 0.3rem 0px; }\n.ghchat-dot { width: 6px; height: 6px; background: var(--ghchat-accent); border-radius: 50%; animation: 1.2s ease 0s infinite normal none running ghchat-bounce; box-shadow: 0 0 5px var(--ghchat-accent); }\n.ghchat-dot:nth-child(2) { animation-delay: 0.2s; background: var(--ghchat-accent-purple); box-shadow: 0 0 5px var(--ghchat-accent-purple); }\n.ghchat-dot:nth-child(3) { animation-delay: 0.4s; background: var(--ghchat-accent-green); box-shadow: 0 0 5px var(--ghchat-accent-green); }\n@keyframes ghchat-bounce {\n0%, 80%, 100% { transform: scale(0.7); opacity: 0.4; }\n40% { transform: scale(1.1); opacity: 1; }\n}\n.ghchat-ai-inline { padding: 0.75rem 0px; border-top: 1px dashed var(--ghchat-border); margin-top: 0.75rem; }\n.ghchat-ai-inline-input { display: flex; gap: 0.5rem; }\n.ghchat-ai-inline-input input { flex: 1 1 0%; padding: 0.55rem 0.75rem; background: rgba(0, 0, 0, 0.4); border: 1px solid var(--ghchat-border); border-radius: 4px; color: var(--ghchat-text); font-family: inherit; font-size: 0.82rem; outline: none; }\n.ghchat-ai-inline-input button { padding: 0.5rem 1rem; background: rgba(57, 255, 20, 0.1); border: 1px solid var(--ghchat-accent-green); border-radius: 4px; color: var(--ghchat-accent-green); font-family: inherit; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: 0.2s; text-transform: uppercase; }\n.ghchat-ai-inline-input button:hover { background: rgba(57, 255, 20, 0.2); box-shadow: rgba(57, 255, 20, 0.2) 0px 0px 8px; }\n.ghchat-ai { display: flex; flex-direction: column; height: 100%; }\n.ghchat-modal-overlay { position: fixed; inset: 0px; background: rgba(0, 0, 0, 0.85); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 1000; }\n.ghchat-modal { background: rgb(7, 9, 14); border: 1px solid var(--ghchat-border); border-radius: 4px; padding: 1.5rem; width: 90%; max-width: 560px; max-height: 80vh; overflow-y: auto; box-shadow: rgba(0, 240, 255, 0.2) 0px 0px 30px; }\n.ghchat-modal h3 { margin: 0px 0px 1rem; font-size: 1.1rem; text-transform: uppercase; color: rgb(255, 255, 255); letter-spacing: 1px; }\n.ghchat-modal-input { width: 100%; padding: 0.55rem 0.75rem; background: rgba(0, 0, 0, 0.4); border: 1px solid var(--ghchat-border); border-radius: 4px; color: var(--ghchat-text); font-family: inherit; font-size: 0.82rem; outline: none; margin-bottom: 0.75rem; box-sizing: border-box; }\n.ghchat-modal-input:focus { border-color: var(--ghchat-accent); }\n.ghchat-gist-file { margin-bottom: 0.75rem; }\n.ghchat-gist-file textarea { width: 100%; padding: 0.55rem 0.75rem; background: rgba(0, 0, 0, 0.5); border: 1px solid var(--ghchat-border); border-radius: 4px; color: var(--ghchat-text); font-family: \"Fira Code\", Consolas, monospace; font-size: 0.8rem; outline: none; resize: vertical; box-sizing: border-box; }\n.ghchat-gist-file textarea:focus { border-color: var(--ghchat-accent); }\n.ghchat-modal-remove { background: transparent; border: none; color: rgb(255, 0, 127); font-size: 0.75rem; cursor: pointer; padding: 0.25rem 0px; font-family: inherit; font-weight: 600; text-transform: uppercase; }\n.ghchat-modal-actions { display: flex; align-items: center; justify-content: space-between; margin-top: 1rem; gap: 0.5rem; }\n.ghchat-modal-btn { padding: 0.55rem 1.25rem; border: 1px solid var(--ghchat-border); background: transparent; color: var(--ghchat-text); border-radius: 4px; font-family: inherit; font-size: 0.78rem; cursor: pointer; transition: 0.2s; text-transform: uppercase; font-weight: 600; }\n.ghchat-modal-btn:hover { background: var(--ghchat-hover); color: rgb(255, 255, 255); }\n.ghchat-modal-btn.primary { background: linear-gradient(135deg, var(--ghchat-accent), var(--ghchat-accent-purple)); border: 1px solid rgba(255, 255, 255, 0.15); color: white; margin-left: 0.5rem; }\n.ghchat-modal-btn.primary:disabled { opacity: 0.3; cursor: not-allowed; }\n.ghchat-messages::-webkit-scrollbar, .ghchat-thread-list::-webkit-scrollbar { width: 6px; }\n.ghchat-messages::-webkit-scrollbar-track, .ghchat-thread-list::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.2); }\n.ghchat-messages::-webkit-scrollbar-thumb, .ghchat-thread-list::-webkit-scrollbar-thumb { background: var(--ghchat-border); border-radius: 3px; }\n.ghchat-messages::-webkit-scrollbar-thumb:hover, .ghchat-thread-list::-webkit-scrollbar-thumb:hover { background: var(--ghchat-accent); }\n@media (max-width: 768px) {\n.ghchat-sidebar { width: 100%; height: auto; max-height: 40vh; border-right: none; border-bottom: 1px dashed var(--ghchat-border); }\n.ghchat-body { flex-direction: column; }\n.ghchat-thread-list { width: 100%; max-height: 180px; border-right: none; border-bottom: 1px dashed var(--ghchat-border); }\n.ghchat-header { flex-direction: column; gap: 0.6rem; padding: 0.75rem 1rem; align-items: stretch; }\n.ghchat-header-left { justify-content: space-between; }\n.ghchat-tabs { justify-content: flex-end; }\n.ghchat-msg { max-width: 92%; }\n}\n.movie-hub-container { display: flex; min-height: 100vh; background-color: rgb(8, 8, 10); color: rgb(245, 245, 247); font-family: Outfit, Inter, sans-serif; overflow: hidden; }\n.movie-sub-sidebar { width: 280px; background: rgba(15, 15, 20, 0.85); backdrop-filter: blur(20px); border-right: 1px solid rgba(255, 255, 255, 0.08); padding: 2.5rem 1.5rem; display: flex; flex-direction: column; gap: 2.5rem; z-index: 10; flex-shrink: 0; }\n.sidebar-brand-container { display: flex; align-items: center; gap: 0.75rem; }\n.brand-logo { font-size: 2.2rem; filter: drop-shadow(rgba(229, 9, 20, 0.4) 0px 0px 10px); }\n.brand-title { font-size: 1.4rem; font-weight: 800; letter-spacing: -0.5px; background: linear-gradient(135deg, rgb(255, 255, 255) 30%, rgb(229, 169, 59) 100%) text; -webkit-text-fill-color: transparent; }\n.sidebar-navigation-items { display: flex; flex-direction: column; gap: 0.75rem; }\n.sub-sidebar-nav-btn { display: flex; align-items: center; gap: 1rem; width: 100%; padding: 0.9rem 1.2rem; background: transparent; border: 1px solid transparent; border-radius: 12px; color: rgb(160, 160, 171); font-size: 0.95rem; font-weight: 600; text-align: left; cursor: pointer; transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); }\n.sub-sidebar-nav-btn:hover { color: rgb(255, 255, 255); background: rgba(255, 255, 255, 0.05); transform: translateX(4px); }\n.sub-sidebar-nav-btn.active { color: rgb(255, 255, 255); background: rgba(229, 9, 20, 0.15); border-color: rgba(229, 9, 20, 0.4); box-shadow: rgba(229, 9, 20, 0.2) 0px 4px 20px; }\n.sub-sidebar-nav-btn .btn-icon { font-size: 1.2rem; }\n.sidebar-filter-section { display: flex; flex-direction: column; gap: 1rem; margin-top: auto; border-top: 1px solid rgba(255, 255, 255, 0.08); padding-top: 2rem; }\n.filter-title { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1.5px; color: rgb(112, 112, 122); font-weight: 700; }\n.region-selector-block { display: flex; flex-direction: column; gap: 0.5rem; }\n.region-select-btn { display: flex; align-items: center; gap: 0.8rem; padding: 0.75rem 1rem; background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 10px; color: rgb(212, 212, 216); font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: 0.25s; }\n.region-select-btn:hover { background: rgba(255, 255, 255, 0.06); border-color: rgba(255, 255, 255, 0.15); }\n.region-select-btn.active { background: rgba(229, 169, 59, 0.15); border-color: rgba(229, 169, 59, 0.5); color: rgb(229, 169, 59); box-shadow: rgba(229, 169, 59, 0.1) 0px 0px 15px; }\n.movie-main-content { flex: 1 1 0%; padding: 2.5rem 3rem; overflow-y: auto; height: 100vh; box-sizing: border-box; }\n.movie-section-header { margin-bottom: 2.5rem; }\n.page-heading-title { font-size: 2.5rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 0.4rem; background: linear-gradient(135deg, rgb(255, 255, 255) 50%, rgb(212, 212, 216) 100%) text; -webkit-text-fill-color: transparent; }\n.page-sub-title { color: rgb(112, 112, 122); font-size: 1.05rem; }\n.movie-search-form { display: flex; gap: 1rem; padding: 0.5rem; margin-bottom: 3rem; }\n.movie-search-input { flex: 1 1 0%; background: transparent; border: none; outline: none; color: rgb(255, 255, 255); font-size: 1.1rem; padding: 0.8rem 1.2rem; font-family: inherit; }\n.movie-search-input::placeholder { color: rgb(82, 82, 91); }\n.movie-search-btn { background: rgb(229, 9, 20); color: rgb(255, 255, 255); border: none; padding: 0.8rem 2rem; border-radius: 10px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: 0.3s; box-shadow: rgba(229, 9, 20, 0.4) 0px 4px 15px; }\n.movie-search-btn:hover { background: rgb(244, 27, 39); transform: translateY(-2px); box-shadow: rgba(229, 9, 20, 0.6) 0px 6px 20px; }\n.movie-hub-section { margin-bottom: 3.5rem; }\n.section-title-line { font-size: 1.4rem; font-weight: 800; margin-bottom: 1.5rem; letter-spacing: -0.3px; border-left: 4px solid rgb(229, 9, 20); padding-left: 0.75rem; }\n.section-loading { padding: 3rem 0px; text-align: center; color: rgb(112, 112, 122); font-size: 1.1rem; }\n.movie-grid-container { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 2rem; }\n.movie-grid-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 5rem 2rem; text-align: center; background: rgba(255, 255, 255, 0.02); border: 1px dashed rgba(255, 255, 255, 0.08); border-radius: 20px; }\n.empty-movie-icon { font-size: 3.5rem; margin-bottom: 1rem; opacity: 0.5; }\n.empty-movie-text { color: rgb(112, 112, 122); font-size: 1.1rem; }\n.glass-panel { background: rgba(20, 20, 25, 0.55); border: 1px solid rgba(255, 255, 255, 0.08); backdrop-filter: blur(12px); border-radius: 16px; }\n.movie-card { cursor: pointer; transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); overflow: hidden; position: relative; display: flex; flex-direction: column; }\n.movie-card:hover { transform: translateY(-8px); border-color: rgba(229, 169, 59, 0.5); box-shadow: rgba(229, 169, 59, 0.2) 0px 12px 30px; }\n.movie-poster-container { position: relative; width: 100%; aspect-ratio: 2 / 3; overflow: hidden; background: rgb(20, 20, 25); border-radius: 12px; }\n.movie-poster { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1); }\n.movie-card:hover .movie-poster { transform: scale(1.08); }\n.no-poster { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; background: linear-gradient(135deg, rgb(20, 20, 25) 0%, rgb(30, 30, 36) 100%); }\n.no-poster-icon { font-size: 2.5rem; opacity: 0.3; }\n.movie-rating-badge { position: absolute; top: 10px; right: 10px; background: rgba(8, 8, 10, 0.85); border: 1px solid rgba(229, 169, 59, 0.4); padding: 0.4rem 0.6rem; border-radius: 8px; font-size: 0.8rem; font-weight: 700; color: rgb(229, 169, 59); display: flex; align-items: center; gap: 0.3rem; backdrop-filter: blur(4px); }\n.rating-star { color: rgb(229, 169, 59); }\n.movie-card-info { padding: 1rem 0.5rem; display: flex; flex-direction: column; gap: 0.4rem; }\n.movie-card-title { font-size: 1rem; font-weight: 700; color: rgb(255, 255, 255); line-height: 1.3; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }\n.movie-card-meta { display: flex; align-items: center; gap: 0.8rem; font-size: 0.85rem; color: rgb(112, 112, 122); }\n.movie-card-genres { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.2rem; }\n.movie-genre-tag { font-size: 0.75rem; background: rgba(255, 255, 255, 0.05); padding: 0.2rem 0.5rem; border-radius: 6px; color: rgb(212, 212, 216); }\n.watchlist-categories-container { display: flex; flex-direction: column; gap: 2.5rem; }\n.watchlist-category-section { display: flex; flex-direction: column; gap: 1.2rem; }\n.watchlist-status-title { font-size: 1.25rem; font-weight: 800; color: rgb(229, 169, 59); border-bottom: 1px solid rgba(255, 255, 255, 0.08); padding-bottom: 0.5rem; }\n.watchlist-cards-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }\n.watchlist-row-card { display: flex; gap: 1rem; padding: 0.8rem; cursor: pointer; transition: 0.3s; align-items: center; }\n.watchlist-row-card:hover { transform: translateY(-4px); border-color: rgba(229, 9, 20, 0.4); box-shadow: rgba(229, 9, 20, 0.15) 0px 8px 25px; }\n.watchlist-poster-img { width: 70px; aspect-ratio: 2 / 3; object-fit: cover; border-radius: 8px; background: rgb(20, 20, 25); }\n.watchlist-card-details { flex: 1 1 0%; display: flex; flex-direction: column; gap: 0.5rem; }\n.watchlist-movie-title { font-size: 1rem; font-weight: 700; color: rgb(255, 255, 255); }\n.watchlist-progress-bar-container { display: flex; flex-direction: column; gap: 0.3rem; }\n.watchlist-progress-meta { display: flex; justify-content: space-between; font-size: 0.75rem; color: rgb(112, 112, 122); }\n.progress-track { width: 100%; height: 6px; background: rgba(255, 255, 255, 0.1); border-radius: 3px; overflow: hidden; }\n.progress-fill { height: 100%; background: linear-gradient(90deg, rgb(229, 9, 20), rgb(229, 169, 59)); border-radius: 3px; }\n.movie-detail-container { background: rgb(8, 8, 10); min-height: 100vh; position: relative; }\n.movie-detail-backdrop { height: 45vh; background-size: cover; background-position: center center; position: relative; display: flex; align-items: flex-end; padding: 2rem 4rem; }\n.movie-detail-back-arrow { position: absolute; top: 2rem; left: 2rem; background: rgba(8, 8, 10, 0.7); border: 1px solid rgba(255, 255, 255, 0.1); color: rgb(255, 255, 255); padding: 0.6rem 1.2rem; border-radius: 30px; cursor: pointer; font-size: 0.9rem; font-weight: 600; transition: 0.3s; backdrop-filter: blur(8px); }\n.movie-detail-back-arrow:hover { background: rgb(229, 9, 20); border-color: rgb(229, 9, 20); box-shadow: rgba(229, 9, 20, 0.4) 0px 4px 15px; }\n.movie-detail-content-wrapper { max-width: 1200px; margin: -10vh auto 0px; padding: 0px 2rem 5rem; position: relative; z-index: 5; }\n.movie-detail-primary-grid { display: grid; grid-template-columns: 300px 1fr; gap: 3rem; align-items: start; }\n.poster-glow-frame { border-radius: 20px; overflow: hidden; border: 2px solid rgba(255, 255, 255, 0.1); box-shadow: rgba(0, 0, 0, 0.8) 0px 15px 40px, rgba(229, 169, 59, 0.15) 0px 0px 20px; margin-bottom: 2rem; background: rgb(20, 20, 25); }\n.detail-poster-img { width: 100%; display: block; aspect-ratio: 2 / 3; object-fit: cover; }\n.no-poster-detail { display: flex; align-items: center; justify-content: center; aspect-ratio: 2 / 3; background: rgb(20, 20, 25); font-size: 5rem; }\n.detail-actions-panel { padding: 1.5rem; display: flex; flex-direction: column; gap: 1.2rem; }\n.favorite-action-btn { display: flex; align-items: center; justify-content: center; gap: 0.6rem; width: 100%; padding: 0.8rem; border-radius: 12px; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); color: rgb(255, 255, 255); font-size: 0.95rem; font-weight: 700; cursor: pointer; transition: 0.3s; }\n.favorite-action-btn:hover { background: rgba(255, 255, 255, 0.1); }\n.favorite-action-btn.active { background: rgba(229, 9, 20, 0.15); border-color: rgba(229, 9, 20, 0.5); color: rgb(255, 255, 255); }\n.watchlist-control-block { display: flex; flex-direction: column; gap: 0.5rem; }\n.watchlist-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: rgb(112, 112, 122); font-weight: 700; }\n.watchlist-status-select { background: rgba(8, 8, 10, 0.6); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 10px; padding: 0.75rem; color: rgb(255, 255, 255); font-family: inherit; font-size: 0.9rem; outline: none; cursor: pointer; transition: border-color 0.3s; }\n.watchlist-status-select:focus { border-color: rgb(229, 169, 59); }\n.watchlist-progress-slider-block { display: flex; flex-direction: column; gap: 0.5rem; border-top: 1px solid rgba(255, 255, 255, 0.08); padding-top: 1rem; }\n.slider-meta { font-size: 0.85rem; color: rgb(212, 212, 216); }\n.watchlist-progress-slider { appearance: none; width: 100%; height: 6px; border-radius: 3px; background: rgba(255, 255, 255, 0.1); outline: none; }\n.watchlist-progress-slider::-webkit-slider-thumb { appearance: none; width: 16px; height: 16px; border-radius: 50%; background: rgb(229, 169, 59); cursor: pointer; box-shadow: rgba(229, 169, 59, 0.6) 0px 0px 8px; }\n.movie-detail-info-column { display: flex; flex-direction: column; gap: 2rem; }\n.movie-detail-title-block { display: flex; flex-direction: column; gap: 0.5rem; }\n.detail-movie-title { font-size: 3rem; font-weight: 900; line-height: 1.1; letter-spacing: -1.5px; }\n.detail-original-title { font-size: 1.1rem; color: rgb(112, 112, 122); font-style: italic; }\n.detail-meta-row { display: flex; align-items: center; gap: 1rem; margin-top: 0.5rem; }\n.meta-badge-item { background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.08); padding: 0.4rem 0.8rem; border-radius: 8px; font-size: 0.9rem; font-weight: 600; color: rgb(212, 212, 216); }\n.meta-badge-item.gold-badge { background: rgba(229, 169, 59, 0.1); border-color: rgba(229, 169, 59, 0.3); color: rgb(229, 169, 59); }\n.detail-genres-row { display: flex; flex-wrap: wrap; gap: 0.6rem; }\n.genre-badge { background: rgba(229, 9, 20, 0.12); border: 1px solid rgba(229, 9, 20, 0.25); color: rgb(248, 58, 69); padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }\n.detail-synopsis-section { padding: 2rem; }\n.section-subtitle { font-size: 1.2rem; font-weight: 800; margin-bottom: 0.8rem; color: rgb(255, 255, 255); }\n.synopsis-text { color: rgb(212, 212, 216); line-height: 1.6; font-size: 1.05rem; }\n.detail-crew-section { padding: 1.5rem 2rem; display: flex; flex-direction: column; gap: 1.2rem; }\n.crew-item { display: flex; flex-direction: column; gap: 0.2rem; }\n.crew-role { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: rgb(112, 112, 122); font-weight: 700; }\n.crew-name { font-size: 1.1rem; font-weight: 600; color: rgb(255, 255, 255); }\n.detail-integrations-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }\n.availability-checker-panel { padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem; }\n.availability-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }\n.availability-title { font-size: 1.15rem; font-weight: 800; color: rgb(255, 255, 255); }\n.region-selector-buttons { display: flex; gap: 0.4rem; background: rgba(0, 0, 0, 0.3); padding: 0.3rem; border-radius: 10px; border: 1px solid rgba(255, 255, 255, 0.05); }\n.region-btn { display: flex; align-items: center; gap: 0.3rem; padding: 0.4rem 0.6rem; border-radius: 8px; background: transparent; border: none; color: rgb(160, 160, 171); font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: 0.25s; }\n.region-btn.active { background: rgba(255, 255, 255, 0.1); color: rgb(255, 255, 255); }\n.availability-platforms-list { display: flex; flex-direction: column; gap: 0.8rem; max-height: 250px; overflow-y: auto; }\n.platform-link-card { display: flex; align-items: center; gap: 1rem; padding: 0.8rem 1.2rem; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 12px; text-decoration: none; color: rgb(255, 255, 255); transition: 0.3s; }\n.platform-link-card:hover { background: rgba(255, 255, 255, 0.08); border-color: rgba(255, 255, 255, 0.15); transform: translateX(4px); }\n.platform-logo { width: 36px; height: 36px; border-radius: 8px; object-fit: contain; }\n.platform-info { flex: 1 1 0%; display: flex; justify-content: space-between; align-items: center; }\n.platform-name { font-weight: 700; font-size: 0.95rem; }\n.platform-watch-tag { font-size: 0.8rem; color: rgb(229, 169, 59); font-weight: 600; }\n.no-availability-message { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2.5rem 1rem; text-align: center; gap: 0.5rem; }\n.no-stream-icon { font-size: 2rem; opacity: 0.4; }\n.redirect-links-panel { padding: 2rem; display: flex; flex-direction: column; gap: 1.2rem; }\n.redirect-title { font-size: 1.15rem; font-weight: 800; color: rgb(255, 255, 255); }\n.redirect-description { color: rgb(112, 112, 122); font-size: 0.88rem; line-height: 1.4; }\n.redirect-buttons-container { display: flex; flex-direction: column; gap: 0.8rem; }\n.redirect-glow-button { display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.2rem; border-radius: 12px; background: linear-gradient(135deg, rgba(229, 9, 20, 0.08) 0%, rgba(229, 9, 20, 0.02) 100%); border: 1px solid rgba(229, 9, 20, 0.25); text-decoration: none; color: rgb(255, 255, 255); transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }\n.redirect-glow-button:hover { border-color: rgba(229, 9, 20, 0.7); box-shadow: rgba(229, 9, 20, 0.3) 0px 0px 15px; transform: translateY(-2px); }\n.redirect-glow-button .btn-icon { font-size: 1.2rem; }\n.redirect-glow-button .btn-text { font-weight: 700; font-size: 0.95rem; flex-grow: 1; margin-left: 0.75rem; }\n.redirect-glow-button .btn-arrow { color: rgb(229, 9, 20); font-weight: 800; transition: transform 0.3s; }\n.redirect-glow-button:hover .btn-arrow { transform: translateX(4px); }\n.detail-recommendations-section { margin-top: 5rem; border-top: 1px solid rgba(255, 255, 255, 0.08); padding-top: 3rem; }\n.recommendations-heading { font-size: 1.6rem; font-weight: 800; margin-bottom: 2rem; }\n.movie-detail-loading-screen, .movie-detail-error-screen { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; background: rgb(8, 8, 10); color: rgb(255, 255, 255); padding: 2rem; text-align: center; gap: 1.5rem; }\n.spinner { width: 50px; height: 50px; border-width: 4px; border-style: solid; border-color: rgb(229, 9, 20) rgba(255, 255, 255, 0.1) rgba(255, 255, 255, 0.1); border-image: initial; border-radius: 50%; animation: 1s linear 0s infinite normal none running spin; }\n.error-icon { font-size: 4rem; filter: drop-shadow(rgba(229, 9, 20, 0.4) 0px 0px 15px); }\n.back-btn-glow { background: transparent; border: 1px solid rgb(229, 9, 20); color: rgb(255, 255, 255); padding: 0.8rem 2rem; border-radius: 30px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: 0.3s; }\n.back-btn-glow:hover { background: rgb(229, 9, 20); box-shadow: rgba(229, 9, 20, 0.5) 0px 0px 15px; transform: translateY(-2px); }\n@keyframes spin {\n0% { transform: rotate(0deg); }\n100% { transform: rotate(360deg); }\n}\n@media (max-width: 1024px) {\n.movie-detail-primary-grid { grid-template-columns: 250px 1fr; gap: 2rem; }\n.detail-movie-title { font-size: 2.4rem; }\n.detail-integrations-grid { grid-template-columns: 1fr; gap: 1.5rem; }\n}\n@media (max-width: 768px) {\n.movie-hub-container { flex-direction: column; }\n.movie-sub-sidebar { width: 100%; border-right: none; border-bottom: 1px solid rgba(255, 255, 255, 0.08); padding: 1.5rem; gap: 1.5rem; }\n.sidebar-filter-section { margin-top: 0px; border-top: none; padding-top: 0px; }\n.region-selector-block { flex-flow: wrap; }\n.movie-main-content { padding: 1.5rem; height: auto; }\n.movie-detail-primary-grid { grid-template-columns: 1fr; gap: 2rem; }\n.movie-detail-poster-column { max-width: 300px; margin: 0px auto; width: 100%; }\n.detail-movie-title { font-size: 2rem; text-align: center; }\n.detail-original-title, .detail-meta-row, .detail-genres-row { justify-content: center; text-align: center; }\n.movie-detail-backdrop { height: 30vh; padding: 1rem 2rem; }\n.movie-detail-back-arrow { top: 1rem; left: 1rem; }\n}\n.sidebar-footer-back { margin-top: auto; border-top: 1px solid rgba(255, 255, 255, 0.08); padding-top: 1.5rem; }\n.sub-sidebar-back-btn { display: flex; align-items: center; justify-content: center; gap: 0.6rem; width: 100%; padding: 0.8rem 1rem; background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 10px; color: rgb(160, 160, 171); font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: 0.3s; }\n.sub-sidebar-back-btn:hover { color: rgb(255, 255, 255); background: rgba(229, 9, 20, 0.1); border-color: rgba(229, 9, 20, 0.4); box-shadow: rgba(229, 9, 20, 0.15) 0px 4px 15px; }\n.region-btn-flag { font-size: 1.1rem; }\n.region-btn-label { font-size: 0.9rem; }\n.movie-topbar-actions { display: flex; justify-content: flex-end; margin-bottom: 2rem; }\n.movie-search-form-netflix { position: relative; display: flex; align-items: center; gap: 0.5rem; background: rgba(0, 0, 0, 0.55); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 30px; padding: 0.4rem 1rem; transition: 0.3s; backdrop-filter: blur(8px); }\n.movie-search-form-netflix:focus-within { border-color: rgba(229, 9, 20, 0.5); box-shadow: rgba(229, 9, 20, 0.2) 0px 0px 10px; }\n.search-icon-lens { font-size: 0.9rem; color: rgb(112, 112, 122); }\n.movie-search-input-netflix { border: none; outline: none; background: transparent; color: rgb(255, 255, 255); font-size: 0.9rem; font-family: inherit; width: 200px; }\n.movie-search-input-netflix::placeholder { color: rgb(82, 82, 91); }\n.clear-search-btn { background: transparent; border: none; color: rgb(112, 112, 122); cursor: pointer; font-size: 0.85rem; padding: 0.2rem; }\n.clear-search-btn:hover { color: rgb(255, 255, 255); }\n.netflix-hero-banner { height: 52vh; min-height: 380px; border-radius: 20px; background-size: cover; background-position: center 20%; display: flex; align-items: flex-end; padding: 3rem; margin-bottom: 3.5rem; position: relative; overflow: hidden; box-shadow: rgba(0, 0, 0, 0.7) 0px 15px 40px; box-sizing: border-box; }\n.netflix-hero-content { max-width: 650px; display: flex; flex-direction: column; gap: 1rem; z-index: 5; text-shadow: rgba(8, 8, 10, 0.9) 0px 2px 10px; }\n.netflix-hero-title { font-size: 3.6rem; font-weight: 950; color: rgb(255, 255, 255); letter-spacing: -2px; margin: 0px; line-height: 1.05; }\n.netflix-hero-meta { display: flex; align-items: center; gap: 1rem; font-size: 0.95rem; font-weight: 600; }\n.match-score { color: rgb(70, 211, 105); font-weight: 700; }\n.hero-meta-item { color: rgb(212, 212, 216); }\n.rating-badge-gold { color: rgb(229, 169, 59); background: rgba(229, 169, 59, 0.15); border: 1px solid rgba(229, 169, 59, 0.3); padding: 0.1rem 0.5rem; border-radius: 6px; font-size: 0.8rem; }\n.netflix-hero-synopsis { font-size: 1.05rem; line-height: 1.5; color: rgb(212, 212, 216); margin: 0px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }\n.netflix-hero-buttons { display: flex; gap: 1rem; margin-top: 0.5rem; }\n.netflix-btn-play { display: flex; align-items: center; gap: 0.6rem; background: rgb(255, 255, 255); color: rgb(8, 8, 10); border: none; border-radius: 8px; padding: 0.75rem 1.6rem; font-size: 1rem; font-weight: 800; cursor: pointer; transition: 0.25s cubic-bezier(0.165, 0.84, 0.44, 1); }\n.netflix-btn-play:hover { background: rgba(255, 255, 255, 0.85); transform: translateY(-2px) scale(1.03); box-shadow: rgba(255, 255, 255, 0.15) 0px 8px 20px; }\n.netflix-btn-info { display: flex; align-items: center; gap: 0.6rem; background: rgba(109, 109, 110, 0.7); color: rgb(255, 255, 255); border-radius: 8px; padding: 0.75rem 1.6rem; font-size: 1rem; font-weight: 800; cursor: pointer; transition: 0.25s cubic-bezier(0.165, 0.84, 0.44, 1); backdrop-filter: blur(8px); border: 1px solid rgba(255, 255, 255, 0.08); }\n.netflix-btn-info:hover { background: rgba(109, 109, 110, 0.45); transform: translateY(-2px) scale(1.03); }\n.btn-symbol { font-size: 1.1rem; }\n.netflix-rows-container { display: flex; flex-direction: column; gap: 3.5rem; }\n.netflix-row { display: flex; flex-direction: column; gap: 0.8rem; position: relative; }\n.row-category-title { font-size: 1.35rem; font-weight: 800; color: rgb(255, 255, 255); margin: 0px 0px 0.2rem 0.5rem; letter-spacing: -0.3px; display: inline-block; }\n.carousel-wrapper { position: relative; display: flex; align-items: center; }\n.carousel-track { display: flex; gap: 1.5rem; overflow-x: scroll; scroll-behavior: smooth; padding: 0.6rem 0.5rem; scrollbar-width: none; width: 100%; }\n.carousel-track::-webkit-scrollbar { display: none; }\n.carousel-card-item { flex-shrink: 0; width: 220px; }\n.carousel-control { position: absolute; top: 0.6rem; bottom: 0.6rem; width: 45px; background: rgba(8, 8, 10, 0.75); backdrop-filter: blur(8px); color: rgb(255, 255, 255); border: 1px solid rgba(255, 255, 255, 0.05); font-size: 2.2rem; font-weight: 300; cursor: pointer; transition: 0.3s; z-index: 10; opacity: 0; display: flex; align-items: center; justify-content: center; box-sizing: border-box; }\n.carousel-wrapper:hover .carousel-control { opacity: 1; }\n.carousel-control:hover { background: rgb(229, 9, 20); border-color: rgb(229, 9, 20); box-shadow: rgba(229, 9, 20, 0.4) 0px 0px 15px; }\n.carousel-control.left { left: 0px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; }\n.carousel-control.right { right: 0px; border-top-left-radius: 10px; border-bottom-left-radius: 10px; }\n.watchlist-carousel-card { width: 240px !important; cursor: pointer; }\n.watchlist-slide-content { background: rgba(20, 20, 25, 0.65); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 12px; overflow: hidden; position: relative; transition: 0.3s; }\n.watchlist-slide-content:hover { transform: translateY(-4px); border-color: rgb(229, 9, 20); box-shadow: rgba(229, 9, 20, 0.2) 0px 6px 20px; }\n.slide-watchlist-poster { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; display: block; }\n.slide-watchlist-progress { height: 4px; width: 100%; background: rgba(255, 255, 255, 0.1); position: relative; }\n.slide-progress-fill { height: 100%; background: linear-gradient(90deg, rgb(229, 9, 20), rgb(229, 169, 59)); }\n.slide-watchlist-overlay { padding: 0.75rem; font-weight: 700; font-size: 0.85rem; color: rgb(255, 255, 255); text-align: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n.tab-contents-netflix { margin-top: 1rem; }\n.movie-search-results-section { margin-top: 1rem; }\n.movie-search-results-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 2rem; padding: 0.5rem; }\n.theater-mode-modal-overlay { position: fixed; inset: 0px; background: rgba(5, 5, 8, 0.92); backdrop-filter: blur(15px); display: flex; align-items: center; justify-content: center; z-index: 9999; padding: 2rem; }\n.theater-player-modal-box { width: 95%; max-width: 1050px; display: flex; flex-direction: column; gap: 1.25rem; padding: 1.8rem; box-sizing: border-box; box-shadow: rgba(0, 0, 0, 0.8) 0px 20px 50px, rgba(229, 9, 20, 0.15) 0px 0px 30px; }\n.theater-player-modal-header { display: flex; justify-content: space-between; align-items: center; }\n.playing-title-details { display: flex; align-items: center; gap: 1rem; }\n.movie-icon-indicator { font-size: 2rem; filter: drop-shadow(rgba(229, 9, 20, 0.5) 0px 0px 8px); }\n.theater-modal-movie-title { font-size: 1.4rem; font-weight: 850; 