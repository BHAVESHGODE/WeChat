utube-related-artist { font-size: 0.75rem; color: var(--text-tertiary); }\n.ambient-section { width: 100%; }\n.ambient-header { text-align: center; margin-bottom: 1.5rem; animation: 0.5s ease 0s 1 normal none running fadeUp; }\n.ambient-title { font-size: 1.8rem; font-weight: 700; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.25rem; }\n.ambient-subtitle { font-size: 0.95rem; color: var(--text-secondary); }\n.ambient-grid { column-count: 4; column-gap: 0.75rem; }\n@media (max-width: 1200px) {\n.ambient-grid { column-count: 3; }\n}\n@media (max-width: 900px) {\n.ambient-grid { column-count: 2; }\n}\n@media (max-width: 600px) {\n.ambient-grid { column-count: 1; }\n}\n.ambient-card { background: var(--bg-card); backdrop-filter: blur(8px); border: 2px solid transparent; border-radius: var(--radius-lg); overflow: hidden; transition: all var(--transition); position: relative; break-inside: avoid; margin-bottom: 0.75rem; display: inline-block; width: 100%; }\n.ambient-card:hover { transform: translateY(-4px); border-color: rgba(67, 233, 123, 0.25); box-shadow: rgba(67, 233, 123, 0.1) 0px 8px 30px; }\n.ambient-card.active { border-color: var(--accent-2); background: rgba(67, 233, 123, 0.08); box-shadow: rgba(67, 233, 123, 0.1) 0px 0px 20px; }\n.ambient-card-btn { width: 100%; padding: 1.5rem 1rem; background: none; border: none; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; color: var(--text-primary); font-family: var(--font); transition: all var(--transition); }\n.ambient-card.active .ambient-card-btn { animation: 2s ease 0s infinite normal none running pulse; }\n.ambient-card-icon { font-size: 2.2rem; transition: transform var(--transition); }\n.ambient-card:hover .ambient-card-icon { transform: scale(1.15); }\n.ambient-card-label { font-size: 0.85rem; font-weight: 600; }\n.ambient-card-status { font-size: 0.8rem; color: var(--accent-2); }\n.ambient-card-del { position: absolute; top: 6px; right: 6px; background: rgba(255, 0, 0, 0.15); border: none; border-radius: 50%; width: 24px; height: 24px; font-size: 0.7rem; cursor: pointer; color: var(--accent-3); display: flex; align-items: center; justify-content: center; transition: all var(--transition); }\n.ambient-card-del:hover { background: rgba(255, 0, 0, 0.35); transform: scale(1.1); }\n.ambient-controls { background: var(--bg-card); backdrop-filter: blur(8px); border: 1px solid var(--border-glass); border-radius: var(--radius-lg); padding: 1.25rem; margin-bottom: 1rem; display: flex; flex-direction: column; gap: 1rem; animation: 0.3s ease 0s 1 normal none running fadeUp; }\n.ambient-volume-row { display: flex; align-items: center; gap: 1rem; color: var(--text-secondary); font-size: 0.9rem; }\n.ambient-volume-row input[type=\"range\"] { flex: 1 1 0%; accent-color: var(--accent-2); cursor: pointer; }\n.ambient-timer-row { display: flex; align-items: center; gap: 1rem; color: var(--text-secondary); font-size: 0.9rem; }\n.ambient-timer-btns { display: flex; gap: 0.5rem; }\n.ambient-timer-btn { background: var(--bg-card); border: 1px solid var(--border-glass); border-radius: var(--radius-md); padding: 0.35rem 0.75rem; font-size: 0.8rem; font-family: var(--font); cursor: pointer; color: var(--text-secondary); transition: all var(--transition); }\n.ambient-timer-btn:hover { background: rgba(67, 233, 123, 0.15); border-color: var(--accent-2); color: var(--accent-2); }\n.ambient-timer-btn.cancel { background: rgba(255, 0, 0, 0.08); border-color: rgba(255, 0, 0, 0.15); color: var(--accent-3); }\n.ambient-timer-active { display: flex; align-items: center; gap: 0.5rem; color: var(--accent-2); font-weight: 600; }\n.ambient-upload-row { text-align: center; }\n.ambient-upload-btn { background: var(--bg-card); border: 1px dashed var(--border-glass); b