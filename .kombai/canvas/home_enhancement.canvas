      "html": "\n<div class=\"relative min-h-screen w-full flex flex-col items-center justify-between py-12 px-0 overflow-hidden font-['Plus_Jakarta_Sans',sans-serif] bg-slate-950\" data-kid=\"0\">\n    \n    \n    <div class=\"fixed inset-0 z-0\" data-kid=\"1\">\n        <video src=\"https://kombai-assets.b-cdn.net/generated_assets/91a26b3e-751c-465b-b58d-def7ecb58607/c9ab74b6c82d43a895f9d8e56b33b4b3.mp4\" poster=\"https://kombai-assets.b-cdn.net/generated_assets/91a26b3e-751c-465b-b58d-def7ecb58607/c9ab74b6c82d43a895f9d8e56b33b4b3.mp4?poster\" autoplay muted loop playsinline class=\"w-full h-full object-cover opacity-40\" data-kid=\"2\"></video>\n        <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(2,6,23,0.4)_40%,rgba(2,6,23,0.9)_100%)]\" data-kid=\"3\"></div>\n    </div>\n\n    \n    <div class=\"relative z-10 w-full flex flex-col items-center flex-grow\" data-kid=\"4\">\n        \n        \n        <header class=\"logo-plaque-container mb-12\" id=\"logo-plaque\" data-kid=\"5\">\n            <div class=\"relative px-16 py-8 rounded-[32px] border border-white/20 bg-white/5 backdrop-blur-[60px] shadow-[0_40px_80px_-15px_rgba(0,0,0,0.5),inset_0_0_40px_rgba(255,255,255,0.1)]\" data-kid=\"6\">\n                <div class=\"text-center\" data-kid=\"7\">\n                    <h1 class=\"text-7xl font-black tracking-tighter bg-gradient-to-br from-[#E8D08D] via-[#FFCCB3] to-[#E8D08D] bg-clip-text text-transparent filter drop-shadow-[0_4px_20px_rgba(0,0,0,0.2)]\" data-kid=\"8\">\n                        WeGift\n                    </h1>\n                    <div class=\"flex items-center justify-center gap-5 mt-4\" data-kid=\"9\">\n                        <div class=\"h-[1px] w-8 bg-white/30\" data-kid=\"10\"></div>\n                        <p class=\"text-[10px] tracking-[0.8em] font-bold text-white uppercase opacity-70\" data-kid=\"11\">Luxury Gifting</p>\n                        <div class=\"h-[1px] w-8 bg-white/30\" data-kid=\