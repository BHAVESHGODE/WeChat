1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-emerald-500/40 blur-[100px] rounded-full opacity-40 group-hover:opacity-70 transition-opacity duration-700\" data-kid=\"72\"></div>\n                <div class=\"relative glass-card h-[360px] rounded-[32px] border border-white/25 backdrop-blur-[48px] bg-white/5 p-8 flex flex-col justify-between overflow-hidden shadow-[0_32px_64px_rgba(0,0,0,0.2),inset_0_0_30px_rgba(255,255,255,0.1)] hover:border-white/50 transition-all duration-500\" data-kid=\"73\">\n                    <div class=\"flex justify-between items-start\" data-kid=\"74\">\n                        <div data-kid=\"75\">\n                            <p class=\"text-[11px] tracking-[0.4em] font-black text-white/50 uppercase mb-2\" data-kid=\"76\">Vol. III</p>\n                            <h2 class=\"text-4xl font-black text-white tracking-tighter drop-shadow-md\" data-kid=\"77\">Goju</h2>\n                        </div>\n                        <div class=\"w-10 h-10 rounded-full bg-white/10 border border-white/20 flex items-center justify-center\" data-kid=\"78\">\n                            <i class=\"ti ti-leaf text-emerald-200\" data-kid=\"79\"></i>\n                        </div>\n                    </div>\n                    <div class=\"space-y-6\" data-kid=\"80\">\n                        <div class=\"h-[1px] w-full bg-white/10\" data-kid=\"81\"></div>\n                        <button class=\"w-full py-5 rounded-2xl bg-white text-black font-black text-xs tracking-[0.3em] uppercase hover:bg-emerald-50 hover:shadow-2xl hover:scale-[1.02] transition-all duration-300\" data-kid=\"82\">\n                            Enter\n                        </button>\n                    </div>\n                </div>\n            </div>\n\n        </main>\n    </div>\n\n    <style data-kid=\"83\">\n        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        /* Custom Glass Highlights */\n        .glass-card::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            height: 100%;\n            background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 60%);\n            pointer-events: none;\n        }\n\n        .logo-plaque-container > div::after {\n            content: '';\n            position: absolute;\n            inset: 0;\n            border-radius: inherit;\n            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.4);\n            pointer-events: none;\n        }\n\n        .ti {\n            display: inline-block;\n        }\n    </style>\n\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"84\"></script>\n    <script data-kid=\"85\">\n        document.addEventListener('DOMContentLoaded', () => {\n            const tl = gsap.timeline();\n\n            // Initial states\n            gsap.set(\"#logo-plaque\", { y: -50, opacity: 0 });\n            gsap.set(\".category-item\", { scale: 0.8, opacity: 0 });\n            gsap.set(\".path-card-wrapper\", { y: 100, opacity: 0 });\n\n            // Animation sequence\n            tl.to(\"#logo-plaque\", { \n                y: 0, \n                opacity: 1, \n                duration: 1.2, \n                ease: \"expo.out\" \n            })\n            .to(\".category-item\", { \n                scale: 1, \n                opacity: 1, \n                stagger: 0.05, \n                duration: 0.8, \n                ease: \"back.out(1.7)\" \n            }, \"-=0.8\")\n            .to(\".path-card-wrapper\", { \n                y: 0, \n                opacity: 1, \n                stagger: 0.1, \n                duration: 1.2, \n                ease: \"power4.out\" \n            }, \"-=0.6\");\n\n            // Subtle floating effect for cards\n            gsap.to(\".path-card-wrapper\", {\n                y: \"-=15\",\n                duration: 3,\n                repeat: -1,\n                yoyo: true,\n                ease: \"sine.inOut\",\n                stagger: {\n                    each: 0.4,\n                    from: \"random\"\n                }\n            });\n        });\n    </script>\n</div>\n",
