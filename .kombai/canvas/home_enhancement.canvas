uto; padding: 0.5rem 1rem; gap: 0px; border-right: none; border-bottom: 1px solid var(--border-glass); }\n.anime-sidebar-item { padding: 0.5rem 1rem; white-space: nowrap; width: auto; border-radius: var(--radius-full); }\n.anime-sidebar-item.active { border-right: none; background: rgba(124, 77, 255, 0.15); }\n.anime-sidebar-label { display: none; }\n.anime-content { padding: 1rem; max-height: none; }\n.anime-detail-hero { flex-direction: column; align-items: center; text-align: center; }\n.anime-detail-poster { width: 200px; }\n.anime-detail-meta { justify-content: center; }\n.ghibli-grid { grid-template-columns: 1fr; padding: 1rem; }\n.anime-quotes-bar { flex-direction: column; text-align: center; padding: 0.5rem 1rem; }\n.trace-upload-area { padding: 1.5rem; }\n.reader-header { flex-direction: column; gap: 0.5rem; padding: 0.5rem 1rem; }\n.reader-nav { flex-wrap: wrap; justify-content: center; }\n}\n:root { --yp-red: #ff0000; --yp-red-dark: #cc0000; --yp-red-light: #ff6b6b; --yp-glow: rgba(255, 0, 0, 0.3); --yp-bg: rgba(12, 12, 16, 0.95); --yp-card-bg: rgba(20, 20, 28, 0.85); --yp-border: rgba(255, 255, 255, 0.06); --yp-text: rgba(255, 255, 255, 0.92); --yp-text-secondary: rgba(255, 255, 255, 0.6); --yp-text-tertiary: rgba(255, 255, 255, 0.35); }\n.yp-container { width: 100%; animation: 0.5s ease 0s 1 normal none running fadeUp; }\n.yp-quotes-bar { background: var(--bg-glass); backdrop-filter: blur(12px); border: 1px solid var(--border-glass); border-radius: var(--radius-lg); padding: 0.6rem 1rem; margin-bottom: 1rem; animation: 0.4s ease 0s 1 normal none running fadeUp; }\n.yp-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem; animation: 0.5s ease 0s 1 normal none running fadeUp; }\n.yp-header-content { flex: 1 1 0%; min-width: 200px; }\n.yp-brand { display: flex; align-items: center; gap: 0.6rem; }\n.yp-brand-icon { font-size: 1.8rem; color: var(--yp-red); text-shadow: 0 0 20px var(--yp-glow); animation: 2s ease 0s infinite normal none running ypPulse; }\n@keyframes ypPulse {\n0%, 100% { text-shadow: 0 0 20px var(--yp-glow); }\n50% { text-shadow: 0 0 40px var(--yp-glow), 0 0 60px rgba(255,0,0,0.2); }\n}\n.yp-title { font-size: 2rem; font-weight: 800; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; letter-spacing: -0.5px; }\n.yp-subtitle { font-size: 0.85rem; color: var(--yp-text-secondary); margin-top: 0.15rem; letter-spacing: 0.3px; }\n.yp-header-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }\n.yp-pill-btn { background: var(--bg-card); border: 1px solid var(--border-glass); color: var(--text-secondary); padding: 0.5rem 1rem; border-radius: 50px; font-size: 0.82rem; font-family: var(--font); cursor: pointer; transition: all var(--transition); display: flex; align-items: center; gap: 0.4rem; }\n.yp-pill-btn:hover { background: var(--bg-card-hover); color: var(--text-primary); border-color: rgba(255, 255, 255, 0.15); transform: translateY(-1px); }\n.yp-pill-btn.active { background: rgba(255, 0, 0, 0.12); border-color: var(--yp-red); color: var(--yp-red); }\n.yp-ambient-panel { background: var(--bg-glass); backdrop-filter: blur(12px); border: 1px solid var(--border-glass); border-radius: var(--radius-lg); padding: 1rem 1.25rem; margin-bottom: 1rem; animation: 0.3s ease 0s 1 normal none running fadeUp; }\n.yp-search-wrap { margin-bottom: 1.25rem; animation: 0.4s ease 0s 1 normal none running fadeUp; }\n.yp-search { display: flex; align-items: center; gap: 0.5rem; background: var(--bg-card); border: 1px solid var(--border-glass); border-radius: 50px; padding: 0.3rem 0.3rem 0.3rem 1.2rem; transition: all var(--transition); }\n.yp-search:focus-within { border-color: var(--yp-red); box-shadow: rgba(255, 0, 0, 0.1) 0px 0px 0px 3px; }\n.yp-search-icon { font-size: 0.95rem; color: var(--text-tertiary); flex-shrink: 0; }\n.yp-search-input { flex: 1 1 0%; border: none; background: none; outline: none; font-size: 0.92rem; font-family: var(--font); color: var(--text-primary); padding: 0.6rem 0px; min-width: 0px; }\n.yp-search-input::placeholder { color: var(--text-tertiary); }\n.yp-search-clear { background: none; border: none; color: var(--text-tertiary); font-size: 0.9rem; cursor: pointer; padding: 0.3rem 0.5rem; border-radius: 50%; transition: all var(--transition); }\n.yp-search-clear:hover { background: rgba(255, 255, 255, 0.08); color: var(--text-primary); }\n.yp-search-btn { background: var(--yp-red); color: rgb(255, 255, 255); border: none; border-radius: 50px; padding: 0.55rem 1.5rem; font-size: 0.85rem; font-weight: 600; font-family: var(--font); cursor: pointer; transition: all var(--transition); white-space: nowrap; }\n.yp-search-btn:hover { background: var(--yp-red-dark); transform: translateX(-1px); }\n.yp-search-btn:disabled { opacity: 0.5; cursor: not-allowed; }\n.yp-spinner { display: inline-block; width: 14px; height: 14px; border-width: 2px; border-style: solid; border-color: rgb(255, 255, 255) rgba(255, 255, 255, 0.3) rgba(255, 255, 255, 0.3); border-image: initial; border-radius: 50%; animation: 0.6s linear 0s infinite normal none running ypSpin; }\n.yp-spinner-lg { width: 36px; height: 36px; border-width: 3px; border-style: solid; border-right-color: rgba(255, 0, 0, 0.15); border-bottom-color: rgba(255, 0, 0, 0.15); border-left-color: rgba(255, 0, 0, 0.15); border-image: initial; border-top-color: var(--yp-red); border-radius: 50%; animation: 0.8s linear 0s infinite normal none running ypSpin; margin-bottom: 0.75rem; }\n@keyframes ypSpin {\n100% { transform: rotate(360deg); }\n}\n.yp-tabs { display: flex; gap: 0.4rem; margin-bottom: 1.25rem; flex-wrap: wrap; animation: 0.45s ease 0s 1 normal none running fadeUp; }\n.yp-tab { background: var(--bg-card); border: 1px solid var(--border-glass); border-radius: var(--radius-md); padding: 0.45rem 1.1rem; font-size: 0.85rem; font-family: var(--font); cursor: pointer; color: var(--text-secondary); transition: all var(--transition); position: relative; }\n.yp-tab:hover { background: var(--bg-card-hover); color: var(--text-primary); transform: translateY(-1px); }\n.yp-tab.active { background: rgba(255, 0, 0, 0.1); border-color: var(--yp-red); color: var(--yp-red); font-weight: 600; box-shadow: rgba(255, 0, 0, 0.08) 0px 0px 20px; }\n.yp-tab:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }\n.yp-fav-msg { background: rgba(255, 0, 0, 0.1); border: 1px solid rgba(255, 0, 0, 0.2); color: var(--yp-red-light); padding: 0.5rem 1rem; border-radius: var(--radius-md); font-size: 0.85rem; margin-bottom: 0.75rem; text-align: center; animation: 0.3s ease 0s 1 normal none running fadeUp; }\n.yp-error { background: rgba(255, 107, 107, 0.1); border: 1px solid rgba(255, 107, 107, 0.2); color: var(--yp-red-light); padding: 0.5rem 1rem; border-radius: var(--radius-md); font-size: 0.85rem; margin-bottom: 0.75rem; }\n.yp-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4rem 2rem; color: var(--text-tertiary); font-size: 0.9rem; gap: 0.75rem; }\n.yp-grid { column-count: 4; column-gap: 0.85rem; }\n@media (max-width: 1200px) {\n.yp-grid { column-count: 3; }\n}\n@media (max-width: 900px) {\n.yp-grid { column-count: 2; }\n}\n@media (max-width: 600px) {\n.yp-grid { column-count: 1; }\n}\n.yp-card { background: var(--yp-card-bg); backdrop-filter: blur(8px); border: 1px solid var(--yp-border); border-radius: 16px; overflow: hidden; transition: 0.35s cubic-bezier(0.4, 0, 0.2, 1); break-inside: avoid; margin-bottom: 0.85rem; display: inline-block; width: 100%; position: relative; }\n.yp-card:hover { transform: translateY(-8px) scale(1.01); border-color: rgba(255, 0, 0, 0.2); box-shadow: rgba(255, 0, 0, 0.1) 0px 12px 40px; }\n.yp-card.active { border-color: var(--yp-red); box-shadow: rgba(255, 0, 0, 0.15) 0px 0px 0px 2px, rgba(255, 0, 0, 0.08) 0px 12px 40px; }\n.yp-card-img-wrap { position: relative; cursor: pointer; aspect-ratio: 16 / 9; background: rgba(0, 0, 0, 0.4); overflow: hidden; }\n.yp-card-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1); }\n.yp-card:hover .yp-card-img { transform: scale(1.08); }\n.yp-card-overlay { position: absolute; inset: 0px; background: rgba(0, 0, 0, 0.3); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s; }\n.yp-card-img-wrap:hover .yp-card-overlay { opacity: 1; }\n.yp-card-play-btn { background: rgba(0, 0, 0, 0.75); backdrop-filter: blur(8px); color: rgb(255, 255, 255); width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; transform: scale(0.85); transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: rgba(0, 0, 0, 0.3) 0px 4px 20px; }\n.yp-card-img-wrap:hover .yp-card-play-btn { transform: scale(1); }\n.yp-card-play-btn:hover { background: var(--yp-red); transform: scale(1.08); }\n.yp-card-dur { position: absolute; bottom: 8px; right: 8px; background: rgba(0, 0, 0, 0.88); color: rgb(255, 255, 255); padding: 0.2rem 0.45rem; border-radius: 6px; font-size: 0.75rem; font-weight: 600; backdrop-filter: blur(4px); letter-spacing: 0.3px; }\n.yp-card-playing-bar { position: absolute; bottom: 0px; left: 0px; right: 0px; height: 3px; background: rgba(255, 255, 255, 0.08); }\n.yp-card-playing-bar-inner { height: 100%; width: 100%; animation: 2s linear 0s infinite normal none running ypBarScroll; background-image: ; background-position-x: ; background-position-y: ; background-repeat: ; background-attachment: ; background-origin: ; background-clip: ; background-color: ; background-size: 200% 100%; }\n@keyframes ypBarScroll {\n0% { background-position: 200% 0px; }\n100% { background-position: -200% 0px; }\n}\n.yp-card-body { padding: 0.7rem 0.85rem 0.85rem; }\n.yp-card-title { font-size: 0.88rem; font-weight: 600; color: var(--yp-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 0.1rem; }\n.yp-card-artist { font-size: 0.76rem; color: var(--yp-text-secondary); margin-bottom: 0.2rem; }\n.yp-card-meta { font-size: 0.7rem; color: var(--yp-text-tertiary); margin-bottom: 0.5rem; }\n.yp-card-actions { display: flex; gap: 0.35rem; flex-wrap: wrap; }\n.yp-action-btn { background: rgba(255, 255, 255, 0.06); border: 1px solid rgba(255, 255, 255, 0.08); color: var(--text-secondary); border-radius: 8px; padding: 0.3rem 0.6rem; font-size: 0.72rem; font-weight: 600; font-family: var(--font); cursor: pointer; transition: all var(--transition); display: flex; align-items: center; gap: 0.2rem; }\n.yp-action-btn:hover { background: rgba(255, 0, 0, 0.12); border-color: rgba(255, 0, 0, 0.25); color: var(--yp-red); transform: translateY(-1px); }\n.yp-action-btn.primary { background: var(--yp-red); border-color: var(--yp-red); color: rgb(255, 255, 255); }\n.yp-action-btn.primary:hover { background: var(--yp-red-dark); border-color: var(--yp-red-dark); box-shadow: rgba(255, 0, 0, 0.25) 0px 4px 15px; }\n.yp-action-btn.faved { color: rgb(255, 68, 68); }\n.yp-action-btn.tiny { padding: 0.2rem 0.45rem; font-size: 0.65rem; }\n.yp-action-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }\n.yp-empty { text-align: center; padding: 4rem 2rem; color: var(--text-tertiary); animation: 0.4s ease 0s 1 normal none running fadeUp; }\n.yp-empty-icon { font-size: 3rem; display: block; margin-bottom: 1rem; opacity: 0.5; }\n.yp-now-playing { position: relative; background: var(--yp-card-bg); backdrop-filter: blur(12px); border: 1px solid var(--yp-border); border-radius: 20px; overflow: hidden; margin-top: 1.5rem; margin-bottom: 1.5rem; transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1); animation: 0.5s ease 0s 1 normal none running fadeUp; }\n.yp-now-blur { position: absolute; inset: 0px; background-size: cover; background-position: center center; filter: blur(60px) brightness(0.15); opacity: 0.6; pointer-events: none; }\n.yp-now-inner { position: relative; padding: 1.25rem 1.5rem; z-index: 1; }\n.yp-now-visualizer { margin-bottom: 0.75rem; }\n.yp-vis-canvas { width: 100%; height: 60px; border-radius: 12px; background: rgba(0, 0, 0, 0.3); }\n.yp-now-info { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }\n.yp-now-thumb-wrap { flex-shrink: 0; }\n.yp-now-thumb { width: 64px; height: 64px; border-radius: 14px; object-fit: cover; box-shadow: rgba(0, 0, 0, 0.3) 0px 4px 20px; }\n.yp-now-text { flex: 1 1 0%; min-width: 0px; }\n.yp-now-title { font-size: 1.05rem; font-weight: 700; color: var(--yp-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.yp-now-artist { font-size: 0.82rem; color: var(--yp-text-secondary); }\n.yp-now-controls-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }\n.yp-time { font-size: 0.75rem; color: var(--yp-text-tertiary); font-variant-numeric: tabular-nums; min-width: 40px; }\n.yp-progress { flex: 1 1 0%; height: 4px; background: rgba(255, 255, 255, 0.08); border-radius: 4px; cursor: pointer; position: relative; transition: height var(--transition); }\n.yp-progress:hover { height: 6px; }\n.yp-progress-fill { height: 100%; background: linear-gradient(90deg, var(--yp-red), var(--yp-red-light)); border-radius: 4px; transition: width 0.3s linear; position: relative; }\n.yp-progress-fill::after { content: \"\"; position: absolute; right: -5px; top: 50%; transform: translateY(-50%); width: 12px; height: 12px; background: var(--yp-red); border-radius: 50%; opacity: 0; transition: opacity var(--transition); }\n.yp-progress:hover .yp-progress-fill::after { opacity: 1; }\n.yp-now-settings { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }\n.yp-toggle-label { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.82rem; color: var(--text-secondary); }\n.yp-toggle-label input { display: none; }\n.yp-toggle-track { width: 36px; height: 20px; background: rgba(255, 255, 255, 0.1); border-radius: 20px; position: relative; transition: all var(--transition); flex-shrink: 0; }\n.yp-toggle-label input:checked + .yp-toggle-track { background: var(--yp-red); }\n.yp-toggle-thumb { position: absolute; top: 2px; left: 2px; width: 16px; height: 16px; background: rgb(255, 255, 255); border-radius: 50%; transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1); }\n.yp-toggle-label input:checked + .yp-toggle-track .yp-toggle-thumb { left: 18px; }\n.yp-toggle-text { font-size: 0.82rem; color: var(--text-secondary); }\n.yp-quality-select { background: rgba(255, 255, 255, 0.06); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 8px; padding: 0.35rem 0.75rem; font-size: 0.8rem; font-family: var(--font); color: var(--text-primary); cursor: pointer; outline: none; transition: border-color var(--transition); }\n.yp-quality-select:focus { border-color: var(--yp-red); }\n.yp-quality-select option { background: var(--bg-secondary); color: var(--text-primary); }\n.yp-queue-panel { background: var(--yp-card-bg); backdrop-filter: blur(12px); border: 1px solid var(--yp-border); border-radius: 16px; overflow: hidden; margin-bottom: 1.5rem; animation: 0.3s ease 0s 1 normal none running fadeUp; }\n.yp-queue-header { display: flex; justify-content: space-between; align-items: center; padding: 0.85rem 1rem; border-bottom: 1px solid var(--yp-border); }\n.yp-queue-header h3 { font-size: 0.95rem; font-weight: 600; color: var(--text-secondary); }\n.yp-queue-close { background: none; border: none; color: var(--text-tertiary); font-size: 0.95rem; cursor: pointer; padding: 0.3rem; border-radius: 50%; transition: all var(--transition); }\n.yp-queue-close:hover { background: rgba(255, 255, 255, 0.08); color: var(--text-primary); }\n.yp-queue-list { max-height: 300px; overflow-y: auto; padding: 0.4rem; }\n.yp-queue-item { display: flex; align-items: center; gap: 0.65rem; padding: 0.55rem 0.65rem; border-radius: var(--radius-md); cursor: pointer; transition: all var(--transition); }\n.yp-queue-item:hover { background: rgba(255, 255, 255, 0.04); }\n.yp-queue-item.active { background: rgba(255, 0, 0, 0.08); border-left: 3px solid var(--yp-red); }\n.yp-queue-idx { width: 22px; text-align: center; color: var(--text-tertiary); font-size: 0.78rem; font-variant-numeric: tabular-nums; flex-shrink: 0; }\n.yp-queue-thumb { width: 38px; height: 38px; object-fit: cover; border-radius: 8px; flex-shrink: 0; }\n.yp-queue-info { flex: 1 1 0%; min-width: 0px; }\n.yp-queue-title { font-size: 0.83rem; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.yp-queue-artist { font-size: 0.7rem; color: var(--text-tertiary); }\n.yp-queue-remove { background: rgba(255, 70, 70, 0.1); border: none; color: var(--accent-3); width: 24px; height: 24px; border-radius: 50%; font-size: 0.6rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all var(--transition); flex-shrink: 0; }\n.yp-queue-remove:hover { background: rgba(255, 70, 70, 0.3); transform: scale(1.1); }\n.yp-related { background: var(--yp-card-bg); backdrop-filter: blur(12px); border: 1px solid var(--yp-border); border-radius: 16px; padding: 1rem; margin-bottom: 1.5rem; animation: 0.5s ease 0s 1 normal none running fadeUp; }\n.yp-related-title { font-size: 1rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.5rem; }\n.yp-related-title::before { content: \"рҹ’Ў\"; }\n.yp-related-list { display: flex; flex-direction: column; gap: 0.35rem; }\n.yp-related-item { display: flex; align-items: center; gap: 0.65rem; padding: 0.5rem 0.65rem; border-radius: var(--radius-md); cursor: pointer; transition: all var(--transition); }\n.yp-related-item:hover { background: rgba(255, 255, 255, 0.04); transform: translateX(4px); }\n.yp-related-thumb { width: 80px; height: 45px; object-fit: cover; border-radius: 8px; flex-shrink: 0; }\n.yp-related-info { flex: 1 1 0%; min-width: 0px; }\n.yp-related-name { font-size: 0.83rem; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.yp-related-artist { font-size: 0.72rem; color: var(--text-tertiary); }\n@keyframes fadeUp {\n0% { opacity: 0; transform: translateY(12px); }\n100% { opacity: 1; transform: translateY(0px); }\n}\n@media (max-width: 768px) {\n.yp-title { font-size: 1.4rem; }\n.yp-header { flex-direction: column; align-items: flex-start; }\n.yp-now-inner { padding: 1rem; }\n.yp-now-thumb { width: 48px; height: 48px; }\n.yp-vis-canvas { height: 40px; }\n.yp-now-settings { flex-direction: column; align-items: flex-start; }\n}\n@media (max-width: 480px) {\n.yp-search { border-radius: var(--radius-md); padding: 0.3rem 0.3rem 0.3rem 1rem; flex-wrap: wrap; }\n.yp-search-btn { padding: 0.45rem 1rem; font-size: 0.8rem; }\n.yp-grid { column-gap: 0.6rem; }\n.yp-related-thumb { width: 60px; height: 34px; }\n}\n:root { --sidebar-width: 260px; --mobile-nav-height: 60px; --player-bar-height: 72px; }\n.app-layout { display: flex; min-height: 100vh; background: var(--gradient-bg); }\n.app-sidebar { width: var(--sidebar-width); flex-shrink: 0; background: rgba(15, 15, 19, 0.95); backdrop-filter: blur(20px); border-right: 1px solid rgba(255, 255, 255, 0.06); display: flex; flex-direction: column; position: fixed; top: 0px; left: 0px; height: 100vh; z-index: 100; overflow-y: auto; transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }\n.sidebar-header { display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255, 255, 255, 0.06); }\n.sidebar-logo { display: flex; align-items: center; gap: 0.6rem; cursor: pointer; }\n.sidebar-logo-icon { font-size: 1.5rem; }\n.sidebar-logo h2 { font-size: 1.3rem; font-weight: 800; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; margin: 0px; }\n.sidebar-close-btn { background: none; border: none; color: var(--text-secondary); font-size: 1.2rem; cursor: pointer; padding: 0.25rem; display: none; }\n.sidebar-nav { flex: 1 1 0%; padding: 0.75rem 0.5rem; overflow-y: auto; }\n.sidebar-section { margin-bottom: 1rem; }\n.sidebar-section-label { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1.2px; color: var(--text-tertiary); padding: 0.5rem 0.75rem 0.25rem; }\n.sidebar-item { display: flex; align-items: center; gap: 0.7rem; width: 100%; padding: 0.6rem 0.75rem; border: none; background: transparent; color: rgba(255, 255, 255, 0.55); font-size: 0.88rem; font-weight: 500; font-family: inherit; cursor: pointer; border-radius: 10px; transition: 0.2s; text-align: left; }\n.sidebar-item:hover { background: rgba(255, 255, 255, 0.06); color: rgba(255, 255, 255, 0.9); transform: translateX(4px); }\n.sidebar-item.active { background: rgba(124, 77, 255, 0.15); color: var(--accent-1); box-shadow: inset 3px 0 0 var(--accent-1); }\n.sidebar-item-icon { font-size: 1.1rem; width: 24px; text-align: center; flex-shrink: 0; }\n.sidebar-footer { padding: 0.75rem 1.25rem; border-top: 1px solid rgba(255, 255, 255, 0.06); }\n.sidebar-version { font-size: 0.75rem; color: var(--text-tertiary); }\n.app-main { flex: 1 1 0%; margin-left: var(--sidebar-width); min-height: 100vh; padding-bottom: var(--player-bar-height); position: relative; }\n.app-content-inner { width: 100%; min-height: 100vh; }\n.sidebar-overlay { position: fixed; inset: 0px; background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(4px); z-index: 99; animation: 0.2s ease 0s 1 normal none running fadeIn; }\n.mobile-bottom-nav { display: none; position: fixed; bottom: 0px; left: 0px; right: 0px; height: var(--mobile-nav-height); background: rgba(15, 15, 19, 0.95); backdrop-filter: blur(20px); border-top: 1px solid rgba(255, 255, 255, 0.06); z-index: 90; justify-content: space-around; align-items: center; padding-top: 0px; padding-right: 0.5rem; padding-left: 0.5rem; padding-bottom: env(safe-area-inset-bottom, 0); }\n.mobile-nav-item { display: flex; flex-direction: column; align-items: center; gap: 0.15rem; background: none; border: none; color: rgba(255, 255, 255, 0.4); font-family: inherit; cursor: pointer; padding: 0.3rem 0.5rem; border-radius: 8px; transition: 0.2s; min-width: 56px; }\n.mobile-nav-item:hover { color: rgba(255, 255, 255, 0.7); }\n.mobile-nav-item.active { color: var(--accent-1); }\n.mobile-nav-icon { font-size: 1.2rem; }\n.mobile-nav-label { font-size: 0.6rem; font-weight: 600; }\n.mobile-hamburger { display: none; position: fixed; top: 0.75rem; left: 0.75rem; z-index: 95; background: rgba(15, 15, 19, 0.9); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 10px; color: var(--text-primary); font-size: 1.3rem; padding: 0.4rem 0.7rem; cursor: pointer; font-family: inherit; transition: 0.2s; }\n.mobile-hamburger:hover { background: rgba(255, 255, 255, 0.1); }\n.discover-section { padding: 2rem; max-width: 1200px; margin: 0px auto; animation: 0.6s ease 0s 1 normal none running fadeUp; }\n.discover-title { font-size: 1.8rem; font-weight: 800; margin-bottom: 1.5rem; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; }\n.discover-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }\n.discover-card { padding: 1.5rem; border-radius: var(--radius-lg); cursor: pointer; transition: 0.3s; color: rgb(255, 255, 255); min-height: 140px; display: flex; flex-direction: column; justify-content: flex-end; position: relative; overflow: hidden; }\n.discover-card::before { content: \"\"; position: absolute; inset: 0px; background: rgba(0, 0, 0, 0.3); transition: opacity 0.3s; }\n.discover-card:hover::before { opacity: 0.5; }\n.discover-card:hover { transform: translateY(-4px); box-shadow: rgba(0, 0, 0, 0.3) 0px 12px 40px; }\n.discover-card h3 { font-size: 1.2rem; font-weight: 700; position: relative; z-index: 1; margin-bottom: 0.25rem; }\n.discover-card p { font-size: 0.85rem; opacity: 0.8; position: relative; z-index: 1; }\n.unified-player-bar { position: fixed; bottom: 0px; left: var(--sidebar-width); right: 0px; background: rgba(15, 15, 19, 0.95); backdrop-filter: blur(20px); border-top: 1px solid rgba(255, 255, 255, 0.06); z-index: 80; padding: 0.5rem 1rem; }\n.player-progress-track { position: absolute; top: -3px; left: 0px; right: 0px; height: 3px; background: rgba(255, 255, 255, 0.06); cursor: pointer; }\n.player-progress-fill { height: 100%; background: var(--gradient-1); border-radius: 0px 2px 2px 0px; transition: width 0.1s linear; }\n.player-bar-inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }\n.player-track-info { display: flex; align-items: center; gap: 0.75rem; min-width: 200px; flex: 1 1 0%; }\n.player-thumb-sm { width: 40px; height: 40px; border-radius: 8px; flex-shrink: 0; }\n.player-track-text { overflow: hidden; }\n.player-track-title { font-size: 0.85rem; font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.player-track-artist { font-size: 0.75rem; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.player-center-controls { display: flex; align-items: center; gap: 0.25rem; }\n.player-btn { background: none; border: none; color: var(--text-secondary); font-size: 1.1rem; cursor: pointer; padding: 0.4rem; border-radius: 8px; transition: 0.2s; font-family: inherit; display: flex; align-items: center; justify-content: center; }\n.player-btn:hover { color: var(--text-primary); background: rgba(255, 255, 255, 0.06); }\n.player-btn.active { color: var(--accent-1); }\n.player-btn.small { font-size: 0.9rem; padding: 0.3rem; }\n.player-btn.play-btn { font-size: 1.4rem; padding: 0.3rem 0.5rem; }\n.player-right-controls { display: flex; align-items: center; gap: 0.75rem; flex: 1 1 0%; justify-content: flex-end; }\n.player-time { font-size: 0.75rem; color: var(--text-tertiary); font-variant-numeric: tabular-nums; white-space: nowrap; }\n.player-volume { display: flex; align-items: center; gap: 0.4rem; }\n.volume-slider { width: 80px; height: 4px; accent-color: var(--accent-1); cursor: pointer; }\n.book-reader { min-height: 100vh; display: flex; flex-direction: column; }\n.reader-toolbar { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: rgba(0, 0, 0, 0.3); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255, 255, 255, 0.06); gap: 0.75rem; flex-wrap: wrap; position: sticky; top: 0px; z-index: 10; }\n.toolbar-left, .toolbar-center, .toolbar-right { display: flex; align-items: center; gap: 0.5rem; }\n.reader-search-input { padding: 0.4rem 0.8rem; background: rgba(255, 255, 255, 0.06); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 8px; font-family: inherit; font-size: 0.85rem; outline: none; color: var(--text-primary); width: 200px; }\n.reader-search-input:focus { border-color: var(--accent-1); }\n.reader-progress { font-size: 0.8rem; color: var(--accent-2); font-weight: 600; }\n.book-text-content { flex: 1 1 0%; overflow-y: auto; }\n.book-text-content p { margin-bottom: 0.5rem; }\n.manga-reader { min-height: 100vh; display: flex; flex-direction: column; }\n.reader-controls { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: rgba(0, 0, 0, 0.3); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255, 255, 255, 0.06); position: sticky; top: 0px; z-index: 10; }\n.reader-controls-left, .reader-controls-right { display: flex; align-items: center; gap: 0.5rem; }\n.reader-pages { flex: 1 1 0%; overflow-y: auto; display: flex; flex-direction: column; align-items: center; gap: 0px; }\n.reader-page-wrap { width: 100%; max-width: 800px; }\n.reader-page-wrap img { width: 100%; display: block; }\n.thread-list { display: flex; flex-direction: column; gap: 0.5rem; }\n.thread-item { padding: 0.75rem 1rem; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 12px; cursor: pointer; transition: 0.2s; }\n.thread-item:hover { background: rgba(255, 255, 255, 0.06); border-color: rgba(124, 77, 255, 0.2); }\n.thread-item.active { background: rgba(124, 77, 255, 0.1); border-color: var(--accent-1); }\n.thread-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.3rem; }\n.thread-type-badge { font-size: 1rem; }\n.thread-state { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; padding: 0.1rem 0.4rem; border-radius: 4px; }\n.thread-state.open { background: rgba(67, 233, 123, 0.15); color: rgb(67, 233, 123); }\n.thread-state.closed { background: rgba(255, 107, 157, 0.15); color: rgb(255, 107, 157); }\n.thread-title { font-size: 0.9rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.3rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }\n.thread-meta { display: flex; gap: 0.5rem; font-size: 0.75rem; color: var(--text-tertiary); }\n.markdown-body { font-size: 0.95rem; line-height: 1.6; color: var(--text-primary); }\n.markdown-body h1, .markdown-body h2, .markdown-body h3 { margin: 1rem 0px 0.5rem; color: var(--text-primary); }\n.markdown-body pre { background: rgba(0, 0, 0, 0.3); border-radius: 8px; padding: 1rem; overflow-x: auto; margin: 0.5rem 0px; }\n.markdown-body code { font-size: 0.85rem; color: var(--accent-4); }\n.markdown-body a { color: var(--accent-1); text-decoration: none; }\n.markdown-body a:hover { text-decoration: underline; }\n.book-card { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 14px; overflow: hidden; cursor: pointer; transition: 0.3s; }\n.book-card:hover { transform: translateY(-4px); border-color: rgba(124, 77, 255, 0.2); box-shadow: rgba(124, 77, 255, 0.12) 0px 8px 32px; }\n.book-cover-wrap { width: 100%; padding-top: 150%; position: relative; background: rgba(255, 255, 255, 0.03); }\n.book-cover-wrap img { position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; object-fit: cover; }\n.book-cover-placeholder { position: absolute; inset: 0px; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; font-weight: 800; color: var(--text-tertiary); }\n.book-info { padding: 0.75rem; }\n.book-title { font-size: 0.85rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.2rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }\n.book-author { font-size: 0.78rem; color: var(--text-secondary); }\n.book-year { font-size: 0.7rem; color: var(--text-tertiary); }\n.video-card { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 14px; overflow: hidden; cursor: pointer; transition: 0.3s; }\n.video-card:hover { transform: translateY(-4px); border-color: rgba(255, 255, 255, 0.12); box-shadow: rgba(0, 0, 0, 0.3) 0px 8px 32px; }\n.video-card.compact { display: flex; gap: 0.75rem; }\n.video-thumb-wrap { position: relative; width: 100%; padding-top: 56.25%; }\n.video-card.compact .video-thumb-wrap { width: 168px; padding-top: 94px; flex-shrink: 0; }\n.video-thumb-wrap img { position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; object-fit: cover; }\n.video-duration-badge { position: absolute; bottom: 0.4rem; right: 0.4rem; padding: 0.1rem 0.35rem; background: rgba(0, 0, 0, 0.8); color: rgb(255, 255, 255); font-size: 0.7rem; font-weight: 600; border-radius: 4px; }\n.video-info { padding: 0.65rem; }\n.video-card.compact .video-info { padding: 0.25rem 0.5rem; }\n.video-title { font-size: 0.85rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.15rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }\n.video-channel { font-size: 0.75rem; color: var(--text-secondary); }\n.video-views { font-size: 0.7rem; color: var(--text-tertiary); }\n.anime-quotes-overlay { position: fixed; bottom: 80px; right: 1rem; z-index: 60; cursor: pointer; animation: 0.4s ease 0s 1 normal none running slideUp; max-width: 360px; }\n.anime-quote-card { padding: 1rem 1.25rem; }\n.loading-spinner-container { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4rem 0px; gap: 1rem; }\n.loading-text { color: var(--text-tertiary); font-size: 0.9rem; }\n.empty-state h3 { font-size: 1.1rem; color: var(--text-secondary); margin-bottom: 0.5rem; }\n.empty-state p { color: var(--text-tertiary); font-size: 0.9rem; }\n@media (max-width: 768px) {\n.app-sidebar { transform: translateX(-100%); width: 280px; }\n.app-sidebar.open { transform: translateX(0px); }\n.sidebar-close-btn { display: block; }\n.app-main { margin-left: 0px; padding-bottom: calc(var(--mobile-nav-height) + var(--player-bar-height)); }\n.mobile-bottom-nav { display: flex; }\n.mobile-hamburger { display: block; }\n.unified-player-bar { left: 0px; bottom: var(--mobile-nav-height); }\n.player-bar-inner { flex-wrap: wrap; }\n.player-track-info { min-width: auto; flex: 0 1 auto; }\n.player-right-controls { display: none; }\n.discover-grid { grid-template-columns: 1fr; }\n.reader-toolbar { flex-direction: column; align-items: stretch; }\n.reader-search-input { width: 100%; }\n}\n:root { --bg-gradient: linear-gradient(135deg, #1e1e2f, #3a3a5a); --card-bg: rgba(255, 255, 255, 0.08); --card-backdrop: blur(12px); --primary-text: #e1e1e6; --secondary-text: #b3b3c1; --accent: #1db954; }\nbody { background: var(--bg-gradient); color: var(--primary-text); font-family: Inter, sans-serif; min-height: 100vh; margin: 0px; }\n.spotify-section { padding: 2rem; }\n.spotify-card { background: var(--card-bg); backdrop-filter: var(--card-backdrop); border-radius: 12px; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; }\n.spotify-card:hover { transform: translateY(-4px); box-shadow: rgba(0, 0, 0, 0.4) 0px 8px 32px; }\n.spotify-card img { width: 100%; height: auto; }\n.spotify-card-body { padding: 0.75rem; }\n.spotify-card-title { font-size: 1rem; font-weight: 600; color: var(--primary-text); }\n.spotify-card-artist { font-size: 0.875rem; color: var(--secondary-text); }\n.spotify-action-btn { background: none; border: none; color: var(--accent); cursor: pointer; font-size: 1.2rem; }\n.spotify-hero { background: var(--bg-gradient); padding: 3rem 1rem; text-align: center; }\n.spotify-tabs { margin: 1rem 0px; display: flex; gap: 0.5rem; }\n.spotify-tab { background: rgba(255, 255, 255, 0.1); border: none; padding: 0.5rem 1rem; border-radius: 8px; color: var(--primary-text); cursor: pointer; }\n.spotify-tab.active { background: var(--accent); color: rgb(255, 255, 255); }\n.spotify-error { color: rgb(255, 107, 107); margin-top: 0.5rem; }\n.spotify-loading { color: var(--secondary-text); }\n.spotify-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }\n.spotify-playlist-select { margin-top: 0.5rem; background: rgba(255, 255, 255, 0.1); color: var(--primary-text); border: none; padding: 0.25rem; }\n.spotify-saved-msg { color: var(--accent); margin-left: 0.5rem; }\n@font-face { font-family: Caveat; font-style: normal; font-weight: 400; font-display: swap; src: url(\"https://fonts.gstatic.com/s/caveat/v23/Wnz6HAc5bAfYB2Q7azYYmg8.woff2\") format(\"woff2\"); unicode-range: U+460-52F, U+1C80-1C8A, U+20B4, U+2DE0-2DFF, U+A640-A69F, U+FE2E-FE2F; }\n@font-face { font-family: Caveat; font-style: normal; font-weight: 400; font-display: swap; src: url(\"ht