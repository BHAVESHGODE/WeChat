m; overflow-x: auto; scroll-snap-type: x mandatory; padding: 0.5rem 0px 1rem; scrollbar-width: none; }\n.playlist-carousel::-webkit-scrollbar { display: none; }\n.playlist-carousel-card { flex: 0 0 85%; max-width: 260px; scroll-snap-align: start; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 12px; padding: 1.25rem; cursor: pointer; transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; gap: 0.75rem; text-align: left; min-width: 44px; min-height: 44px; box-shadow: rgba(0, 0, 0, 0.25) 0px 4px 30px; }\n.playlist-carousel-card:hover { background: rgba(255, 255, 255, 0.08); border-color: rgba(16, 185, 129, 0.25); transform: translateY(-4px); box-shadow: rgba(16, 185, 129, 0.12) 0px 10px 30px; }\n.playlist-carousel-card.active { background: rgba(16, 185, 129, 0.08); border-color: var(--spotify-accent); }\n.playlist-carousel-icon { font-size: 2.5rem; background: rgb(40, 40, 40); width: 100%; aspect-ratio: 1 / 1; display: flex; align-items: center; justify-content: center; border-radius: 6px; box-shadow: rgba(0, 0, 0, 0.3) 0px 8px 16px; object-fit: cover; }\n.playlist-carousel-name { font-size: 1rem; font-weight: 700; color: var(--spotify-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.playlist-carousel-count { font-size: 0.8rem; color: var(--spotify-text-dim); font-weight: 500; }\n.playlist-tracks-modal { background: rgba(20, 20, 25, 0.98); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 12px; margin-top: 1rem; overflow: hidden; animation: 0.3s ease 0s 1 normal none running fadeUp; }\n.playlist-tracks-header { display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255, 255, 255, 0.06); }\n.playlist-tracks-header h3 { font-size: 1.1rem; font-weight: 800; color: var(--spotify-text); }\n.playlist-tracks-close { background: none; border: none; color: var(--spotify-text-dim); font-size: 1.25r