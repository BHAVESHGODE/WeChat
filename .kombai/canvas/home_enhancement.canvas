      "html": "\n<section class=\"relative min-h-screen w-full flex flex-col items-center justify-center overflow-x-hidden font-['Crimson_Text'] bg-black\" data-kid=\"0\">\n    \n    \n    <div class=\"fixed inset-0 pointer-events-none opacity-[0.03] z-50 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')]\" data-kid=\"1\"></div>\n\n    \n    <div class=\"fixed inset-0 z-0\" data-kid=\"2\">\n        <video src=\"https://kombai-assets.b-cdn.net/generated_assets/91a26b3e-751c-465b-b58d-def7ecb58607/c9ab74b6c82d43a895f9d8e56b33b4b3.mp4\" poster=\"https://images.pexels.com/photos/35719475/pexels-photo-35719475.jpeg?auto=compress&cs=tinysrgb&w=1920&q=80\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover\" data-kid=\"3\"></video>\n        \n        \n        <div class=\"absolute inset-0 bg-radial-[circle_at_center,_transparent_30%,_black_95%] opacity-90\" data-kid=\"4\"></div>\n        <div class=\"absolute inset-0 bg-black/60 backdrop-blur-[2px]\" data-kid=\"5\"></div>\n    </div>\n\n    \n    <div class=\"relative z-10 w-full max-w-7xl mx-auto px-6 py-16 flex flex-col items-center justify-between min-h-screen\" data-kid=\"6\">\n        \n        \n        <div id=\"logo-container\" class=\"logo-box relative w-full max-w-[560px] h-[220px] bg-[#2A140E] rounded-sm border-[1px] border-[#D4AF37]/40 shadow-[0_50px_100px_-30px_rgba(0,0,0,1),inset_0_2px_15px_rgba(255,255,255,0.1)] flex flex-col items-center justify-center overflow-hidden mt-8 mb-12 ring-12 ring-[#1A0F0A] ring-offset-1 ring-offset-[#D4AF37]/20\" data-kid=\"7\">\n            \n            <div class=\"absolute inset-0 opacity-25 pointer-events-none\" style=\"background-image: url('https://www.transparenttextures.com/patterns/leather.png');\" data-kid=\"8\"></div>\n            \n            \n            <div class=\"absolute inset-y-6 left-8 w-[2px] bg-gradient-to-b from-transparent via-[#D4AF37]/60 to-transparent\" data-kid=\"9\"></div>\n            <div 