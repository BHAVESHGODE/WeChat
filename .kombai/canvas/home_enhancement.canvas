tLeft {\n0% { transform: translate3d(0, var(--y), 0); }\n100% { visibility: hidden; transform: translate3d(-110%, var(--y), 0); }\n}\n@keyframes Toastify__slideOutDown {\n0% { transform: translate3d(0, var(--y), 0); }\n100% { visibility: hidden; transform: translate3d(0px, 500px, 0px); }\n}\n@keyframes Toastify__slideOutUp {\n0% { transform: translate3d(0, var(--y), 0); }\n100% { visibility: hidden; transform: translate3d(0px, -500px, 0px); }\n}\n.Toastify__slide-enter--top-left, .Toastify__slide-enter--bottom-left { animation-name: Toastify__slideInLeft; }\n.Toastify__slide-enter--top-right, .Toastify__slide-enter--bottom-right { animation-name: Toastify__slideInRight; }\n.Toastify__slide-enter--top-center { animation-name: Toastify__slideInDown; }\n.Toastify__slide-enter--bottom-center { animation-name: Toastify__slideInUp; }\n.Toastify__slide-exit--top-left, .Toastify__slide-exit--bottom-left { animation-name: Toastify__slideOutLeft; animation-timing-function: ease-in; animation-duration: 0.3s; }\n.Toastify__slide-exit--top-right, .Toastify__slide-exit--bottom-right { animation-name: Toastify__slideOutRight; animation-timing-function: ease-in; animation-duration: 0.3s; }\n.Toastify__slide-exit--top-center { animation-name: Toastify__slideOutUp; animation-timing-function: ease-in; animation-duration: 0.3s; }\n.Toastify__slide-exit--bottom-center { animation-name: Toastify__slideOutDown; animation-timing-function: ease-in; animation-duration: 0.3s; }\n@keyframes Toastify__spin {\n0% { transform: rotate(0deg); }\n100% { transform: rotate(360deg); }\n}\n.cinematic-home-container { position: relative; width: 100%; min-height: 100vh; overflow-x: hidden; background-color: rgb(11, 12, 16); font-family: Montserrat, sans-serif; color: white; }\n.glass-obsidian { background: linear-gradient(135deg, rgba(20, 20, 25, 0.75), rgba(10, 10, 12, 0.85)); backdrop-filter: blur(30px); border: 1px solid rgba(255, 255, 255, 0.07); box-shadow: rgba(0, 0, 0, 0.8) 0px 30px 60px -12px, rgba(255, 255, 255, 0.02) 0px 0px 30px inset; position: relative; }\n.glass-obsidian::before { content: \"\"; position: absolute; inset: 0px; background: radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.03) 0%, transparent 50%); pointer-events: none; }\n.gold-glow { text-shadow: rgba(255, 193, 7, 0.6) 0px 0px 15px, rgba(255, 193, 7, 0.3) 0px 0px 35px, rgba(255, 193, 7, 0.15) 0px 0px 70px; }\n.main-video-bg { position: fixed; inset: -40px; width: calc(100% + 80px); height: calc(100% + 80px); object-fit: cover; opacity: 0.65; z-index: 0; pointer-events: none; transform: scale(1.1); }\n.fog-overlay { position: absolute; inset: 0px; background: radial-gradient(circle, rgba(11, 12, 16, 0.2) 0%, rgba(11, 12, 16, 0.5) 40%, rgba(11, 12, 16, 0.98) 100%); z-index: 1; pointer-events: none; }\n.gradient-overlay { position: absolute; inset: 0px; background: linear-gradient(to top, rgb(11, 12, 16), transparent 40%, transparent 60%, rgba(11, 12, 16, 0.8)); z-index: 2; pointer-events: none; }\n.dust-particles-container { position: fixed; inset: 0px; z-index: 5; pointer-events: none; }\n.dust-particle { position: absolute; background: rgba(255, 255, 255, 0.3); border-radius: 50%; pointer-events: none; filter: blur(1px); }\n.shimmer-line { height: 1px; width: 120px; background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.2), transparent); }\n.main-content { position: relative; z-index: 10; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: space-between; padding: 5rem 2rem; }\n.logo-container { margin-bottom: 2rem; opacity: 0; transform: translateY(-40px); }\n.logo-plaque { padding: 2.5rem 6rem; border-radius: 2rem; overflow: hidden; text-align: center; }\n.logo-plaque h1 { font-family: \"Cinzel Decorative\", cursive; font-size: 5rem; color: rgb(255, 193, 7); font-weight: 700; letter-spacing: 0.6rem; margin: 0px; user-select: none; }\n.byline-container { display: flex; align-items: center; justify-content: center; gap: 1.5rem; margin-top: 1.5rem; }\n.accent-line { height: 1px; width: 3rem; background: rgba(255, 255, 255, 0.25); }\n.byline-text { font-size: 0.7rem; letter-spacing: 0.7em; text-transform: uppercase; color: rgba(255, 255, 255, 0.5); font-weight: 500; margin: 0px; }\n.orb-dock { display: flex; flex-wrap: wrap; justify-content: center; gap: 4rem; margin: 4rem 0px; width: 100%; max-width: 1000px; }\n.orb-item { display: flex; flex-direction: column; align-items: center; gap: 1rem; cursor: pointer; opacity: 0; transform: translateY(40px); }\n.orb-circle { width: 4.5rem; height: 4.5rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: 0.5s cubic-bezier(0.23, 1, 0.32, 1); }\n.orb-circle i { font-size: 2rem; }\n.orb-music .orb-circle { border-color: rgba(138, 43, 226, 0.3); box-shadow: rgba(138, 43, 226, 0.4) 0px 0px 25px; }\n.orb-music:hover .orb-circle { box-shadow: rgba(138, 43, 226, 0.7) 0px 0px 50px; }\n.orb-music i { color: rgb(138, 43, 226); }\n.orb-movies .orb-circle { border-color: rgba(220, 20, 60, 0.3); box-shadow: rgba(220, 20, 60, 0.4) 0px 0px 25px; }\n.orb-movies:hover .orb-circle { box-shadow: rgba(220, 20, 60, 0.7) 0px 0px 50px; }\n.orb-movies i { color: rgb(220, 20, 60); }\n.orb-anime .orb-circle { border-color: rgba(0, 255, 127, 0.3); box-shadow: rgba(0, 255, 127, 0.4) 0px 0px 25px; }\n.orb-anime:hover .orb-circle { box-shadow: rgba(0, 255, 127, 0.7) 0px 0px 50px; }\n.orb-anime i { color: rgb(0, 255, 127); }\n.orb-manga .orb-circle { border-color: rgba(255, 107, 107, 0.3); box-shadow: rgba(255, 107, 107, 0.4) 0px 0px 25px; }\n.orb-manga:hover .orb-circle { box-shadow: rgba(255, 107, 107, 0.7) 0px 0px 50px; }\n.orb-manga i { color: rgb(255, 107, 107); }\n.orb-books .orb-circle { border-color: rgba(255, 193, 7, 0.3); box-shadow: rgba(255, 193, 7, 0.3) 0px 0px 25px; }\n.orb-books:hover .orb-circle { box-shadow: rgba(255, 193, 7, 0.6) 0px 0px 50px; }\n.orb-books i { color: rgb(255, 193, 7); }\n.orb-study .orb-circle { border-color: rgba(236, 72, 153, 0.3); box-shadow: rgba(236, 72, 153, 0.3) 0px 0px 25px; }\n.orb-study:hover .orb-circle { box-shadow: rgba(236, 72, 153, 0.6) 0px 0px 50px; }\n.orb-study i { color: rgb(236, 72, 153); }\n.orb-games .orb-circle { border-color: rgba(59, 130, 246, 0.3); box-shadow: rgba(59, 130, 246, 0.3) 0px 0px 25px; }\n.orb-games:hover .orb-circle { box-shadow: rgba(59, 130, 246, 0.6) 0px 0px 50px; }\n.orb-games i { color: rgb(59, 130, 246); }\n.orb-chat .orb-circle { border-color: rgba(255, 255, 255, 0.3); box-shadow: rgba(255, 255, 255, 0.2) 0px 0px 25px; }\n.orb-chat:hover .orb-circle { box-shadow: rgba(255, 255, 255, 0.5) 0px 0px 50px; }\n.orb-chat i { color: rgb(255, 255, 255); }\n.orb-youtube .orb-circle { border-color: rgba(255, 0, 0, 0.3); box-shadow: rgba(255, 0, 0, 0.4) 0px 0px 25px; }\n.orb-youtube:hover .orb-circle { box-shadow: rgba(255, 0, 0, 0.7) 0px 0px 50px; }\n.orb-youtube i { color: rgb(255, 0, 0); }\n.path-section { width: 100%; max-width: 1300px; display: flex; flex-direction: column; align-items: center; gap: 3rem; margin-top: 2rem; }\n.path-header-wrapper { display: flex; align-items: center; gap: 4rem; opacity: 0; }\n.path-header-text { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1.1em; color: rgba(255, 255, 255, 0.4); font-weight: 500; font-style: italic; user-select: none; }\n.path-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3rem; width: 100%; min-height: 460px; }\n.path-card { position: relative; height: 460px; border-radius: 3.5rem; padding: 3rem; display: flex; flex-direction: column; justify-content: flex-end; cursor: pointer; overflow: hidden; opacity: 0; transform: translateY(60px); transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); }\n.card-icon-badge { position: absolute; top: 2.5rem; right: 2.5rem; width: 3.5rem; height: 3.5rem; border-radius: 1.25rem; display: flex; align-items: center; justify-content: center; transition: 0.6s cubic-bezier(0.23, 1, 0.32, 1); }\n.card-icon-badge i { font-size: 1.5rem; }\n.card-title { font-family: \"Cinzel Decorative\", cursive; font-size: 3.5rem; font-weight: 700; margin: 0px 0px 2.5rem; transition: color 0.4s; }\n.card-maverick { box-shadow: rgba(138, 43, 226, 0.5) 0px 0px 60px -20px; border-color: rgba(138, 43, 226, 0.15); }\n.card-maverick:hover { box-shadow: rgba(138, 43, 226, 0.8) 0px 0px 120px -5px; border-color: rgba(138, 43, 226, 0.5); }\n.card-maverick .card-icon-badge { background: rgba(138, 43, 226, 0.1); border: 1px solid rgba(138, 43, 226, 0.2); box-shadow: rgba(138, 43, 226, 0.1) 0px 0px 20px; }\n.card-maverick:hover .card-icon-badge { box-shadow: rgba(138, 43, 226, 0.5) 0px 0px 45px; }\n.card-maverick i { color: rgb(163, 112, 247); }\n.card-bell { box-shadow: rgba(220, 20, 60, 0.5) 0px 0px 60px -20px; border-color: rgba(220, 20, 60, 0.15); }\n.card-bell:hover { box-shadow: rgba(220, 20, 60, 0.8) 0px 0px 120px -5px; border-color: rgba(220, 20, 60, 0.5); }\n.card-bell .card-icon-badge { background: rgba(220, 20, 60, 0.1); border: 1px solid rgba(220, 20, 60, 0.2); box-shadow: rgba(220, 20, 60, 0.1) 0px 0px 20px; }\n.card-bell:hover .card-icon-badge { box-shadow: rgba(220, 20, 60, 0.5) 0px 0px 45px; }\n.card-bell i { color: rgb(220, 20, 60); }\n.card-goju { box-shadow: rgba(0, 255, 127, 0.5) 0px 0px 60px -20px; border-color: rgba(0, 255, 127, 0.15); }\n.card-goju:hover { box-shadow: rgba(0, 255, 127, 0.8) 0px 0px 120px -5px; border-color: rgba(0, 255, 127, 0.5); }\n.card-goju .card-icon-badge { background: rgba(0, 255, 127, 0.1); border: 1px solid rgba(0, 255, 127, 0.2); box-shadow: rgba(0, 255, 127, 0.1) 0px 0px 20px; }\n.card-goju:hover .card-icon-badge { box-shadow: rgba(0, 255, 127, 0.5) 0px 0px 45px; }\n.card-goju i { color: rgb(0, 255, 127); }\n.dock-spark { position: absolute; pointer-events: none; border-radius: 50%; }\n.cinematic-home-container::-webkit-scrollbar { display: none; }\n@media (max-width: 1024px) {\n.path-grid { grid-template-columns: 1fr; }\n.logo-plaque 