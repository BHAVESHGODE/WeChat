      "html": "\n<div class=\"relative h-screen w-full flex flex-col items-center justify-between py-8 px-0 overflow-hidden font-['Plus_Jakarta_Sans',sans-serif]\" data-kid=\"0\">\n    \n    \n    <div class=\"fixed inset-0 z-0 bg-slate-950\" data-kid=\"1\">\n        <video src=\"https://kombai-assets.b-cdn.net/generated_assets/91a26b3e-751c-465b-b58d-def7ecb58607/c9ab74b6c82d43a895f9d8e56b33b4b3.mp4\" poster=\"https://kombai-assets.b-cdn.net/generated_assets/91a26b3e-751c-465b-b58d-def7ecb58607/c9ab74b6c82d43a895f9d8e56b33b4b3.mp4?poster\" autoplay muted loop playsinline class=\"w-full h-full object-cover opacity-80\" data-kid=\"2\"></video>\n        \n        <div class=\"absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/20\" data-kid=\"3\"></div>\n    </div>\n\n    \n    <div class=\"relative z-10 w-full flex flex-col items-center flex-grow\" data-kid=\"4\">\n        \n        \n        <header class=\"logo-plaque-container mb-8\" id=\"logo-plaque\" data-kid=\"5\">\n            <div class=\"relative px-12 py-6 rounded-[28px] border border-white/30 bg-white/10 backdrop-blur-[40px] shadow-[0_32px_64px_rgba(0,0,0,0.2),inset_0_0_40px_rgba(255,255,255,0.15)]\" data-kid=\"6\">\n                <div class=\"text-center\" data-kid=\"7\">\n                    <h1 class=\"text-6xl font-black tracking-tighter bg-gradient-to-br from-[#E8D08D] via-[#FFCCB3] to-[#E8D08D] bg-clip-text text-transparent filter drop-shadow-[0_4px_12px_rgba(0,0,0,0.1)]\" data-kid=\"8\">\n                        WeGift\n                    </h1>\n                    <div class=\"flex items-center justify-center gap-4 mt-3\" data-kid=\"9\">\n                        <div class=\"h-[1px] w-6 bg-white/40\" data-kid=\"10\"></div>\n                        <p class=\"text-[11px] tracking-[0.6em] font-bold text-white uppercase opacity-90\" data-kid=\"11\">Luxury Gifting</p>\n                        <div class=\"h-[1px] w-6 bg-white/40\" data-kid=\"12\"></div>\n                    </di