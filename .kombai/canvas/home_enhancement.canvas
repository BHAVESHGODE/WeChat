, 0, 0.4) 0px 8px 16px; transition: transform 0.4s; }\n.artist-card:hover .artist-card-img { transform: scale(1.04); }\n.artist-card-name { font-size: 1rem; font-weight: 700; color: var(--spotify-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%; margin-bottom: 0.25rem; }\n.artist-card-type { font-size: 0.8rem; color: var(--spotify-text-dim); font-weight: 500; }\n.album-card { background: var(--spotify-card); border: 1px solid rgba(255, 255, 255, 0.04); border-radius: 8px; padding: 1rem; cursor: pointer; transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; text-align: left; }\n.album-card:hover { background: var(--spotify-card-hover); border-color: rgba(16, 185, 129, 0.25); transform: translateY(-6px); box-shadow: rgba(16, 185, 129, 0.12) 0px 10px 30px; }\n.album-card-img { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; border-radius: 6px; margin-bottom: 1rem; box-shadow: rgba(0, 0, 0, 0.4) 0px 8px 16px; transition: transform 0.4s; }\n.album-card:hover .album-card-img { transform: scale(1.04); }\n.album-card-title { font-size: 1rem; font-weight: 700; color: var(--spotify-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 0.25rem; }\n.album-card-artists { font-size: 0.8rem; color: var(--spotify-text-dim); font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.discover-suggestions-box { margin-top: 1.5rem; margin-bottom: 2rem; animation: 0.3s ease 0s 1 normal none running fadeIn; }\n.discover-suggestions-title { font-size: 0.95rem; font-weight: 800; color: var(--spotify-text-dim); margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; }\n.discover-suggestions-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }\n.discover-suggestion-tag { display: inline-flex; align-items: center; gap: 0.35rem; background: rgb(36, 36, 36); border: 1px solid rgba(255, 255, 255, 0.05); padding: 0.6rem 1.25rem; border-radius: 500px; color: var(--spotify-text); font-size: 0.875rem; font-weight: 700; cursor: pointer; transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1); }\n.discover-suggestion-tag:hover { background: var(--spotify-accent); color: rgb(0, 0, 0); border-color: var(--spotify-accent); transform: translateY(-2px); box-shadow: rgba(16, 185, 129, 0.2) 0px 4px 12px; }\n.discover-search-clear-btn { position: absolute; right: 1.2rem; background: none; border: none; color: rgb(167, 167, 167); font-size: 0.95rem; cursor: pointer; transition: color 0.2s; z-index: 3; }\n.discover-search-clear-btn:hover { color: rgb(255, 255, 255); }\n.discover-search-input { padding-right: 3.2rem !important; }\n.discover-vibe-recommendations { margin-top: 2rem; margin-bottom: 2rem; animation: 0.4s ease 0s 1 normal none running fadeIn; }\n.discover-vibe-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.2rem; flex-wrap: wrap; gap: 1rem; }\n.discover-vibe-title { font-size: 1.25rem; font-weight: 800; color: var(--spotify-text); margin: 0px; }\n.autoplay-vibe-toggle-wrap { display: flex; align-items: center; gap: 0.75rem; }\n.autoplay-vibe-label { font-size: 0.85rem; font-weight: 700; color: var(--spotify-text-dim); }\n.player-bar { padding-top: 12px !important; }\n.player-progress-container { display: flex; align-items: center; position: absolute; top: -8px; left: 0px; right: 0px; z-index: 10; padding: 0px 1rem; width: 100%; box-sizing: border-box; }\n.player-progress-track { flex: 1 1 0%; height: 4px; background: rgba(255, 255, 255, 0.15); cursor: pointer; position: relative; transition: height 0.15s; margin: 0px 10px; border-radius: 2px; }\n.player-progress-track:hover { height: 6px; }\n.player-time-elapsed, .player-time-duration { font-size: 0.7rem; color: var(--spotify-text-dim); font-weight: 700; min-width: 35px; text-align: center; user-select: none; }\n.player-controls { gap: 1.25rem !important; }\n.player-btn-shuffle.active, .player-btn-repeat.active, .player-btn-lyrics.active { color: var(--spotify-accent) !important; }\n.player-btn-seek { color: var(--spotify-text-dim); opacity: 0.75; }\n.player-btn-seek:hover { opacity: 1; transform: scale(1.08); }\n.player-volume-wrap { position: relative; }\n.player-volume-slider { position: absolute; bottom: calc(100% + 12px); right: -8px; background: rgb(24, 24, 24); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 8px; padding: 0.8rem 0.6rem; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; box-shadow: rgba(0, 0, 0, 0.6) 0px 10px 25px; z-index: 100; min-width: 46px; animation: 0.15s cubic-bezier(0.4, 0, 0.2, 1) 0s 1 normal none running fadeIn; }\n.player-volume-slider input[type=\"range\"] { appearance: slider-vertical; width: 6px; height: 90px; accent-color: var(--spotify-accent); background: rgba(255, 255, 255, 0.1); border-radius: 4px; outline: none; }\n.player-volume-slider span { font-size: 0.65rem; color: var(--spotify-text); font-weight: 700; text-align: center; }\n@keyframes fadeIn {\n0% { opacity: 0; transform: translateY(5px); }\n100% { opacity: 1; transform: translateY(0px); }\n}\n:root { --anime-bg: linear-gradient(135deg, #0f0f13 0%, #1a0a2e 50%, #0f1923 100%); --anime-accent: #ff6b9d; --anime-accent2: #7c4dff; --anime-accent3: #00d4ff; --manga-accent: #43e97b; --manga-accent2: #ffa751; }\n.anime-page { width: 100%; min-height: 100vh; background: var(--anime-bg); display: flex; flex-direction: column; }\n.anime-header { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2rem; background: rgba(15, 15, 19, 0.8); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border-glass); position: sticky; top: 0px; z-index: 100; }\n.anime-header-left { display: flex; align-items: center; gap: 1rem; }\n.anime-header-right { display: flex; align-items: center; gap: 0.75rem; }\n.anime-logo { font-size: 1.4rem; font-weight: 900; background: linear-gradient(135deg, rgb(255, 107, 157), rgb(124, 77, 255), rgb(0, 212, 255)) text; -webkit-text-fill-color: transparent; cursor: pointer; }\n.anime-back-btn { background: var(--bg-glass); border: 1px solid var(--border-glass); border-radius: var(--radius-full); padding: 0.4rem 1rem; font-family: var(--font); font-size: 0.85rem; cursor: pointer; color: var(--text-secondary); transition: all var(--transition); }\n.anime-back-btn:hover { background: var(--bg-card-hover); color: var(--text-primary); }\n.anime-layout { display: flex; flex: 1 1 0%; }\n.anime-sidebar { width: 220px; flex-shrink: 0; background: rgba(15, 15, 19, 0.6); backdrop-filter: blur(12px); border-right: 1px solid var(--border-glass); padding: 1.5rem 0px; display: flex; flex-direction: column; gap: 0.25rem; position: sticky; top: 73px; height: calc(-73px + 100vh); overflow-y: auto; }\n.anime-sidebar-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1.5rem; color: var(--text-secondary); text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: all var(--transition); border: none; background: none; width: 100%; text-align: left; cursor: pointer; font-family: var(--font); }\n.anime-sidebar-item:hover { background: rgba(255, 255, 255, 0.05); color: var(--text-primary); }\n.anime-sidebar-item.active { background: rgba(124, 77, 255, 0.12); color: var(--accent-1); border-right: 3px solid var(--accent-1); }\n.anime-sidebar-icon { font-size: 1.2rem; width: 24px; text-align: center; }\n.anime-sidebar-label { color: var(--text-tertiary); padding: 0.5rem 1.5rem 0.25rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.7rem; }\n.anime-content { flex: 1 1 0%; padding: 1.5rem 2rem; overflow-y: auto; max-height: calc(-73px + 100vh); }\n.anime-content-title { font-size: 1.8rem; font-weight: 800; margin-bottom: 0.25rem; background: linear-gradient(135deg, rgb(255, 107, 157), rgb(124, 77, 255)) text; -webkit-text-fill-color: transparent; }\n.anime-content-subtitle { font-size: 0.95rem; color: var(--text-secondary); margin-bottom: 1.5rem; }\n.anime-search-bar { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap; align-items: center; }\n.anime-search-input { flex: 1 1 0%; min-width: 200px; padding: 0.75rem 1rem; background: rgba(255, 255, 255, 0.06); border: 1px solid var(--border-glass); border-radius: var(--radius-md); font-family: var(--font); font-size: 0.95rem; outline: none; color: var(--text-primary); transition: border-color var(--transition); }\n.anime-search-input:focus { border-color: var(--anime-accent); }\n.anime-filter-select { padding: 0.7rem 0.8rem; background: rgba(255, 255, 255, 0.06); border: 1px solid var(--border-glass); border-radius: var(--radius-md); font-family: var(--font); font-size: 0.85rem; outline: none; color: var(--text-primary); cursor: pointer; min-width: 130px; }\n.anime-filter-select:focus { border-color: var(--anime-accent); }\n.anime-masonry { column-count: 5; column-gap: 1rem; padding: 0px; }\n@media (max-width: 1400px) {\n.anime-masonry { column-count: 4; }\n}\n@media (max-width: 1100px) {\n.anime-masonry { column-count: 3; }\n}\n@media (max-width: 800px) {\n.anime-masonry { column-count: 2; }\n}\n@media (max-width: 500px) {\n.anime-masonry { column-count: 1; }\n}\n.anime-masonry-item { break-inside: avoid; margin-bottom: 1rem; animation: 0.5s ease 0s 1 normal none running fadeUp; }\n.anime-card { background: var(--bg-card); backdrop-filter: blur(12px); border: 1px solid var(--border-glass); border-radius: var(--radius-lg); overflow: hidden; cursor: pointer; transition: all var(--transition); position: relative; }\n.anime-card:hover { background: var(--bg-card-hover); transform: translateY(-6px); box-shadow: var(--shadow-lg), 0 0 30px rgba(124, 77, 255, 0.1); }\n.anime-card-img-wrap { position: relative; overflow: hidden; aspect-ratio: 3 / 4; }\n.anime-card-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }\n.anime-card:hover .anime-card-img { transform: scale(1.08); }\n.anime-card-overlay { position: a