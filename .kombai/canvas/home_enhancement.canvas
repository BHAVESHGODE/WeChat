4px; --radius-lg: 20px; --radius-xl: 28px; --radius-full: 999px; --bg-primary: #0f0f13; --bg-secondary: #1a1a23; --bg-card: rgba(255, 255, 255, 0.06); --bg-card-hover: rgba(255, 255, 255, 0.10); --bg-glass: rgba(255, 255, 255, 0.05); --border-glass: rgba(255, 255, 255, 0.08); --text-primary: #ffffff; --text-secondary: rgba(255, 255, 255, 0.65); --text-tertiary: rgba(255, 255, 255, 0.35); --accent-1: #7c4dff; --accent-2: #43e97b; --accent-3: #ff6b9d; --accent-4: #00d4ff; --gradient-1: linear-gradient(135deg, #7c4dff, #43e97b); --gradient-2: linear-gradient(135deg, #ff6b9d, #ffa751); --gradient-3: linear-gradient(135deg, #00d4ff, #7c4dff); --gradient-bg: linear-gradient(135deg, #0f0f13 0%, #1a1a2e 50%, #16213e 100%); --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.2); --shadow-md: 0 8px 24px rgba(0, 0, 0, 0.25); --shadow-lg: 0 16px 48px rgba(0, 0, 0, 0.35); --shadow-glow: 0 0 20px rgba(124, 77, 255, 0.15); --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1); }\n* { margin: 0px; padding: 0px; box-sizing: border-box; }\nbody { font-family: var(--font); background: var(--bg-primary); color: var(--text-primary); min-height: 100vh; -webkit-font-smoothing: antialiased; }\n::-webkit-scrollbar { width: 6px; }\n::-webkit-scrollbar-track { background: transparent; }\n::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 3px; }\n::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }\n.app { min-height: 100vh; display: flex; flex-direction: column; }\n.app-content { flex: 1 1 0%; display: flex; flex-direction: column; padding-bottom: 90px; min-height: 100vh; }\n.app-content > * { flex: 1 1 0%; }\n@keyframes fadeUp {\n0% { opacity: 0; transform: translateY(20px); }\n100% { opacity: 1; transform: translateY(0px); }\n}\n@keyframes fadeIn {\n0% { opacity: 0; }\n100% { opacity: 1; }\n}\n@keyframes slideUp {\n0% { opacity: 0; transform: translateY(30px); }\n100% { opacity: 1; transform: translateY(0px); }\n}\n@keyframes scaleIn {\n0% { opacity: 0; transform: scale(0.95); }\n100% { opacity: 1; transform: scale(1); }\n}\n@keyframes spin {\n100% { transform: rotate(360deg); }\n}\n@keyframes shimmer {\n0% { background-position: -200% 0px; }\n100% { background-position: 200% 0px; }\n}\n@keyframes pulse {\n0%, 100% { opacity: 0.6; }\n50% { opacity: 1; }\n}\n.animate-fade-up { animation: 0.5s ease 0s 1 normal none running fadeUp; }\n.animate-slide-up { animation: 0.6s ease 0s 1 normal none running slideUp; }\n.animate-scale-in { animation: 0.4s ease 0s 1 normal none running scaleIn; }\n.loading-spinner { width: 36px; height: 36px; border-width: 3px; border-style: solid; border-right-color: rgba(255, 255, 255, 0.06); border-bottom-color: rgba(255, 255, 255, 0.06); border-left-color: rgba(255, 255, 255, 0.06); border-image: initial; border-top-color: var(--accent-1); border-radius: 50%; animation: 0.8s linear 0s infinite normal none running spin; }\n.glass-card { background: var(--bg-card); backdrop-filter: blur(12px); border: 1px solid var(--border-glass); border-radius: var(--radius-lg); transition: all var(--transition); }\n.glass-card:hover { background: var(--bg-card-hover); transform: translateY(-4px); box-shadow: var(--shadow-lg); }\n.pill-btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.55rem 1.25rem; border: none; border-radius: var(--radius-full); font-family: var(--font); font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all var(--transition); color: rgb(255, 255, 255); }\n.pill-btn.primary { background: var(--gradient-1); }\n.pill-btn.primary:hover { box-shadow: rgba(124, 77, 255, 0.4) 0px 4px 16px; transform: translateY(-2px); }\n.pill-btn.secondary { background: rgba(255, 255, 255, 0.08); border: 1px solid var(--border-glass); }\n.pill-btn.secondary:hover { background: rgba(255, 255, 255, 0.14); }\n.pill-btn.glow:hover { box-shadow: var(--shadow-glow); }\n.pill-btn:disabled { opacity: 0.5; cursor: not-allowed; }\n.login-container { text-align: center; padding: 2rem; animation: 0.6s ease 0s 1 normal none running fadeUp; }\n.login-title { font-size: 3rem; font-weight: 900; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.5rem; }\n.login-subtitle { font-size: 1.1rem; color: var(--text-secondary); margin-bottom: 3rem; }\n.login-buttons { display: flex; gap: 1.5rem; flex-wrap: wrap; justify-content: center; }\n.login-btn { border: none; border-radius: var(--radius-lg); padding: 2rem 2.5rem; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; color: rgb(255, 255, 255); font-size: 1.2rem; font-weight: 600; box-shadow: var(--shadow-md); transition: all var(--transition); min-width: 170px; position: relative; overflow: hidden; }\n.login-btn::before { content: \"\"; position: absolute; inset: 0px; opacity: 0; background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), transparent); transition: opacity var(--transition); }\n.login-btn:hover { transform: translateY(-8px) scale(1.02); box-shadow: var(--shadow-lg); }\n.login-btn:hover::before { opacity: 1; }\n.login-btn-emoji { font-size: 2.5rem; }\n.dashboard-container { width: 100%; min-height: 100vh; display: flex; align-items: center; justify-content: center; flex-direction: column; padding: 2rem; position: relative; background: var(--gradient-bg); }\n.back-btn { position: absolute; top: 1.5rem; left: 1.5rem; background: var(--bg-glass); border: 1px solid var(--border-glass); border-radius: var(--radius-full); padding: 0.5rem 1.2rem; font-family: var(--font); font-size: 0.9rem; cursor: pointer; color: var(--text-secondary); transition: all var(--transition); }\n.back-btn:hover { background: var(--bg-card-hover); color: var(--text-primary); }\n.dashboard-card { background: var(--bg-card); backdrop-filter: blur(16px); border: 1px solid var(--border-glass); border-radius: var(--radius-xl); padding: 3rem 4rem; text-align: center; max-width: 480px; width: 100%; animation: 0.5s ease 0s 1 normal none running scaleIn; }\n.dashboard-greeting { font-size: 2rem; margin-bottom: 1.5rem; }\n.dashboard-info p { font-size: 1.1rem; color: var(--text-secondary); margin-bottom: 0.75rem; }\n.dashboard-loading { color: var(--text-tertiary); font-style: italic; }\n.study-room-btn { border: none; border-radius: var(--radius-full); padding: 0.85rem 2rem; color: rgb(255, 255, 255); font-family: var(--font); font-size: 1.05rem; font-weight: 600; cursor: pointer; transition: all var(--transition); box-shadow: var(--shadow-md); }\n.study-room-btn:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }\n.dashboard-links { display: flex; gap: 0.75rem; margin-top: 1.5rem; flex-wrap: wrap; justify-content: center; }\n.study-room { width: 100%; min-height: 100vh; padding: 2rem; background: var(--gradient-bg); }\n.study-room-title { text-align: center; font-size: 2.2rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.25rem; }\n.study-room-subtitle { text-align: center; color: var(--text-secondary); margin-bottom: 2rem; font-size: 1.05rem; }\n.study-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; max-width: 1100px; margin: 0px auto 2rem; }\n.study-card { background: var(--bg-card); backdrop-filter: blur(12px); border: 1px solid var(--border-glass); border-radius: var(--radius-lg); padding: 1.75rem; text-align: center; animation: 0.5s ease 0s 1 normal none running fadeUp; transition: all var(--transition); }\n.study-card:hover { background: var(--bg-card-hover); transform: translateY(-3px); box-shadow: var(--shadow-md); }\n.study-card-title { font-size: 1.2rem; color: var(--text-primary); margin-bottom: 1rem; font-weight: 600; }\n.timer-display { font-size: 3rem; font-weight: 800; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; letter-spacing: 4px; margin-bottom: 1rem; font-variant-numeric: tabular-nums; }\n.timer-buttons { display: flex; gap: 0.75rem; justify-content: center; }\n.study-btn { border: none; border-radius: var(--radius-full); padding: 0.6rem 1.4rem; font-family: var(--font); font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all var(--transition); }\n.study-btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-sm); }\n.timer-btn { background: var(--gradient-1); color: rgb(255, 255, 255); }\n.timer-reset { background: rgba(255, 255, 255, 0.08); color: var(--text-secondary); border: 1px solid var(--border-glass); }\n.audio-btn { background: var(--gradient-2); color: rgb(255, 255, 255); font-size: 1.05rem; padding: 0.75rem 2rem; }\n.audio-embed { margin-top: 1rem; border-radius: var(--radius-md); overflow: hidden; }\n.audio-embed iframe { width: 100%; height: 180px; border: none; }\n.quotes-card { min-height: 180px; display: flex; flex-direction: column; justify-content: center; }\n.quote-text { font-size: 1.05rem; font-style: italic; color: var(--text-primary); margin-bottom: 0.5rem; line-height: 1.5; }\n.quote-author { font-size: 0.9rem; color: var(--text-tertiary); margin-bottom: 1rem; }\n.quote-btn { background: var(--gradient-1); color: rgb(255, 255, 255); align-self: center; }\n.auth-page { width: 100%; min-height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--gradient-bg); padding: 2rem; }\n.auth-card { background: var(--bg-card); backdrop-filter: blur(16px); border: 1px solid var(--border-glass); border-radius: var(--radius-xl); padding: 2.5rem 3rem; text-align: center; max-width: 420px; width: 100%; animation: 0.4s ease 0s 1 normal none running scaleIn; }\n.auth-title { font-size: 2rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.25rem; }\n.auth-subtitle { font-size: 1rem; color: var(--text-secondary); margin-bottom: 2rem; }\n.auth-input { width: 100%; padding: 0.75rem 1rem; margin-bottom: 1rem; background: rgba(255, 255, 255, 0.06); border: 1px solid var(--border-glass); border-radius: var(--radius-md); font-family: var(--font); font-size: 0.95rem; outline: none; color: var(--text-primary); transition: border-color var(--transition); }\n.auth-input:focus { border-color: var(--accent-1); }\n.auth-btn { width: 100%; padding: 0.8rem; border: none; border-radius: var(--radius-md); background: var(--gradient-1); color: rgb(255, 255, 255); font-family: var(--font); font-size: 1.05rem; font-weight: 600; cursor: pointer; transition: all var(--transition); }\n.auth-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: var(--shadow-glow); }\n.auth-btn:disabled { opacity: 0.6; cursor: not-allowed; }\n.auth-error { color: var(--accent-3); background: rgba(255, 107, 157, 0.1); padding: 0.6rem 1rem; border-radius: var(--radius-md); font-size: 0.85rem; margin-bottom: 1rem; border: 1px solid rgba(255, 107, 157, 0.2); }\n.auth-link { margin-top: 1.2rem; font-size: 0.9rem; color: var(--text-secondary); }\n.auth-link a { color: var(--accent-1); text-decoration: none; font-weight: 600; }\n.auth-link a:hover { text-decoration: underline; }\n.auth-logout-btn { background: var(--bg-glass); border: 1px solid var(--border-glass); color: var(--text-secondary); padding: 0.4rem 1rem; border-radius: var(--radius-full); cursor: pointer; font-family: var(--font); font-size: 0.85rem; transition: all var(--transition); position: absolute; top: 1.5rem; right: 1.5rem; }\n.auth-logout-btn:hover { background: var(--bg-card-hover); color: var(--text-primary); }\n.venting-page { width: 100%; min-height: 100vh; display: flex; flex-direction: column; background: var(--gradient-bg); padding: 1rem 1rem 0px; }\n.venting-header { text-align: center; padding: 0.5rem 0px 0.25rem; }\n.venting-title { font-size: 1.6rem; font-weight: 800; color: var(--text-primary); }\n.venting-subtitle { color: var(--text-secondary); font-size: 0.95rem; margin-top: 0.15rem; }\n.chat-window { flex: 1 1 0%; overflow-y: auto; padding: 1rem 0.5rem; display: flex; flex-direction: column; gap: 0.6rem; max-width: 680px; width: 100%; margin: 0px auto; }\n.chat-empty { text-align: center; color: var(--text-tertiary); margin-top: 3rem; font-style: italic; }\n.chat-empty-hint { font-size: 0.9rem; color: var(--text-tertiary); margin-top: 0.3rem; }\n.chat-bubble { display: flex; flex-direction: column; max-width: 80%; animation: 0.3s ease 0s 1 normal none running fadeUp; }\n.chat-bubble.user { align-self: flex-end; align-items: flex-end; }\n.chat-bubble.ai { align-self: flex-start; align-items: flex-start; }\n.chat-bubble-content { display: flex; align-items: flex-start; gap: 0.5rem; }\n.chat-bubble.user .chat-bubble-content { flex-direction: row-reverse; }\n.chat-text { background: var(--bg-card); backdrop-filter: blur(8px); padding: 0.7rem 1rem; border-radius: 18px; font-size: 0.95rem; color: var(--text-primary); line-height: 1.5; word-break: break-word; border: 1px solid var(--border-glass); }\n.chat-bubble.user .chat-text { background: rgba(124, 77, 255, 0.2); border-color: rgba(124, 77, 255, 0.3); border-bottom-right-radius: 4px; }\n.chat-bubble.ai .chat-text { background: var(--bg-card); border-bottom-left-radius: 4px; }\n.chat-avatar { font-size: 1.4rem; flex-shrink: 0; margin-top: 0.2rem; }\n.chat-time { font-size: 0.7rem; color: var(--text-tertiary); margin-top: 0.2rem; padding: 0px 0.5rem; }\n.chat-meta { display: flex; align-items: center; gap: 0.4rem; margin-top: 0.2rem; }\n.provider-badge { font-size: 0.6rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; padding: 0.15rem 0.45rem; border-radius: var(--radius-sm); background: rgba(255, 255, 255, 0.08); color: var(--text-secondary); }\n.provider-badge.nvapi { background: rgb(118, 185, 0); color: rgb(255, 255, 255); }\n.provider-badge.openai { background: rgb(16, 163, 127); color: rgb(255, 255, 255); }\n.provider-badge.gemini { background: rgb(66, 133, 244); color: rgb(255, 255, 255); }\n.provider-badge.fallback { background: rgb(255, 152, 0); color: rgb(255, 255, 255); }\n.typing-dots { display: flex; align-items: center; gap: 2px; background: var(--bg-card); padding: 0.7rem 1.2rem; border-radius: 18px 18px 18px 4px; border: 1px solid var(--border-glass); }\n.typing-dots span { font-size: 2rem; font-weight: 700; color: var(--accent-1); line-height: 1; animation: 1.2s ease 0s infinite normal none running dotPulse; }\n.typing-dots span:nth-child(2) { animation-delay: 0.2s; }\n.typing-dots span:nth-child(3) { animation-delay: 0.4s; }\n@keyframes dotPulse {\n0%, 60%, 100% { opacity: 0.3; transform: translateY(0px); }\n30% { opacity: 1; transform: translateY(-4px); }\n}\n.chat-input-bar { display: flex; gap: 0.5rem; padding: 0.75rem 1rem; background: var(--bg-glass); backdrop-filter: blur(12px); border-top: 1px solid var(--border-glass); max-width: 720px; width: 100%; margin: 0px auto; border-radius: var(--radius-lg) var(--radius-lg) 0 0; }\n.chat-input { flex: 1 1 0%; padding: 0.7rem 1rem; background: rgba(255, 255, 255, 0.06); border: 1px solid var(--border-glass); border-radius: var(--radius-md); font-family: var(--font); font-size: 0.95rem; outline: none; color: var(--text-primary); transition: border-color var(--transition); }\n.chat-input:focus { border-color: var(--accent-1); }\n.chat-send-btn { background: var(--gradient-1); color: rgb(255, 255, 255); border: none; border-radius: var(--radius-md); padding: 0.7rem 1.5rem; font-family: var(--font); font-weight: 600; font-size: 0.95rem; cursor: pointer; transition: all var(--transition); }\n.chat-send-btn:hover:not(:disabled) { box-shadow: var(--shadow-glow); transform: translateY(-1px); }\n.chat-send-btn:disabled { opacity: 0.5; cursor: not-allowed; }\n.chat-clear-btn { background: none; border: none; font-size: 1.2rem; cursor: pointer; padding: 0px 0.5rem; color: var(--text-secondary); transition: all var(--transition); }\n.chat-clear-btn:hover { transform: scale(1.15); color: var(--text-primary); }\n.games-page { width: 100%; min-height: 100vh; padding: 2rem; background: var(--gradient-bg); }\n.games-page-title { text-align: center; font-size: 2.2rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.25rem; }\n.games-page-subtitle { text-align: center; color: var(--text-secondary); margin-bottom: 2rem; font-size: 1.05rem; }\n.games-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; max-width: 650px; margin: 0px auto 2rem; }\n.game-card { background: var(--bg-card); backdrop-filter: blur(12px); border: 1px solid var(--border-glass); border-radius: var(--radius-lg); padding: 1.5rem 1rem; text-align: center; cursor: pointer; transition: all var(--transition); display: flex; flex-direction: column; align-items: center; gap: 0.3rem; }\n.game-card:hover { transform: translateY(-4px); border-color: rgba(0, 212, 255, 0.3); box-shadow: var(--shadow-md); }\n.game-card-icon { font-size: 2.2rem; }\n.game-card-label { font-size: 1.1rem; font-weight: 600; color: var(--text-primary); }\n.game-card-desc { font-size: 0.85rem; color: var(--text-tertiary); }\n.games-scores { max-width: 500px; margin: 0px auto; text-align: center; }\n.games-scores h3 { color: var(--text-secondary); margin-bottom: 0.75rem; }\n.scores-empty { color: var(--text-tertiary); font-style: italic; font-size: 0.9rem; }\n.score-row { display: flex; justify-content: space-between; padding: 0.4rem 0.8rem; background: var(--bg-glass); border-radius: var(--radius-sm); margin-bottom: 0.3rem; font-size: 0.9rem; }\n.score-game { font-weight: 600; color: var(--text-primary); text-transform: capitalize; }\n.score-pts { color: var(--accent-1); font-weight: 600; }\n.score-time { color: var(--text-tertiary); font-size: 0.8rem; }\n.game-active { display: flex; flex-direction: column; align-items: center; animation: 0.3s ease 0s 1 normal none running fadeUp; }\n.back-btn-inset { align-self: flex-start; margin-bottom: 1rem; position: static !important; }\n.game-inner { background: var(--bg-card); backdrop-filter: blur(8px); border: 1px solid var(--border-glass); border-radius: var(--radius-lg); padding: 1.5rem 2rem; text-align: center; animation: 0.3s ease 0s 1 normal none running fadeUp; }\n.game-name { font-size: 1.2rem; color: var(--text-primary); margin-bottom: 0.5rem; font-weight: 600; }\n.game-reset-btn { background: var(--gradient-1); color: rgb(255, 255, 255); border: none; border-radius: var(--radius-full); padding: 0.55rem 1.4rem; font-family: var(--font); font-size: 0.9rem; font-weight: 600; cursor: pointer; margin: 0.3rem; transition: all var(--transition); }\n.game-reset-btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-glow); }\n.ttt-status { font-size: 1rem; color: var(--text-secondary); margin-bottom: 0.75rem; }\n.ttt-status.winner { color: var(--accent-2); font-weight: 700; }\n.ttt-board { display: grid; grid-template-columns: repeat(3, 70px); gap: 6px; justify-content: center; margin-bottom: 0.75rem; }\n.ttt-cell { width: 70px; height: 70px; font-size: 1.8rem; font-weight: 700; background: var(--bg-card); border: 1px solid var(--border-glass); border-radius: var(--radius-md); cursor: pointer; transition: all var(--transition); color: var(--text-primary); }\n.ttt-cell:hover { background: var(--bg-card-hover); transform: scale(1.04); }\n.rps-wins { font-size: 1rem; color: var(--text-secondary); margin-bottom: 0.75rem; }\n.rps-choices { display: flex; gap: 0.75rem; justify-content: center; margin-bottom: 1rem; }\n.rps-btn { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; background: var(--bg-card); border: 1px solid var(--border-glass); border-radius: var(--radius-md); padding: 0.75rem 1.25rem; cursor: pointer; font-family: var(--font); font-size: 0.9rem; font-weight: 600; color: var(--text-primary); transition: all var(--transition); }\n.rps-btn:hover { transform: translateY(-3px); border-color: var(--accent-1); box-shadow: rgba(124, 77, 255, 0.15) 0px 6px 16px; }\n.rps-icon { font-size: 2rem; }\n.rps-result { margin-bottom: 0.75rem; font-size: 1rem; color: var(--text-secondary); }\n.rps-outcome { font-size: 1.15rem; font-weight: 700; color: var(--accent-1); margin-top: 0.3rem; }\n.snake-stats { font-size: 1rem; color: var(--text-secondary); margin-bottom: 0.5rem; }\n.snake-grid { display: inline-flex; flex-direction: column; border: 1px solid var(--border-glass); border-radius: var(--radius-sm); overflow: hidden; margin-bottom: 0.5rem; }\n.snake-row { display: flex; }\n.snake-cell { width: 14px; height: 14px; background: rgba(255, 255, 255, 0.03); }\n.snake-cell.head { background: var(--accent-1); border-radius: 3px; }\n.snake-cell.body { background: rgba(124, 77, 255, 0.4); border-radius: 2px; }\n.snake-cell.food { background: var(--accent-3); border-radius: 50%; }\n.snake-controls { display: flex; gap: 0.5rem; justify-content: center; }\n.birthday-page { position: relative; min-height: 100vh; width: 100%; background: linear-gradient(135deg, rgb(102, 126, 234), rgb(118, 75, 162), rgb(240, 147, 251), rgb(245, 87, 108)) 0% 0% / 400% 400%; animation: 8s ease 0s infinite normal none running gradientShift; overflow: hidden; display: flex; align-items: center; justify-content: center; padding: 2rem; }\n@keyframes gradientShift {\n0% { background-position: 0% 50%; }\n50% { background-position: 100% 50%; }\n100% { background-position: 0% 50%; }\n}\n.birthday-content { text-align: center; z-index: 2; max-width: 700px; width: 100%; }\n.birthday-title { font-size: 2.5rem; color: rgb(255, 255, 255); text-shadow: rgba(0, 0, 0, 0.2) 0px 4px 20px; margin-bottom: 0.5rem; font-weight: 800; }\n.birthday-subtitle { font-size: 1.1rem; color: rgba(255, 255, 255, 0.8); margin-bottom: 2rem; }\n.birthday-cake-area { margin-bottom: 2rem; }\n.birthday-cake { position: relative; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 0.25rem; padding: 1rem; transition: transform var(--transition); }\n.birthday-cake:hover { transform: scale(1.03); }\n.cake-plate { width: 160px; height: 12px; background: rgb(232, 213, 196); border-radius: 6px; box-shadow: rgba(0, 0, 0, 0.15) 0px 4px 12px; }\n.cake-base { position: relative; width: 140px; height: 80px; background: rgb(255, 181, 167); border-radius: 8px; overflow: hidden; }\n.cake-frosting { height: 16px; background: rgb(255, 240, 224); border-radius: 8px 8px 0px 0px; }\n.cake-filling { height: 48px; background: rgb(255, 214, 200); }\n.cake-frosting-bottom { height: 16px; background: rgb(255, 240, 224); border-radius: 0px 0px 8px 8px; }\n.cake-candles { position: absolute; top: -30px; width: 100%; height: 30px; }\n.cake-candle { position: absolute; font-size: 1rem; animation: 0.5s ease 0s infinite alternate none running candleFlicker; }\n@keyframes candleFlicker {\n0% { transform: translateY(0px); }\n100% { transform: translateY(-3px); }\n}\n.candle-flame { display: block; font-size: 0.8rem; }\n.cake-slices { display: flex; justify-content: center; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.5rem; font-size: 1.5rem; }\n.cake-hint { margin-top: 0.5rem; font-size: 0.9rem; color: rgba(255, 255, 255, 0.7); }\n.birthday-card-display { max-width: 400px; margin: 0px auto; border-radius: var(--radius-xl); padding: 2rem; animation: 0.6s ease 0s 1 normal none running fadeUp; }\n.birthday-card-inner { background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(12px); border-radius: var(--radius-lg); padding: 1.5rem; }\n.birthday-card-emoji { font-size: 3rem; display: block; margin-bottom: 0.5rem; }\n.birthday-card-inner h2 { color: rgb(255, 255, 255); font-size: 1.5rem; margin-bottom: 0.5rem; }\n.birthday-card-role { font-size: 1rem; color: rgba(255, 255, 255, 0.8); margin-bottom: 0.75rem; text-transform: capitalize; }\n.birthday-card-quote { font-size: 0.95rem; font-style: italic; color: rgba(255, 255, 255, 0.9); margin-bottom: 1rem; line-height: 1.5; }\n.birthday-card-flip { background: rgba(255, 255, 255, 0.2); border: 1px solid rgba(255, 255, 255, 0.3); color: rgb(255, 255, 255); padding: 0.5rem 1.2rem; border-radius: var(--radius-full); cursor: pointer; font-family: var(--font); font-size: 0.9rem; transition: all var(--transition); }\n.birthday-card-flip:hover { background: rgba(255, 255, 255, 0.35); }\n.confetti-container { position: fixed; inset: 0px; pointer-events: none; z-index: 100; }\n.confetti-piece { position: absolute; top: -10px; animation: 3s ease-out 0s 1 normal forwards running confettiFall; }\n@keyframes confettiFall {\n0% { transform: translateY(0px) rotate(0deg); opacity: 1; }\n100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }\n}\n.birthday-balloon { position: absolute; bottom: -50px; animation: 6s ease-in-out 0s infinite normal none running balloonFloat; z-index: 1; pointer-events: none; }\n@keyframes balloonFloat {\n0%, 100% { transform: translateY(0px) rotate(-5deg); }\n50% { transform: translateY(-100vh) rotate(5deg); }\n}\n.toggle-label { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; user-select: none; }\n.toggle-label input { display: none; }\n.toggle-track { width: 44px; height: 24px; background: rgba(255, 255, 255, 0.15); border-radius: 12px; position: relative; transition: background 0.2s; }\n.toggle-label input:checked + .toggle-track { background: var(--accent-1); }\n.toggle-thumb { position: absolute; top: 2px; left: 2px; width: 20px; height: 20px; background: rgb(255, 255, 255); border-radius: 50%; transition: transform 0.2s; }\n.toggle-label input:checked + .toggle-track .toggle-thumb { transform: translateX(20px); }\n.toggle-text { font-size: 0.9rem; color: var(--text-secondary); font-weight: 600; }\n.focus-overlay { position: fixed; inset: 0px; z-index: 2000; background: linear-gradient(135deg, rgb(15, 12, 41), rgb(48, 43, 99), rgb(36, 36, 62)); display: flex; align-items: center; justify-content: center; overflow: hidden; }\n.focus-particles { position: absolute; inset: 0px; pointer-events: none; }\n.focus-particle { position: absolute; bottom: -10px; width: 6px; height: 6px; border-radius: 50%; animation: auto linear 0s infinite normal none running floatUp; opacity: 0.6; }\n@keyframes floatUp {\n0% { transform: translateY(0px) scale(1); opacity: 0.6; }\n100% { transform: translateY(-100vh) scale(0); opacity: 0; }\n}\n.focus-exit-btn { position: absolute; top: 1.5rem; right: 1.5rem; background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); color: rgb(255, 255, 255); padding: 0.6rem 1.2rem; border-radius: var(--radius-full); cursor: pointer; font-family: var(--font); font-size: 0.95rem; transition: all var(--transition); z-index: 10; }\n.focus-exit-btn:hover { background: rgba(255, 255, 255, 0.2); }\n.focus-content { text-align: center; z-index: 1; }\n.focus-display { font-size: 6rem; font-weight: 800; color: rgb(255, 255, 255); letter-spacing: 8px; font-variant-numeric: tabular-nums; text-shadow: rgba(124, 77, 255, 0.4) 0px 0px 40px; margin-bottom: 1.5rem; }\n.focus-buttons { display: flex; gap: 1rem; justify-content: center; margin-bottom: 2rem; }\n.focus-btn { border: none; border-radius: var(--radius-full); padding: 0.8rem 2rem; font-family: var(--font); font-size: 1.05rem; font-weight: 600; cursor: pointer; transition: all var(--transition); }\n.focus-btn:hover { transform: translateY(-2px); }\n.focus-btn-primary { background: var(--gradient-1); color: rgb(255, 255, 255); box-shadow: rgba(124, 77, 255, 0.3) 0px 4px 16px; }\n.focus-btn-secondary { background: rgba(255, 255, 255, 0.1); color: rgb(255, 255, 255); border: 1px solid rgba(255, 255, 255, 0.2); }\n.focus-quote { font-size: 1.2rem; font-style: italic; color: rgba(255, 255, 255, 0.7); max-width: 500px; margin: 0px auto 2rem; line-height: 1.5; }\n.focus-ambient-label { font-size: 0.9rem; color: rgba(255, 255, 255, 0.5); margin-bottom: 0.5rem; }\n.focus-ambient-buttons { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; align-items: center; }\n.focus-ambient-btn { background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.15); color: rgba(255, 255, 255, 0.7); padding: 0.5rem 1rem; border-radius: var(--radius-full); cursor: pointer; font-family: var(--font); font-size: 0.9rem; transition: all var(--transition); }\n.focus-ambient-btn:hover { background: rgba(255, 255, 255, 0.15); }\n.focus-ambient-btn.active { background: rgba(124, 77, 255, 0.3); border-color: var(--accent-1); color: rgb(255, 255, 255); }\n.focus-ambient-item { display: flex; align-items: center; gap: 0.25rem; }\n.focus-ambient-del { background: rgba(255, 70, 70, 0.2); border: none; color: rgba(255, 100, 100, 0.8); border-radius: 50%; width: 22px; height: 22px; font-size: 0.65rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.15s; }\n.focus-ambient-del:hover { background: rgba(255, 70, 70, 0.4); }\n.focus-volume-row { display: flex; align-items: center; gap: 0.75rem; margin-top: 1rem; justify-content: center; }\n.focus-volume-label { font-size: 0.85rem; color: rgba(255, 255, 255, 0.6); }\n.focus-volume-slider { width: 160px; accent-color: var(--accent-1); cursor: pointer; }\n.focus-volume-val { font-size: 0.8rem; color: rgba(255, 255, 255, 0.5); min-width: 32px; text-align: right; }\n.focus-upload-row { margin-top: 1rem; }\n.focus-upload-btn { background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.15); color: rgba(255, 255, 255, 0.7); padding: 0.5rem 1.2rem; border-radius: var(--radius-full); cursor: pointer; font-family: var(--font); font-size: 0.85rem; transition: all var(--transition); }\n.focus-upload-btn:hover:not(:disabled) { background: rgba(255, 255, 255, 0.15); }\n.focus-upload-btn:disabled { opacity: 0.5; cursor: not-allowed; }\n.gaana-section { background: var(--bg-card); backdrop-filter: blur(8px); border: 1px solid var(--border-glass); border-radius: var(--radius-lg); padding: 1.5rem; }\n.gaana-input-row { display: flex; gap: 0.6rem; margin-bottom: 1rem; }\n.gaana-input { flex: 1 1 0%; padding: 0.7rem 1rem; background: rgba(255, 255, 255, 0.06); border: 1px solid var(--border-glass); border-radius: var(--radius-md); font-family: var(--font); font-size: 0.95rem; outline: none; color: var(--text-primary); transition: border-color var(--transition); }\n.gaana-input:focus { border-color: var(--accent-1); }\n.gaana-fetch-btn { background: var(--gradient-2); color: rgb(255, 255, 255); border: none; border-radius: var(--radius-md); padding: 0.7rem 1.5rem; font-family: var(--font); font-weight: 600; font-size: 0.95rem; cursor: pointer; transition: all var(--transition); white-space: nowrap; }\n.gaana-fetch-btn:hover:not(:disabled) { box-shadow: rgba(255, 107, 157, 0.3) 0px 4px 16px; transform: translateY(-2px); }\n.gaana-fetch-btn:disabled { opacity: 0.6; cursor: not-allowed; }\n.gaana-error { color: var(--accent-3); background: rgba(255, 107, 157, 0.1); padding: 0.6rem 1rem; border-radius: var(--radius-md); font-size: 0.9rem; margin-bottom: 1rem; border: 1px solid rgba(255, 107, 157, 0.2); }\n.gaana-song-card { display: flex; gap: 1.5rem; align-items: flex-start; flex-wrap: wrap; animation: 0.4s ease 0s 1 normal none running fadeUp; }\n.gaana-art-wrapper { flex-shrink: 0; }\n.gaana-art { width: 200px; height: 200px; object-fit: cover; border-radius: var(--radius-lg); box-shadow: var(--shadow-md); }\n.gaana-details { flex: 1 1 0%; min-width: 200px; }\n.gaana-title { font-size: 1.4rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.25rem; }\n.gaana-artist { font-size: 1rem; color: var(--text-secondary); margin-bottom: 0.5rem; }\n.gaana-album, .gaana-lang { font-size: 0.9rem; color: var(--text-tertiary); margin-bottom: 0.2rem; }\n.gaana-meta { font-size: 0.85rem; color: var(--text-tertiary); margin: 0.5rem 0px; }\n.gaana-actions { display: flex; align-items: center; gap: 1rem; margin: 1rem 0px; flex-wrap: wrap; }\n.gaana-play-btn { background: var(--gradient-1); color: rgb(255, 255, 255); border: none; border-radius: var(--radius-full); padding: 0.7rem 1.8rem; font-family: var(--font); font-weight: 600; font-size: 1rem; cursor: pointer; transition: all var(--transition); }\n.gaana-play-btn:hover { box-shadow: var(--shadow-glow); transform: translateY(-2px); }\n.gaana-lyrics { background: rgba(255, 255, 255, 0.04); border: 1px solid var(--border-glass); border-radius: var(--radius-md); padding: 1rem; font-size: 0.9rem; line-height: 1.6; color: var(--text-secondary); max-height: 300px; overflow-y: auto; white-space: pre-wrap; font-family: var(--font); margin: 0.75rem 0px; }\n.gaana-lyrics-empty { color: var(--text-tertiary); font-style: italic; font-size: 0.9rem; margin: 0.75rem 0px; }\n.gaana-save-section { display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; margin-top: 0.75rem; padding-top: 0.75rem; border-top: 1px solid var(--border-glass); }\n.gaana-playlist-select { padding: 0.5rem 0.8rem; background: rgba(255, 255, 255, 0.06); border: 1px solid var(--border-glass); border-radius: var(--radius-md); font-family: var(--font); font-size: 0.9rem; outline: none; color: var(--text-primary); cursor: pointer; min-width: 160px; }\n.gaana-playlist-select:focus { border-color: var(--accent-1); }\n.gaana-save-btn { background: var(--gradient-1); color: rgb(255, 255, 255); border: none; border-radius: var(--radius-full); padding: 0.5rem 1.2rem; font-family: var(--font); font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: all var(--transition); }\n.gaana-save-btn:hover:not(:disabled) { box-shadow: var(--shadow-glow); }\n.gaana-save-btn:disabled { opacity: 0.5; cursor: not-allowed; }\n.gaana-save-msg { font-size: 0.85rem; color: var(--accent-2); font-weight: 600; }\n.modal-overlay { position: fixed; inset: 0px; background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; z-index: 1500; animation: 0.2s ease 0s 1 normal none running fadeIn; }\n.modal-content { background: var(--bg-secondary); border: 1px solid var(--border-glass); border-radius: var(--radius-xl); padding: 2rem; max-width: 400px; width: 100%; animation: 0.3s ease 0s 1 normal none running scaleIn; }\n.modal-content h3 { font-size: 1.2rem; color: var(--text-primary); margin-bottom: 1rem; }\n.modal-input { width: 100%; padding: 0.7rem 1rem; background: rgba(255, 255, 255, 0.06); border: 1px solid var(--border-glass); border-radius: var(--radius-md); font-family: var(--font); font-size: 0.95rem; outline: none; color: var(--text-primary); margin-bottom: 1rem; transition: border-color var(--transition); }\n.modal-input:focus { border-color: var(--accent-1); }\n.modal-actions { display: flex; gap: 0.75rem; justify-content: flex-end; }\n.modal-btn { padding: 0.55rem 1.25rem; border-radius: var(--radius-full); border: none; font-family: var(--font); font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: all var(--transition); }\n.modal-btn-primary { background: var(--gradient-1); color: rgb(255, 255, 255); }\n.modal-btn-primary:hover { box-shadow: var(--shadow-glow); }\n.modal-btn:not(.modal-btn-primary) { background: rgba(255, 255, 255, 0.08); color: var(--text-secondary); }\n.modal-btn:not(.modal-btn-primary):hover { background: rgba(255, 255, 255, 0.14); }\n@media (max-width: 768px) {\n.app-content { padding-bottom: calc(90px + env(safe-area-inset-bottom, 0px)); min-height: 100dvh; }\n.auth-page { padding: 1rem; min-height: 100dvh; }\n.auth-card { padding: 2rem 1.5rem; max-width: 100%; margin: 0px 0.5rem; }\n.anime-quotes-bar { max-width: 220px !important; padding: 0.4rem 0.6rem !important; font-size: 0.75rem !important; bottom: 75px !important; right: 0.5rem !important; }\n.anime-quotes-text-wrap { max-width: 140px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.player-controls-bottom { padding: 0.3rem 0.5rem !important; }\n.player-controls-bottom .track-info { min-width: 0px !important; max-width: 120px; }\n.toast-container { max-width: 90vw !important; right: 5vw !important; bottom: 80px !important; }\n.dashboard-links { display: grid !important; grid-template-columns: 1fr 1fr !important; gap: 0.5rem !important; }\n.dashboard-links .study-room-btn { white-space: nowrap; padding: 0.6rem !important; font-size: 0.75rem !important; }\n.dashboard-section-divider { grid-column: 1 / -1 !important; }\n.sz-sidebar { width: 56px !important; min-width: 56px !important; }\n.sz-main { margin-left: 56px !important; }\n}\n@media (max-width: 480px) {\n.app-content { padding-bottom: calc(70px + env(safe-area-inset-bottom, 0px)); }\n.auth-card { padding: 1.5rem 1rem; }\n.auth-title { font-size: 1.3rem !important; }\n.auth-input { padding: 0.6rem 0.8rem !important; font-size: 0.85rem !important; }\n.auth-btn { padding: 0.65rem !important; font-size: 0.9rem !important; }\n.dashboard-links { grid-template-columns: 1fr !important; }\n.anime-quotes-bar { max-width: 180px !important; bottom: 70px !important; }\n.anime-quotes-text-wrap { max-width: 100px; }\n.anime-quotes-bar.expanded { max-width: 280px !important; }\n.anime-quotes-bar.expanded .anime-quotes-text-wrap { max-width: 220px; white-space: normal; }\n.toast-container { max-width: 95vw !important; left: 2.5vw !important; right: 2.5vw !important; bottom: 75px !important; }\n.toast { margin-bottom: 0.5rem !important; padding: 0.6rem 0.8rem !important; font-size: 0.8rem !important; }\n}\n:root { --spotify-bg: #040508; --spotify-sidebar: rgba(8, 8, 12, 0.85); --spotify-card: rgba(255, 255, 255, 0.03); --spotify-card-hover: rgba(255, 255, 255, 0.08); --spotify-accent: #10b981; --spotify-text: #f8fafc; --spotify-text-dim: #94a3b8; }\n.music-layout { display: flex; height: 100vh; width: 100%; background: var(--spotify-bg); color: var(--spotify-text); overflow: hidden; font-family: var(--font-rounded), sans-serif !important; }\n.music-sidebar { width: 240px; min-width: 240px; background: var(--spotify-sidebar); backdrop-filter: blur(24px); border-right: 1px solid rgba(255, 255, 255, 0.05); display: flex; flex-direction: column; padding: 1.5rem 1rem; gap: 0.5rem; overflow-y: auto; transition: width var(--transition); z-index: 100; }\n.music-sidebar-logo { font-size: 1.3rem; font-weight: 800; color: var(--spotify-accent); padding: 0.5rem 0.75rem; margin-bottom: 1rem; cursor: pointer; letter-spacing: 0.5px; display: flex; align-items: center; gap: 8px; }\n.music-sidebar-logo::before { content: \"рҹ”Ҡ\"; font-size: 1.5rem; }\n.music-sidebar-nav { display: flex; flex-direction: column; gap: 0.2rem; }\n.music-sidebar-link { background: none; border: none; color: var(--spotify-text-dim); padding: 0.75rem; border-radius: var(--radius-sm); text-align: left; font-size: 0.95rem; font-weight: 700; font-family: var(--font-rounded); cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 0.75rem; }\n.music-sidebar-link:hover { color: rgb(255, 255, 255); background: rgba(255, 255, 255, 0.04); transform: translateX(4px); }\n.music-sidebar-link.active { background: rgba(16, 185, 129, 0.1); color: var(--spotify-accent); }\n.music-sidebar-divider { height: 1px; background: rgba(255, 255, 255, 0.05); margin: 1rem 0px; }\n.music-sidebar-section-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--spotify-text-dim); padding: 0.5rem 0.75rem; font-weight: 700; }\n.music-sidebar-new-btn { background: none; border: 1px dashed rgb(40, 40, 40); color: var(--spotify-text-dim); padding: 0.6rem 0.75rem; border-radius: var(--radius-sm); font-size: 0.85rem; font-family: var(--font-rounded); font-weight: 600; cursor: pointer; transition: 0.2s; margin: 0.25rem 0px; }\n.music-sidebar-new-btn:hover { border-color: var(--spotify-accent); color: var(--spotify-accent); background: rgba(29, 185, 84, 0.08); }\n.music-sidebar-footer { margin-top: auto; padding-top: 1rem; }\n.music-sidebar-back { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); color: var(--spotify-text-dim); padding: 0.6rem 0.75rem; border-radius: 20px; font-size: 0.85rem; font-weight: 700; font-family: var(--font-rounded); cursor: pointer; width: 100%; transition: 0.2s; }\n.music-sidebar-back:hover { border-color: var(--spotify-accent); color: rgb(255, 255, 255); background: rgba(16, 185, 129, 0.08); box-shadow: rgba(16, 185, 129, 0.2) 0px 0px 12px; }\n.music-main { flex: 1 1 0%; background: radial-gradient(circle at 0% 0%, rgba(16, 185, 129, 0.08) 0%, transparent 55%), radial-gradient(circle at 100% 100%, rgba(99, 102, 241, 0.06) 0%, transparent 60%), rgb(4, 5, 8); overflow: hidden; position: relative; }\n.music-main-scroll { height: 100%; overflow-y: auto; padding: 2rem 2.5rem 120px; scroll-behavior: smooth; }\n.music-hero { text-align: left; margin-bottom: 2.5rem; animation: 0.5s ease 0s 1 normal none running fadeUp; display: flex; flex-direction: column; justify-content: flex-end; min-height: 180px; }\n.music-hero-title { font-size: 4rem; font-weight: 900; color: var(--spotify-text); margin-bottom: 0.5rem; letter-spacing: -1px; }\n.music-hero-subtitle { font-size: 1.1rem; color: var(--spotify-text-dim); font-weight: 600; }\n.music-section { background: transparent; border-radius: 0px; padding: 0px; margin-bottom: 2.5rem; border: none; animation: 0.4s ease 0s 1 normal none running fadeUp; transition: none; }\n.music-section:hover { box-shadow: none; }\n.music-section-title { font-size: 1.5rem; font-weight: 800; color: var(--spotify-text); margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; letter-spacing: -0.5px; }\n.playlist-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1.5rem; }\n.playlist-card { background: var(--spotify-card); border: 1px solid rgba(255, 255, 255, 0.04); border-radius: var(--radius-md); padding: 1.25rem; text-align: left; cursor: pointer; transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; align-items: flex-start; gap: 0.75rem; position: relative; overflow: hidden; box-shadow: rgba(0, 0, 0, 0.25) 0px 4px 30px; }\n.playlist-card::before { display: none; }\n.playlist-card:hover { background: var(--spotify-card-hover); border-color: rgba(16, 185, 129, 0.25); transform: translateY(-6px); box-shadow: rgba(16, 185, 129, 0.12) 0px 10px 30px; }\n.playlist-card.active { background: rgba(16, 185, 129, 0.08); border-color: var(--spotify-accent); box-shadow: rgba(16, 185, 129, 0.15) 0px 0px 15px; }\n.playlist-icon { font-size: 2.5rem; background: rgb(40, 40, 40); width: 100%; aspect-ratio: 1 / 1; display: flex; align-items: center; justify-content: center; border-radius: 6px; box-shadow: rgba(0, 0, 0, 0.3) 0px 8px 16px; }\n.playlist-card:hover .playlist-icon { background: rgb(62, 62, 62); }\n.playlist-name { font-size: 1rem; font-weight: 700; color: var(--spotify-text); }\n.playlist-count { font-size: 0.8rem; color: var(--spotify-text-dim); font-weight: 500; }\n.track-list { display: flex; flex-direction: column; gap: 0.1rem; }\n.track-item { display: flex; align-items: center; gap: 1rem; padding: 0.75rem 1.25rem; border-radius: 8px; cursor: pointer; transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1); background: transparent; border: 1px solid transparent; }\n.track-item:hover { background: rgba(255, 255, 255, 0.05); border-color: rgba(255, 255, 255, 0.03); transform: translateX(4px); }\n.track-item.active { background: rgba(16, 185, 129, 0.08); border-color: rgba(16, 185, 129, 0.15); }\n.track-item.active .track-title { color: var(--spotify-accent); }\n.track-item.active .track-idx { color: var(--spotify-accent); }\n.track-idx { width: 20px; text-align: right; color: var(--spotify-text-dim); font-size: 0.9rem; font-variant-numeric: tabular-nums; font-weight: 500; }\n.track-thumb { width: 40px; height: 40px; object-fit: cover; border-radius: 4px; flex-shrink: 0; box-shadow: rgba(0, 0, 0, 0.3) 0px 4px 8px; }\n.track-info { flex: 1 1 0%; min-width: 0px; display: flex; flex-direction: column; gap: 0.15rem; }\n.track-title { font-weight: 600; color: var(--spotify-text); font-size: 0.95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.track-artist { font-size: 0.8rem; color: var(--spotify-text-dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.track-status { font-size: 0.9rem; color: var(--spotify-accent); }\n.track-remove-btn { background: transparent; border: none; color: var(--spotify-text-dim); width: 28px; height: 28px; border-radius: 50%; font-size: 0.8rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.2s; }\n.track-remove-btn:hover { color: rgb(255, 74, 74); background: rgba(255, 74, 74, 0.15); transform: scale(1.1); }\n.track-queue-btn { background: transparent; border: 1px solid var(--spotify-text-dim); color: var(--spotify-text-dim); width: 32px; height: 26px; border-radius: 12px; font-size: 0.7rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.2s; }\n.track-queue-btn:hover { border-color: var(--spotify-text); color: var(--spotify-text); background: rgba(255, 255, 255, 0.08); transform: scale(1.05); }\n.player-bg-blur { position: fixed; bottom: 0px; left: 0px; right: 0px; height: 100px; z-index: 999; background-size: cover; background-position: center center; filter: blur(50px) brightness(0.2); opacity: 0.6; pointer-events: none; }\n.player-bar { position: fixed; bottom: 0px; left: var(--sidebar-width, 260px); right: 0px; z-index: 1000; background: rgba(8, 8, 8, 0.85); backdrop-filter: blur(20px); border-top: 1px solid rgba(255, 255, 255, 0.08); color: rgb(255, 255, 255); box-shadow: rgba(0, 0, 0, 0.5) 0px -8px 32px; transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1), bottom 0.3s cubic-bezier(0.4, 0, 0.2, 1); }\n.player-progress-track { height: 4px; background: rgba(255, 255, 255, 0.1); cursor: pointer; position: relative; transition: height 0.2s; }\n.player-progress-track:hover { height: 6px; }\n.player-progress-fill { height: 100%; background: var(--spotify-accent); border-radius: 0px 3px 3px 0px; transition: width 0.1s linear; position: relative; }\n.player-progress-fill::after { content: \"\"; position: absolute; right: -5px; top: 50%; transform: translateY(-50%); width: 10px; height: 10px; background: rgb(255, 255, 255); border-radius: 50%; opacity: 0; box-shadow: rgba(0, 0, 0, 0.5) 0px 2px 4px; transition: opacity 0.2s; }\n.player-progress-track:hover .player-progress-fill::after { opacity: 1; }\n.player-inner { display: flex; align-items: center; justify-content: space-between; padding: 0.8rem 1.5rem; gap: 1rem; max-width: 1400px; margin: 0px auto; }\n.player-track-info { display: flex; align-items: center; gap: 0.75rem; flex: 1 1 0%; min-width: 0px; max-width: 300px; }\n.player-thumb { width: 50px; height: 50px; border-radius: 4px; flex-shrink: 0; box-shadow: rgba(0, 0, 0, 0.5) 0px 4px 10px; }\n.player-track-text { display: flex; flex-direction: column; min-width: 0px; gap: 0.1rem; }\n.player-track-title { font-weight: 700; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: rgb(255, 255, 255); }\n.player-track-artist { font-size: 0.8rem; color: var(--spotify-text-dim); }\n.player-controls { display: flex; align-items: center; gap: 0.75rem; }\n.player-visualizer { border-radius: 4px; background: rgba(0, 0, 0, 0.3); flex-shrink: 0; width: 120px; height: 28px; }\n@media (max-width: 768px) {\n.player-bar { left: 0px; bottom: var(--mobile-nav-height, 60px); background: rgba(10, 10, 12, 0.95); }\n.player-inner { padding: 0.5rem 0.75rem; gap: 0.5rem; }\n.player-track-info { flex: 2 1 0%; }\n.player-thumb { width: 36px; height: 36px; }\n.player-track-title { font-size: 0.8rem; }\n.player-track-artist { font-size: 0.7rem; }\n.player-visualizer { display: none; }\n.player-controls { flex: 1.5 1 0%; gap: 0.4rem; justify-content: center; }\n.player-btn { font-size: 0.95rem; padding: 0.25rem; }\n.player-btn-play { width: 32px; height: 32px; font-size: 1rem; }\n.player-shuffle, .player-repeat { display: none; }\n.player-right { flex: 1 1 0%; justify-content: flex-end; gap: 0.35rem; }\n.player-time { display: none; }\n.player-volume-wrap { display: none; }\n}\n.player-btn { background: none; border: none; color: var(--spotify-text-dim); font-size: 1.1rem; cursor: pointer; padding: 0.4rem; border-radius: 50%; transition: 0.2s; display: flex; align-items: center; justify-content: center; }\n.player-btn:hover { color: rgb(255, 255, 255); transform: scale(1.08); }\n.player-btn.active { color: var(--spotify-accent); }\n.player-btn-play { font-size: 1.25rem; background: rgb(255, 255, 255); color: rgb(0, 0, 0); width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: rgba(0, 0, 0, 0.3) 0px 4px 8px; }\n.player-btn-play:hover { background: rgb(255, 255, 255); color: rgb(0, 0, 0); transform: scale(1.06); }\n.player-right { display: flex; align-items: center; gap: 0.5rem; }\n.player-time { display: flex; align-items: center; gap: 0.25rem; font-size: 0.75rem; color: var(--text-tertiary); font-variant-numeric: tabular-nums; }\n.player-volume-wrap { position: relative; }\n.player-volume-slider { position: absolute; bottom: 100%; right: 0px; background: var(--bg-secondary); border: 1px solid var(--border-glass); border-radius: var(--radius-md); padding: 0.5rem 0.75rem; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; white-space: nowrap; box-shadow: var(--shadow-md); }\n.player-volume-slider input[type=\"range\"] { width: 80px; accent-color: var(--accent-1); cursor: pointer; }\n.player-volume-slider span { font-size: 0.75rem; color: var(--text-tertiary); min-width: 28px; text-align: right; }\n.discover-section { width: 100%; }\n.discover-search { position: sticky; top: 0px; z-index: 10; background: var(--spotify-bg); padding: 1rem 0px; max-width: 400px; width: 100%; margin-bottom: 0.5rem; display: flex; align-items: center; }\n.discover-search-input { width: 100%; padding: 0.8rem 1rem 0.8rem 2.8rem; border: none; background: rgb(36, 36, 36); color: rgb(255, 255, 255); border-radius: 500px; font-size: 0.95rem; font-weight: 500; outline: none; transition: background-color 0.2s, box-shadow 0.2s; box-shadow: rgba(0, 0, 0, 0.25) 0px 4px 12px; }\n.discover-search-input:focus { background: rgb(42, 42, 42); box-shadow: rgb(255, 255, 255) 0px 0px 0px 2px, rgba(0, 0, 0, 0.25) 0px 4px 12px; }\n.discover-search-input::placeholder { color: rgb(167, 167, 167); font-weight: 500; }\n.discover-search-btn { position: absolute; left: 1rem; cursor: pointer; transition: color 0.2s; z-index: 2; background: none !important; border: none !important; padding: 0px !important; color: rgb(167, 167, 167) !important; font-size: 1.1rem !important; }\n.discover-search-btn:hover { color: rgb(255, 255, 255) !important; transform: scale(1.1); }\n.discover-tabs { margin: 1.5rem 0px; display: flex; gap: 0.75rem; }\n.discover-tab { background: rgb(36, 36, 36); padding: 0.5rem 1.25rem; border-radius: 500px; font-size: 0.875rem; font-weight: 700; cursor: pointer; transition: background-color 0.2s, color 0.2s; border: none !important; color: rgb(255, 255, 255) !important; }\n.discover-tab:hover { background: rgb(42, 42, 42); }\n.discover-tab.active { background: rgb(255, 255, 255) !important; color: rgb(0, 0, 0) !important; }\n.discover-title { font-size: 1.25rem; font-weight: 800; color: var(--spotify-text); margin-bottom: 1rem; }\n.discover-loading { color: var(--spotify-text-dim); font-size: 0.9rem; }\n.discover-error { color: rgb(255, 107, 107); background: rgba(255, 107, 107, 0.1); padding: 0.6rem 1rem; border-radius: 8px; font-size: 0.9rem; margin-bottom: 1rem; border: 1px solid rgba(255, 107, 107, 0.2); }\n.discover-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1.5rem; }\n.discover-card { background: var(--spotify-card); border: 1px solid rgba(255, 255, 255, 0.04); border-radius: 8px; overflow: hidden; cursor: pointer; transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; height: 100%; padding: 1rem; }\n.discover-card:hover { background: var(--spotify-card-hover); border-color: rgba(16, 185, 129, 0.25); transform: translateY(-6px); box-shadow: rgba(16, 185, 129, 0.12) 0px 10px 30px; }\n.discover-card-img { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; border-radius: 6px; transition: transform 0.4s; box-shadow: rgba(0, 0, 0, 0.3) 0px 8px 16px; }\n.discover-card:hover .discover-card-img { transform: scale(1.04); }\n.discover-card-body { padding: 0.75rem 0px 0px; display: flex; flex-direction: column; flex-grow: 1; justify-content: space-between; }\n.discover-card-title { font-size: 0.95rem; font-weight: 700; color: var(--spotify-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 0.25rem; }\n.discover-card-artist { font-size: 0.8rem; color: var(--spotify-text-dim); font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.discover-card-album, .discover-card-duration, .discover-card-listeners { font-size: 0.7rem; color: var(--text-tertiary); margin-top: 0.15rem; }\n.discover-card-actions { display: flex; gap: 0.3rem; align-items: center; margin-top: 0.4rem; flex-wrap: wrap; }\n.discover-action-btn { background: rgba(124, 77, 255, 0.12); border: 1px solid rgba(124, 77, 255, 0.25); color: var(--accent-1); padding: 0.2rem 0.5rem; border-radius: var(--radius-sm); font-size: 0.7rem; font-weight: 600; font-family: var(--font); cursor: pointer; transition: all var(--transition); }\n.discover-action-btn:hover { background: rgba(124, 77, 255, 0.25); }\n.discover-playlist-select { padding: 0.2rem 0.4rem; border: 1px solid var(--border-glass); border-radius: var(--radius-sm); font-size: 0.7rem; font-family: var(--font); background: rgba(255, 255, 255, 0.06); color: var(--text-primary); cursor: pointer; max-width: 100px; }\n.discover-playlist-select option { background: var(--bg-secondary); color: var(--text-primary); }\n.discover-saved-msg { font-size: 0.7rem; color: var(--accent-2); font-weight: 700; }\n.lyrics-panel { background: linear-gradient(rgb(75, 0, 130) 0%, rgb(18, 18, 18) 100%); border-radius: 8px; overflow: hidden; border: 1px solid rgba(255, 255, 255, 0.1); box-shadow: rgba(0, 0, 0, 0.5) 0px 10px 30px; transition: 0.3s; }\n.lyrics-header { display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.5rem; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }\n.lyrics-header h3 { font-size: 1rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--spotify-accent); }\n.lyrics-close { background: none; border: none; color: var(--spotify-text-dim); font-size: 1.25rem; cursor: pointer; transition: color var(--transition); }\n.lyrics-close:hover { color: rgb(255, 255, 255); }\n.lyrics-content { padding: 2rem 2.5rem; max-height: 480px; overflow-y: auto; scroll-behavior: smooth; }\n.lyrics-song-title { font-size: 1.8rem; font-weight: 800; color: rgb(255, 255, 255); margin-bottom: 0.25rem; letter-spacing: -0.5px; }\n.lyrics-song-artist { font-size: 1.1rem; color: var(--spotify-text-dim); margin-bottom: 2rem; font-weight: 500; }\n.lyrics-lines { display: flex; flex-direction: column; gap: 1.2rem; }\n.lyrics-line { font-size: 1.35rem; font-weight: 700; color: rgba(255, 255, 255, 0.4); line-height: 1.5; transition: 0.25s; cursor: pointer; transform-origin: left center; }\n.lyrics-line:hover { color: rgba(255, 255, 255, 0.85); }\n.lyrics-line.active { color: rgb(255, 255, 255); transform: scale(1.04); text-shadow: rgba(255, 255, 255, 0.3) 0px 0px 15px; }\n.lyrics-empty { padding: 4rem 2rem; text-align: center; color: var(--spotify-text-dim); }\n.lyrics-empty-sub { font-size: 0.95rem; color: var(--spotify-text-dim); opacity: 0.6; margin-top: 0.5rem; }\n.adyoutube-section { width: 100%; }\n.adyoutube-header { text-align: center; margin-bottom: 1.5rem; animation: 0.5s ease 0s 1 normal none running fadeUp; }\n.adyoutube-title { font-size: 1.8rem; font-weight: 700; background: linear-gradient(135deg, rgb(255, 0, 0), rgb(255, 107, 107)) text; -webkit-text-fill-color: transparent; margin-bottom: 0.25rem; }\n.adyoutube-subtitle { font-size: 0.95rem; color: var(--text-secondary); }\n.adyoutube-search { display: flex; gap: 0.5rem; margin-bottom: 1rem; }\n.adyoutube-search-input { flex: 1 1 0%; padding: 0.7rem 1rem; border: 1px solid var(--border-glass); border-radius: var(--radius-md); font-size: 0.9rem; font-family: var(--font); outline: none; background: rgba(255, 255, 255, 0.06); color: var(--text-primary); transition: border-color var(--transition); }\n.adyoutube-search-input:focus { border-color: rgb(255, 0, 0); }\n.adyoutube-search-input::placeholder { color: var(--text-tertiary); }\n.adyoutube-search-btn { background: rgb(255, 0, 0); border: none; border-radius: var(--radius-md); padding: 0.7rem 1rem; font-size: 1rem; cursor: pointer; transition: all var(--transition); }\n.adyoutube-search-btn:hover { background: rgb(204, 0, 0); transform: translateY(-1px); }\n.adyoutube-tabs { display: flex; gap: 0.5rem; margin-bottom: 1rem; }\n.adyoutube-tab { background: var(--bg-card); border: 1px solid var(--border-glass); border-radius: var(--radius-md); padding: 0.4rem 1rem; font-size: 0.85rem; font-family: var(--font); cursor: pointer; color: var(--text-secondary); transition: all var(--transition); }\n.adyoutube-tab:hover { background: var(--bg-card-hover); color: var(--text-primary); }\n.adyoutube-tab.active { background: rgba(255, 0, 0, 0.15); border-color: rgb(255, 0, 0); color: rgb(255, 0, 0); }\n.adyoutube-error { color: var(--accent-3); background: rgba(255, 107, 157, 0.1); padding: 0.5rem 0.75rem; border-radius: var(--radius-md); font-size: 0.85rem; margin-bottom: 0.75rem; border: 1px solid rgba(255, 107, 157, 0.2); }\n.adyoutube-loading { color: var(--text-tertiary); font-style: italic; font-size: 0.85rem; }\n.adyoutube-grid { column-count: 4; column-gap: 1rem; }\n@media (max-width: 1200px) {\n.adyoutube-grid { column-count: 3; }\n}\n@media (max-width: 900px) {\n.adyoutube-grid { column-count: 2; }\n}\n@media (max-width: 600px) {\n.adyoutube-grid { column-count: 1; }\n}\n.adyoutube-card { background: var(--bg-card); backdrop-filter: blur(8px); border-radius: var(--radius-lg); overflow: hidden; transition: all var(--transition); border: 2px solid transparent; break-inside: avoid; margin-bottom: 1rem; display: inline-block; width: 100%; }\n.adyoutube-card:hover { transform: translateY(-6px); border-color: rgba(255, 0, 0, 0.25); box-shadow: rgba(255, 0, 0, 0.12) 0px 8px 30px; }\n.adyoutube-card.active { border-color: rgb(255, 0, 0); box-shadow: rgba(255, 0, 0, 0.25) 0px 0px 0px 2px; }\n.adyoutube-card-img-wrap { position: relative; cursor: pointer; aspect-ratio: 16 / 9; background: rgba(0, 0, 0, 0.3); overflow: hidden; }\n.adyoutube-card-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }\n.adyoutube-card-img-wrap:hover .adyoutube-card-img { transform: scale(1.08); }\n.adyoutube-card-play-overlay { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0.8); background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(4px); color: rgb(255, 255, 255); width: 52px; height: 52px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; opacity: 0; transition: 0.3s; }\n.adyoutube-card-img-wrap:hover .adyoutube-card-play-overlay { opacity: 1; transform: translate(-50%, -50%) scale(1); }\n.adyoutube-card-dur { position: absolute; bottom: 6px; right: 6px; background: rgba(0, 0, 0, 0.85); color: rgb(255, 255, 255); padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; }\n.adyoutube-card-body { padding: 0.65rem 0.75rem; }\n.adyoutube-card-title { font-size: 0.85rem; font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 0.15rem; }\n.adyoutube-card-artist { font-size: 0.75rem; color: var(--text-tertiary); margin-bottom: 0.25rem; }\n.adyoutube-card-meta { font-size: 0.7rem; color: var(--text-tertiary); margin-bottom: 0.4rem; }\n.adyoutube-card-actions { display: flex; gap: 0.4rem; }\n.adyoutube-action-btn { background: rgb(255, 0, 0); color: rgb(255, 255, 255); border: none; border-radius: var(--radius-sm); padding: 0.35rem 0.75rem; font-size: 0.75rem; font-weight: 600; font-family: var(--font); cursor: pointer; transition: all var(--transition); }\n.adyoutube-action-btn:hover { background: rgb(204, 0, 0); transform: translateY(-1px); }\n.adyoutube-action-btn.secondary { background: var(--bg-card); color: var(--text-secondary); border: 1px solid var(--border-glass); }\n.adyoutube-action-btn.secondary:hover { background: var(--bg-card-hover); color: var(--text-primary); }\n.adyoutube-related { margin-top: 2rem; background: var(--bg-card); backdrop-filter: blur(8px); border: 1px solid var(--border-glass); border-radius: var(--radius-lg); padding: 1rem; animation: 0.4s ease 0s 1 normal none running fadeUp; }\n.adyoutube-related-title { font-size: 1rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.75rem; }\n.adyoutube-related-list { display: flex; flex-direction: column; gap: 0.4rem; }\n.adyoutube-related-item { display: flex; align-items: center; gap: 0.65rem; padding: 0.5rem; border-radius: var(--radius-md); cursor: pointer; transition: all var(--transition); }\n.adyoutube-related-item:hover { background: var(--bg-card-hover); transform: translateX(4px); }\n.adyoutube-related-thumb { width: 64px; height: 36px; object-fit: cover; border-radius: var(--radius-sm); flex-shrink: 0; }\n.adyoutube-related-info { flex: 1 1 0%; min-width: 0px; }\n.adyoutube-related-name { font-size: 0.85rem; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.adyoutube-related-artist { font-size: 0.75rem; color: var(--text-tertiary); }\n.ambient-section { width: 100%; }\n.ambient-header { text-align: center; margin-bottom: 1.5rem; animation: 0.5s ease 0s 1 normal none running fadeUp; }\n.ambient-title { font-size: 1.8rem; font-weight: 700; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.25rem; }\n.ambient-subtitle { font-size: 0.95rem; color: var(--text-secondary); }\n.ambient-grid { column-count: 4; column-gap: 0.75rem; }\n@media (max-width: 1200px) {\n.ambient-grid { column-count: 3; }\n}\n@media (max-width: 900px) {\n.ambient-grid { column-count: 2; }\n}\n@media (max-width: 600px) {\n.ambient-grid { column-count: 1; }\n}\n.ambient-card { background: var(--bg-card); backdrop-filter: blur(8px); border: 2px solid transparent; border-radius: var(--radius-lg); overflow: hidden; transition: all var(--transition); position: relative; break-inside: avoid; margin-bottom: 0.75rem; display: inline-block; width: 100%; }\n.ambient-card:hover { transform: translateY(-4px); border-color: rgba(67, 233, 123, 0.25); box-shadow: rgba(67, 233, 123, 0.1) 0px 8px 30px; }\n.ambient-card.active { border-color: var(--accent-2); background: rgba(67, 233, 123, 0.08); box-shadow: rgba(67, 233, 123, 0.1) 0px 0px 20px; }\n.ambient-card-btn { width: 100%; padding: 1.5rem 1rem; background: none; border: none; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; color: var(--text-primary); font-family: var(--font); transition: all var(--transition); }\n.ambient-card.active .ambient-card-btn { animation: 2s ease 0s infinite normal none running pulse; }\n.ambient-card-icon { font-size: 2.2rem; transition: transform var(--transition); }\n.ambient-card:hover .ambient-card-icon { transform: scale(1.15); }\n.ambient-card-label { font-size: 0.85rem; font-weight: 600; }\n.ambient-card-status { font-size: 0.8rem; color: var(--accent-2); }\n.ambient-card-del { position: absolute; top: 6px; right: 6px; background: rgba(255, 0, 0, 0.15); border: none; border-radius: 50%; width: 24px; height: 24px; font-size: 0.7rem; cursor: pointer; color: var(--accent-3); display: flex; align-items: center; justify-content: center; transition: all var(--transition); }\n.ambient-card-del:hover { background: rgba(255, 0, 0, 0.35); transform: scale(1.1); }\n.ambient-controls { background: var(--bg-card); backdrop-filter: blur(8px); border: 1px solid var(--border-glass); border-radius: var(--radius-lg); padding: 1.25rem; margin-bottom: 1rem; display: flex; flex-direction: column; gap: 1rem; animation: 0.3s ease 0s 1 normal none running fadeUp; }\n.ambient-volume-row { display: flex; align-items: center; gap: 1rem; color: var(--text-secondary); font-size: 0.9rem; }\n.ambient-volume-row input[type=\"range\"] { flex: 1 1 0%; accent-color: var(--accent-2); cursor: pointer; }\n.ambient-timer-row { display: flex; align-items: center; gap: 1rem; color: var(--text-secondary); font-size: 0.9rem; }\n.ambient-timer-btns { display: flex; gap: 0.5rem; }\n.ambient-timer-btn { background: var(--bg-card); border: 1px solid var(--border-glass); border-radius: var(--radius-md); padding: 0.35rem 0.75rem; font-size: 0.8rem; font-family: var(--font); cursor: pointer; color: var(--text-secondary); transition: all var(--transition); }\n.ambient-timer-btn:hover { background: rgba(67, 233, 123, 0.15); border-color: var(--accent-2); color: var(--accent-2); }\n.ambient-timer-btn.cancel { background: rgba(255, 0, 0, 0.08); border-color: rgba(255, 0, 0, 0.15); color: var(--accent-3); }\n.ambient-timer-active { display: flex; align-items: center; gap: 0.5rem; color: var(--accent-2); font-weight: 600; }\n.ambient-upload-row { text-align: center; }\n.ambient-upload-btn { background: var(--bg-card); border: 1px dashed var(--border-glass); b