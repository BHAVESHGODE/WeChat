      "html": "\n<div class=\"relative w-full min-h-screen overflow-hidden bg-[#0B0C10] font-['Montserrat'] text-white\" data-kid=\"0\">\n  \n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Montserrat:wght@300;400;500;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n    @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n    body {\n      margin: 0;\n      padding: 0;\n      background: #0B0C10;\n    }\n\n    .glass-obsidian {\n      background: rgba(10, 10, 12, 0.7);\n      backdrop-filter: blur(20px);\n      border: 1px solid rgba(255, 255, 255, 0.08);\n      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);\n    }\n\n    .gold-glow {\n      text-shadow: 0 0 10px rgba(255, 193, 7, 0.4), \n                   0 0 20px rgba(255, 193, 7, 0.2), \n                   0 0 40px rgba(255, 193, 7, 0.1);\n    }\n\n    .dust-particle {\n      position: absolute;\n      background: rgba(255, 255, 255, 0.4);\n      border-radius: 50%;\n      pointer-events: none;\n      filter: blur(1px);\n    }\n\n    .orb-glow {\n      transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);\n    }\n\n    /* Card Glows - Enhanced for intense cinematic effect */\n    .card-purple-glow { box-shadow: 0 20px 80px -20px rgba(138, 43, 226, 0.6), inset 0 0 20px rgba(138, 43, 226, 0.1); }\n    .card-red-glow { box-shadow: 0 20px 80px -20px rgba(220, 20, 60, 0.6), inset 0 0 20px rgba(220, 20, 60, 0.1); }\n    .card-green-glow { box-shadow: 0 20px 80px -20px rgba(0, 255, 127, 0.6), inset 0 0 20px rgba(0, 255, 127, 0.1); }\n\n    .card-purple-glow:hover { box-shadow: 0 0 120px -10px rgba(138, 43, 226, 0.9), inset 0 0 30px rgba(138, 43, 226, 0.3); border-color: rgba(138, 43, 226, 0.6); }\n    .card-red-glow:hover { box-shadow: 0 0 120px -10px rgba(220, 20, 60, 0.9), inset 0 0 30px rgba(220, 20, 60, 0.3); border-color: rgba(220, 20, 60, 0.6); }\n    .card-green-glow:hover { box-shadow: 0 0 120px -10px rgba(0, 255, 127, 0.9), inset 0 0 30px rgba(0, 255, 127, 0.3); border-color: rgba(0, 255, 127, 0.6); }\n\n    /* Custom Hide Scrollbar */\n    ::-webkit-scrollbar { display: none; }\n  </style>\n\n  \n  <div class=\"fixed inset-0 z-0\" data-kid=\"2\">\n    <img src=\"https://images.unsplash.com/photo-1612273629591-b1788ff64e58?auto=format&w=1920&q=85&fit=crop\" class=\"w-full h-full object-cover opacity-60 scale-110 blur-[1px]\" alt=\"Fantasy Library\" decoding=\"async\" loading=\"lazy\" data-kid=\"3\">\n    \n    <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(11,12,16,0.8)_80%)]\" data-kid=\"4\"></div>\n    <div class=\"absolute inset-0 bg-gradient-to-b from-[#0B0C10] via-transparent to-[#0B0C10]\" data-kid=\"5\"></div>\n  </div>\n\n  \n  <div id=\"particles\" class=\"fixed inset-0 z-1 pointer-events-none\" data-kid=\"6\"></div>\n\n  \n  <main class=\"relative z-10 min-h-screen flex flex-col items-center justify-between py-16 px-8\" data-kid=\"7\">\n    \n    \n    <div class=\"logo-container opacity-0 translate-y-[-20px]\" data-kid=\"8\">\n      <div class=\"glass-obsidian px-16 py-8 rounded-2xl relative overflow-hidden group\" data-kid=\"9\">\n        \n        <div class=\"absolute inset-0 bg-gradient-to-r from-transparent via-white/5 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000\" data-kid=\"10\"></div>\n        \n        <h1 class=\"font-['Cinzel_Decorative'] text-6xl text-[#FFC107] font-bold gold-glow tracking-widest text-center select-none\" data-kid=\"11\">\n          WeGift\n        </h1>\n        <div class=\"flex items-center justify-center gap-4 mt-3\" data-kid=\"12\">\n          <div class=\"h-[1px] w-8 bg-white/20\" data-kid=\"13\"></div>\n          <p class=\"text-[10px] tracking-[0.5em] text-white/50 uppercase font-medium\" data-kid=\"14\">\n            By - Maverick aka Bhavesh\n          </p>\n          <div class=\"h-[1px] w-8 bg-white/20\" data-kid=\"15\"></div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"flex flex-col items-center gap-12 w-full max-w-5xl\" data-kid=\"16\">\n      <div id=\"orb-row\" class=\"flex flex-wrap justify-center gap-8 md:gap-12\" data-kid=\"17\">\n        \n        <div class=\"orb group flex flex-col items-center gap-3\" data-kid=\"18\">\n          <div class=\"w-16 h-16 rounded-full glass-obsidian flex items-center justify-center orb-glow cursor-pointer border-purple-500/30 shadow-[0_0_20px_rgba(138,43,226,0.2)] hover:shadow-[0_0_40px_rgba(138,43,226,0.5)] group-hover:scale-110\" data-kid=\"19\">\n            <i class=\"ti ti-music text-2xl text-[rgb(138,43,226)]\" data-kid=\"20\"></i>\n          </div>\n        </div>\n        \n        <div class=\"orb group flex flex-col items-center gap-3\" data-kid=\"21\">\n          <div class=\"w-16 h-16 rounded-full glass-obsidian flex items-center justify-center orb-glow cursor-pointer border-red-500/30 shadow-[0_0_20px_rgba(220,20,60,0.2)] hover:shadow-[0_0_40px_rgba(220,20,60,0.5)] group-hover:scale-110\" data-kid=\"22\">\n            <i class=\"ti ti-movie text-2xl text-[rgb(220,20,60)]\" data-kid=\"23\"></i>\n          </div>\n        </div>\n        \n        <div class=\"orb group flex flex-col items-center gap-3\" data-kid=\"24\">\n          <div class=\"w-16 h-16 rounded-full glass-obsidian flex items-center justify-center orb-glow cursor-pointer border-green-500/30 shadow-[0_0_20px_rgba(0,255,127,0.2)] hover:shadow-[0_0_40px_rgba(0,255,127,0.5)] group-hover:scale-110\" data-kid=\"25\">\n            <i class=\"ti ti-device-tv text-2xl text-[rgb(0,255,127)]\" data-kid=\"26\"></i>\n          </div>\n        </div>\n        \n        <div class=\"orb group flex flex-col items-center gap-3\" data-kid=\"27\">\n          <div class=\"w-16 h-16 rounded-full glass-obsidian flex items-center justify-center orb-glow cursor-pointer border-amber-500/30 shadow-[0_0_20px_rgba(255,193,7,0.2)] h