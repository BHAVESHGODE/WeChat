r { position: fixed; top: 0px; left: 0px; bottom: 0px; z-index: 200; transform: translateX(-100%); transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); width: 260px !important; min-width: 260px !important; }\n.music-sidebar--open { transform: translateX(0px); }\n.music-sidebar-overlay { display: block; position: fixed; inset: 0px; z-index: 199; background: rgba(0, 0, 0, 0.6); animation: 0.2s ease 0s 1 normal none running fadeIn; }\n.music-sidebar-logo { font-size: 1rem !important; padding: 0.75rem !important; }\n.music-sidebar-link { font-size: 0.9rem !important; padding: 0.75rem !important; justify-content: flex-start !important; }\n.music-sidebar-section-label { display: block !important; }\n.music-sidebar-new-btn { font-size: 0.85rem !important; padding: 0.6rem 0.75rem !important; display: flex !important; align-items: center !important; justify-content: flex-start !important; }\n.music-sidebar-back { font-size: 0.85rem !important; padding: 0.6rem 0.75rem !important; display: flex !important; align-items: center !important; }\n}\n.player-track-info { cursor: pointer; transition: background 0.2s; border-radius: 8px; padding: 0.25rem; background: none; border: none; color: inherit; display: flex; align-items: center; gap: 0.75rem; flex: 1 1 0%; min-width: 0px; max-width: 300px; min-height: 44px; }\n.player-track-info:hover { background: rgba(255, 255, 255, 0.03); }\n.player-btn svg { display: block; }\n@keyframes fadeIn {\n0% { opacity: 0; }\n100% { opacity: 1; }\n}\n@media (min-width: 768px) {\n.music-header { display: none; }\n.music-sidebar-overlay { display: none !important; }\n.playlist-carousel-card { flex: 0 0 200px; }\n.playlist-carousel { padding: 0.5rem 0px 1rem; }\n}\n.track-equalizer { display: inline-flex; align-items: center; gap: 2px; height: 16px; }\n.track-equalizer span { width: 3px; background: var(--spotify-accent); border-radius: 1px; animation: 0.8s ease-in-out 0s infinite alternate none running equalizer; }\n.track-equalizer span:nth-child(1) { height: 6px; animation-delay: 0s; }\n.track-equalizer span:nth-child(2) { height: 14px; animation-delay: 0.2s; }\n.track-equalizer span:nth-child(3) { height: 10px; animation-delay: 0.4s; }\n@keyframes equalizer {\n0% { transform: scaleY(0.4); }\n100% { transform: scaleY(1); }\n}\n.nowplaying-visualizer { display: flex; align-items: center; justify-content: center; gap: 3px; height: 24px; margin-bottom: 1rem; width: 100%; max-width: 200px; }\n.nowplaying-visualizer-bar { width: 3px; background: linear-gradient(180deg, var(--spotify-accent), rgba(16, 185, 129, 0.3)); border-radius: 2px; animation: 0.6s ease-in-out 0s infinite alternate none running visualizerBounce; }\n@keyframes visualizerBounce {\n0% { height: 3px; }\n100% { height: 20px; }\n}\n.player-bar--playing .player-progress-track { height: 4px; }\n.player-bar--playing .player-progress-fill { box-shadow: rgba(16, 185, 129, 0.4) 0px 0px 8px; }\n.player-bar--playing { border-top-color: rgba(16, 185, 129, 0.15); }\n.player-thumb-ring { position: absolute; inset: -3px; border: 2px solid var(--spotify-accent); border-radius: 6px; opacity: 0.6; animation: 2s ease-in-out 0s infinite normal none running pulseRing; }\n@keyframes pulseRing {\n0%, 100% { opacity: 0.3; transform: scale(1); }\n50% { opacity: 0.8; transform: scale(1.04); }\n}\n.player-thumb { position: relative; }\n.track-duration { font-size: 0.75rem; color: var(--spotify-text-dim); font-variant-numeric: tabular-nums; white-space: nowrap; min-width: 36px; text-align: right; }\n.music-hero-title { background: linear-gradient(135deg, rgb(248, 250, 252) 0%, rgb(16, 185, 129) 100%) text; -webkit-text-fill-color: transparent; }\n.music-main-scroll::-webkit-scrollbar { width: 6px; }\n.music-main-scroll::-webkit-scrollbar-track { background: transparent; }\n.music-main-scroll::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 3px; }\n.music-main-scroll::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }\n@keyframes shimmer {\n0% { background-position: -200px 0px; }\n100% { background-position: 200px 0px; }\n}\n.skeleton-card { background: linear-gradient(90deg, rgba(255, 255, 255, 0.03) 25%, rgba(255, 255, 255, 0.06) 50%, rgba(255, 255, 255, 0.03) 75%) 0% 0% / 400px 100%; animation: 1.5s ease-in-out 0s infinite normal none running shimmer; border-radius: 12px; min-height: 180px; flex: 0 0 200px; }\n.skeleton-line { background: linear-gradient(90deg, rgba(255, 255, 255, 0.03) 25%, rgba(255, 255, 255, 0.06) 50%, rgba(255, 255, 255, 0.03) 75%) 0% 0% / 400px 100%; animation: 1.5s ease-in-out 0s infinite normal none running shimmer; border-radius: 4px; height: 14px; margin-bottom: 0.5rem; }\n@media (max-width: 768px) {\n.music-hero { min-height: auto; margin-bottom: 1.25rem; }\n.music-hero-title { font-size: 1.3rem; }\n.music-hero-subtitle { font-size: 0.85rem; }\n.music-sidebar { width: 56px; min-width: 56px; padding: 0.75rem 0.35rem; }\n.music-sidebar-logo { font-size: 0px; padding: 0.35rem; }\n.music-sidebar-logo::after { content: \"рҹҺө\"; font-size: 1.2rem; -webkit-text-fill-color: initial; background: none; }\n.music-sidebar-link { font-size: 0px; padding: 0.5rem; justify-content: center; }\n.music-sidebar-section-label { display: none; }\n.music-sidebar-new-btn { font-size: 0px; padding: 0.4rem; display: flex; align-items: center; justify-content: center; }\n.music-sidebar-back { font-size: 0px; padding: 0.4rem; display: flex; align-items: center; justify-content: center; }\n.music-sidebar-footer { padding-top: 0.5rem; }\n.music-section { margin-bottom: 1.5rem; }\n.music-section-title { font-size: 1.1rem; margin-bottom: 0.75rem; }\n.playlist-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.75rem; }\n.playlist-card { padding: 0.75rem; }\n.playlist-icon { font-size: 1.8rem; }\n.playlist-name { font-size: 0.85rem; }\n.playlist-count { font-size: 0.7rem; }\n.track-item { padding: 0.5rem 0.75rem; gap: 0.5rem; }\n.track-idx { width: 16px; font