      "html": "\n<div class=\"relative w-full min-h-screen overflow-hidden bg-[#0B0C10] font-['Montserrat'] text-white\" data-kid=\"0\">\n  \n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Montserrat:wght@300;400;500;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css');\n    @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n    .glass-obsidian {\n      background: linear-gradient(135deg, rgba(20, 20, 25, 0.75), rgba(10, 10, 12, 0.85));\n      backdrop-filter: blur(30px);\n      border: 1px solid rgba(255, 255, 255, 0.07);\n      box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.8), inset 0 0 30px rgba(255, 255, 255, 0.02);\n      position: relative;\n    }\n\n    .glass-obsidian::before {\n      content: '';\n      position: absolute;\n      inset: 0;\n      background: radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.03) 0%, transparent 50%);\n      pointer-events: none;\n    }\n\n    @keyframes shimmer {\n      0% { opacity: 0.1; }\n      50% { opacity: 0.3; }\n      100% { opacity: 0.1; }\n    }\n    .shimmer-line { animation: shimmer 3s infinite ease-in-out; }\n\n    .gold-glow {\n      text-shadow: 0 0 15px rgba(255, 193, 7, 0.6), \n                   0 0 35px rgba(255, 193, 7, 0.3), \n                   0 0 70px rgba(255, 193, 7, 0.15);\n    }\n\n    .dust-particle {\n      position: absolute;\n      background: rgba(255, 255, 255, 0.3);\n      border-radius: 50%;\n      pointer-events: none;\n      filter: blur(1px);\n    }\n\n    /* Card Glows - Enhanced for intense cinematic effect */\n    .card-purple-glow { box-shadow: 0 0 60px -20px rgba(138, 43, 226, 0.5), inset 0 0 25px rgba(138, 43, 226, 0.05); border-color: rgba(138, 43, 226, 0.2); }\n    .card-crimson-glow { box-shadow: 0 0 60px -20px rgba(220, 20, 60, 0.5), inset 0 0 25px rgba(220, 20, 60, 0.05); border-color: rgba(220, 20, 60, 0.2); }\n    .card-green-glow { box-shadow: 0 0 60px -20px rgba(0, 255, 127, 0.5), inset 0 0 25px rgba(0, 255, 127, 0.05); border-color: rgba(0, 255, 127, 0.2); }\n\n    .card-purple-glow:hover { box-shadow: 0 0 120px -5px rgba(138, 43, 226, 0.8), inset 0 0 40px rgba(138, 43, 226, 0.2); border-color: rgba(138, 43, 226, 0.6); }\n    .card-crimson-glow:hover { box-shadow: 0 0 120px -5px rgba(220, 20, 60, 0.8), inset 0 0 40px rgba(220, 20, 60, 0.2); border-color: rgba(220, 20, 60, 0.6); }\n    .card-green-glow:hover { box-shadow: 0 0 120px -5px rgba(0, 255, 127, 0.8), inset 0 0 40px rgba(0, 255, 127, 0.2); border-color: rgba(0, 255, 127, 0.6); }\n\n    /* Fog Overlay */\n    .fog-overlay {\n      background: radial-gradient(circle at 50% 50%, rgba(11, 12, 16, 0.2) 0%, rgba(11, 12, 16, 0.5) 40%, rgba(11, 12, 16, 0.98) 100%);\n    }\n\n    ::-webkit-scrollbar { display: none; }\n  </style>\n\n  \n  <div class=\"fixed inset-[-40px] z-0 bg-[#0B0C10]\" data-kid=\"2\">\n    <video src=\"https://kombai-assets.b-cdn.net/generated_assets/91a26b3e-751c-465b-b58d-def7ecb58607/c9ab74b6c82d43a895f9d8e56b33b4b3.mp4\" poster=\"https://images.unsplash.com/photo-1612273629591-b1788ff64e58?auto=format&w=1920&q=40&fit=crop\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover opacity-65 scale-110\" data-kid=\"3\"></video>\n    \n    <div class=\"absolute inset-0 fog-overlay\" data-kid=\"4\"></div>\n    <div class=\"absolute inset-0 bg-gradient-to-t from-[#0B0C10] via-transparent to-[#0B0C10]/80\" data-kid=\"5\"></div>\n  </div>\n\n  \n  <div id=\"particles\" class=\"fixed inset-0 z-[5] pointer-events-none\" data-kid=\"6\"></div>\n\n  \n  <main class=\"relative z-10 min-h-screen flex flex-col items-center justify-between py-16 md:py-24 px-6\" data-kid=\"7\">\n    \n    \n    <div class=\"logo-container opacity-0 -translate-y-10\" data-kid=\"8\">\n      <div class=\"glass-obsidian px-12 md:px-20 py-8 md:py-10 rounded-3xl relative overflow-hidden group\" data-kid=\"9\">\n 