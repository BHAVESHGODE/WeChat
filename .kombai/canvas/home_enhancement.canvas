      "html": "\n<div class=\"relative min-h-screen w-full flex flex-col items-center justify-between py-12 px-0 overflow-hidden font-['Plus_Jakarta_Sans',sans-serif] bg-slate-100\" data-kid=\"0\">\n    \n    \n    <div class=\"fixed inset-0 z-0\" data-kid=\"1\">\n        <img src=\"https://images.unsplash.com/photo-1507738978512-35798112892c?auto=format&w=1920&q=80&fit=crop\" alt=\"Library Background\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"2\">\n        \n        <div class=\"absolute inset-0 bg-slate-950/20 backdrop-blur-[40px]\" data-kid=\"3\"></div>\n    </div>\n\n    \n    <div class=\"relative z-10 w-full flex flex-col items-center flex-grow\" data-kid=\"4\">\n        \n        \n        <header class=\"logo-plaque-container mb-12\" id=\"logo-plaque\" data-kid=\"5\">\n            <div class=\"relative px-16 py-8 rounded-[32px] border border-white/40 bg-white/15 backdrop-blur-3xl shadow-[0_32px_64px_rgba(0,0,0,0.1),inset_0_0_40px_rgba(255,255,255,0.25)]\" data-kid=\"6\">\n                <div class=\"text-center\" data-kid=\"7\">\n                    <h1 class=\"text-7xl font-black tracking-tighter bg-gradient-to-br from-[#E8D08D] via-[#FFCCB3] to-[#E8D08D] bg-clip-text text-transparent filter drop-shadow-[0_4px_12px_rgba(0,0,0,0.1)]\" data-kid=\"8\">\n                        WeGift\n                    </h1>\n                    <div class=\"flex items-center justify-center gap-4 mt-3\" data-kid=\"9\">\n                        <div class=\"h-[1px] w-6 bg-white/40\" data-kid=\"10\"></div>\n                        <p class=\"text-[11px] tracking-[0.6em] font-bold text-white uppercase opacity-90\" data-kid=\"11\">Luxury Gifting</p>\n                        <div class=\"h-[1px] w-6 bg-white/40\" data-kid=\"12\"></div>\n                    </div>\n                </div>\n            </div>\n        </header>\n\n        \n        <nav class=\"categories-row flex flex-wrap justify-center gap-6 mb-20 max-w-4xl\" id=\"categories\" data-kid=\"13\">\n            \n            <div class=\"category-item group flex flex-col items-center gap-3\" data-kid=\"14\">\n                <div class=\"w-16 h-16 rounded-full flex items-center justify-center bg-white/20 border border-white/40 backdrop-blur-3xl cursor-pointer hover:bg-white/40 hover:scale-110 hover:border-white/80 transition-all duration-300 shadow-2xl group-hover:shadow-white/30\" data-kid=\"15\">\n                    <i class=\"ti ti-headphones text-2xl text-white group-hover:scale-110 transition-transform\" data-kid=\"16\"></i>\n                </div>\n                <span class=\"text-[10px] uppercase tracking-widest text-white/60 font-black group-hover:text-white transition-colors\" data-kid=\"17\">Music</span>\n            </div>\n            \n            <div class=\"category-item group flex flex-col items-center gap-3\" data-kid=\"18\">\n                <div class=\"w-16 h-16 rounded-full flex items-center justify-center bg-white/20 border border-white/40 backdrop-blur-3xl cursor-pointer hover:bg-white/40 hover:scale-110 hover:border-white/80 transition-all duration-300 shadow-2xl group-hover:shadow-white/30\" data-kid=\"19\">\n                    <i class=\"ti ti-movie text-2xl text-white group-hover:scale-110 transition-transform\" data-kid=\"20\"></i>\n                </div>\n                <span class=\"text-[10px] uppercase tracking-widest text-white/60 font-black group-hover:text-white transition-colors\" data-kid=\"21\">Film</span>\n            </div>\n            \n            <div class=\"category-item group flex flex-col items-center gap-3\" data-kid=\"22\">\n                <div class=\"w-16 h-16 rounded-full flex items-center justify-center bg-white/20 border border-white/40 backdrop-blur-3xl cursor-pointer hover:bg-white/40 hover:scale-110 hover:border-white/80 transition-all duration-300 shadow-2xl group-hover:shadow-white/30\" data-kid=\"23\">\n                    <i class=\"ti ti-device-tv text-2xl text-white group-hover:scale-110 transition-transform\" data-kid=\"24\"></i>\n                </div>\n                <span class=\"text-[10px] uppercase tracking-widest text-white/60 font-black group-hover:text-white transition-colors\" data-kid=\"25\">TV</span>\n            </div>\n            \n            <div class=\"category-item group flex flex-col items-center gap-3\" data-kid=\"26\">\n                <div class=\"w-16 h-16 rounded-full flex items-center justify-center bg-white/20 border border-white/40 backdrop-blur-3xl cursor-pointer hover:bg-white/40 hover:scale-110 hover:border-white/80 transition-all duration-300 shadow-2xl group-hover:shadow-white/30\" data-kid=\"27\">\n                    <i class=\"ti ti-book text-2xl text-white group-hover:scale-110 transition-transform\" data-kid=\"28\"></i>\n                </div>\n                <span class=\"text-[10px] uppercase tracking-widest text-white/60 font-black group-hover:text-white transition-colors\" data-kid=\"29\">Books</span>\n            </div>\n            \n            <div class=\"category-item group flex flex-col items-center gap-3\" data-kid=\"30\">\n                <div class=\"w-16 h-16 rounded-full flex items-center justify-center bg-white/20 border border-white/40 backdrop-blur-3xl cursor-pointer hover:bg-white/40 hover:scale-110 hover:border-white/80 transition-all duration-300 shadow-2xl group-hover:shadow-white/30\" data-kid=\"31\">\n                    <i class=\"ti ti-ballpen text-2xl text-white group-hover:scale-110 transition-transform\" data-kid=\"32\"></i>\n                </div>\n                <span class=\"text-[10px] uppercase tracking-widest text-white/60 font-black group-hover:text-white transition-colors\" data-kid=\"33\">Art</span>\n            </div>\n            \n            <div class=\"category-item group flex flex-col items-center gap-3\" data-kid=\"34\">\n                <div class=\"w-16 h-16 rounded-full flex items-center justify-center bg-white/20 border border-white/40 backdrop-blur-3xl cursor-pointer hover:bg-white/40 hover:scale-110 hover:border-white/80 transition-all duration-300 shadow-2xl group-hover:shadow-white/30\" data-kid=\"35\">\n                    <i class=\"ti ti-device-gamepad-2 text-2xl text-white group-hover:scale-110 transition-transform\" data-kid=\"36\"></i>\n                </div>\n                <span class=\"text-[10px] uppercase tracking-widest text-white/60 font-black group-hover:text-white transition-colors\" data-kid=\"37\">Gaming</span>\n            </div>\n            \n            <div class=\"category-item group flex flex-col items-center gap-3\" data-kid=\"38\">\n                <div class=\"w-16 h-16 rounded-full flex items-center justify-center bg-white/20 border border-white/40 backdrop-blur-3xl cursor-pointer hover:bg-white/40 hover:scale-110 hover:border-white/80 transition-all duration-300 shadow-2xl group-hover:shadow-white/30\" data-kid=\"39\">\n                    <i class=\"ti ti-message-circle text-2xl text-white group-hover:scale-110 transition-transform\" data-kid=\"40\"></i>\n                </div>\n                <span class=\"text-[10px] uppercase tracking-widest text-white/60 font-black group-hover:text-white transition-colors\" data-kid=\"41\">Chat</span>\n            </div>\n            \n            <div class=\"category-item group flex flex-col items-center gap-3\" data-kid=\"42\">\n                <div class=\"w-16 h-16 rounded-full flex items-center justify-center bg-white/20 border border-white/40 backdrop-blur-3xl cursor-pointer hover:bg-white/40 hover:scale-110 hover:border-white/80 transition-all duration-300 shadow-2xl group-hover:shadow-white/30\" data-kid=\"43\">\n                    <i class=\"ti brand-youtube text-2xl text-white group-hover:scale-110 transition-transform\" data-kid=\"44\"></i>\n                </div>\n                <span class=\"text-[10px] uppercase tracking-widest text-white/60 font-black group-hover:text-white transition-colors\" data-kid=\"45\">Video</span>\n            </div>\n        </nav>\n\n        \n        <main class=\"w-full max-w-6xl px-8 flex justify-center items-end gap-8 mb-4\" data-kid=\"46\">\n            \n            \n            <div class=\"path-card-wrapper relative flex-1 group\" id=\"card-maverick\" data-kid=\"47\">\n                \n                <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-purple-600/50 blur-[100px] rounded-full opacity-40 group-hover:opacity-80 transition-opacity duration-700\" data-kid=\"48\"></div>\n                \n                <div class=\"relative glass-card-body h-[420px] rounded-[40px] border border-white/40 backdrop-blur-3xl bg-white/20 p-10 flex flex-col justify-between overflow-hidden shadow-[0_32px_64px_rgba(0,0,0,0.15),inset_0_0_30px_rgba(255,255,255,0.1)] hover:border-white/70 transition-all duration-500\" data-kid=\"49\">\n                    <div class=\"flex justify-between items-start\" data-kid=\"50\">\n                        <div data-kid=\"51\">\n                            <p class=\"text-[11px] tracking-[0.4em] font-black text-white/50 uppercase mb-2\" data-kid=\"52\">Vol. I</p>\n                            <h2 class=\"text-4xl font-black text-white tracking-tighter drop-shadow-md\" data-kid=\"53\">Maverick</h2>\n                        </div>\n                        <div class=\"w-10 h-10 rounded-full bg-white/10 border border-white/20 flex items-center justify-center\" data-kid=\"54\">\n                            <i class=\"ti ti-rocket text-purple-200\" data-kid=\"55\"></i>\n                        </div>\n                    </div>\n                    \n                    <div class=\"space-y-6\" data-kid=\"56\">\n                        <div class=\"h-[1px] w-full bg-white/10\" data-kid=\"57\"></div>\n                        <button class=\"w-full py-5 rounded-2xl bg-white text-black font-black text-xs tracking-[0.3em] uppercase hover:bg-purple-50 hover:shadow-2xl hover:scale-[1.02] transition-all duration-300\" data-kid=\"58\">\n                            Enter\n                        </button>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"path-card-wrapper relative flex-1 group\" id=\"card-bell\" data-kid=\"59\">\n                \n                <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-rose-600/50 blur-[100px] rounded-full opacity-40 group-hover:opacity-80 transition-opacity duration-700\" data-kid=\"60\"></div>\n                \n                <div class=\"relative glass-card-body h-[420px] rounded-[40px] border border-white/40 backdrop-blur-3xl bg-white/20 p-10 flex flex-col justify-between overflow-hidden shadow-[0_32px_64px_rgba(0,0,0,0.15),inset_0_0_30px_rgba(255,255,255,0.1)] hover:border-white/70 transition-all duration-500\" data-kid=\"61\">\n                    <div class=\"flex justify-between items-start\" data-kid=\"62\">\n                        <div data-kid=\"63\">\n                            <p class=\"text-[11px] tracking-[0.4em] font-black text-white/50 uppercase mb-2\" data-kid=\"64\">Vol. II</p>\n                            <h2 class=\"text-4xl font-black text-white tracking-tighter drop-shadow-md\" data-kid=\"65\">Bell</h2>\n                        </div>\n                        <div class=\"w-10 h-10 rounded-full bg-white/10 border border-white/20 flex items-center justify-center\" data-kid=\"66\">\n                            <i class=\"ti ti-bell text-rose-200\" data-kid=\"67\"></i>\n                        </div>\n                    </div>\n                    \n                    <div class=\"space-y-6\" data-kid=\"68\">\n                        <div class=\"h-[1px] w-full bg-white/10\" data-kid=\"69\"></div>\n                        <button class=\"w-full py-5 rounded-2xl bg-white text-black font-black text-xs tracking-[0.3em] uppercase hover:bg-rose-50 hover:shadow-2xl hover:scale-[1.02] transition-all duration-300\" data-kid=\"70\">\n                            Enter\n                        </button>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"path-card-wrapper relative flex-1 group\" id=\"card-goju\" data-kid=\"71\">\n                \n                <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-emerald-500/50 blur-[100px] rounded-full opacity-40 group-hover:opacity-80 transition-opacity duration-700\" data-kid=\"72\"></div>\n                \n                <div class=\"relative glass-card-body h-[420px] rounded-[40px] border border-white/40 backdrop-blur-3xl bg-white/20 p-10 flex flex-col justify-between overflow-hidden shadow-[0_32px_64px_rgba(0,0,0,0.15),inset_0_0_30px_rgba(255,255,255,0.1)] hover:border-white/70 transition-all duration-500\" data-kid=\"73\">\n                    <div class=\"flex justify-between items-start\" data-kid=\"74\">\n                        <div data-kid=\"75\">\n                            <p class=\"text-[11px] tracking-[0.4em] font-black text-white/50 uppercase mb-2\" data-kid=\"76\">Vol. III</p>\n                            <h2 class=\"text-4xl font-black text-white tracking-tighter drop-shadow-md\" data-kid=\"77\">Goju</h2>\n                        </div>\n                        <div class=\"w-10 h-10 rounded-full bg-white/10 border border-white/20 flex items-center justify-center\" data-kid=\"78\">\n                            <i class=\"ti ti-leaf text-emerald-200\" data-kid=\"79\"></i>\n                        </div>\n                    </div>\n                    \n                    <div class=\"space-y-6\" data-kid=\"80\">\n                        <div class=\"h-[1px] w-full bg-white/10\" data-kid=\"81\"></div>\n                        <button class=\"w-full py-5 rounded-2xl bg-white text-black font-black text-xs tracking-[0.3em] uppercase hover:bg-emerald-50 hover:shadow-2xl hover:scale-[1.02] transition-all duration-300\" data-kid=\"82\">\n                            Enter\n                        </button>\n                    </div>\n                </div>\n            </div>\n\n        </main>\n    </div>\n\n    \n</div>\n\n<style data-kid=\"83\">\n    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;600&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    body {\n        margin: 0;\n        background: #f0f4f8;\n    }\n\n    /* Glass Effect Highlights */\n    .glass-card-body::before {\n        content: '';\n        position: absolute;\n        top: 0;\n        left: 0;\n        right: 0;\n        height: 100%;\n        background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 60%);\n        pointer-events: none;\n    }\n\n    .logo-plaque-container div::after {\n        content: '';\n        position: absolute;\n        inset: 0;\n        border-radius: inherit;\n        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.4);\n        pointer-events: none;\n    }\n\n    /* Animation Classes */\n    .ti {\n        display: inline-block;\n    }\n\n    /* Tabler Icons Fixes */\n    .brand-youtube::before {\n        content: \"\\f0d1\";\n        font-family: \"tabler-icons\";\n    }\n</style>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"84\"></script>\n<script data-kid=\"85\">\n    document.addEventListener('DOMContentLoaded', () => {\n        const tl = gsap.timeline();\n\n        // Initial states\n        gsap.set(\"#logo-plaque\", { y: -50, opacity: 0 });\n        gsap.set(\".category-item\", { scale: 0.8, opacity: 0 });\n        gsap.set(\".path-card-wrapper\", { y: 100, opacity: 0 });\n\n        // Animation sequence\n        tl.to(\"#logo-plaque\", { \n            y: 0, \n            opacity: 1, \n            duration: 1.2, \n            ease: \"expo.out\" \n        })\n        .to(\".category-item\", { \n            scale: 1, \n            opacity: 1, \n            stagger: 0.05, \n            duration: 0.8, \n            ease: \"back.out(1.7)\" \n        }, \"-=0.8\")\n        .to(\".path-card-wrapper\", { \n            y: 0, \n            opacity: 1, \n            stagger: 0.1, \n            duration: 1.2, \n            ease: \"power4.out\" \n        }, \"-=0.6\");\n\n        // Subtle floating effect for cards\n        gsap.to(\".path-card-wrapper\", {\n            y: \"-=15\",\n            duration: 3,\n            repeat: -1,\n            yoyo: true,\n            ease: \"sine.inOut\",\n            stagger: {\n                each: 0.4,\n                from: \"random\"\n            }\n        });\n    });\n</script>\n",
