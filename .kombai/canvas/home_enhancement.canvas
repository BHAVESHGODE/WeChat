      "html": "\n<section class=\"relative min-h-screen w-full flex flex-col items-center justify-center overflow-hidden font-['Crimson_Text']\" data-kid=\"0\">\n    \n    \n    <div class=\"absolute inset-0 z-0\" data-kid=\"1\">\n        <img src=\"https://images.pexels.com/photos/35719475/pexels-photo-35719475.jpeg?auto=compress&cs=tinysrgb&w=1920&q=80\" alt=\"Library Background\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"2\">\n        \n        <div class=\"absolute inset-0 bg-radial-[circle_at_center,_transparent_40%,_black_90%] opacity-90\" data-kid=\"3\"></div>\n        <div class=\"absolute inset-0 bg-black/40\" data-kid=\"4\"></div>\n    </div>\n\n    \n    <div class=\"relative z-10 w-full max-w-7xl mx-auto px-4 flex flex-col items-center justify-center min-h-screen py-20\" data-kid=\"5\">\n        \n        \n        <div id=\"logo-container\" class=\"logo-box relative w-[480px] h-[180px] bg-[#3A1C14] rounded-xs border-2 border-[#D4AF37]/40 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.8)] flex flex-col items-center justify-center overflow-hidden mb-12\" data-kid=\"6\">\n            \n            <div class=\"absolute inset-0 opacity-15 pointer-events-none\" style=\"background-image: url('https://www.transparenttextures.com/patterns/leather.png');\" data-kid=\"7\"></div>\n            \n            <div class=\"absolute inset-y-0 left-6 w-px bg-gradient-to-b from-transparent via-[#D4AF37]/30 to-transparent\" data-kid=\"8\"></div>\n            <div class=\"absolute inset-y-0 left-8 w-px bg-gradient-to-b from-transparent via-[#D4AF37]/30 to-transparent\" data-kid=\"9\"></div>\n            <div class=\"absolute inset-y-0 right-6 w-px bg-gradient-to-b from-transparent via-[#D4AF37]/30 to-transparent\" data-kid=\"10\"></div>\n            <div class=\"absolute inset-y-0 right-8 w-px bg-gradient-to-b from-transparent via-[#D4AF37]/30 to-transparent\" data-kid=\"11\"></div>\n            \n            \n            <h1 class=\"text-7xl font-['Cinzel'] font-bold tracking-[0.15em] text-transparent bg-clip-text bg-gradient-to-b from-[#FFF5CC] via-[#D4AF37] to-[#8C6F25] filter drop-shadow-[0_2px_1px_rgba(0,0,0,1)] select-none\" data-kid=\"12\">\n                WeGift\n            </h1>\n            \n            \n            <div class=\"mt-6 flex items-center gap-6 w-full px-16\" data-kid=\"13\">\n                <div class=\"h-[1px] grow bg-gradient-to-r from-transparent via-[#D4AF37]/40 to-transparent\" data-kid=\"14\"></div>\n                <p class=\"text-[11px] tracking-[0.45em] font-['Cinzel'] text-[#D4AF37] uppercase opacity-90 drop-shadow-[0_1px_1px_rgba(0,0,0,0.5)]\" data-kid=\"15\">\n                    By - Maverick aka Bhavesh\n                </p>\n                <div class=\"h-[1px] grow bg-gradient-to-l from-transparent via-[#D4AF37]/40 to-transparent\" data-kid=\"16\"></div>\n            </div>\n        </div>\n\n        \n        <div class=\"relative w-full flex flex-col items-center mb-24\" data-kid=\"17\">\n            \n            <div class=\"absolute bottom-[-10px] w-1/2 h-1 bg-gradient-to-r from-transparent via-[#D4AF37]/20 to-transparent\" data-kid=\"18\"></div>\n            <div id=\"category-shelf\" class=\"flex flex-wrap items-center justify-center gap-10\" data-kid=\"19\">\n                \n                <button class=\"brass-coin group relative w-16 h-16 rounded-full flex items-center justify-center cursor-pointer\" data-kid=\"20\">\n                    <i class=\"ti ti-music text-[#3A1C14] text-2xl opacity-80 group-hover:opacity-100 transition-opacity\" data-kid=\"21\"></i>\n                </button>\n                <button class=\"brass-coin group relative w-16 h-16 rounded-full flex items-center justify-center cursor-pointer\" data-kid=\"22\">\n                    <i class=\"ti ti-movie text-[#3A1C14] text-2xl opacity-80 group-hover:opacity-100 transition-opacity\" data-kid=\"23\"></i>\n                </button>\n                <button class=\"brass-coin group relative w-16 h-16 rounded-full flex items-center justify-center cursor-pointer\" data-kid=\"24\">\n                    <i class=\"ti ti-device-tv text-[#3A1C14] text-2xl opacity-80 group-hover:opacity-100 transition-opacity\" data-kid=\"25\"></i>\n                </button>\n                <button class=\"brass-coin group relative w-16 h-16 rounded-full flex items-center justify-center cursor-pointer\" data-kid=\"26\">\n                    <i class=\"ti ti-book text-[#3A1C14] text-2xl opacity-80 group-hover:opacity-100 transition-opacity\" data-kid=\"27\"></i>\n                </button>\n                <button class=\"brass-coin group relative w-16 h-16 rounded-full flex items-center justify-center cursor-pointer\" data-kid=\"28\">\n                    <i class=\"ti ti-palette text-[#3A1C14] text-2xl opacity-80 group-hover:opacity-100 transition-opacity\" data-kid=\"29\"></i>\n                </button>\n                <button class=\"brass-coin group relative w-16 h-16 rounded-full flex items-center justify-center cursor-pointer\" data-kid=\"30\">\n                    <i class=\"ti ti-device-gamepad text-[#3A1C14] text-2xl opacity-80 group-hover:opacity-100 transition-opacity\" data-kid=\"31\"></i>\n                </button>\n                <button class=\"brass-coin group relative w-16 h-16 rounded-full flex items-center justify-center cursor-pointer\" data-kid=\"32\">\n                    <i class=\"ti ti-message-circle text-[#3A1C14] text-2xl opacity-80 group-hover:opacity-100 transition-opacity\" data-kid=\"33\"></i>\n                </button>\n                <button class=\"brass-coin group relative w-16 h-16 rounded-full flex items-center justify-center cursor-pointer\" data-kid=\"34\">\n                    <i class=\"ti ti-player-play text-[#3A1C14] text-2xl opacity-80 group-hover:opacity-100 transition-opacity\" data-kid=\"35\"></i>\n                </button>\n            </div>\n        </div>\n\n        \n        <div id=\"path-cards\" class=\"grid grid-cols-1 md:grid-cols-3 gap-12 w-full max-w-5xl\" data-kid=\"36\">\n            \n            <div class=\"book-card group relative bg-[#4B2E5C] h-96 rounded-sm shadow-[15px_15px_40px_rgba(0,0,0,0.7)] flex flex-col p-8 cursor-pointer border-l-10 border-black/30 transform-gpu perspective-1000\" data-kid=\"37\">\n                <div class=\"absolute inset-0 opacity-20 pointer-events-none\" style=\"background-image: url('https://www.transparenttextures.com/patterns/leather.png');\" data-kid=\"38\"></div>\n                <div class=\"flex justify-between items-start mb-10\" data-kid=\"39\">\n                    <span class=\"font-['Cinzel'] text-sm text-[#D4AF37]/70 italic tracking-widest\" data-kid=\"40\">VOL. I</span>\n                    <div class=\"w-10 h-10 flex items-center justify-center bg-black/20 rounded-full p-2\" data-kid=\"41\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/rocket.svg\" class=\"w-full h-full drop-shadow-[0_5px_5px_rgba(0,0,0,0.5)]\" alt=\"Rocket\" decoding=\"async\" loading=\"lazy\" data-kid=\"42\">\n                    </div>\n                </div>\n                <div class=\"mt-auto flex flex-col items-center\" data-kid=\"43\">\n                    <h2 class=\"text-4xl font-['Cinzel'] font-bold text-[#D4AF37] tracking-wider mb-12 drop-shadow-[0_3px_2px_rgba(0,0,0,0.6)]\" data-kid=\"44\">Maverick</h2>\n                    <div class=\"enter-btn relative w-full py-3 bg-black/50 border-t border-b border-[#D4AF37]/20 flex items-center justify-center text-[#D4AF37] font-['Cinzel'] text-xs tracking-[0.4em] overflow-hidden group-hover:bg-[#D4AF37] group-hover:text-[#1A0F0A] transition-all duration-500\" data-kid=\"45\">\n                        <span class=\"relative z-10\" data-kid=\"46\">ENTER</span>\n                        <div class=\"absolute inset-0 bg-gradient-to-r from-transparent via-[#D4AF37]/10 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000\" data-kid=\"47\"></div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"book-card group relative bg-[#6B2737] h-96 rounded-sm shadow-[15px_15px_40px_rgba(0,0,0,0.7)] flex flex-col p-8 cursor-pointer border-l-10 border-black/30 transform-gpu perspective-1000\" data-kid=\"48\">\n                <div class=\"absolute inset-0 opacity-20 pointer-events-none\" style=\"background-image: url('https://www.transparenttextures.com/patterns/leather.png');\" data-kid=\"49\"></div>\n                <div class=\"flex justify-between items-start mb-10\" data-kid=\"50\">\n                    <span class=\"font-['Cinzel'] text-sm text-[#D4AF37]/70 italic tracking-widest\" data-kid=\"51\">VOL. II</span>\n                    <div class=\"w-10 h-10 flex items-center justify-center bg-black/20 rounded-full p-2\" data-kid=\"52\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bell.svg\" class=\"w-full h-full drop-shadow-[0_5px_5px_rgba(0,0,0,0.5)]\" alt=\"Bell\" decoding=\"async\" loading=\"lazy\" data-kid=\"53\">\n                    </div>\n                </div>\n                <div class=\"mt-auto flex flex-col items-center\" data-kid=\"54\">\n                    <h2 class=\"text-4xl font-['Cinzel'] font-bold text-[#D4AF37] tracking-wider mb-12 drop-shadow-[0_3px_2px_rgba(0,0,0,0.6)]\" data-kid=\"55\">Bell</h2>\n                    <div class=\"enter-btn relative w-full py-3 bg-black/50 border-t border-b border-[#D4AF37]/20 flex items-center justify-center text-[#D4AF37] font-['Cinzel'] text-xs tracking-[0.4em] overflow-hidden group-hover:bg-[#D4AF37] group-hover:text-[#1A0F0A] transition-all duration-500\" data-kid=\"56\">\n                        <span class=\"relative z-10\" data-kid=\"57\">ENTER</span>\n                        <div class=\"absolute inset-0 bg-gradient-to-r from-transparent via-[#D4AF37]/10 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000\" data-kid=\"58\"></div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"book-card group relative bg-[#2C4C3B] h-96 rounded-sm shadow-[15px_15px_40px_rgba(0,0,0,0.7)] flex flex-col p-8 cursor-pointer border-l-10 border-black/30 transform-gpu perspective-1000\" data-kid=\"59\">\n                <div class=\"absolute inset-0 opacity-20 pointer-events-none\" style=\"background-image: url('https://www.transparenttextures.com/patterns/leather.png');\" data-kid=\"60\"></div>\n                <div class=\"flex justify-between items-start mb-10\" data-kid=\"61\">\n                    <span class=\"font-['Cinzel'] text-sm text-[#D4AF37]/70 italic tracking-widest\" data-kid=\"62\">VOL. III</span>\n                    <div class=\"w-10 h-10 flex items-center justify-center bg-black/20 rounded-full p-2\" data-kid=\"63\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/dragon.svg\" class=\"w-full h-full drop-shadow-[0_5px_5px_rgba(0,0,0,0.5)]\" alt=\"Dragon\" decoding=\"async\" loading=\"lazy\" data-kid=\"64\">\n                    </div>\n                </div>\n                <div class=\"mt-auto flex flex-col items-center\" data-kid=\"65\">\n                    <h2 class=\"text-4xl font-['Cinzel'] font-bold text-[#D4AF37] tracking-wider mb-12 drop-shadow-[0_3px_2px_rgba(0,0,0,0.6)]\" data-kid=\"66\">Goju</h2>\n                    <div class=\"enter-btn relative w-full py-3 bg-black/50 border-t border-b border-[#D4AF37]/20 flex items-center justify-center text-[#D4AF37] font-['Cinzel'] text-xs tracking-[0.4em] overflow-hidden group-hover:bg-[#D4AF37] group-hover:text-[#1A0F0A] transition-all duration-500\" data-kid=\"67\">\n                        <span class=\"relative z-10\" data-kid=\"68\">ENTER</span>\n                        <div class=\"absolute inset-0 bg-gradient-to-r from-transparent via-[#D4AF37]/10 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000\" data-kid=\"69\"></div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    \n    <div class=\"absolute top-0 left-1/4 w-[600px] h-[600px] bg-[#D4AF37]/5 rounded-full blur-[150px] pointer-events-none\" data-kid=\"70\"></div>\n    <div class=\"absolute bottom-0 right-1/4 w-[600px] h-[600px] bg-[#D4AF37]/5 rounded-full blur-[150px] pointer-events-none\" data-kid=\"71\"></div>\n\n</section>\n\n<style data-kid=\"72\">\n@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Crimson+Text:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n/* Brass Coin Styling */\n.brass-coin {\n    background: radial-gradient(circle at 35% 35%, #FFF0BE 0%, #E6C87E 25%, #D4AF37 45%, #B8860B 70%, #5C4314 100%);\n    box-shadow: \n        inset 0 3px 6px rgba(255,255,255,0.5),\n        inset 0 -3px 6px rgba(0,0,0,0.6),\n        0 15px 25px rgba(0,0,0,0.5),\n        0 0 0 2px #5C4314;\n    border: none;\n    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n}\n\n.brass-coin:hover {\n    transform: translateY(-4px) scale(1.05);\n    box-shadow: \n        inset 0 2px 4px rgba(255,255,255,0.5),\n        inset 0 -2px 6px rgba(0,0,0,0.4),\n        0 15px 30px rgba(0,0,0,0.5);\n}\n\n.brass-coin:active {\n    transform: translateY(2px) scale(0.98);\n    box-shadow: \n        inset 0 4px 8px rgba(0,0,0,0.7),\n        0 5px 10px rgba(0,0,0,0.3);\n}\n\n/* Recessed Label Styling for Enter Button */\n.enter-btn {\n    box-shadow: inset 0 2px 8px rgba(0,0,0,0.8);\n    transition: all 0.4s ease;\n}\n\n/* Book Card Hover Effect */\n.book-card {\n    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.6s ease;\n}\n\n.book-card:hover {\n    transform: perspective(1000px) rotateY(-5deg) translateY(-10px);\n    box-shadow: 25px 25px 60px rgba(0,0,0,0.8);\n}\n\n/* Custom Scrollbar (if any) */\n::-webkit-scrollbar {\n    width: 6px;\n}\n::-webkit-scrollbar-track {\n    background: #1A0F0A;\n}\n::-webkit-scrollbar-thumb {\n    background: #3A1C14;\n    border: 1px solid #D4AF37;\n}\n</style>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"73\"></script>\n<script data-kid=\"74\">\ndocument.addEventListener('DOMContentLoaded', () => {\n    // Initial Entrance Animations\n    const tl = gsap.timeline();\n\n    tl.from(\"#logo-container\", {\n        y: -100,\n        opacity: 0,\n        duration: 1.5,\n        ease: \"power4.out\"\n    });\n\n    // Add a gold shine animation to the logo\n    gsap.to(\"h1\", {\n        backgroundPosition: \"200% center\",\n        duration: 5,\n        repeat: -1,\n        ease: \"linear\"\n    });\n\n    tl.from(\".brass-coin\", {\n        scale: 0,\n        opacity: 0,\n        stagger: 0.1,\n        duration: 0.8,\n        ease: \"back.out(1.7)\"\n    }, \"-=0.8\");\n\n    tl.from(\".book-card\", {\n        y: 100,\n        opacity: 0,\n        stagger: 0.2,\n        duration: 1,\n        ease: \"power3.out\"\n    }, \"-=0.6\");\n\n    // Add subtle ambient hover animations for icons if needed\n});\n</script>\n",
