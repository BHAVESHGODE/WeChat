infinite alternate none running gb-flame-dance; }\n.gb-flame-glow { position: absolute; top: -18px; left: 50%; transform: translateX(-50%); width: 20px; height: 24px; background: radial-gradient(rgba(255, 215, 0, 0.4), transparent 70%); border-radius: 50%; pointer-events: none; animation: 0.6s ease-in-out 0s infinite alternate none running gb-flame-glow-pulse; }\n@keyframes gb-candle-wiggle {\n0%, 100% { transform: rotate(0deg); }\n25% { transform: rotate(1.5deg); }\n75% { transform: rotate(-1.5deg); }\n}\n@keyframes gb-flame-dance {\n0% { transform: translateX(-50%) scale(1) rotate(-2deg); }\n100% { transform: translateX(-50%) scale(1.1, 0.9) rotate(2deg); }\n}\n@keyframes gb-flame-glow-pulse {\n0% { opacity: 0.4; transform: translateX(-50%) scale(1); }\n100% { opacity: 0.8; transform: translateX(-50%) scale(1.15); }\n}\n.gb-cake-cut { cursor: default; }\n.gb-cake-cut:hover { transform: none; }\n.gb-cake-cut .gb-candle { animation: 0.5s ease-out 0s 1 normal forwards running gb-blow-out; }\n.gb-cake-cut .gb-flame { animation: 0.3s ease-out 0s 1 normal forwards running gb-flame-out; }\n.gb-cake-cut .gb-flame-glow { animation: 0.3s ease-out 0s 1 normal forwards running gb-flame-out; }\n@keyframes gb-blow-out {\n0% { transform: rotate(0deg) scaleY(1); opacity: 1; }\n50% { transform: rotate(10deg) scaleY(1.5); opacity: 0.6; }\n100% { transform: rotate(-5deg) scaleY(0.1); opacity: 0; }\n}\n@keyframes gb-flame-out {\n0% { opacity: 1; }\n100% { opacity: 0; transform: scale(0); }\n}\n.gb-smoke-puff { position: absolute; top: -10px; left: 50%; transform: translateX(-50%); width: 30px; height: 30px; background: radial-gradient(circle, rgba(200, 200, 200, 0.3), transparent); border-radius: 50%; animation: 1s ease-out 0s 1 normal forwards running gb-smoke-rise; }\n@keyframes gb-smoke-rise {\n0% { transform: translateX(-50%) scale(0.5); opacity: 0.6; }\n100% { transform: translateX(-50%) translateY(-30px) scale(2); opacity: 0; }\n}\n.gb-slice-container { position: absolute; top: 30px; left: 0px; right: 0px; height: 100px; z-index: 6; pointer-events: none; }\n.gb-slice { position: absolute; left: 50%; top: 50%; font-size: 1.8rem; animation: 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0s 1 normal forwards running gb-slice-pop; opacity: 0; }\n@keyframes gb-slice-pop {\n0% { transform: scale(0) rotate(0deg); opacity: 0; }\n60% { transform: scale(1.3); opacity: 1; }\n100% { transform: scale(1); opacity: 1; }\n}\n.gb-cake-hint { font-size: clamp(0.8rem, 2.5vw, 0.95rem); color: var(--gb-text-muted); text-align: center; margin: 0.75rem 0px; animation: 0.5s ease 0s 1 normal both running gb-fade-up; }\n.gb-celebrate-actions { animation: 0.6s ease 0s 1 normal both running gb-fade-up; }\n.gb-card-page { background: radial-gradient(ellipse at 30% 30%, rgba(199, 125, 255, 0.12) 0%, transparent 50%),\n    radial-gradient(ellipse at 70% 60%, rgba(255, 215, 0, 0.06) 0%, transparent 40%),\n    radial-gradient(ellipse at 50% 80%, rgba(255, 143, 171, 0.08) 0%, transparent 40%),\n    linear-gradient(180deg, var(--gb-bg-end), var(--gb-bg-mid)); }\n.gb-card-rk-aura { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 340px; height: 340px; pointer-events: none; z-index: 1; }\n.gb-rk-glow-ring { position: absolute; inset: 0px; border-radius: 50%; border: 2px solid rgba(255, 215, 0, 0.06); box-shadow: rgba(199, 125, 255, 0.04) 0px 0px 80px, rgba(255, 215, 0, 0.02) 0px 0px 80px inset; animation: 5s ease-in-out 0s infinite normal none running gb-aura-pulse; }\n.gb-rk-g2 { inset: 20%; border-color: rgba(255, 143, 171, 0.08); animation-delay: 1s; }\n.gb-rk-g3 { inset: 40%; border-color: rgba(199, 125, 255, 0.1); animation-delay: 2s; box-shadow: rgba(199, 125, 255, 0.06) 0px 0px 60px, rgba(255, 215, 0, 0.03) 0px 0px 60px inset; }\n@keyframes gb-aura-pulse {\n0%, 100% { transform: scale(1); opacity: 0.5; }\n50% { transform: scale(1.06); opacity: 1; }\n}\n.gb-card-content { display: flex; flex-direction: column; align-items: center; width: 100%; max-width: 400px; position: relative; z-index: 2; }\n.gb-flip-card { width: 280px; height: 380px; perspective: 1000px; cursor: pointer; margin: 0.5rem 0px; }\n.gb-flip-inner { position: relative; width: 100%; height: 100%; transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1); transform-style: preserve-3d; }\n.gb-flipped .gb-flip-inner { transform: rotateY(180deg); }\n.gb-flip-front, .gb-flip-back { position: absolute; inset: 0px; backface-visibility: hidden; border-radius: 16px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 1.5rem; box-sizing: border-box; }\n.gb-flip-front { background: linear-gradient(145deg, rgba(255, 143, 171, 0.15), rgba(199, 125, 255, 0.18)); border: 1px solid rgba(255, 215, 0, 0.2); box-shadow: rgba(0, 0, 0, 0.3) 0px 8px 32px, rgba(255, 255, 255, 0.1) 0px 1px 0px inset, rgba(255, 215, 0, 0.06) 0px 0px 40px; }\n.gb-flip-back { background: linear-gradient(145deg, rgba(199, 125, 255, 0.2), rgba(255, 143, 171, 0.18)); border: 1px solid rgba(199, 125, 255, 0.3); box-shadow: rgba(0, 0, 0, 0.3) 0px 8px 32px, rgba(255, 255, 255, 0.1) 0px 1px 0px inset, rgba(199, 125, 255, 0.1) 0px 0px 40px; transform: rotateY(180deg); }\n.gb-card-front-deco { display: flex; gap: 0.75rem; margin-bottom: 1rem; }\n.gb-card-front-deco span { font-size: 1.8rem; animation: 2s ease-in-out 0s infinite normal none running gb-twinkle; }\n.gb-card-front-deco span:nth-child(2) { animation-delay: 0.7s; }\n.gb-card-front-text { display: flex; flex-direction: column; align-items: center; gap: 0.1rem; }\n.gb-front-line { font-family: \"Playfair Display\", serif; font-size: clamp(1.4rem, 5vw, 2rem); color: var(--gb-text); text-shadow: rgba(255, 215, 0, 0.2) 0px 2px 10px; }\n.gb-front-name { font-size: clamp(1.8rem, 6vw, 2.6rem); background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; font-weight: 700; }\n.gb-card-tap-hint { font-size: 0.75rem; color: var(--gb-text-muted); margin-top: 0.75rem; opacity: 0.6; }\n.gb-card-back-deco { font-size: 2.5rem; margin-bottom: 0.75rem; animation: 3s ease-in-out 0s infinite normal none running gb-glow-pulse; }\n@keyframes gb-glow-pulse {\n0%, 100% { filter: drop-shadow(rgba(255, 215, 0, 0.3) 0px 0px 5px); }\n50% { filter: drop-shadow(rgba(255, 215, 0, 0.6) 0px 0px 25px); }\n}\n.gb-blessing-text { font-family: \"Playfair Display\", serif; font-size: clamp(1rem, 3vw, 1.2rem); font-style: italic; text-align: center; line-height: 1.7; color: var(--gb-text); margin: 0.5rem 0px; max-width: 240px; }\n.gb-card-back-ornament { display: flex; gap: 0.5rem; margin: 0.75rem 0px; }\n.gb-card-back-ornament span { font-size: 1.2rem; opacity: 0.7; }\n.gb-card-back-signature { font-family: \"Playfair Display\", serif; font-size: 0.85rem; font-style: italic; color: var(--gb-gold); opacity: 0.7; }\n.gb-card-hint { font-size: clamp(0.8rem, 2.5vw, 0.9rem); color: var(--gb-text-muted); margin: 0.75rem 0px; text-align: center; }\n.gb-collage-page { background: radial-gradient(ellipse at 25% 40%, rgba(199, 125, 255, 0.1) 0%, transparent 50%),\n    radial-gradient(ellipse at 75% 60%, rgba(255, 143, 171, 0.1) 0%, transparent 50%),\n    radial-gradient(ellipse at 50% 30%, rgba(255, 215, 0, 0.04) 0%, transparent 40%),\n    linear-gradient(180deg, var(--gb-bg-mid), var(--gb-bg-start)); }\n.gb-collage-content { display: flex; flex-direction: column; align-items: center; width: 100%; max-width: 480px; padding: 0.5rem 0px; }\n.gb-polaroid-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; width: 100%; padding: 0.5rem; box-sizing: border-box; }\n.gb-polaroid { background: rgba(255, 255, 255, 0.07); border-radius: 8px; padding: 0.5rem 0.5rem 0.6rem; box-shadow: rgba(0, 0, 0, 0.3) 0px 4px 15px, rgba(199, 125, 255, 0.04) 0px 0px 20px; transition: 0.3s; backdrop-filter: blur(4px); border: 1px solid rgba(199, 125, 255, 0.12); animation: 0.5s ease 0s 1 normal both running gb-stagger-in; position: relative; overflow: hidden; }\n@keyframes gb-stagger-in {\n0% { opacity: 0; transform: translateY(15px) scale(0.95); }\n100% { opacity: 1; transform: translateY(0px) scale(1); }\n}\n.gb-polaroid::before { content: \"\"; position: absolute; inset: 0px; background: linear-gradient(135deg, rgba(199, 125, 255, 0.03), transparent); pointer-events: none; border-radius: 8px; }\n.gb-polaroid:hover { box-shadow: rgba(0, 0, 0, 0.4) 0px 12px 30px, rgba(255, 143, 171, 0.15) 0px 0px 25px, rgba(199, 125, 255, 0.12) 0px 0px 35px; border-color: rgba(255, 215, 0, 0.3); transform: translateY(-6px) scale(1.04) !important; }\n.gb-polaroid-image { aspect-ratio: 1 / 1; border-radius: 4px; overflow: hidden; background: rgba(0, 0, 0, 0.35); display: flex; align-items: center; justify-content: center; position: relative; }\n.gb-polaroid-placeholder { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; opacity: 0.5; transition: opacity 0.3s; }\n.gb-polaroid:hover .gb-polaroid-placeholder { opacity: 0.8; }\n.gb-placeholder-emoji { font-size: 1.8rem; }\n.gb-placeholder-text { font-size: 0.6rem; color: var(--gb-text-muted); font-family: Quicksand, sans-serif; letter-spacing: 0.1em; text-transform: uppercase; }\n.gb-polaroid-bts-badge { position: absolute; top: 4px; right: 4px; font-size: 0.7rem; opacity: 0.25; transition: 0.3s; pointer-events: none; z-index: 2; }\n.gb-polaroid:hover .gb-polaroid-bts-badge { opacity: 0.8; transform: scale(1.2); }\n.gb-polaroid-sparkle-burst { position: absolute; inset: 0px; pointer-events: none; z-index: 3; background: radial-gradient(circle at 20% 30%, rgba(255, 215, 0, 0.08) 0%, transparent 50%), radial-gradient(circle at 80% 70%, rgba(199, 125, 255, 0.08) 0%, transparent 50%), radial-gradient(circle, rgba(255, 255, 255, 0.04) 0%, transparent 60%); animation: 0.6s ease-out 0s 1 normal forwards running gb-sparkle-burst; border-radius: 8px; }\n@keyframes gb-sparkle-burst {\n0% { transform: scale(0.3); opacity: 0; }\n50% { opacity: 1; }\n100% { transform: scale(1.2); opacity: 0; }\n}\n.gb-polaroid-caption { font-size: clamp(0.7rem, 2vw, 0.8rem); text-align: center; margin-top: 0.35rem; color: var(--gb-text); font-family: Caveat, cursive; font-weight: 600; letter-spacing: 0.02em; position: relative; z-index: 1; }\n.gb-blessing-page { background: radial-gradient(ellipse at 50% 30%, rgba(199, 125, 255, 0.15) 0%, transparent 50%),\n    radial-gradient(ellipse at 50% 70%, rgba(255, 215, 0, 0.08) 0%, transparent 40%),\n    radial-gradient(ellipse at 80% 40%, rgba(255, 143, 171, 0.08) 0%, transparent 40%),\n    linear-gradient(180deg, var(--gb-bg-start), var(--gb-bg-end)); text-align: center; }\n.gb-blessing-aura { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 350px; height: 350px; pointer-events: none; z-index: 0; }\n.gb-aura-ring { position: absolute; inset: 0px; border-radius: 50%; animation: 4s ease-in-out 0s infinite normal none running gb-aura-pulse; }\n.gb-aura-outer { border: 2px solid rgba(199, 125, 255, 0.08); box-shadow: rgba(199, 125, 255, 0.04) 0px 0px 80px, rgba(199, 125, 255, 0.02) 0px 0px 80px inset; animation-delay: 0s; }\n.gb-aura-mid { inset: 15%; border: 2px solid rgba(255, 215, 0, 0.06); box-shadow: rgba(255, 215, 0, 0.04) 0px 0px 60px, rgba(255, 215, 0, 0.02) 0px 0px 60px inset; animation-delay: 0.6s; }\n.gb-aura-inner { inset: 30%; border: 2px solid rgba(255, 143, 171, 0.08); box-shadow: rgba(255, 143, 171, 0.05) 0px 0px 40px, rgba(255, 143, 171, 0.02) 0px 0px 40px inset; animation-delay: 1.2s; }\n.gb-blessing-rk-overlay { position: absolute; inset: 0px; pointer-events: none; z-index: 1; display: flex; justify-content: space-around; align-items: center; opacity: 0.12; }\n.gb-rk-peacock, .gb-rk-flute, .gb-rk-lotus { font-size: 3rem; animation: 4s ease-in-out 0s infinite normal none running gb-float-sym; filter: blur(0.5px); }\n.gb-rk-peacock { animation-delay: 0s; }\n.gb-rk-flute { animation-delay: 1.3s; font-size: 2.5rem; }\n.gb-rk-lotus { animation-delay: 2.6s; }\n.gb-blessing-content { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 0.75rem; max-width: 380px; animation: 1s ease 0s 1 normal both running gb-fade-up; }\n.gb-blessing-symbols { display: flex; gap: 1rem; align-items: center; margin-bottom: 0.25rem; }\n.gb-sym { font-size: 1.8rem; opacity: 0.6; animation: 3s ease-in-out 0s infinite normal none running gb-float-sym; }\n.gb-sym-main { font-size: 2.8rem; opacity: 1; filter: drop-shadow(rgba(255, 215, 0, 0.5) 0px 0px 20px); animation-delay: 0.3s; }\n.gb-sym:nth-child(1) { animation-delay: 0s; }\n.gb-sym:nth-child(3) { animation-delay: 0.6s; }\n@keyframes gb-float-sym {\n0%, 100% { transform: translateY(0px); }\n50% { transform: translateY(-7px); }\n}\n.gb-blessing-title { font-family: \"Playfair Display\", serif; font-size: clamp(1.8rem, 6vw, 2.6rem); color: var(--gb-gold-light); margin: 0px; }\n.gb-blessing-message { display: flex; flex-direction: column; gap: 0.3rem; }\n.gb-blessing-message p { font-family: \"Playfair Display\", serif; font-size: clamp(0.95rem, 3vw, 1.15rem); font-style: italic; margin: 0px; color: var(--gb-text); opacity: 0.9; line-height: 1.5; }\n.gb-blessing-highlight { font-weight: 700; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; font-style: normal !important; margin-top: 0.25rem !important; }\n.gb-blessing-deco { display: flex; gap: 0.6rem; }\n.gb-blessing-deco span { color: var(--gb-gold); opacity: 0.4; font-size: 0.9rem; animation: 2.5s ease-in-out 0s infinite normal none running gb-twinkle; }\n.gb-blessing-deco span:nth-child(2) { animation-delay: 0.4s; }\n.gb-blessing-deco span:nth-child(3) { animation-delay: 0.8s; }\n.gb-blessing-deco span:nth-child(4) { animation-delay: 1.2s; }\n.gb-blessing-deco span:nth-child(5) { animation-delay: 1.6s; }\n.gb-final-text { font-family: Quicksand, sans-serif; font-size: clamp(1.2rem, 4vw, 1.6rem); font-weight: 700; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; margin: 0px; }\n.gb-blessing-footer { font-family: \"Playfair Display\", serif; font-size: clamp(0.8rem, 2.5vw, 0.95rem); font-style: italic; color: var(--gb-gold); opacity: 0.7; margin: 0px; }\n.gb-letter-page { background: radial-gradient(at 30% 20%, rgba(255, 143, 171, 0.1) 0%, transparent 50%), radial-gradient(at 70% 80%, rgba(199, 125, 255, 0.1) 0%, transparent 50%), linear-gradient(rgb(26, 14, 46), rgb(45, 27, 78)); position: relative; }\n.gb-letter-content { display: flex; flex-direction: column; align-items: center; width: 100%; max-width: 440px; position: relative; z-index: 3; }\n.gb-letter-ornament-top, .gb-letter-ornament-bottom { position: absolute; left: 50%; transform: translateX(-50%); display: flex; gap: 0.6rem; z-index: 3; pointer-events: none; }\n.gb-letter-ornament-top { top: 1rem; }\n.gb-letter-ornament-bottom { bottom: 1rem; }\n.gb-letter-ornament-top span, .gb-letter-ornament-bottom span { font-size: 1.2rem; opacity: 0.4; animation: 3s ease-in-out 0s infinite normal none running gb-float-sym; }\n.gb-letter-ornament-top span:nth-child(2) { animation-delay: 0.5s; }\n.gb-letter-ornament-top span:nth-child(3) { animation-delay: 1s; }\n.gb-letter-ornament-bottom span:nth-child(2) { animation-delay: 0.7s; }\n.gb-letter-ornament-bottom span:nth-child(3) { animation-delay: 1.4s; }\n.gb-letter-paper { position: relative; width: 100%; max-width: 400px; max-height: 55vh; overflow-y: auto; padding: 1.5rem 1.2rem; margin: 0.5rem 0px; background: rgba(255, 255, 255, 0.06); border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.08); box-shadow: rgba(0, 0, 0, 0.3) 0px 8px 32px, rgba(255, 255, 255, 0.05) 0px 1px 0px inset; scrollbar-width: thin; scrollbar-color: rgba(255, 255, 255, 0.1) transparent; }\n.gb-letter-paper::-webkit-scrollbar { width: 4px; }\n.gb-letter-paper::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 2px; }\n.gb-letter-lines { position: absolute; inset: 0px; pointer-events: none; background: repeating-linear-gradient(0deg, transparent, transparent 28px, rgba(255, 255, 255, 0.03) 28px, rgba(255, 255, 255, 0.03) 29px); border-radius: 12px; }\n.gb-letter-para { font-family: \"Playfair Display\", serif; font-size: clamp(0.85rem, 2.5vw, 1rem); line-height: 1.8; color: var(--gb-text); margin: 0px 0px 0.6rem; opacity: 0; transform: translateY(8px); position: relative; z-index: 1; }\n.gb-para-entering { animation: 0.8s ease 0s 1 normal forwards running gb-para-reveal; }\n.gb-para-visible { opacity: 0.9; transform: translateY(0px); }\n@keyframes gb-para-reveal {\n0% { opacity: 0; transform: translateY(8px); }\n100% { opacity: 0.9; transform: translateY(0px); }\n}\n.gb-letter-typing { display: flex; gap: 4px; padding: 0.5rem 0px; position: relative; z-index: 1; }\n.gb-typing-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gb-pink); animation: 1.2s ease-in-out 0s infinite normal none running gb-typing-bounce; }\n.gb-typing-dot:nth-child(2) { animation-delay: 0.2s; }\n.gb-typing-dot:nth-child(3) { animation-delay: 0.4s; }\n@keyframes gb-typing-bounce {\n0%, 60%, 100% { transform: translateY(0px); opacity: 0.3; }\n30% { transform: translateY(-8px); opacity: 1; }\n}\n.gb-memory-page { background: radial-gradient(ellipse at 70% 20%, rgba(199, 125, 255, 0.12) 0%, transparent 50%),\n    radial-gradient(ellipse at 30% 80%, rgba(255, 143, 171, 0.1) 0%, transparent 50%),\n    linear-gradient(180deg, var(--gb-bg-end), var(--gb-bg-start)); }\n.gb-memory-content { display: flex; flex-direction: column; align-items: center; width: 100%; max-width: 420px; position: relative; z-index: 3; }\n.gb-memory-timeline { position: relative; width: 100%; padding: 0.5rem 0px 0.5rem 1.5rem; }\n.gb-timeline-line { position: absolute; left: 6px; top: 0px; bottom: 0px; width: 2px; background: linear-gradient(180deg, var(--gb-purple), var(--gb-pink), var(--gb-gold)); border-radius: 1px; opacity: 0.4; }\n.gb-memory-card { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.6rem 0.75rem; margin-bottom: 0.4rem; background: rgba(255, 255, 255, 0.04); border-radius: 10px; border: 1px solid rgba(255, 255, 255, 0.05); backdrop-filter: blur(4px); animation: 0.5s ease 0s 1 normal both running gb-stagger-in; transition: 0.3s; position: relative; }\n.gb-memory-card:hover { background: rgba(255, 255, 255, 0.08); border-color: rgba(255, 215, 0, 0.15); transform: translateX(4px); }\n.gb-memory-dot { position: absolute; left: -1.45rem; top: 0.9rem; width: 10px; height: 10px; border-radius: 50%; background: var(--gb-gold); box-shadow: rgba(255, 215, 0, 0.4) 0px 0px 8px; flex-shrink: 0; }\n.gb-memory-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 0.1rem; }\n.gb-memory-text { font-family: \"Playfair Display\", serif; font-size: clamp(0.8rem, 2.5vw, 0.95rem); line-height: 1.5; color: var(--gb-text); opacity: 0.85; }\n.gb-memory-pulse { width: 20px; height: 20px; margin: 1rem auto 0px; border-top-style: ; border-top-width: ; border-right-color: ; border-right-style: ; border-right-width: ; border-bottom-color: ; border-bottom-style: ; border-bottom-width: ; border-left-color: ; border-left-style: ; border-left-width: ; border-image-source: ; border-image-slice: ; border-image-width: ; border-image-outset: ; border-image-repeat: ; border-top-color: transparent; border-radius: 50%; animation: 0.8s linear 0s infinite normal none running gb-spin-loader; }\n@keyframes gb-spin-loader {\n100% { transform: rotate(360deg); }\n}\n.gb-wish-page { background: radial-gradient(ellipse at 50% 20%, rgba(199, 125, 255, 0.12) 0%, transparent 45%),\n    radial-gradient(ellipse at 50% 80%, rgba(255, 215, 0, 0.06) 0%, transparent 40%),\n    linear-gradient(180deg, var(--gb-bg-start), var(--gb-bg-mid)); position: relative; }\n.gb-wish-tree-bg { position: absolute; inset: 0px; pointer-events: none; z-index: 1; display: flex; justify-content: center; align-items: flex-end; }\n.gb-tree-trunk { position: absolute; bottom: 0px; width: 30px; height: 55%; background: linear-gradient(rgba(139, 90, 43, 0.15), rgba(139, 90, 43, 0.25)); border-radius: 6px 6px 0px 0px; }\n.gb-tree-canopy { position: absolute; inset: 5% 10% 20%; }\n.gb-tree-leaf { position: absolute; border-radius: 50%; background: rgba(255, 215, 0, 0.08); animation: auto ease-in-out 0s infinite normal none running gb-leaf-drift; }\n@keyframes gb-leaf-drift {\n0%, 100% { transform: translate(0px, 0px) scale(1); opacity: 0.1; }\n25% { transform: translate(8px, -10px) scale(1.2); opacity: 0.3; }\n50% { transform: translate(-4px, -18px) scale(0.9); opacity: 0.2; }\n75% { transform: translate(6px, -6px) scale(1.1); opacity: 0.3; }\n}\n.gb-wish-content { display: flex; flex-direction: column; align-items: center; width: 100%; max-width: 420px; position: relative; z-index: 3; }\n.gb-wish-stars { display: flex; flex-direction: column; gap: 0.5rem; width: 100%; padding: 0.5rem 0px; }\n.gb-wish-star { display: flex; align-items: center; gap: 0.65rem; padding: 0.55rem 0.75rem; background: rgba(255, 255, 255, 0.04); border-radius: 10px; border: 1px solid rgba(255, 215, 0, 0.08); animation: 0.5s ease 0s 1 normal both running gb-stagger-in; transition: 0.3s; }\n.gb-wish-star:hover { background: rgba(255, 215, 0, 0.06); border-color: rgba(255, 215, 0, 0.2); transform: translateX(4px); }\n.gb-wish-icon { font-size: 1.2rem; flex-shrink: 0; animation: 2s ease-in-out 0s infinite normal none running gb-twinkle; }\n.gb-wish-text { font-family: Caveat, cursive; font-size: clamp(0.9rem, 2.5vw, 1.05rem); color: var(--gb-text); opacity: 0.85; line-height: 1.4; }\n.gb-wish-glowing { text-align: center; font-size: 1.8rem; animation: 1.5s ease-in-out 0s infinite normal none running gb-pulse-hint; margin-top: 0.5rem; }\n.gb-finale-page { background: radial-gradient(at 50% 30%, rgba(199, 125, 255, 0.1) 0%, transparent 55%), radial-gradient(at 50% 70%, rgba(255, 143, 171, 0.08) 0%, transparent 45%), linear-gradient(rgb(13, 6, 24), rgb(26, 10, 46), rgb(45, 27, 78)); position: relative; text-align: center; }\n.gb-firework-layer { position: absolute; inset: 0px; pointer-events: none; z-index: 2; overflow: hidden; }\n.gb-firework-burst { position: absolute; width: 0px; height: 0px; z-index: 2; }\n.gb-firework-dot { position: absolute; left: 0px; top: 0px; border-radius: 50%; animation: 1s ease-out 0s 1 normal forwards running gb-firework-particle; opacity: 0; }\n@keyframes gb-firework-particle {\n0% { transform: rotate(var(--fw-angle)) translateY(0) scale(1); opacity: 1; }\n50% { opacity: 1; }\n100% { transform: rotate(var(--fw-angle)) translateY(calc(var(--fw-dist) * -1)) scale(0.2); opacity: 0; }\n}\n.gb-finale-content { display: flex; flex-direction: column; align-items: center; gap: 0.6rem; position: relative; z-index: 5; max-width: 420px; animation: 1s ease 0s 1 normal both running gb-fade-up; }\n.gb-finale-badge { font-size: clamp(2.5rem, 10vw, 4rem); animation: 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0s 1 normal both running gb-bounce-in; filter: drop-shadow(rgba(255, 215, 0, 0.3) 0px 0px 25px); }\n.gb-finale-title { font-family: \"Playfair Display\", serif; font-size: clamp(2rem, 8vw, 3.2rem); line-height: 1.2; margin: 0px; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; }\n.gb-finale-message { display: flex; flex-direction: column; gap: 0.2rem; margin: 0.5rem 0px; }\n.gb-finale-line { font-family: \"Playfair Display\", serif; font-size: clamp(0.9rem, 2.5vw, 1.05rem); font-style: italic; color: var(--gb-text); opacity: 0; animation: 0.8s ease 0s 1 normal forwards running gb-para-reveal; margin: 0px; line-height: 1.6; }\n.gb-finale-line:nth-child(1) { animation-delay: 0.3s; }\n.gb-finale-line:nth-child(2) { animation-delay: 0.8s; }\n.gb-finale-line:nth-child(3) { animation-delay: 1.3s; }\n.gb-finale-line:nth-child(4) { animation-delay: 1.8s; }\n.gb-finale-hearts { position: relative; width: 100%; height: 60px; margin: 0.5rem 0px; }\n.gb-heart-float { position: absolute; font-size: 1.3rem; animation: 3s ease-in-out 0s infinite normal none running gb-heart-rise; opacity: 0.6; }\n@keyframes gb-heart-rise {\n0% { transform: translateY(0px) scale(1); opacity: 0.3; }\n50% { transform: translateY(-20px) scale(1.15); opacity: 0.8; }\n100% { transform: translateY(0px) scale(1); opacity: 0.3; }\n}\n.gb-finale-signature { font-family: Caveat, cursive; font-size: clamp(1rem, 3vw, 1.3rem); color: var(--gb-gold-light); opacity: 0.85; margin: 0.25rem 0px; animation: 0.8s ease 2s 1 normal both running gb-fade-up; }\n.gb-finale-from { font-family: \"Playfair Display\", serif; font-size: clamp(0.75rem, 2vw, 0.9rem); font-style: italic; color: var(--gb-text-muted); margin: 0px; animation: 0.8s ease 2.5s 1 normal both running gb-fade-up; }\n.gb-music-bar { position: absolute; bottom: 4rem; left: 50%; transform: translateX(-50%); z-index: 40; animation: 0.8s ease 1s 1 normal both running gb-fade-up; }\n.gb-music-bar-btn { display: flex; align-items: center; gap: 0.5rem; padding: 0.35rem 1rem 0.35rem 0.6rem; border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 50px; background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(10px); color: var(--gb-text); font-family: Quicksand, sans-serif; font-size: 0.75rem; cursor: pointer; transition: 0.3s; white-space: nowrap; }\n.gb-music-bar-btn:hover { border-color: var(--gb-pink); background: rgba(0, 0, 0, 0.55); }\n.gb-music-icon { font-size: 0.9rem; }\n.gb-music-label { 