tion: fixed; inset: 0px; background: linear-gradient(145deg, var(--gb-bg-start), var(--gb-bg-mid), var(--gb-bg-end)); color: var(--gb-text); font-family: Quicksand, sans-serif; overflow: hidden; z-index: 1000; display: flex; flex-direction: column; }\n.gb-slider-wrapper { flex: 1 1 0%; overflow: hidden; position: relative; }\n.gb-slider-track { display: flex; height: 100%; transition: transform 0.65s cubic-bezier(0.4, 0, 0.2, 1); will-change: transform; }\n.gb-slide { min-width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem 1.5rem; position: relative; overflow: hidden auto; box-sizing: border-box; }\n.gb-section-title { font-family: Quicksand, sans-serif; font-size: clamp(1.6rem, 5vw, 2.4rem); font-weight: 700; text-align: center; margin: 0px 0px 0.4rem; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; }\n.gb-section-sub { font-size: clamp(0.85rem, 2.5vw, 1.05rem); color: var(--gb-text-muted); text-align: center; margin: 0px 0px 1.5rem; }\n.neon-glow { animation: 2s ease-in-out 0s infinite alternate none running gb-neon-pulse; }\n.neon-glow-sm { animation: 2.5s ease-in-out 0s infinite alternate none running gb-neon-pulse-sm; }\n@keyframes gb-neon-pulse {\n0% { text-shadow: 0 0 7px var(--gb-neon-gold), 0 0 15px var(--gb-neon-gold), 0 0 30px var(--gb-neon-gold), 0 0 60px rgba(255, 230, 0, 0.4); }\n50% { text-shadow: 0 0 10px var(--gb-neon-gold), 0 0 25px var(--gb-neon-gold), 0 0 50px var(--gb-neon-gold), 0 0 80px rgba(255, 230, 0, 0.5); }\n100% { text-shadow: 0 0 7px var(--gb-neon-gold), 0 0 15px var(--gb-neon-gold), 0 0 30px var(--gb-neon-gold), 0 0 60px rgba(255, 230, 0, 0.4), 0 0 100px rgba(255, 16, 176, 0.15); }\n}\n@keyframes gb-neon-pulse-sm {\n0% { text-shadow: 0 0 4px var(--gb-neon-gold), 0 0 12px var(--gb-neon-gold), 0 0 25px rgba(255, 230, 0, 0.4); }\n100% { text-shadow: 0 0 6px var(--gb-neon-gold), 0 0 18px var(--gb-neon-gold), 0 0 35px rgba(255, 230, 0, 0.5), 0 0 60px rgba(255, 16, 176, 0.1); }\n}\n.gb-confetti-layer { position: absolute; inset: 0px; pointer-events: none; z-index: 10; overflow: hidden; }\n.gb-confetti-piece { position: absolute; top: -10px; animation: auto linear 0s 1 normal forwards running gb-confetti-fall; pointer-events: none; }\n@keyframes gb-confetti-fall {\n0% { transform: translateY(0px) rotate(0deg) scale(1); opacity: 1; }\n100% { transform: translateY(100vh) rotate(720deg) scale(0.3); opacity: 0; }\n}\n.gb-sparkle-layer { position: absolute; inset: 0px; pointer-events: none; z-index: 6; overflow: hidden; }\n.gb-sparkle { position: absolute; border-radius: 50%; animation: auto ease-in-out 0s infinite normal none running gb-sparkle-pulse; pointer-events: none; box-shadow: currentcolor 0px 0px 4px; }\n@keyframes gb-sparkle-pulse {\n0%, 100% { transform: scale(0); opacity: 0; }\n40% { transform: scale(1.3); opacity: 0.9; }\n60% { transform: scale(0.8); opacity: 0.6; }\n80% { transform: scale(1.1); opacity: 0.8; }\n}\n.gb-balloon-layer { position: absolute; inset: 0px; pointer-events: none; z-index: 5; overflow: hidden; }\n.gb-balloon { position: absolute; bottom: -40px; animation: auto ease-in-out 0s infinite normal none running gb-balloon-rise; pointer-events: none; filter: drop-shadow(rgba(0, 0, 0, 0.3) 0px 4px 8px); }\n@keyframes gb-balloon-rise {\n0% { transform: translateY(0px) scale(1); opacity: 0; }\n10% { opacity: 0.9; }\n85% { opacity: 0.85; }\n100% { transform: translateY(-110vh) scale(1.12); opacity: 0; }\n}\n.gb-bts-layer { position: absolute; inset: 0px; pointer-events: none; z-index: 2; overflow: hidden; }\n.gb-bts-shape { position: absolute; opacity: 0.08; animation: 6s ease-in-out 0s infinite normal none running gb-float-bts; filter: blur(1px); }\n.gb-bts-s1 { top: 10%; left: 5%; font-size: 4rem; animation-delay: 0s; }\n.gb-bts-s2 { top: 60%; right: 8%; font-size: 5rem; animation-delay: 1.2s; }\n.gb-bts-s3 { top: 25%; right: 12%; font-size: 3.5rem; animation-delay: 2s; }\n.gb-bts-s4 { bottom: 20%; left: 10%; font-size: 2.5rem; animation-delay: 0.5s; }\n.gb-bts-s5 { top: 50%; left: 6%; font-size: 3rem; animation-delay: 3s; }\n.gb-bts-s6 { bottom: 35%; right: 5%; font-size: 4.5rem; animation-delay: 1.8s; }\n.gb-bts-silhouette { position: absolute; border-radius: 50%; background: radial-gradient(circle, rgba(199, 125, 255, 0.12), transparent 70%); animation: 8s ease-in-out 0s infinite normal none running gb-float-bts; }\n.gb-bts-fig1 { width: 120px; height: 120px; top: 15%; left: 20%; animation-delay: 0.3s; }\n.gb-bts-fig2 { width: 90px; height: 90px; bottom: 25%; right: 15%; animation-delay: 2.5s; }\n.gb-bts-fig3 { width: 70px; height: 70px; top: 45%; left: 60%; background: radial-gradient(circle, rgba(255, 143, 171, 0.1), transparent 70%); animation-delay: 1.2s; }\n@keyframes gb-float-bts {\n0%, 100% { transform: translateY(0px) rotate(0deg); }\n50% { transform: translateY(-12px) rotate(4deg); }\n}\n.gb-anime-party { position: absolute; inset: 0px; pointer-events: none; z-index: 2; overflow: hidden; }\n.gb-ap-star { position: absolute; font-size: 1.6rem; opacity: 0.15; animation: 5s ease-in-out 0s infinite normal none running gb-spin-float; }\n.gb-ap-s1 { top: 8%; left: 10%; animation-delay: 0s; }\n.gb-ap-s2 { top: 15%; right: 15%; animation-delay: 1s; font-size: 2rem; }\n.gb-ap-s3 { bottom: 20%; left: 8%; animation-delay: 2s; }\n.gb-ap-s4 { bottom: 30%; right: 10%; animation-delay: 0.5s; font-size: 2rem; }\n.gb-ap-s5 { top: 40%; left: 50%; animation-delay: 1.5s; font-size: 1.8rem; }\n.gb-ap-ribbon { position: absolute; font-size: 1.8rem; opacity: 0.12; animation: 4s ease-in-out 0s infinite normal none running gb-sway; }\n.gb-ap-r1 { top: 5%; right: 20%; animation-delay: 0.3s; }\n.gb-ap-r2 { bottom: 10%; left: 15%; animation-delay: 1.8s; }\n.gb-ap-streamer { position: absolute; height: 2px; border-radius: 2px; opacity: 0.1; animation: 3s ease-in-out 0s infinite normal none running gb-streamer-sway; }\n.gb-ap-st1 { width: 200px; top: 10%; left: -30px; transform: rotate(-15deg); background: linear-gradient(90deg, var(--gb-pink), var(--gb-purple)); animation-delay: 0s; }\n.gb-ap-st2 { width: 150px; bottom: 15%; right: -20px; transform: rotate(20deg); background: linear-gradient(90deg, var(--gb-gold), var(--gb-pink)); animation-delay: 1.2s; }\n.gb-ap-st3 { width: 180px; top: 55%; left: -40px; transform: rotate(-8deg); background: linear-gradient(90deg, var(--gb-purple), var(--gb-gold)); animation-delay: 2.5s; }\n@keyframes gb-spin-float {\n0%, 100% { transform: translateY(0px) rotate(0deg); }\n50% { transform: translateY(-10px) rotate(15deg); }\n}\n@keyframes gb-sway {\n0%, 100% { transform: translateX(0px); }\n50% { transform: translateX(8px); }\n}\n@keyframes gb-streamer-sway {\n0%, 100% { transform: translateY(0) rotate(var(--rot, 0deg)); opacity: 0.08; }\n50% { transform: translateY(-6px) rotate(var(--rot, 0deg)); opacity: 0.15; }\n}\n.gb-intro { background: radial-gradient(ellipse at 50% 30%, rgba(199, 125, 255, 0.18) 0%, transparent 60%),\n    radial-gradient(ellipse at 80% 70%, rgba(255, 143, 171, 0.12) 0%, transparent 50%),\n    radial-gradient(ellipse at 20% 60%, rgba(255, 215, 0, 0.06) 0%, transparent 40%),\n    linear-gradient(180deg, var(--gb-bg-start), var(--gb-bg-mid)); }\n.gb-intro-badge { font-size: clamp(3rem, 12vw, 5rem); animation: 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0s 1 normal both running gb-bounce-in; margin-bottom: 0.5rem; filter: drop-shadow(rgba(255, 215, 0, 0.3) 0px 0px 20px); }\n@keyframes gb-bounce-in {\n0% { transform: scale(0) rotate(-20deg); opacity: 0; }\n60% { transform: scale(1.2) rotate(5deg); opacity: 1; }\n100% { transform: scale(1) rotate(0deg); }\n}\n.gb-intro-title { display: flex; flex-direction: column; align-items: center; gap: 0.15rem; margin: 0px 0px 0.75rem; animation: 0.8s ease 0.3s 1 normal both running gb-fade-up; }\n.gb-title-line { font-family: Quicksand, sans-serif; font-size: clamp(1.4rem, 4vw, 2rem); font-weight: 600; color: var(--gb-text); opacity: 0.7; letter-spacing: 0.3em; text-transform: uppercase; }\n.gb-title-name { font-family: \"Playfair Display\", serif; font-size: clamp(3rem, 12vw, 5.5rem); font-weight: 700; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; line-height: 1.1; }\n.gb-intro-sub { font-size: clamp(0.9rem, 2.5vw, 1.1rem); color: var(--gb-text-muted); text-align: center; max-width: 320px; margin: 0px auto 1rem; animation: 0.8s ease 0.5s 1 normal both running gb-fade-up; }\n.gb-intro-ornament { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; animation: 0.8s ease 0.6s 1 normal both running gb-fade-up; }\n.gb-intro-ornament span { color: var(--gb-gold); opacity: 0.5; font-size: 1rem; animation: 2s ease-in-out 0s infinite normal none running gb-twinkle; }\n.gb-intro-ornament span:nth-child(2) { animation-delay: 0.5s; }\n.gb-intro-ornament span:nth-child(3) { animation-delay: 1s; }\n@keyframes gb-fade-up {\n0% { opacity: 0; transform: translateY(20px); }\n100% { opacity: 1; transform: translateY(0px); }\n}\n@keyframes gb-twinkle {\n0%, 100% { opacity: 0.3; transform: scale(1); }\n50% { opacity: 0.8; transform: scale(1.2); }\n}\n.gb-cta-btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.8rem 2rem; border: none; border-radius: 50px; background: linear-gradient(135deg, var(--gb-purple-dark), var(--gb-pink-dark)); color: rgb(255, 255, 255); font-family: Quicksand, sans-serif; font-size: clamp(0.9rem, 2.5vw, 1.05rem); font-weight: 700; cursor: pointer; transition: 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); box-shadow: rgba(155, 93, 229, 0.4) 0px 6px 25px, rgba(255, 16, 176, 0.2) 0px 0px 15px; animation: 0.8s ease 0.7s 1 normal both running gb-fade-up; position: relative; overflow: hidden; }\n.gb-cta-btn::before { content: \"\"; position: absolute; inset: 0px; background: linear-gradient(135deg, rgba(255, 255, 255, 0.15), transparent); pointer-events: none; }\n.gb-cta-btn:hover { transform: translateY(-3px) scale(1.03); box-shadow: rgba(155, 93, 229, 0.5) 0px 10px 35px, rgba(255, 16, 176, 0.3) 0px 0px 25px; }\n.gb-cta-btn:active { transform: translateY(0px) scale(0.98); }\n.gb-cta-arrow { display: inline-block; transition: transform 0.3s; font-size: 1.2em; }\n.gb-cta-btn:hover .gb-cta-arrow { transform: translateX(4px); }\n.gb-cta-secondary { background: linear-gradient(135deg, var(--gb-pink-dark), var(--gb-purple-dark)); }\n.gb-scroll-hint { position: absolute; bottom: 1.5rem; left: 50%; transform: translateX(-50%); font-size: 0.75rem; color: var(--gb-text-muted); opacity: 0.4; animation: 2s ease-in-out 0s infinite normal none running gb-pulse-hint; }\n@keyframes gb-pulse-hint {\n0%, 100% { opacity: 0.3; transform: translateX(-50%) translateY(0px); }\n50% { opacity: 0.7; transform: translateX(-50%) translateY(-4px); }\n}\n.gb-cake-page { background: radial-gradient(ellipse at 30% 20%, rgba(199, 125, 255, 0.12) 0%, transparent 45%),\n    radial-gradient(ellipse at 70% 80%, rgba(255, 143, 171, 0.15) 0%, transparent 45%),\n    radial-gradient(ellipse at 50% 50%, rgba(255, 215, 0, 0.04) 0%, transparent 30%),\n    linear-gradient(180deg, var(--gb-bg-mid), var(--gb-bg-end)); }\n.gb-cake-content { display: flex; flex-direction: column; align-items: center; width: 100%; max-width: 400px; }\n.gb-cake-wrapper { position: relative; width: 200px; height: 200px; cursor: pointer; margin: 0.5rem 0px; transition: transform 0.3s; }\n.gb-cake-wrapper:hover { transform: scale(1.03); }\n.gb-cake-wrapper:active { transform: scale(0.97); }\n.gb-cake-plate { position: absolute; bottom: 8px; left: -10px; right: -10px; height: 14px; background: linear-gradient(135deg, rgb(224, 201, 166), rgb(212, 175, 55), rgb(201, 