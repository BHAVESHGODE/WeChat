ata-kid=\"69\"></div>\n                        <button class=\"w-full py-5 rounded-2xl bg-white/10 border border-white/20 backdrop-blur-xl text-white font-black text-[11px] tracking-[0.4em] uppercase hover:bg-white/20 hover:scale-[1.03] transition-all duration-300 shadow-2xl cursor-pointer\" data-kid=\"70\">\n                            Access\n                        </button>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"path-card-wrapper relative flex-1 group\" id=\"card-goju\" data-kid=\"71\">\n                \n                <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-emerald-500/50 blur-[110px] rounded-full opacity-40 group-hover:opacity-80 transition-opacity duration-1000\" data-kid=\"72\"></div>\n                \n                <div class=\"relative glass-card h-[420px] rounded-[48px] border border-white/15 backdrop-blur-[60px] bg-white/[0.02] p-10 flex flex-col justify-between overflow-hidden shadow-[0_32px_64px_rgba(0,0,0,0.4)] transition-all duration-500 hover:border-white/40 hover:bg-white/[0.06]\" data-kid=\"73\">\n                    <div class=\"flex justify-between items-start\" data-kid=\"74\">\n                        <div data-kid=\"75\">\n                            <p class=\"text-[11px] tracking-[0.4em] font-black text-emerald-200/40 uppercase mb-3\" data-kid=\"76\">Series 03</p>\n                            <h2 class=\"text-5xl font-black text-white tracking-tighter leading-none drop-shadow-2xl\" data-kid=\"77\">Goju</h2>\n                        </div>\n                        \n                        <div class=\"w-6 h-6 flex items-center justify-center border border-white/30 bg-white/10 rounded-full backdrop-blur-xl group-hover:border-emerald-400/50 transition-colors\" data-kid=\"78\">\n                            <div class=\"w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_15px_rgba(52,211,153,1),0_0_5px_white]\" data-kid=\"79\"></div>\n                        </div>\n                    </div>\n                    \n                    <div class=\"space-y-8\" data-kid=\"80\">\n                        <div class=\"h-[1px] w-full bg-gradient-to-r from-white/20 via-white/5 to-transparent\" data-kid=\"81\"></div>\n                        <button class=\"w-full py-5 rounded-2xl bg-white/10 border border-white/20 backdrop-blur-xl text-white font-black text-[11px] tracking-[0.4em] uppercase hover:bg-white/20 hover:scale-[1.03] transition-all duration-300 shadow-2xl cursor-pointer\" data-kid=\"82\">\n                            Access\n                        </button>\n                    </div>\n                </div>\n            </div>\n\n        </main>\n    </div>\n\n    \n    <footer class=\"relative z-10 w-full px-12 py-6 flex justify-between items-center text-[10px] text-white/30 tracking-widest font-bold uppercase\" data-kid=\"83\">\n        <div class=\"flex gap-8\" data-kid=\"84\">\n            <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"85\">Privacy</a>\n            <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"86\">Terms</a>\n        </div>\n        <div class=\"text-center\" data-kid=\"87\">В© 2024 WEGIFT GLOBAL</div>\n        <div class=\"flex gap-8\" data-kid=\"88\">\n            <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"89\">Instagram</a>\n            <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"90\">Twitter</a>\n        </div>\n    </footer>\n\n    <style data-kid=\"91\">\n        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n        .glass-card::after {\n            content: '';\n            position: absolute;\n            inset: 0;\n            border-radius: inherit;\n            background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0) 50%, rgba(255,255,255,0.02) 100%);\n            pointer-events: none;\n        }\n\n        .bg-radial-gradient {\n            background: radial-gradient(circle at center, var(--tw-gradient-from) 0%, var(--tw-gradient-via) 40%, var(--tw-gradient-to) 100%);\n        }\n\n        .ti {\n            display: inline-block;\n            line-height: 1;\n        }\n    </style>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"92\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"93\"></script>\n    <script data-kid=\"94\">\n        gsap.registerPlugin(ScrollTrigger);\n        \n        document.addEventListener('DOMContentLoaded', () => {\n            const tl = gsap.timeline();\n\n            // Initial states\n            gsap.set(\"#logo-plaque\", { y: -40, opacity: 0, scale: 0.95 });\n            gsap.set(\".category-item\", { y: 20, opacity: 0 });\n            gsap.set(\".path-card-wrapper\", { y: 60, opacity: 0, scale: 0.98 });\n            gsap.set(\"footer\", { opacity: 0 });\n\n            // Entrance Sequence\n            tl.to(\"#logo-plaque\", { \n                y: 0, \n                opacity: 1, \n                scale: 1,\n                duration: 1.5, \n                ease: \"expo.out\" \n            })\n            .to(\".category-item\", { \n                y: 0, \n                opacity: 1, \n                stagger: 0.08, \n                duration: 1, \n                ease: \"power3.out\" \n            }, \"-=1\")\n            .to(\".path-card-wrapper\", { \n                y: 0, \n                opacity: 1, \n                scale: 1,\n                stagger: 0.15, \n                duration: 1.4, \n                ease: \"power4.out\" \n            }, \"-=0.8\")\n            .to(\"footer\", {\n                opacity: 1,\n                duration: 1.2\n            }, \"-=0.5\");\n\n            // Subtle Floating Animation\n            gsap.to(\".path-card-wrapper\", {\n                y: \"-=20\",\n                duration: 4,\n                repeat: -1,\n                yoyo: true,\n                ease: \"sine.inOut\",\n                stagger: {\n                    each: 0.6,\n                    from: \"center\"\n                }\n            });\n\n            // Interactive Hover for Logo\n            const plaque = document.querySelector('.logo-plaque-container');\n            plaque.addEventListener('mousemove', (e) => {\n                const { left, top, width, height } = plaque.getBoundingClientRect();\n                const x = (e.clientX - left) / width - 0.5;\n                const y = (e.clientY - top) / height - 0.5;\n                gsap.to(plaque.querySelector('div'), {\n                    rotateY: x * 10,\n                    rotateX: -y * 10,\n                    duration: 0.4,\n                    ease: \"power2.out\"\n                });\n            });\n            plaque.addEventListener('mouseleave', () => {\n                gsap.to(plaque.querySelector('div'), {\n                    rotateY: 0,\n                    rotateX: 0,\n                    duration: 0.8,\n                    ease: \"elastic.out(1, 0.3)\"\n                });\n            });\n        });\n    </script>\n</div>\n",
